APP_NAME=Classic Trip
NODE_ENV=development
PORT=5000
APP_URL=http://localhost:5000
SITE_URL=http://localhost:5000

MONGO_URI=mongodb://127.0.0.1:27017/classic-trip
# Recommended for Atlas URIs that do not include a database path.
MONGO_DB_NAME=classic-trip
# Production requires a MongoDB replica set or Atlas cluster; standalone MongoDB is rejected.
MONGO_TRANSACTIONS=true
SESSION_SECRET=change_this_to_a_long_random_secret
# Temporarily disabled. Set true later to require authenticator MFA for all platform admins.
PLATFORM_MFA_ENABLED=false
MFA_ENCRYPTION_KEY=change_this_to_a_different_long_random_secret
MFA_SESSION_MAX_AGE_MINUTES=720

SUPER_ADMIN_EMAIL=superadmin@classictrip.com
SUPER_ADMIN_PASSWORD=change_this_to_a_strong_admin_password
SUPER_ADMIN_NAME=Classic Trip Super Admin
# Must be different from every partner, promoter, staff, driver and customer phone.
SUPER_ADMIN_PHONE=+256700000001

CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_FOLDER=classic-trip
MAX_UPLOAD_SIZE_MB=5

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:5000/auth/google/callback

# Configure one live payment provider. Pesapal is the default integration.
PAYMENT_PROVIDER=pesapal
PAYMENT_WEBHOOK_SECRET=change_this_webhook_secret
PAYMENT_API_URL=
PAYMENT_API_KEY=
PAYMENT_API_SECRET=
PAYMENT_CALLBACK_URL=http://localhost:5000/booking/payment/callback
PAYMENT_IPN_URL=http://localhost:5000/api/webhooks/payments

PESAPAL_API_URL=https://pay.pesapal.com/v3/api
PESAPAL_CONSUMER_KEY=
PESAPAL_CONSUMER_SECRET=
PESAPAL_CALLBACK_URL=http://localhost:5000/booking/payment/callback
PESAPAL_IPN_URL=http://localhost:5000/api/webhooks/payments
PESAPAL_IPN_ID=
PESAPAL_WEBHOOK_SECRET=
PESAPAL_NOTIFICATION_TYPE=POST

MTN_MOMO_API_URL=
MTN_MOMO_API_KEY=
MTN_MOMO_CALLBACK_URL=
MTN_MOMO_WEBHOOK_SECRET=

AIRTEL_MONEY_API_URL=
AIRTEL_MONEY_API_KEY=
AIRTEL_MONEY_CALLBACK_URL=
AIRTEL_MONEY_WEBHOOK_SECRET=

FLUTTERWAVE_API_URL=
FLUTTERWAVE_API_KEY=
FLUTTERWAVE_CALLBACK_URL=
FLUTTERWAVE_WEBHOOK_SECRET=

PAYSTACK_API_URL=
PAYSTACK_API_KEY=
PAYSTACK_CALLBACK_URL=
PAYSTACK_WEBHOOK_SECRET=

DPO_API_URL=
DPO_API_KEY=
DPO_CALLBACK_URL=
DPO_WEBHOOK_SECRET=


EMAIL_FROM=no-reply@classictrip.com
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

SMS_API_URL=
SMS_API_TOKEN=
SMS_FROM=Classic Trip

WHATSAPP_PROVIDER=meta
WHATSAPP_GRAPH_VERSION=v20.0
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_API_URL=
WHATSAPP_FROM=Classic Trip

PUSH_ENABLED=true
PUSH_VAPID_PUBLIC_KEY=
PUSH_VAPID_PRIVATE_KEY=
PUSH_VAPID_SUBJECT=mailto:support@classictrip.com

SEO_DEFAULT_TITLE=Classic Trip | East Africa travel marketplace
SEO_DEFAULT_DESCRIPTION=Book verified bus services and hotels across East Africa with Classic Trip.
SEO_DEFAULT_IMAGE=
GOOGLE_SITE_VERIFICATION=
BING_SITE_VERIFICATION=
SEO_ALLOW_AI_SEARCH=true
SEO_ALLOW_AI_TRAINING=false
INDEXNOW_KEY=
SEO_EXTRA_URLS=

ENABLE_JOBS=false
JOB_PROCESS_OUTBOX=* * * * *
JOB_CLEANUP_EXPIRED_LOCKS=*/5 * * * *
JOB_EXPIRE_PAYMENT_INTENTS=*/5 * * * *
JOB_RELEASE_COMMISSION=*/10 * * * *
JOB_BOOKING_REMINDERS=*/15 * * * *
JOB_EXPIRE_PROMOTIONS=*/30 * * * *
JOB_PAYOUT_REPORTS=0 6 * * *
