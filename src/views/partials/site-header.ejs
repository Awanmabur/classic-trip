<nav class="nav" id="siteNav">
  <div class="navIn">
    <a class="brand" href="/"><img class="mark" src="/images/logo-symbol-128.png" alt="Classic Trip"><span>Classic Trip</span></a>
    <div class="navLinks" id="siteNavLinks">
      <a href="/" class="<%= currentPath === '/' ? 'active' : '' %>">Home</a>
      <a href="/search" class="<%= currentPath.startsWith('/search') ? 'active' : '' %>">Search</a>
      <a href="/services" class="<%= currentPath.startsWith('/services') ? 'active' : '' %>">Services</a>
      <a href="/routes" class="<%= currentPath.startsWith('/routes') ? 'active' : '' %>">Routes</a>
      <a href="/partner-commission" class="<%= currentPath.startsWith('/partner-commission') ? 'active' : '' %>">Partners</a>
      <a href="/blogs" class="<%= currentPath.startsWith('/blogs') ? 'active' : '' %>">Guides</a>
    </div>
    <div class="navActions">
      <button class="iconbtn" id="siteThemeBtn" title="Toggle theme" data-site-action="theme"><i class="fa-solid fa-moon" id="siteThemeIcon"></i></button>
      <a class="btn btnGhost" href="/tickets" style="<%= currentPath.startsWith('/tickets') ? 'background:rgba(255,183,3,.13);border-color:rgba(255,183,3,.30);color:var(--accent)' : '' %>"><i class="fa-solid fa-ticket"></i><span class="navBtnText">Tickets</span></a>
      <% if (currentUser) { %>
        <a class="btn btnGhost login" href="<%= dashboardUrl %>"><i class="fa-regular fa-user"></i><span class="navBtnText"><%= (currentUser.fullName || currentUser.name || 'Account').split(' ')[0] %></span></a>
      <% } else { %>
        <a class="btn btnGhost login" href="/login"><i class="fa-regular fa-user"></i><span class="navBtnText">Login</span></a>
      <% } %>
      <% if (currentUser) { %><form method="POST" action="/logout" style="display:contents"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><button class="btn btnPrimary" type="submit"><i class="fa-solid fa-arrow-right-from-bracket"></i><span class="navBtnText">Logout</span></button></form><% } else { %><a class="btn btnPrimary" href="/register?role=partner#partner"><i class="fa-solid fa-store"></i><span class="navBtnText">Partner</span></a><% } %>
      <button class="iconbtn" id="siteMenuBtn" title="Menu" data-site-action="drawer-toggle"><i class="fa-solid fa-bars"></i></button>
    </div>
  </div>
</nav>

<div class="drawer" id="siteDrawer" data-site-drawer>
  <div class="drawerPanel">
    <div style="display:flex;align-items:center;justify-content:space-between;gap:12px;padding-bottom:12px;border-bottom:1px solid var(--line)">
      <a class="brand" href="/" data-site-action="drawer-close"><img class="mark" src="/images/logo-symbol-128.png" alt="Classic Trip"><span>Classic Trip</span></a>
      <button class="iconbtn" type="button" data-site-action="drawer-close"><i class="fa-solid fa-xmark"></i></button>
    </div>
    <% if (currentUser) { %>
      <a class="drawerProfile" href="<%= dashboardUrl %>">
        <span class="drawerProfileAvatar"><i class="fa-solid fa-user"></i></span>
        <span class="drawerProfileText"><b><%= currentUser.fullName || currentUser.name || 'Account' %></b><span class="muted">View dashboard</span></span>
        <i class="fa-solid fa-chevron-right"></i>
      </a>
    <% } else { %>
      <a class="drawerProfile" href="/login">
        <span class="drawerProfileAvatar"><i class="fa-regular fa-user"></i></span>
        <span class="drawerProfileText"><b>Login / Sign up</b><span class="muted">Access your bookings & account</span></span>
        <i class="fa-solid fa-chevron-right"></i>
      </a>
    <% } %>
    <div class="drawerLinks">
      <a href="/" class="<%= currentPath === '/' ? 'active' : '' %>"><i class="fa-solid fa-house"></i> Home</a>
      <a href="/search" class="<%= currentPath.startsWith('/search') ? 'active' : '' %>"><i class="fa-solid fa-magnifying-glass"></i> Search</a>
      <a href="/services" class="<%= currentPath.startsWith('/services') ? 'active' : '' %>"><i class="fa-solid fa-layer-group"></i> Services</a>
      <a href="/routes" class="<%= currentPath.startsWith('/routes') ? 'active' : '' %>"><i class="fa-solid fa-route"></i> Routes</a>
      <a href="/companies" class="<%= currentPath.startsWith('/companies') ? 'active' : '' %>"><i class="fa-solid fa-building"></i> Partners</a>
      <a href="/promoters" class="<%= currentPath.startsWith('/promoters') ? 'active' : '' %>"><i class="fa-solid fa-users"></i> Promoters</a>
      <a href="/partner-commission" class="<%= currentPath.startsWith('/partner-commission') ? 'active' : '' %>"><i class="fa-solid fa-percent"></i> Partner commission</a>
      <a href="/tickets" class="<%= currentPath.startsWith('/tickets') ? 'active' : '' %>"><i class="fa-solid fa-ticket"></i> Find Ticket</a>
      <a href="/blogs" class="<%= currentPath.startsWith('/blogs') ? 'active' : '' %>"><i class="fa-regular fa-newspaper"></i> Travel Guides</a>
      <a href="/how-it-works"><i class="fa-solid fa-circle-question"></i> How It Works</a>
    </div>
    <div style="display:grid;gap:9px;padding-top:12px;border-top:1px solid var(--line)">
      <a class="btn btnPrimary" href="/register?role=partner#partner" style="justify-content:flex-start;gap:10px"><i class="fa-solid fa-store"></i> Become a Partner</a>
    </div>
  </div>
</div>

<nav class="bottomNav" id="siteBottomNav">
  <button type="button" data-site-action="navigate" data-url="/" class="<%= currentPath === '/' ? 'active' : '' %>" title="Home"><i class="fa-solid fa-house"></i><span>Home</span></button>
  <button type="button" data-site-action="navigate" data-url="/search" class="<%= currentPath.startsWith('/search') ? 'active' : '' %>" title="Search"><i class="fa-solid fa-magnifying-glass"></i><span>Search</span></button>
  <button type="button" data-site-action="navigate" data-url="/tickets" class="<%= currentPath.startsWith('/tickets') ? 'active' : '' %>" title="Tickets"><i class="fa-solid fa-ticket"></i><span>Tickets</span></button>
  <button type="button" data-site-action="navigate" data-url="/saved" class="<%= currentPath.startsWith('/saved') ? 'active' : '' %>" title="Saved"><i class="fa-regular fa-heart"></i><span>Saved</span></button>
  <button type="button" data-site-action="drawer-toggle" title="Menu"><i class="fa-regular fa-user"></i><span>Profile</span></button>
</nav>

<script src="/js/site-header.js" defer></script>
