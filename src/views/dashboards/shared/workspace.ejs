  <div class="modal" id="deleteModal">
    <div class="modalCard">
      <div class="modalHead">
        <div><h3>Delete record</h3><p>This confirms the delete workflow before any record is changed.</p></div>
        <button class="iconBtn" data-close-modal><i class="fa-solid fa-xmark"></i></button>
      </div>
      <div class="modalBody">
        <div class="deleteBox">
          <span class="badge bad"><i class="fa-solid fa-triangle-exclamation"></i> Delete action</span>
          <strong id="deleteText">Are you sure you want to delete this record?</strong>
          <p style="margin:0;color:var(--muted);font-size:12px;font-weight:800;line-height:1.55">Soft delete keeps the record recoverable and writes the action to audit logs.</p>
          <div style="display:flex;gap:8px;flex-wrap:wrap;justify-content:flex-end">
            <button class="btn" data-close-modal>Cancel</button>
            <form id="deleteForm" method="POST" action="" style="margin:0"><input type="hidden" name="_csrf" value="<%= csrfToken || '' %>"><button class="btn btnDanger" id="confirmDelete" type="submit"><i class="fa-solid fa-trash"></i> Delete</button></form>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="toast" id="toast"><i class="fa-solid fa-circle-check"></i><span id="toastText">Done</span></div>


      <%
        const staticDashboardSectionIds = new Set([
          'overview','analytics','bookings','partners','listings','routes','vehicles','schedules',
          'company-profile','staff','seat-maps','hotel-rooms','manifests','checkins','reviews',
          'revenue','settlement','payments','promoters','customers','support','ads','reports',
          'audit','admins','kyc','refunds','handover','profile','notifications','system','settings',
          'ticket','saved','passengers','receipts','wallet','security',
          'links','share','campaigns','performance','offline-sales','fraud','commissions','withdrawals','payouts',
          'driver-ops','driver-manifest','driver-incidents',
          'bus-dashboard','hotel-dashboard'
        ]);
        const seenDynamicDashboardPages = new Set();
        const dynamicDashboardItems = [];
        (shellGroups || []).forEach(function(group){
          (group.items || []).forEach(function(item){
            if (!item || !item.page || staticDashboardSectionIds.has(item.page) || seenDynamicDashboardPages.has(item.page)) return;
            seenDynamicDashboardPages.add(item.page);
            dynamicDashboardItems.push({
              page: item.page,
              label: item.label || item.page,
              icon: item.icon || 'fa-circle',
              group: group.label || 'Dashboard'
            });
          });
        });
        function dynamicActionHref(page){
          const role = dashboardRoleKey || 'admin';
          if (role === 'customer') {
            if (page === 'ticket') return '/account/bookings';
            if (page === 'saved') return '/search';
            if (page === 'passengers') return '/account/passengers';
            if (page === 'receipts') return '/account/reports/receipts.csv';
            if (page === 'refunds') return '/account/refunds';
            if (page === 'support') return '/account/support';
            return '/account/' + page;
          }
          if (role === 'promoter') {
            if (page === 'links') return '/promoter/links';
            if (page === 'commissions') return '/promoter/commissions';
            if (page === 'withdrawals') return '/promoter/withdrawals';
            if (page === 'offline-sales') return '/promoter/offline-sales';
            return '/promoter/' + page;
          }
          if (role === 'employee') return '/employee/dashboard/' + page;
          if (role === 'driver') return '/driver/dashboard/' + page;
          if (role === 'support') return '/support/dashboard/' + page;
          if (role === 'finance') return '/finance/dashboard/' + page;
          if (role === 'operations') return '/operations/dashboard/' + page;
          return '#'+page;
        }
      %>
      <% dynamicDashboardItems.forEach(function(item){ const employeeDynamicActions = { bookings:'booking', schedule:'delay notice', inventory:'inventory', payments:'payment', refunds:'refund', support:'support notice', handover:'handover', profile:'profile' }; const employeeDynamicAction = isEmployeeDashboard ? employeeDynamicActions[item.page] : ''; const employeeDynamicLabel = item.page === 'profile' ? 'Save profile' : item.page === 'handover' ? 'Create handover' : item.page === 'schedule' ? 'Send delay notice' : item.page === 'inventory' ? 'Update inventory' : item.page === 'payments' ? 'Record payment' : item.page === 'refunds' ? 'Request refund' : item.page === 'support' ? 'Create support notice' : 'Create booking'; %>
        <%- include('sections/dynamic-page', Object.assign({}, sectionLocals, { item, employeeDynamicAction, employeeDynamicLabel, dynamicActionHref })) %>
      <% }) %>

