<section class="section" id="customer-profile"><div class="grid2"><div class="card"><div class="cardHead"><div class="cardTitle"><h3><i class="fa-solid fa-user-gear"></i> Profile</h3><p>Customer identity, contact details, travel preferences, and receipt settings.</p></div><span class="badge ok"><%= dashboardData?.profile?.status || 'active' %></span></div><form class="formPanel" method="POST" action="/account/profile"><input type="hidden" name="_csrf" value="<%= csrfToken || '' %>"><div class="formGrid"><div class="field"><label>Full name</label><div class="control"><i class="fa-solid fa-user"></i><input name="fullName" value="<%= dashboardData?.profile?.fullName || dashboardShell?.profileName || '' %>" required></div></div><div class="field"><label>Email</label><div class="control"><i class="fa-solid fa-envelope"></i><input name="email" type="email" value="<%= dashboardData?.profile?.email || '' %>"></div></div><div class="field"><label>Phone</label><div class="control"><i class="fa-solid fa-phone"></i><input name="phone" value="<%= dashboardData?.profile?.phone || '' %>"></div></div><div class="field"><label>City</label><div class="control"><i class="fa-solid fa-location-dot"></i><input name="city" value="<%= dashboardData?.profile?.city || '' %>"></div></div></div><button class="btn btnPrimary" type="submit"><i class="fa-solid fa-floppy-disk"></i> Save profile</button></form></div><div class="card"><div class="cardHead"><div class="cardTitle"><h3>Preferences</h3><p>Travel preferences used in search and booking workflows.</p></div></div><div class="splitGrid"><div class="splitItem"><div class="splitTop"><span>Preferred seat</span><strong><%= dashboardData?.profile?.preferences?.preferredSeat || 'Window' %></strong></div></div><div class="splitItem"><div class="splitTop"><span>Currency</span><strong><%= dashboardData?.profile?.preferences?.defaultCurrency || platformConfig.defaultCurrency %></strong></div></div><div class="splitItem"><div class="splitTop"><span>Notifications</span><span class="badge ok"><%= dashboardData?.profile?.preferences?.notifications || 'Enabled' %></span></div></div><div class="splitItem"><div class="splitTop"><span>Receipt email</span><span class="badge info"><%= dashboardData?.profile?.preferences?.receiptEmail || 'Enabled' %></span></div></div></div></div></div></section>
