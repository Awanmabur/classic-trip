<section class="section" id="bookings"><div class="card"><div class="cardHead"><div class="cardTitle"><h3><%= isCompanyDashboard ? (companyServiceProfile.primaryLabel || 'Company') + ' bookings' : isEmployeeDashboard ? 'Assigned bookings' : 'All bookings' %></h3><p><%= isCompanyDashboard ? (companySupportsHotel ? 'Monitor hotel stays, room-night holds, refunds, and confirmations.' : companySupportsBus ? 'Monitor bus tickets, seats, passenger holds, refunds, and confirmations.' : 'Monitor this company service bookings, holds, refunds, and confirmations.') : isEmployeeDashboard ? 'Create desk bookings, check in passengers or guests, record payments, and request refunds in your assigned company scope.' : 'Monitor tickets, reservations, rooms, seats, held items, refunds, and confirmations.' %></p></div><button class="btn btnBlue" data-modal="create" data-type="booking"><i class="fa-solid fa-plus"></i> Create booking</button></div><div class="innerTabs" data-tab-group="bookings-tabs"><button type="button" class="tabBtn is-on" data-tab-target="bookings-all"><i class="fa-solid fa-ticket"></i> <%= isCompanyDashboard ? (companyServiceProfile.primaryLabel || 'Service') : isEmployeeDashboard ? 'Assigned' : 'All' %></button><% if(!isCompanyDashboard || companySupportsBus){ %><button type="button" class="tabBtn" data-tab-target="bookings-bus"><i class="fa-solid fa-bus"></i> Bus</button><% } %><% if(!isCompanyDashboard || companySupportsHotel){ %><button type="button" class="tabBtn" data-tab-target="bookings-hotel"><i class="fa-solid fa-hotel"></i> Hotel</button><% } %><button type="button" class="tabBtn" data-tab-target="bookings-hold"><i class="fa-regular fa-clock"></i> On hold</button><button type="button" class="tabBtn" data-tab-target="bookings-refunded"><i class="fa-solid fa-rotate-left"></i> Refunded</button></div><div class="tabPane is-open" id="bookings-all"><div class="tableWrap"><table><thead><tr><th>Booking</th><th>Service</th><th>Customer</th><th>Date</th><th>Hold</th><th>Status</th><th>Amount</th><th></th></tr></thead><tbody id="bookingsTable"></tbody></table></div></div><% if(!isCompanyDashboard || companySupportsBus){ %><div class="tabPane" id="bookings-bus"><div class="tableWrap"><table><thead><tr><th>Booking</th><th>Service</th><th>Customer</th><th>Date</th><th>Hold</th><th>Status</th><th>Amount</th><th></th></tr></thead><tbody id="bookingsBusTable"></tbody></table></div></div><% } %><% if(!isCompanyDashboard || companySupportsHotel){ %><div class="tabPane" id="bookings-hotel"><div class="tableWrap"><table><thead><tr><th>Booking</th><th>Service</th><th>Customer</th><th>Date</th><th>Hold</th><th>Status</th><th>Amount</th><th></th></tr></thead><tbody id="bookingsHotelTable"></tbody></table></div></div><% } %><% if(!isCompanyDashboard){ %><% } %><div class="tabPane" id="bookings-hold"><div class="tableWrap"><table><thead><tr><th>Booking</th><th>Service</th><th>Customer</th><th>Date</th><th>Hold</th><th>Status</th><th>Amount</th><th></th></tr></thead><tbody id="bookingsHoldTable"></tbody></table></div></div><div class="tabPane" id="bookings-refunded"><div class="tableWrap"><table><thead><tr><th>Booking</th><th>Service</th><th>Customer</th><th>Date</th><th>Hold</th><th>Status</th><th>Amount</th><th></th></tr></thead><tbody id="bookingsRefundedTable"></tbody></table></div></div></div></section>
