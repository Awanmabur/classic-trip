<section class="section" id="settlement">
        <% const partnerTerms = companyServiceProfile?.commercialTerms || {}; %>
        <div class="card" style="margin-bottom:14px"><div class="cardHead"><div class="cardTitle"><h3><i class="fa-solid fa-percent"></i> Partner commission contract</h3><p>One booking commission percentage applies to this company. No recurring partner charge is involved.</p></div><span class="badge info"><%= partnerTerms.source === 'admin_override' ? 'Partner-specific' : 'Platform default' %></span></div><div class="splitGrid"><div class="splitItem"><div class="splitTop"><span>Classic Trip commission</span><strong><%= Number(partnerTerms.commissionPercent || 0).toFixed(2) %>%</strong></div></div><div class="splitItem"><div class="splitTop"><span>Partner receives</span><strong><%= Number(partnerTerms.partnerPayoutPercent || 0).toFixed(2) %>%</strong></div></div><div class="splitItem"><div class="splitTop"><span>Promoter funding</span><strong>From Classic Trip commission</strong></div></div><div class="splitItem"><div class="splitTop"><span>Contract version</span><strong><%= partnerTerms.termsVersion || 'commission-v1' %></strong></div></div></div><div class="notice">Every booking freezes its own commission snapshot. A future percentage change applies only to new bookings.</div></div>
        <div class="financeSubgrid">
          <div class="card"><div class="cardHead"><div class="cardTitle"><h3>Settlement batches</h3><p>Batch-level summary for released earnings, statements, and payout readiness.</p></div><a class="btn" href="/company/reports/settlementBatches.csv"><i class="fa-solid fa-download"></i> Export</a></div><div class="tableWrap"><table><thead><tr><th>Batch</th><th>Start</th><th>End</th><th>Gross</th><th>Payable</th><th>Rows</th><th>Status</th><th></th></tr></thead><tbody id="companySettlementBatchTable"></tbody></table></div></div>
          <div class="card"><div class="cardHead"><div class="cardTitle"><h3>Payout requests</h3><p>Company payout requests with risk and payout-batch visibility.</p></div><button class="btn btnBlue" data-modal="create" data-type="payout"><i class="fa-solid fa-wallet"></i> Request payout</button></div><div class="tableWrap"><table><thead><tr><th>Request</th><th>Txn</th><th>Amount</th><th>Method</th><th>Account</th><th>Batch</th><th>Risk</th><th>Status</th><th></th></tr></thead><tbody id="companyPayoutRequestTable"></tbody></table></div></div>
        </div>
        <div class="financeTableGrid" style="margin-top:14px">
          <div class="card"><div class="cardHead"><div class="cardTitle"><h3>Wallet / settlement ledger</h3><p>Every company credit, debit, payout, refund reversal, and settlement transaction.</p></div><a class="btn" href="/company/reports/settlementLedger.csv"><i class="fa-solid fa-file-csv"></i> Export ledger</a></div><div class="dashboardFilters" style="margin:0 16px 12px" data-filter-target="#companySettlementLedgerTable"><div class="field"><label>Search ledger</label><div class="control"><i class="fa-solid fa-magnifying-glass"></i><input data-filter-search placeholder="Transaction, booking, payout, status"></div></div><div class="field"><label>Status</label><div class="control"><i class="fa-solid fa-circle-check"></i><select data-filter-select><option value="">All statuses</option><option value="pending">Pending</option><option value="released">Released</option><option value="paid">Paid</option><option value="refund">Refund</option></select></div></div><div class="filterActions"><button class="btn" type="button" data-filter-reset><i class="fa-solid fa-rotate-left"></i> Reset</button></div></div><div class="tableWrap"><table><thead><tr><th>Txn</th><th>Reference</th><th>Type</th><th>Direction</th><th>Amount</th><th>Batch</th><th>Payout</th><th>Status</th><th></th></tr></thead><tbody id="companySettlementLedgerTable"></tbody></table></div><div class="filterEmpty" style="padding:0 16px" data-empty-for="#companySettlementLedgerTable">No ledger rows match the current filters.</div></div>
          <div class="card"><div class="cardHead"><div class="cardTitle"><h3>Finance statements</h3><p>Generated statement history and printable/exportable summary rows.</p></div><a class="btn" href="/company/reports/financeStatements.csv"><i class="fa-solid fa-file-lines"></i> Export statements</a></div><div class="tableWrap"><table><thead><tr><th>Statement</th><th>Start</th><th>End</th><th>Gross</th><th>Closing / earning</th><th>Refunds</th><th>Status</th><th></th></tr></thead><tbody id="companyFinanceStatementTable"></tbody></table></div></div>
        </div>
      </section>
