<section class="section" id="offline-sales"><div class="grid2"><div class="card"><div class="cardHead"><div class="cardTitle"><h3><i class="fa-solid fa-cash-register"></i> Offline sales</h3><p>Agent / offline sales, receipts, payment method, and booking references.</p></div><button class="btn btnPrimary" data-modal="create" data-type="offline sale"><i class="fa-solid fa-plus"></i> Record sale</button></div><div class="tableWrap"><table><thead><tr><th>Sale</th><th>Booking</th><th>Customer</th><th>Listing</th><th>Method</th><th>Amount</th><th>Status</th><th></th></tr></thead><tbody id="promoterOfflineSalesTable"></tbody></table></div></div><div class="card"><div class="cardHead"><div class="cardTitle"><h3>Agent profile</h3><p>Enable and maintain offline sales identity.</p></div></div><form class="formPanel" method="POST" action="/promoter/agent-profile"><input type="hidden" name="_csrf" value="<%= csrfToken || '' %>"><div class="formGrid"><div class="field"><label>Office name</label><div class="control"><i class="fa-solid fa-shop"></i><input name="officeName" placeholder="Downtown travel desk"></div></div><div class="field"><label>Location</label><div class="control"><i class="fa-solid fa-location-dot"></i><input name="location" placeholder="Kampala"></div></div></div><button class="btn btnPrimary" type="submit"><i class="fa-solid fa-floppy-disk"></i> Save agent profile</button></form></div></div></section>
