<section class="section" id="promoter-support"><div class="grid2"><div class="card"><div class="cardHead"><div class="cardTitle"><h3><i class="fa-solid fa-headset"></i> Promoter support</h3><p>Referral, commission, withdrawal, and verification support cases.</p></div></div><div class="tableWrap"><table><thead><tr><th>Case</th><th>Subject</th><th>Priority</th><th>Status</th><th>Opened</th><th></th></tr></thead><tbody id="promoterSupportTable"></tbody></table></div></div><div class="card"><div class="cardHead"><div class="cardTitle"><h3>Create support request</h3><p>Contact support about links, commissions, or payouts.</p></div></div><form class="formPanel" method="POST" action="/promoter/support"><input type="hidden" name="_csrf" value="<%= csrfToken || '' %>"><div class="formGrid"><div class="field"><label>Subject</label><div class="control"><i class="fa-solid fa-heading"></i><input name="subject" required></div></div><div class="field"><label>Priority</label><div class="control"><i class="fa-solid fa-flag"></i><select name="priority"><option value="normal">Normal</option><option value="high">High</option><option value="urgent">Urgent</option></select></div></div><div class="field full"><label>Message</label><div class="control"><textarea name="message" required></textarea></div></div></div><button class="btn btnPrimary" type="submit"><i class="fa-solid fa-paper-plane"></i> Send support</button></form></div></div></section>
