<%
  const supportRows = Array.isArray(dashboardData?.support) ? dashboardData.support : [];
  const supportRowText = function(row){ return Array.isArray(row) ? row.filter(function(cell){ return typeof cell !== 'object'; }).join(' ').toLowerCase() : String(row || '').toLowerCase(); };
  const urgentSupportCount = supportRows.filter(function(row){ return /urgent|critical|high/.test(supportRowText(row)) && !/closed|resolved|completed/.test(supportRowText(row)); }).length;
  const correspondenceCount = Array.isArray(dashboardData?.correspondence) ? dashboardData.correspondence.length : 0;
  const deliveryCount = Array.isArray(dashboardData?.deliveryAttempts) ? dashboardData.deliveryAttempts.length : 0;
  const timelineCount = Array.isArray(dashboardData?.timeline) ? dashboardData.timeline.length : 0;
  const rescheduleCount = Array.isArray(dashboardData?.reschedules) ? dashboardData.reschedules.length : 0;
%>
<section class="section" id="support"><div class="grid2"><div class="card"><div class="cardHead"><div class="cardTitle"><h3>Support & disputes</h3><p>Refunds, failed payments, missing tickets, partner complaints, and customer support.</p></div><span class="badge <%= urgentSupportCount ? 'bad' : 'ok' %>"><i class="fa-solid fa-triangle-exclamation"></i> <%= urgentSupportCount %> urgent</span></div><div class="tableWrap"><table><thead><tr><th>Ticket</th><th>Customer</th><th>Issue</th><th>Priority</th><th>Status</th><th>Opened</th><th></th></tr></thead><tbody id="supportTable"></tbody></table></div></div><div class="card"><div class="cardHead"><div class="cardTitle"><h3>Create support notice</h3><p>Send a message to affected customers or partners.</p></div></div><form class="formPanel" id="noticeForm" method="POST" action="<%= isEmployeeDashboard ? '/employee/support/notice' : (isCompanyDashboard ? '/company/support/notices' : (isSupportDashboard ? '/support/notices' : '/admin/notices')) %>"><div class="formGrid"><div class="field"><label>Audience</label><div class="control"><i class="fa-solid fa-users"></i><select name="audience"><option value="customers">Customers</option><option value="partners">Partners</option><option value="promoters">Promoters</option><option value="employees">Employees</option></select></div></div><div class="field"><label>Priority</label><div class="control"><i class="fa-solid fa-flag"></i><select name="priority"><option value="normal">Normal</option><option value="high">High</option><option value="urgent">Urgent</option></select></div></div><div class="field full"><label>Message</label><div class="control"><textarea name="message" placeholder="Write notice message..." required></textarea></div></div></div><button class="btn btnPrimary" type="submit"><i class="fa-solid fa-paper-plane"></i> Send notice</button></form></div><div class="card"><div class="cardHead"><div class="cardTitle"><h3>Correspondence records</h3><p>Stored customer messages, delivery attempts, booking timeline entries, and reschedule requests.</p></div></div><div class="splitGrid"><div class="splitItem"><div class="splitTop"><span>Messages</span><strong><%= correspondenceCount.toLocaleString() %></strong></div></div><div class="splitItem"><div class="splitTop"><span>Delivery attempts</span><strong><%= deliveryCount.toLocaleString() %></strong></div></div><div class="splitItem"><div class="splitTop"><span>Timeline events</span><strong><%= timelineCount.toLocaleString() %></strong></div></div><div class="splitItem"><div class="splitTop"><span>Reschedule requests</span><strong><%= rescheduleCount.toLocaleString() %></strong></div></div></div></div><div class="card"><div class="cardHead"><div class="cardTitle"><h3>Reschedule queue</h3><p>Review stored customer schedule-change requests and export the current queue.</p></div><span class="badge <%= rescheduleCount ? 'warn' : 'ok' %>"><%= rescheduleCount.toLocaleString() %> open records</span></div><a class="btn btnBlue" href="<%= isEmployeeDashboard ? '/employee/reports/reschedules.csv' : (isCompanyDashboard ? '/company/reports/reschedules.csv' : (isSupportDashboard ? '/support/reports/reschedules.csv' : '/admin/reports/reschedules.csv')) %>"><i class="fa-solid fa-download"></i> Download queue</a></div></div></section>
