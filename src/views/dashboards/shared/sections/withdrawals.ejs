<section class="section" id="withdrawals"><div class="grid2"><div class="card"><div class="cardHead"><div class="cardTitle"><h3><i class="fa-solid fa-wallet"></i> Withdrawals</h3><p>Withdrawal requests and wallet payout status.</p></div></div><div class="tableWrap"><table><thead><tr><th>Withdrawal</th><th>Type</th><th>Account</th><th>Date</th><th>Amount</th><th>Status</th><th></th></tr></thead><tbody id="promoterWithdrawalsTable"></tbody></table></div></div><div class="card"><div class="cardHead"><div class="cardTitle"><h3>Request withdrawal</h3><p>Withdraw available promoter earnings.</p></div></div><form class="formPanel" method="POST" action="/promoter/withdrawals"><input type="hidden" name="_csrf" value="<%= csrfToken || '' %>"><div class="formGrid"><div class="field"><label>Amount</label><div class="control"><i class="fa-solid fa-coins"></i><input name="amount" type="number" required></div></div><div class="field"><label>Method</label><div class="control"><i class="fa-solid fa-building-columns"></i><select name="method"><option>Mobile Money</option><option>Bank</option><option>Wallet</option></select></div></div><div class="field full"><label>Account</label><div class="control"><input name="account" placeholder="Enter payout account"></div></div></div><button class="btn btnPrimary" type="submit"><i class="fa-solid fa-paper-plane"></i> Request withdrawal</button></form></div></div></section>
