<%
  const refundRows = Array.isArray(dashboardData?.refunds) ? dashboardData.refunds : [];
  const refundText = function(row){ return Array.isArray(row) ? row.filter(function(cell){ return typeof cell !== 'object'; }).join(' ').toLowerCase() : String(row || '').toLowerCase(); };
  const pendingRefunds = refundRows.filter(function(row){ return /pending|requested|review|processing/.test(refundText(row)); }).length;
  const approvedRefunds = refundRows.filter(function(row){ return /approved|paid|completed|refunded/.test(refundText(row)); }).length;
  const rejectedRefunds = refundRows.filter(function(row){ return /rejected|declined|failed|cancelled/.test(refundText(row)); }).length;
%>
<section class="section" id="refunds"><div class="grid2"><div class="card"><div class="cardHead"><div class="cardTitle"><h3><%= isEmployeeDashboard ? 'Refund requests' : 'Refunds & cancellations' %></h3><p><%= isEmployeeDashboard ? 'Create refund requests for assigned bookings and track customer follow-up.' : 'Approve customer refunds, cancellation fees, failed ticket reversals, and partner chargebacks.' %></p></div><button class="btn btnPrimary" data-modal="create" data-type="refund"><i class="fa-solid fa-rotate-left"></i> <%= isEmployeeDashboard ? 'Request refund' : 'Create refund' %></button></div><div class="tableWrap"><table><thead><tr><th>Refund</th><th>Booking</th><th>Customer</th><th>Reason</th><th>Amount</th><th>Status</th><th></th></tr></thead><tbody id="refundsTable"></tbody></table></div></div><div class="card"><div class="cardHead"><div class="cardTitle"><h3>Refund workflow</h3><p>Counts are derived from refund records in the current dashboard scope.</p></div></div><div class="splitGrid"><div class="splitItem"><div class="splitTop"><span>Total refund records</span><strong><%= refundRows.length.toLocaleString() %></strong></div></div><div class="splitItem"><div class="splitTop"><span>Awaiting action</span><strong><%= pendingRefunds.toLocaleString() %></strong></div></div><div class="splitItem"><div class="splitTop"><span>Approved or completed</span><strong><%= approvedRefunds.toLocaleString() %></strong></div></div><div class="splitItem"><div class="splitTop"><span>Rejected or failed</span><strong><%= rejectedRefunds.toLocaleString() %></strong></div></div></div></div></div></section>
