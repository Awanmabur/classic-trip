<section class="section" id="wallet"><div class="grid2"><div class="card"><div class="cardHead"><div class="cardTitle"><h3><i class="fa-solid fa-wallet"></i> Wallet</h3><p>Wallet balances, credits, refunds, and top-up history.</p></div></div><div class="tableWrap"><table><thead><tr><th>Wallet</th><th>Type</th><th>Currency</th><th>Kind</th><th>Balance</th><th>Status</th><th></th></tr></thead><tbody id="customerWalletTable"></tbody></table></div></div><div class="card"><div class="cardHead"><div class="cardTitle"><h3>Top up wallet</h3><p>Add funds for faster checkout.</p></div></div><form class="formPanel" method="POST" action="/account/wallet/top-up"><input type="hidden" name="_csrf" value="<%= csrfToken || '' %>"><div class="formGrid"><div class="field"><label>Amount</label><div class="control"><i class="fa-solid fa-coins"></i><input name="amount" type="number" min="1" placeholder="50000" required></div></div><div class="field"><label>Currency</label><div class="control"><i class="fa-solid fa-money-bill"></i><select name="currency"><% platformConfig.supportedCurrencies.forEach(function(code){ %><option value="<%= code %>" <%= code === platformConfig.defaultCurrency ? 'selected' : '' %>><%= code %></option><% }) %></select></div></div></div><button class="btn btnPrimary" type="submit"><i class="fa-solid fa-plus"></i> Top up</button></form></div></div></section>
