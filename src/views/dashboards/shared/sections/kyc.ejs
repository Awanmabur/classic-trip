<section class="section" id="kyc"><div class="card"><div class="cardHead"><div class="cardTitle"><h3>KYC / Verification</h3><p>Review partner companies, promoters, payout accounts, identity documents, and compliance checklists.</p></div><button class="btn btnPrimary" data-modal="create" data-type="verification task"><i class="fa-solid fa-id-card-clip"></i> New review</button></div><div class="innerTabs" data-tab-group="kyc-tabs"><button type="button" class="tabBtn is-on" data-tab-target="kyc-pending"><i class="fa-regular fa-hourglass-half"></i> Pending</button><button type="button" class="tabBtn" data-tab-target="kyc-approved"><i class="fa-solid fa-circle-check"></i> Approved</button><button type="button" class="tabBtn" data-tab-target="kyc-rejected"><i class="fa-solid fa-circle-xmark"></i> Rejected</button><button type="button" class="tabBtn" data-tab-target="kyc-bank"><i class="fa-solid fa-building-columns"></i> Bank mismatch</button><button type="button" class="tabBtn" data-tab-target="kyc-expired"><i class="fa-solid fa-file-circle-exclamation"></i> Expired docs</button></div><div class="tabPane is-open" id="kyc-pending"><div class="tableWrap"><table><thead><tr><th>Applicant</th><th>Document</th><th>Country</th><th>Payout account</th><th>Risk</th><th>Status</th><th></th></tr></thead><tbody id="kycTable"></tbody></table></div></div><div class="tabPane" id="kyc-approved"><div class="tableWrap"><table><thead><tr><th>Applicant</th><th>Document</th><th>Country</th><th>Payout account</th><th>Risk</th><th>Status</th><th></th></tr></thead><tbody id="kycApprovedTable"></tbody></table></div></div><div class="tabPane" id="kyc-rejected"><div class="tableWrap"><table><thead><tr><th>Applicant</th><th>Document</th><th>Country</th><th>Payout account</th><th>Risk</th><th>Status</th><th></th></tr></thead><tbody id="kycRejectedTable"></tbody></table></div></div><div class="tabPane" id="kyc-bank"><div class="tableWrap"><table><thead><tr><th>Applicant</th><th>Document</th><th>Country</th><th>Payout account</th><th>Risk</th><th>Status</th><th></th></tr></thead><tbody id="kycBankTable"></tbody></table></div></div><div class="tabPane" id="kyc-expired"><div class="tableWrap"><table><thead><tr><th>Applicant</th><th>Document</th><th>Country</th><th>Payout account</th><th>Risk</th><th>Status</th><th></th></tr></thead><tbody id="kycExpiredTable"></tbody></table></div></div></div></section>
