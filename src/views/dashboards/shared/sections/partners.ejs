<section class="section" id="partners"><div class="grid2"><div class="card"><div class="cardHead"><div class="cardTitle"><h3>Partner companies</h3><p>Approve, suspend, verify, and monitor companies.</p></div><button class="btn btnPrimary" data-modal="create" data-type="partner"><i class="fa-solid fa-building-circle-check"></i> Add partner</button></div><div class="innerTabs" data-tab-group="partners-tabs"><button type="button" class="tabBtn is-on" data-tab-target="partners-all"><i class="fa-solid fa-building"></i> All</button><button type="button" class="tabBtn" data-tab-target="partners-bus"><i class="fa-solid fa-bus"></i> Bus</button><button type="button" class="tabBtn" data-tab-target="partners-hotel"><i class="fa-solid fa-hotel"></i> Hotel</button><button type="button" class="tabBtn" data-tab-target="partners-pending"><i class="fa-regular fa-hourglass-half"></i> Pending</button></div><div class="tabPane is-open" id="partners-all"><div class="tableWrap"><table><thead><tr><th>Partner</th><th>Type</th><th>Country</th><th>Listings</th><th>Verification</th><th>Revenue</th><th>Commission</th><th></th></tr></thead><tbody id="partnersTable"></tbody></table></div></div><div class="tabPane" id="partners-bus"><div class="tableWrap"><table><thead><tr><th>Partner</th><th>Type</th><th>Country</th><th>Listings</th><th>Verification</th><th>Revenue</th><th>Commission</th><th></th></tr></thead><tbody id="partnersBusTable"></tbody></table></div></div><div class="tabPane" id="partners-hotel"><div class="tableWrap"><table><thead><tr><th>Partner</th><th>Type</th><th>Country</th><th>Listings</th><th>Verification</th><th>Revenue</th><th>Commission</th><th></th></tr></thead><tbody id="partnersHotelTable"></tbody></table></div></div><div class="tabPane" id="partners-pending"><div class="tableWrap"><table><thead><tr><th>Partner</th><th>Type</th><th>Country</th><th>Listings</th><th>Verification</th><th>Revenue</th><th>Commission</th><th></th></tr></thead><tbody id="partnersPendingTable"></tbody></table></div></div></div><% const partnerRows = Array.isArray(dashboardData?.partners) ? dashboardData.partners : []; const pendingPartnerRows = partnerRows.filter(function(row){ return /pending|review|submitted/.test((Array.isArray(row) ? row.join(' ') : String(row || '')).toLowerCase()); }); %><div class="card"><div class="cardHead"><div class="cardTitle"><h3>Partner onboarding</h3><p>Canonical checks required before a company can publish services or receive payouts.</p></div><span class="badge <%= pendingPartnerRows.length ? 'warn' : 'ok' %>"><%= pendingPartnerRows.length.toLocaleString() %> awaiting review</span></div><div class="splitGrid"><div class="splitItem"><div class="splitTop"><span>Business registration and licence</span><span class="badge info">Required</span></div></div><div class="splitItem"><div class="splitTop"><span>Verified support contacts</span><span class="badge info">Required</span></div></div><div class="splitItem"><div class="splitTop"><span>Payout account ownership</span><span class="badge info">Required</span></div></div><div class="splitItem"><div class="splitTop"><span>Service inventory and compliance</span><span class="badge info">Required</span></div></div><div class="notice">Approval is based on the company and document records in MongoDB. No progress percentage is invented when evidence has not been submitted.</div></div></div></div></section>
