<section class="section" id="admins"><div class="grid2"><div class="card"><div class="cardHead"><div class="cardTitle"><h3>Admins & roles</h3><p>Manage super admins, finance admins, support leads, content reviewers, and access permissions.</p></div><button class="btn btnBlue" data-modal="create" data-type="admin user"><i class="fa-solid fa-user-plus"></i> Invite admin</button></div><div class="tableWrap"><table><thead><tr><th>Admin</th><th>Role</th><th>Access</th><th>2FA</th><th>Last seen</th><th>Status</th><th></th></tr></thead><tbody id="adminsTable"></tbody></table></div></div><div class="card"><div class="cardHead"><div class="cardTitle"><h3>Permission groups</h3><p>Role-based access control for safe operations.</p></div></div><div class="splitGrid"><div class="splitItem"><div class="splitTop"><span>Finance controls</span><span class="badge warn">Restricted</span></div></div><div class="splitItem"><div class="splitTop"><span>Partner approval</span><span class="badge ok">Managers</span></div></div><div class="splitItem"><div class="splitTop"><span>Audit log access</span><span class="badge info">Super admin</span></div></div><div class="splitItem"><div class="splitTop"><span>Delete / suspend</span><span class="badge <%= platformMfaEnabled ? 'bad' : 'warn' %>"><%= platformMfaEnabled ? 'Requires 2FA' : 'MFA enforcement off' %></span></div></div></div></div></div></section>
