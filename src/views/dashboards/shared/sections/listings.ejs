<section class="section" id="listings"><div class="card"><div class="cardHead"><div class="cardTitle"><h3><%= isCompanyDashboard ? (companyServiceProfile.primaryLabel || 'Company') + ' public listings' : 'Listings & inventory' %></h3><p><%= isCompanyDashboard ? (companySupportsHotel ? 'A listing is the customer-facing hotel page. Create the physical property, room types, room units, and room-night availability under Properties, Rooms & Inventory.' : companySupportsBus ? 'A listing is the customer-facing bus service. Routes, vehicles, live seat maps, and departures select this listing; they are not separate marketplace products.' : 'A listing is the customer-facing service record. Operational inventory selects it rather than retyping the service name.') : 'Bus routes, seat maps, hotel rooms, inventory, and price rules.' %></p></div><button class="btn btnBlue" data-modal="create" data-type="listing"><i class="fa-solid fa-plus"></i> <%= companySupportsHotel ? 'Create hotel listing' : companySupportsBus ? 'Create bus listing' : 'Create listing' %></button></div><div class="innerTabs" data-tab-group="inventory"><button type="button" class="tabBtn is-on" data-tab-target="inventory-all"><i class="fa-solid fa-layer-group"></i> <%= isCompanyDashboard ? (companyServiceProfile.primaryLabel || 'Service') + ' inventory' : 'All inventory' %></button><% if(!isCompanyDashboard || companySupportsBusOperations){ %><button type="button" class="tabBtn" data-tab-target="inventory-routes"><i class="fa-solid fa-bus"></i> Routes & seats</button><% } %><% if(!isCompanyDashboard || companySupportsHotel){ %><button type="button" class="tabBtn" data-tab-target="inventory-stays"><i class="fa-solid fa-hotel"></i> Hotels & rooms</button><% } %><button type="button" class="tabBtn" data-tab-target="inventory-pricing"><i class="fa-solid fa-tags"></i> Price rules</button><button type="button" class="tabBtn" data-tab-target="inventory-review"><i class="fa-solid fa-triangle-exclamation"></i> Needs review</button></div><div class="tabPane is-open" id="inventory-all"><div class="tableWrap"><table><thead><tr><th>Listing</th><th>Type</th><th>Partner</th><th>Inventory</th><th>Country route</th><th>Badge</th><th>Price from</th><th></th></tr></thead><tbody id="listingsTable"></tbody></table></div></div><% if(!isCompanyDashboard || companySupportsBusOperations){ %><div class="tabPane" id="inventory-routes"><div class="tableWrap"><table><thead><tr><th>Route</th><th>Vehicle</th><th>Partner</th><th>Seats</th><th>Schedule</th><th>Status</th><th>Price</th><th></th></tr></thead><tbody id="routeInventoryTable"></tbody></table></div></div><% } %><% if(!isCompanyDashboard || companySupportsHotel){ %><div class="tabPane" id="inventory-stays"><div class="tableWrap"><table><thead><tr><th>Property</th><th>Room type</th><th>Partner</th><th>Rooms</th><th>City</th><th>Status</th><th>Price</th><th></th></tr></thead><tbody id="stayInventoryTable"></tbody></table></div></div><% } %><div class="tabPane" id="inventory-pricing"><% const pricingRules = Array.isArray(dashboardData?.priceRules) ? dashboardData.priceRules : (Array.isArray(dashboardData?.scheduleRules) ? dashboardData.scheduleRules : []); %><div class="cardHead"><div class="cardTitle"><h3>Pricing rules</h3><p>Only rules stored in MongoDB are shown and applied. Listing, fare, and departure forms inherit the company currency instead of asking for it repeatedly.</p></div><button class="btn btnBlue" data-modal="edit" data-type="price rule"><i class="fa-solid fa-pen-to-square"></i> Manage price rules</button></div><% if(pricingRules.length){ %><div class="tableWrap"><table><thead><tr><th>Rule</th><th>Scope</th><th>Value</th><th>Status</th><th></th></tr></thead><tbody id="priceRulesTable"></tbody></table></div><% } else { %><div class="emptyState"><i class="fa-solid fa-tags"></i><strong>No pricing rules configured</strong><span>Base fares remain authoritative until a real pricing rule is created.</span></div><% } %></div><div class="tabPane" id="inventory-review"><div class="tableWrap"><table><thead><tr><th>Item</th><th>Partner</th><th>Reason</th><th>Risk</th><th>Submitted</th><th>Status</th><th></th></tr></thead><tbody id="reviewInventoryTable"></tbody></table></div></div></div></section>
