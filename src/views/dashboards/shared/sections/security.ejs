<section class="section" id="security"><div class="grid2"><div class="card"><div class="cardHead"><div class="cardTitle"><h3><i class="fa-solid fa-shield-halved"></i> Security</h3><p>Account sessions, password state, and verification checks.</p></div></div><div class="tableWrap"><table><thead><tr><th>Item</th><th>Scope</th><th>Last update</th><th>Status</th><th></th></tr></thead><tbody id="customerSecurityTable"></tbody></table></div></div><div class="card"><div class="cardHead"><div class="cardTitle"><h3>Update security</h3><p>Change password or notification security options.</p></div></div><form class="formPanel" method="POST" action="/account/security"><input type="hidden" name="_csrf" value="<%= csrfToken || '' %>"><div class="formGrid"><div class="field"><label>Current password</label><div class="control"><i class="fa-solid fa-lock"></i><input name="currentPassword" type="password"></div></div><div class="field"><label>New password</label><div class="control"><i class="fa-solid fa-key"></i><input name="newPassword" type="password"></div></div><div class="field full"><label>Two-factor note</label><div class="control"><textarea name="securityNote" placeholder="Security request note"></textarea></div></div></div><button class="btn btnPrimary" type="submit"><i class="fa-solid fa-floppy-disk"></i> Save security</button></form></div></div></section>
