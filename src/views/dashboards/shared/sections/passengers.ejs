<section class="section" id="passengers"><div class="grid2"><div class="card"><div class="cardHead"><div class="cardTitle"><h3><i class="fa-solid fa-user-group"></i> Saved passengers</h3><p>Passenger details collected from your bookings and reusable passenger records.</p></div></div><div class="tableWrap"><table><thead><tr><th>Passenger</th><th>Booking</th><th>Seat / room</th><th>Phone</th><th>Email</th><th>Status</th><th></th></tr></thead><tbody id="customerPassengersTable"></tbody></table></div></div><div class="card"><div class="cardHead"><div class="cardTitle"><h3>Passenger defaults</h3><p>Keep lead traveler details ready for booking forms.</p></div></div><form class="formPanel" method="POST" action="/account/profile"><input type="hidden" name="_csrf" value="<%= csrfToken || '' %>"><div class="formGrid"><div class="field"><label>Full name</label><div class="control"><i class="fa-solid fa-user"></i><input name="fullName" value="<%= dashboardData?.profile?.fullName || dashboardShell?.profileName || '' %>"></div></div><div class="field"><label>Phone</label><div class="control"><i class="fa-solid fa-phone"></i><input name="phone" value="<%= dashboardData?.profile?.phone || '' %>"></div></div><div class="field full"><label>Passenger note</label><div class="control"><textarea name="passengerNote"><%= dashboardData?.profile?.passengerNote || '' %></textarea></div></div></div><button class="btn btnPrimary" type="submit"><i class="fa-solid fa-floppy-disk"></i> Save passenger details</button></form></div></div></section>
