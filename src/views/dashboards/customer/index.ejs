        ]
      };

      Object.assign(data, backendDashboardData);

      const pageMeta = {
        overview:['Customer Dashboard','Manage bookings, tickets, saved trips, receipts, refunds, support, reviews, wallet, and profile.'],
        bookings:['My Bookings','View upcoming, completed, cancelled, held, and refund bookings.'],
        ticket:['Current Ticket','Open your active ticket, QR code, receipt, and boarding details.'],
        saved:['Saved Trips','Manage trips, hotels, flights, tours, trains, ferries, and rentals saved for later.'],
        receipts:['Receipts','Download receipts and invoices for your bookings.'],
        refunds:['Refunds','Track refund and cancellation requests.'],
        support:['Support','Create and manage support cases.'],
        reviews:['Reviews','Write and manage reviews for completed trips.'],
        wallet:['Wallet','Manage wallet balance, credits, refunds, and optional promoter upgrade.'],
        notifications:['Notifications','View booking updates, payment alerts, support replies, and trip changes.'],
        profile:['Profile','Manage your personal and passenger details.'],
        security:['Security','Protect your account and view login activity.']
      };

      function escapeHtml(value) {
        return String(value ?? '').replace(/[&<>'"]/g, char => ({'&':'&amp;','<':'&lt;','>':'&gt;',"'":'&#039;','"':'&quot;'}[char]));
      }

      function badge(status){
        const s = String(status || '').toLowerCase();
        let cls = 'info';
        if(['paid','active','verified','settled','healthy','published','running','open','completed','available','submitted','approved','current','trusted','confirmed','successful'].some(x=>s.includes(x))) cls='ok';
        if(['hold','pending','review','waiting','paused','few','promotion','upcoming','unread','recommended','not eligible'].some(x=>s.includes(x))) cls='warn';
        if(['refund','cancelled','suspended','urgent','denied','rejected','failed','void'].some(x=>s.includes(x))) cls='bad';
        return `<span class="badge ${cls}">${escapeHtml(status || '-')}</span>`;
      }

      function initials(name){
        return String(name || '?').split(' ').map(x=>x[0]).join('').slice(0,2).toUpperCase();
      }

      function rowMeta(row) {
        const last = Array.isArray(row) ? row[row.length - 1] : null;
        return last && typeof last === 'object' && !Array.isArray(last) ? last : null;
      }

      function rowCells(row) {
        const meta = rowMeta(row);
        return meta ? row.slice(0, -1) : row;
      }

      function encodeDetail(detail) {
        try { return encodeURIComponent(JSON.stringify(detail || {})); } catch (error) { return ''; }
      }

      function bookingPreviewUrl(){
        const savedRows = Array.isArray(data.saved) ? data.saved : [];
        const bookingRows = Array.isArray(data.bookings) ? data.bookings : [];
        const meta = savedRows.concat(bookingRows).map(rowMeta).find(item => item?.detail?.service?.slug || item?.slug || item?.id);
        const detail = meta?.detail || {};
        const serviceType = detail.service?.type || meta?.serviceType || 'bus';
        const slug = detail.service?.slug || meta?.slug || meta?.id;
        return slug ? `/listings/${encodeURIComponent(serviceType)}/${encodeURIComponent(slug)}` : '/search';
      }

      function openBookingPreview(){
        window.location.href = bookingPreviewUrl();
      }

      function parseDetailFromElement(el) {
        const raw = el?.dataset?.rowDetail || '';
        if (!raw) return null;
        try { return JSON.parse(decodeURIComponent(raw)); } catch (error) { return null; }
      }

      function flattenEntries(obj = {}, prefix = '') {
        const entries = [];
        Object.entries(obj || {}).forEach(([key, value]) => {
          const label = prefix ? `${prefix}.${key}` : key;
          if (value && typeof value === 'object' && !Array.isArray(value)) entries.push(...flattenEntries(value, label));
          else entries.push([label, Array.isArray(value) ? value.join(', ') : value]);
        });
        return entries;
      }

      function detailItem(label, value) {
        const shown = value === undefined || value === null || value === '' ? '-' : value;
        return `<div class="detailItem"><span>${escapeHtml(label)}</span><b>${escapeHtml(shown)}</b></div>`;
      }

      function detailGroup(title, value) {
        const entries = Array.isArray(value) ? value.map((item, index) => [`${title} ${index + 1}`, JSON.stringify(item)]) : flattenEntries(value || {});
        if (!entries.length) return '';
        return `<div class="detailGroup"><h4>${escapeHtml(title)}</h4><div class="detailGrid">${entries.map(([label, val]) => detailItem(label, val)).join('')}</div></div>`;
      }

      function detailMarkup(detail = {}) {
        const groups = Object.entries(detail || {}).map(([title, value]) => detailGroup(title, value)).join('');
        return `<div class="detailBlock">${groups || '<div class="notice">No additional backend details were provided for this row.</div>'}</div>`;
      }

      function openDetailModal(type, label, detail) {
        els.crudTitle.textContent = `View ${type || 'record'}`;
        els.crudSub.textContent = label ? `Full customer-scoped details for ${label}` : 'Full customer-scoped backend details';
        els.crudBody.innerHTML = detailMarkup(detail || {});
        els.crudModal.classList.add('is-open');
      }

      function downloadText(filename, text, mime = 'text/plain') {
        const blob = new Blob([text], { type: mime });
        const url = URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = url;
        a.download = filename;
        document.body.appendChild(a);
        a.click();
        a.remove();
        URL.revokeObjectURL(url);
      }


  function exportDetailPdf(detail, name){
    const title = String(name || 'dashboard-record');
    const win = window.open('', '_blank', 'noopener,noreferrer,width=900,height=720');
    if(!win){ if(typeof toast === 'function') toast('Allow popups to export PDF'); else if(typeof showToast === 'function') showToast('Allow popups to export PDF'); return; }
    const body = detailMarkup(detail || {});
    win.document.write(`<!doctype html><html><head><meta charset="utf-8"><title>${escapeHtml(title)} PDF</title><style>
      body{font-family:Inter,Arial,sans-serif;margin:28px;color:#111827;background:#fff}.brand{display:flex;justify-content:space-between;gap:16px;border-bottom:2px solid #e5e7eb;padding-bottom:14px;margin-bottom:18px}.brand h1{font-size:22px;margin:0}.brand p{margin:4px 0 0;color:#6b7280}.detailGroup{break-inside:avoid;margin:0 0 16px}.detailGroup h4{font-size:14px;margin:0 0 8px;color:#111827}.detailGrid{display:grid;grid-template-columns:repeat(3,1fr);gap:8px}.detailItem{border:1px solid #e5e7eb;border-radius:10px;padding:8px;min-width:0}.detailItem span{display:block;font-size:9px;letter-spacing:.06em;text-transform:uppercase;color:#6b7280;font-weight:800}.detailItem b{display:block;font-size:12px;word-break:break-word}.detailItem.full{grid-column:1/-1}@media print{button{display:none}body{margin:14mm}}
    </style></head><body><div class="brand"><div><h1>Classic Trip Dashboard Record</h1><p>${escapeHtml(title)} · ${new Date().toLocaleString()}</p></div><button onclick="window.print()">Print / Save PDF</button></div>${body}<script>setTimeout(()=>window.print(),300)<\/script></body></html>`);
    win.document.close();
  }

      function actions(label, meta){
        const safeLabel = escapeHtml(label || meta?.label || 'record');
        const type = escapeHtml(meta?.entity || 'record');
        const detailAttr = meta?.detail ? ` data-row-detail="${escapeHtml(encodeDetail(meta.detail))}"` : '';
        const actionSet = new Set(meta?.actions || []);
        const ticketBtn = actionSet.has('ticket') ? `<button class="tinyBtn" data-jump="ticket" title="Open current ticket"><i class="fa-solid fa-qrcode"></i></button>` : '';
        const copyBtn = `<button class="tinyBtn" data-copy-value="${safeLabel}" title="Copy reference"><i class="fa-regular fa-copy"></i></button>`;
        const exportBtn = `<button class="tinyBtn" data-export-row="${type}" data-label="${safeLabel}"${detailAttr} title="Export PDF"><i class="fa-solid fa-file-export"></i></button>`;
        return `<div class="rowActions">
          <button class="tinyBtn" data-modal="view" data-type="${type}" data-label="${safeLabel}"${detailAttr} title="View full details"><i class="fa-regular fa-eye"></i></button>
          ${ticketBtn}${copyBtn}${exportBtn}
        </div>`;
      }

      function emptyRow(cols, text='No matching records found'){
        return `<tr><td colspan="${cols}" style="text-align:center;color:var(--muted);border-radius:16px;border:1px solid var(--line2);background:var(--table);padding:18px">${escapeHtml(text)}</td></tr>`;
      }

      function renderRows(tbody, rows, opts = {}){
        if(!tbody) return;
        const cols = opts.cols || 7;
        rows = Array.isArray(rows) ? rows : [];
        if(!rows.length){ tbody.innerHTML = emptyRow(cols); return; }
        tbody.innerHTML = rows.map((r)=>{
          const meta = rowMeta(r);
          const row = rowCells(r);
          const first = opts.avatar ? `<div class="nameCell"><div class="miniLogo">${initials(row[0])}</div><div><strong>${escapeHtml(row[0])}</strong><span>${escapeHtml(row[1] || '')}</span></div></div>` : escapeHtml(row[0]);
          const cells = row.map((cell, i)=>{
            if(i === 0) return `<td>${first}</td>`;
            if(opts.statusIndex === i) return `<td>${badge(cell)}</td>`;
            return `<td>${escapeHtml(cell)}</td>`;
          }).join('');
          return `<tr data-row-text="${escapeHtml(row.join(' '))}">${cells}<td>${actions(row[0], meta)}</td></tr>`;
        }).join('');
      }

      function sameStatus(actual, requested) {
        const a = String(actual || '').toLowerCase();
        const r = String(requested || '').toLowerCase();
        if (!r) return true;
        if (r === 'upcoming') return /(confirmed|pending|ticketed|upcoming)/.test(a);
        if (r === 'refund') return /refund/.test(a);
        return a.includes(r);
      }

      function fillOverview(){
        const stats = Array.isArray(data.overviewStats) ? data.overviewStats : [];
        const cards = $$('#overview .statsGrid .statCard');
        stats.slice(0, cards.length).forEach((stat, index) => {
          const card = cards[index];
          const number = card.querySelector('.statNumber');
          const label = card.querySelector('.statLabel');
          const trend = card.querySelector('.trend');
          const icon = card.querySelector('.statIcon i');
          if (number) number.textContent = stat.value || '-';
          if (label) label.textContent = stat.label || 'Metric';
          if (trend) trend.innerHTML = `<i class="fa-solid fa-circle-info"></i> ${escapeHtml(stat.hint || 'Live')}`;
          if (icon && stat.icon) icon.className = `fa-solid ${stat.icon}`;
        });
        const liveItems = $$('#overview .liveItem');
        (data.liveActivity || []).slice(0, liveItems.length).forEach((item, index) => {
          const node = liveItems[index];
          const span = node.querySelector('span');
          const strong = node.querySelector('strong');
          if (span) span.textContent = item[0];
          if (strong) strong.textContent = item[1];
        });
        const profile = data.profile || {};
        const welcome = $('#overview .welcome h2');
        if (welcome && profile.fullName) welcome.textContent = `Welcome ${profile.fullName}. Your next trip is ready when you are.`;
      }

      function fillCurrentTicket(){
        const ticket = data.currentTicket;
        if (!ticket || !ticket.booking) return;
        const card = $('#ticket .ticketCard');
        if (!card) return;
        const booking = ticket.booking || {};
        const customer = ticket.customer || {};
        const service = ticket.service || {};
        const payment = ticket.payment || {};
        const checkIn = ticket.checkIn || {};
        const seats = Array.isArray(booking.seats) && booking.seats.length ? booking.seats.join(', ') : 'Assigned at check-in';
        card.innerHTML = `
          <div class="ticketCode">
            <div>
              ${badge(booking.bookingStatus || '-')}
              <h3 style="margin:10px 0 4px;font-size:20px">${escapeHtml(service.name || booking.serviceType || 'Current ticket')}</h3>
              <p style="margin:0;color:var(--muted);font-size:12px;font-weight:800">${escapeHtml(ticket.company?.name || 'Classic Trip partner')} • ${escapeHtml(service.departure || service.from || '')} • Seat/room ${escapeHtml(seats)}</p>
            </div>
            <div class="qr">QR</div>
          </div>
          <div class="grid3">
            <div class="splitItem"><div class="splitTop"><span>Booking</span><strong>${escapeHtml(booking.bookingRef || '-')}</strong></div></div>
            <div class="splitItem"><div class="splitTop"><span>Passenger</span><strong>${escapeHtml(customer.name || '-')}</strong></div></div>
            <div class="splitItem"><div class="splitTop"><span>Paid</span><strong>${escapeHtml(payment.currency || 'UGX')} ${escapeHtml(payment.amount || 0)}</strong></div></div>
            <div class="splitItem"><div class="splitTop"><span>Payment ref</span><strong>${escapeHtml(payment.reference || '-')}</strong></div></div>
            <div class="splitItem"><div class="splitTop"><span>Check-in</span><strong>${escapeHtml(checkIn.status || '-')}</strong></div></div>
            <div class="splitItem"><div class="splitTop"><span>Lookup code</span><strong>${escapeHtml(booking.guestLookupCode || booking.bookingRef || '-')}</strong></div></div>
          </div>
          <div class="notice">Show this QR/booking code at check-in. Company contact: ${escapeHtml(ticket.company?.phone || ticket.company?.email || 'available from support')}.</div>`;
      }

      function fillProfile(){
        const profile = data.profile || {};
        const inputs = $$('#profileForm input');
        if (inputs[0]) inputs[0].value = profile.fullName || inputs[0].value;
        if (inputs[1]) inputs[1].value = profile.phone || inputs[1].value;
        if (inputs[2]) inputs[2].value = profile.email || inputs[2].value;
        if (inputs[3]) inputs[3].value = profile.city || inputs[3].value;
        const textarea = $('#profileForm textarea');
        if (textarea) textarea.value = profile.passengerNote || textarea.value;
        const prefs = data.profile?.preferences || {};
        const prefItems = $$('#profile .splitItem .splitTop');
        const values = [prefs.preferredSeat, prefs.defaultCurrency, prefs.notifications, prefs.receiptEmail];
        values.forEach((value, index) => {
          const node = prefItems[index]?.querySelector('strong, .badge');
          if (node && value) node.textContent = value;
        });
      }

      function renderAll(){
        fillOverview();
        fillCurrentTicket();
        fillProfile();
        renderRows($('#recentBookings'), (data.bookings || []).slice(0,5).map(r=>{
          const m = rowMeta(r); const c = rowCells(r); return [c[0],c[1],c[2],c[3],c[5],c[6],m];
        }), {statusIndex:4, cols:7});
        renderRows($('#bookingsTable'), data.bookings || [], {statusIndex:5, cols:8});
        renderRows($('#savedTable'), data.saved || [], {statusIndex:5, cols:7});
        renderRows($('#receiptsTable'), data.receipts || [], {statusIndex:5, cols:7});
        renderRows($('#refundsTable'), data.refunds || [], {statusIndex:4, cols:7});
        renderRows($('#supportTable'), data.support || [], {statusIndex:4, cols:7});
        renderRows($('#reviewsTable'), data.reviews || [], {statusIndex:5, cols:7});
        renderRows($('#walletTable'), data.wallet || [], {statusIndex:5, cols:7});
        renderRows($('#notificationsTable'), data.notifications || [], {statusIndex:4, cols:6});
        renderRows($('#securityTable'), data.security || [], {statusIndex:3, cols:5});

        $$('[data-filter-table]').forEach(tbody => {
          const table = tbody.dataset.filterTable;
          const filter = tbody.dataset.filter;
          let rows = [];
          if(table === 'bookings-status') rows = (data.bookings || []).filter(r => sameStatus(rowCells(r)[5], filter));
          if(table === 'receipts-status') rows = (data.receipts || []).filter(r => sameStatus(rowCells(r)[5], filter));
          if(table === 'reviews-status') rows = (data.reviews || []).filter(r => sameStatus(rowCells(r)[5], filter));

          if(table.startsWith('bookings')) renderRows(tbody, rows, {statusIndex:5, cols:8});
          if(table.startsWith('receipts')) renderRows(tbody, rows, {statusIndex:5, cols:7});
          if(table.startsWith('reviews')) renderRows(tbody, rows, {statusIndex:5, cols:7});
        });
        enhanceTables();
      }

      function enhanceTables() {
        $$('.tableWrap').forEach((wrap, index) => {
          if (wrap.dataset.enhanced === 'true') return;
          const table = wrap.querySelector('table');
          if (!table) return;
          wrap.dataset.enhanced = 'true';
          const tools = document.createElement('div');
          tools.className = 'tableTools';
          tools.innerHTML = `
            <div class="control"><i class="fa-solid fa-magnifying-glass"></i><input data-table-search placeholder="Search this table"></div>
            <div class="control"><i class="fa-solid fa-filter"></i><select data-table-status><option value="">All statuses</option><option>confirmed</option><option>pending</option><option>completed</option><option>cancelled</option><option>refund</option><option>active</option><option>unread</option></select></div>
            <div class="control"><i class="fa-regular fa-calendar"></i><input data-table-date type="date"></div>
            <button class="btn" type="button" data-export-table><i class="fa-solid fa-download"></i> Export CSV</button>`;
          wrap.parentNode.insertBefore(tools, wrap);
          const runFilter = () => {
            const q = tools.querySelector('[data-table-search]').value.toLowerCase().trim();
            const status = tools.querySelector('[data-table-status]').value.toLowerCase().trim();
            const date = tools.querySelector('[data-table-date]').value;
            Array.from(table.tBodies[0]?.rows || []).forEach(row => {
              const text = row.textContent.toLowerCase();
              const okQ = !q || text.includes(q);
              const okS = !status || text.includes(status);
              const okD = !date || text.includes(date);
              row.style.display = okQ && okS && okD ? '' : 'none';
            });
          };
          tools.addEventListener('input', runFilter);
          tools.addEventListener('change', runFilter);
          tools.querySelector('[data-export-table]').addEventListener('click', () => {
            const rows = Array.from(table.rows).filter(row => row.style.display !== 'none').map(row => Array.from(row.cells).map(cell => cell.textContent.trim()));
            const csv = rows.map(row => row.map(cell => `"${cell.replace(/"/g, '""')}"`).join(',')).join('\n');
            downloadText(`classic-trip-customer-table-${index + 1}.csv`, csv, 'text/csv');
            showToast('Table CSV exported');
          });
        });
      }

      function openPage(page){
        $$('.section').forEach(s => s.classList.remove('is-open'));
        const section = $('#' + page);
        if(section) section.classList.add('is-open');

        $$('.navBtn').forEach(b => b.classList.toggle('is-active', b.dataset.page === page));
        const meta = pageMeta[page] || pageMeta.overview;
        els.pageHeading.textContent = meta[0];
        els.pageSub.textContent = meta[1];

        document.body.classList.remove('menu-open');
        requestAnimationFrame(() => {
          window.scrollTo({ top: 0, behavior: 'auto' });
          setTimeout(() => window.scrollTo({ top: 0, behavior: 'auto' }), 30);
        });
      }

      function showToast(text){
        els.toastText.textContent = text;
        els.toast.classList.add('show');
        clearTimeout(showToast.t);
        showToast.t = setTimeout(() => els.toast.classList.remove('show'), 2300);
      }

      function csrfField(){
        const token = document.querySelector('meta[name="csrf-token"]')?.getAttribute('content') || '';
        return token ? `<input type="hidden" name="_csrf" value="${escapeHtml(token)}">` : '';
      }

      function bookingOptions(){
        const rows = (data.bookings || []).map(row => rowCells(row)[0]).filter(Boolean);
        return rows.length ? rows : [''];
      }

      function selectOptions(items, selected = ''){
        return (items || []).map(item => {
          const value = typeof item === 'string' ? item : item.value;
          const label = typeof item === 'string' ? item : item.label;
          return `<option value="${escapeHtml(value)}"${String(value) === String(selected) ? ' selected' : ''}>${escapeHtml(label)}</option>`;
        }).join('');
      }

      function fieldHtml(field, readonly = false, disabled = false){
        const ro = readonly ? 'readonly' : '';
        const dis = disabled ? 'disabled' : '';
        const required = field.required ? 'required' : '';
        const value = field.value || '';
        if(field.type === 'textarea'){
          return `<div class="field ${field.full ? 'full' : ''}"><label>${escapeHtml(field.label)}</label><div class="control"><textarea name="${escapeHtml(field.name)}" placeholder="${escapeHtml(field.placeholder || '')}" ${ro} ${required}>${escapeHtml(value)}</textarea></div></div>`;
        }
        if(field.type === 'select'){
          return `<div class="field ${field.full ? 'full' : ''}"><label>${escapeHtml(field.label)}</label><div class="control"><i class="fa-solid ${field.icon || 'fa-list'}"></i><select name="${escapeHtml(field.name)}" ${dis} ${required}>${selectOptions(field.options, value)}</select></div></div>`;
        }
        if(field.type === 'checkbox'){
          return `<div class="field ${field.full ? 'full' : ''}"><label>${escapeHtml(field.label)}</label><div class="control"><i class="fa-solid ${field.icon || 'fa-toggle-on'}"></i><select name="${escapeHtml(field.name)}" ${dis}><option value="on"${field.checked ? ' selected' : ''}>Enabled</option><option value="">Disabled</option></select></div></div>`;
        }
        return `<div class="field ${field.full ? 'full' : ''}"><label>${escapeHtml(field.label)}</label><div class="control"><i class="fa-solid ${field.icon || 'fa-pen'}"></i><input name="${escapeHtml(field.name)}" type="${escapeHtml(field.type || 'text')}" value="${escapeHtml(value)}" placeholder="${escapeHtml(field.placeholder || '')}" ${ro} ${required}></div></div>`;
      }

      function customerFormConfig(type){
        const key = String(type || '').toLowerCase();
        const bookingRefs = bookingOptions();
        if(key.includes('refund')) return {
          action: '/account/refunds',
          submit: 'Request refund',
          fields: [
            { name:'bookingRef', label:'Booking', type:'select', icon:'fa-ticket', options: bookingRefs, required:true },
            { name:'amount', label:'Refund amount', type:'number', icon:'fa-coins', placeholder:'25000' },
            { name:'reason', label:'Reason', type:'textarea', full:true, required:true, placeholder:'Explain the refund request' }
          ]
        };
        if(key.includes('support')) return {
          action: '/account/support',
          submit: 'Create case',
          fields: [
            { name:'bookingRef', label:'Related booking', type:'select', icon:'fa-ticket', options: bookingRefs },
            { name:'category', label:'Category', type:'select', icon:'fa-tags', options:['Ticket issue','Payment issue','Refund follow-up','Account help'] },
            { name:'priority', label:'Priority', type:'select', icon:'fa-flag', options:['normal','high','urgent'] },
            { name:'message', label:'Message', type:'textarea', full:true, required:true, placeholder:'Tell support what happened' }
          ]
        };
        if(key === 'review') return {
          action: '/account/reviews',
          submit: 'Submit review',
          fields: [
            { name:'bookingRef', label:'Booking', type:'select', icon:'fa-ticket', options: bookingRefs, required:true },
            { name:'rating', label:'Rating', type:'select', icon:'fa-star', options:['5','4','3','2','1'], required:true },
            { name:'comment', label:'Review', type:'textarea', full:true, required:true, placeholder:'Share your trip experience' }
          ]
        };
        if(key.includes('saved')) return {
          action: '/account/saved',
          submit: 'Save trip',
          fields: [
            { name:'listingId', label:'Listing ID or slug', icon:'fa-layer-group', required:true, placeholder:'bus-kampala-nairobi' },
            { name:'notes', label:'Notes', type:'textarea', full:true, placeholder:'Why you want to save this trip' }
          ]
        };
        if(key.includes('wallet')) return {
          action: '/account/wallet/top-up',
          submit: 'Top up wallet',
          fields: [
            { name:'amount', label:'Amount', type:'number', icon:'fa-coins', required:true, placeholder:'50000' },
            { name:'currency', label:'Currency', type:'select', icon:'fa-money-bill', options:['UGX','KES','RWF','TZS','USD'] },
            { name:'method', label:'Method', type:'select', icon:'fa-credit-card', options:['mobile_money','card','bank_transfer','cash'] },
            { name:'paymentReference', label:'Payment reference', icon:'fa-receipt', placeholder:'MM-123456' },
            { name:'notes', label:'Notes', type:'textarea', full:true, placeholder:'Optional payment note' }
          ]
        };
        if(key.includes('promoter')) return {
          action: '/account/promoter',
          submit: 'Create promoter account',
          fields: [
            { name:'referralCode', label:'Referral code', icon:'fa-link', placeholder:'MY-CODE' },
            { name:'defaultChannel', label:'Main channel', type:'select', icon:'fa-share-nodes', options:['social','whatsapp','email','agent_network'] },
            { name:'payoutMethod', label:'Payout method', type:'select', icon:'fa-wallet', options:['Mobile Money','Bank','Wallet'] },
            { name:'payoutAccount', label:'Payout account', icon:'fa-id-card', placeholder:'Phone or account number' },
            { name:'bio', label:'Promoter note', type:'textarea', full:true, placeholder:'Where you plan to share Classic Trip listings' }
          ]
        };
        if(key.includes('security')) return {
          action: '/account/security',
          submit: 'Update security',
          fields: [
            { name:'twoFactorEnabled', label:'Two-factor authentication', type:'checkbox', icon:'fa-shield-halved', checked:Boolean(data.profile?.twoFactorEnabled) },
            { name:'loginAlertsEnabled', label:'Login alerts', type:'checkbox', icon:'fa-bell', checked:true },
            { name:'recoveryEmail', label:'Recovery email', type:'email', icon:'fa-envelope', value:data.profile?.email || '', placeholder:'you@example.com' },
            { name:'passwordChanged', label:'Mark password changed', type:'checkbox', icon:'fa-key' }
          ]
        };
        return null;
      }

      function openCrud(mode, type, label = ''){
        const nice = String(type || 'record');
        if(mode === 'create' && nice.toLowerCase().includes('booking')){
          window.location.href = '/search?bookable=true';
          return;
        }
        const readonly = mode === 'view';
        const disabled = mode === 'view';
        const title = mode === 'view' ? `View ${nice}` : mode === 'edit' ? `Edit ${nice}` : `Create ${nice}`;
        const config = customerFormConfig(nice);
        els.crudTitle.textContent = title;
        els.crudSub.textContent = mode === 'view' ? 'Customer scoped details and safe actions.' : 'Submit this customer workflow to Classic Trip.';
        if(!config && mode !== 'view'){
          els.crudBody.innerHTML = `<div class="notice">This customer action opens from the marketplace or row details.</div><div style="display:flex;gap:8px;justify-content:flex-end;flex-wrap:wrap"><button class="btn btnBlue" type="button" data-close-modal>Done</button></div>`;
          els.crudModal.classList.add('is-open');
          return;
        }
        const fields = config ? config.fields.map(field => fieldHtml(field, readonly, disabled)).join('') : '';
        els.crudBody.innerHTML = `
          <form class="formPanel" data-dashboard-form method="POST" action="${escapeHtml(config?.action || '')}">
            ${csrfField()}
            <div class="formGrid">${fields}</div>
            <div style="display:flex;gap:8px;justify-content:flex-end;flex-wrap:wrap">
              <button class="btn" type="button" data-close-modal>Cancel</button>
              ${mode === 'view' ? `<button class="btn btnBlue" type="button" data-close-modal>Done</button>` : `<button class="btn btnPrimary" type="submit"><i class="fa-solid fa-paper-plane"></i> ${escapeHtml(config.submit || 'Submit')}</button>`}
            </div>
          </form>
        `;
        els.crudModal.classList.add('is-open');
      }

      function closeModals(){
        $$('.modal').forEach(m => m.classList.remove('is-open'));
      }

      $('#sideNav').addEventListener('click', e => {
        const btn = e.target.closest('.navBtn');
        if(btn) openPage(btn.dataset.page);
      });

      $$('[data-jump]').forEach(btn => {
        btn.addEventListener('click', () => openPage(btn.dataset.jump));
      });

      document.addEventListener('click', e => {
        const tabBtn = e.target.closest('.tabBtn');
        if(tabBtn){
          const group = tabBtn.closest('[data-tabs]');
          const tab = tabBtn.dataset.tab;
          $$('.tabBtn', group).forEach(b => b.classList.toggle('is-on', b === tabBtn));
          $$('.tabPane', group).forEach(p => p.classList.toggle('is-on', p.dataset.pane === tab));
          requestAnimationFrame(() => window.scrollTo({ top: 0, behavior: 'auto' }));
        }

        const copyBtn = e.target.closest('[data-copy-value]');
        if(copyBtn){
          e.preventDefault();
          navigator.clipboard?.writeText(copyBtn.dataset.copyValue || '').catch(() => {});
          showToast('Copied reference');
          return;
        }

        const exportRowBtn = e.target.closest('[data-export-row]');
        if(exportRowBtn){
          e.preventDefault();
          const detail = parseDetailFromElement(exportRowBtn) || { label: exportRowBtn.dataset.label || '' };
          exportDetailPdf(detail, exportRowBtn.dataset.exportRow || exportRowBtn.dataset.label || 'record');
          showToast('PDF export opened');
          return;
        }

        const modalBtn = e.target.closest('[data-modal]');
        if(modalBtn){
          e.preventDefault();
          const detail = parseDetailFromElement(modalBtn);
          if (modalBtn.dataset.modal === 'view' && detail) openDetailModal(modalBtn.dataset.type, modalBtn.dataset.label || '', detail);
          else openCrud(modalBtn.dataset.modal, modalBtn.dataset.type, modalBtn.dataset.label || '');
          return;
        }

        const delBtn = e.target.closest('[data-delete]');
        if(delBtn){
          els.deleteText.textContent = `Are you sure you want to delete "${delBtn.dataset.delete}"?`;
          els.deleteModal.classList.add('is-open');
        }

        if(e.target.closest('[data-close-modal]')) closeModals();
      });

      document.addEventListener('submit', e => {
        if(e.target.matches('[data-dashboard-form]')){
          if(e.target.hasAttribute('action')) return;
          e.preventDefault();
          closeModals();
          showToast('Saved successfully');
        }
      });

      if(els.confirmDelete){
        els.confirmDelete.addEventListener('click', () => {
          closeModals();
          showToast('Record deleted');
        });
      }

      if(els.btnNew) els.btnNew.addEventListener('click', () => openCrud('create', 'trip booking'));
      if(els.btnExport) els.btnExport.addEventListener('click', () => { const rows = data.bookings || []; const csv = rows.map(row => rowCells(row).map(cell => `"${String(cell ?? '').replace(/"/g, '""')}"`).join(',')).join('\n'); downloadText('classic-trip-customer-bookings.csv', csv, 'text/csv'); showToast('Bookings exported'); });
      if(els.btnPrintTicket) els.btnPrintTicket.addEventListener('click', () => showToast('Ticket sent to printer'));
      if(els.btnDownloadAll) els.btnDownloadAll.addEventListener('click', () => { const rows = data.receipts || []; const csv = rows.map(row => rowCells(row).map(cell => `"${String(cell ?? '').replace(/"/g, '""')}"`).join(',')).join('\n'); downloadText('classic-trip-customer-receipts.csv', csv, 'text/csv'); showToast('Receipts exported'); });
      if(els.btnMarkRead) els.btnMarkRead.addEventListener('click', () => showToast('All notifications marked as read'));
      if(els.openMenu) els.openMenu.addEventListener('click', () => document.body.classList.add('menu-open'));
      if(els.sideBackdrop) els.sideBackdrop.addEventListener('click', () => document.body.classList.remove('menu-open'));

      if(els.btnTheme){
        els.btnTheme.addEventListener('click', () => {
          const html = document.documentElement;
          const next = html.dataset.theme === 'dark' ? 'light' : 'dark';
          html.dataset.theme = next;
          els.themeIcon.className = next === 'dark' ? 'fa-solid fa-moon' : 'fa-solid fa-sun';
        });
      }

      if(els.sideSearch){
        els.sideSearch.addEventListener('input', () => {
          const q = els.sideSearch.value.trim().toLowerCase();
          $$('.navBtn').forEach(btn => {
            const text = btn.textContent.toLowerCase();
            btn.style.display = text.includes(q) ? 'flex' : 'none';
          });
        });
      }

      document.addEventListener('keydown', e => {
        if(e.key === 'Escape'){
          closeModals();
          document.body.classList.remove('menu-open');
        }
      });

      renderAll();
      openPage('overview');
    });
  </script>
</body>
</html>
