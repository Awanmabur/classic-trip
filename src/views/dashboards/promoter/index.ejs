      function escapeHtml(value) {
        return String(value ?? '').replace(/[&<>'"]/g, char => ({'&':'&amp;','<':'&lt;','>':'&gt;',"'":'&#039;','"':'&quot;'}[char]));
      }

      function badge(status){
        const s = String(status || '').toLowerCase();
        let cls = 'info';
        if(['paid','active','verified','settled','approved','running','open','earned','available','high conversion','low','enabled','successful','completed'].some(x=>s.includes(x))) cls='ok';
        if(['hold','pending','review','waiting','paused','few','promotion','medium','available_balance'].some(x=>s.includes(x))) cls='warn';
        if(['refund','cancelled','suspended','urgent','denied','rejected','blocked','failed'].some(x=>s.includes(x))) cls='bad';
        return `<span class="badge ${cls}">${escapeHtml(status || '-')}</span>`;
      }

      function rowMeta(row) {
        const last = Array.isArray(row) ? row[row.length - 1] : null;
        return last && typeof last === 'object' && !Array.isArray(last) ? last : null;
      }

      function rowCells(row) {
        const meta = rowMeta(row);
        return meta ? row.slice(0, -1) : row;
      }

      function encodeDetail(detail) {
        try { return encodeURIComponent(JSON.stringify(detail || {})); } catch (error) { return ''; }
      }

      function parseDetailFromElement(el) {
        const raw = el?.dataset?.rowDetail || '';
        if (!raw) return null;
        try { return JSON.parse(decodeURIComponent(raw)); } catch (error) { return null; }
      }

      function flattenEntries(obj = {}, prefix = '') {
        const entries = [];
        Object.entries(obj || {}).forEach(([key, value]) => {
          const label = prefix ? `${prefix}.${key}` : key;
          if (value && typeof value === 'object' && !Array.isArray(value)) entries.push(...flattenEntries(value, label));
          else entries.push([label, Array.isArray(value) ? value.join(', ') : value]);
        });
        return entries;
      }

      function detailItem(label, value) {
        const shown = value === undefined || value === null || value === '' ? '-' : value;
        return `<div class="detailItem"><span>${escapeHtml(label)}</span><b>${escapeHtml(shown)}</b></div>`;
      }

      function detailGroup(title, value) {
        const entries = Array.isArray(value) ? value.map((item, index) => [`${title} ${index + 1}`, JSON.stringify(item)]) : flattenEntries(value || {});
        if (!entries.length) return '';
        return `<div class="detailGroup"><h4>${escapeHtml(title)}</h4><div class="detailGrid">${entries.map(([label, val]) => detailItem(label, val)).join('')}</div></div>`;
      }

      function detailMarkup(detail = {}) {
        const groups = Object.entries(detail || {}).map(([title, value]) => detailGroup(title, value)).join('');
        return `<div class="detailBlock">${groups || '<div class="notice">No additional backend details were provided for this row.</div>'}</div>`;
      }

      function openDetailModal(type, label, detail) {
        els.crudTitle.textContent = `View ${type || 'record'}`;
        els.crudSub.textContent = label ? `Full promoter-scoped details for ${label}` : 'Full promoter-scoped backend details';
        els.crudBody.innerHTML = detailMarkup(detail || {});
        els.crudModal.classList.add('is-open');
      }

      function downloadText(filename, text, mime = 'text/plain') {
        const blob = new Blob([text], { type: mime });
        const url = URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = url;
        a.download = filename;
        document.body.appendChild(a);
        a.click();
        a.remove();
        URL.revokeObjectURL(url);
      }


  function exportDetailPdf(detail, name){
    const title = String(name || 'dashboard-record');
    const win = window.open('', '_blank', 'noopener,noreferrer,width=900,height=720');
    if(!win){ if(typeof toast === 'function') toast('Allow popups to export PDF'); else if(typeof showToast === 'function') showToast('Allow popups to export PDF'); return; }
    const body = detailMarkup(detail || {});
    win.document.write(`<!doctype html><html><head><meta charset="utf-8"><title>${escapeHtml(title)} PDF</title><style>
      body{font-family:Inter,Arial,sans-serif;margin:28px;color:#111827;background:#fff}.brand{display:flex;justify-content:space-between;gap:16px;border-bottom:2px solid #e5e7eb;padding-bottom:14px;margin-bottom:18px}.brand h1{font-size:22px;margin:0}.brand p{margin:4px 0 0;color:#6b7280}.detailGroup{break-inside:avoid;margin:0 0 16px}.detailGroup h4{font-size:14px;margin:0 0 8px;color:#111827}.detailGrid{display:grid;grid-template-columns:repeat(3,1fr);gap:8px}.detailItem{border:1px solid #e5e7eb;border-radius:10px;padding:8px;min-width:0}.detailItem span{display:block;font-size:9px;letter-spacing:.06em;text-transform:uppercase;color:#6b7280;font-weight:800}.detailItem b{display:block;font-size:12px;word-break:break-word}.detailItem.full{grid-column:1/-1}@media print{button{display:none}body{margin:14mm}}
    </style></head><body><div class="brand"><div><h1>Classic Trip Dashboard Record</h1><p>${escapeHtml(title)} · ${new Date().toLocaleString()}</p></div><button onclick="window.print()">Print / Save PDF</button></div>${body}<script>setTimeout(()=>window.print(),300)<\/script></body></html>`);
    win.document.close();
  }

      function actions(label, meta){
        const safeLabel = escapeHtml(label || meta?.label || 'record');
        const rawType = meta?.entity || 'record';
        const type = escapeHtml(rawType);
        const detailAttr = meta?.detail ? ` data-row-detail="${escapeHtml(encodeDetail(meta.detail))}"` : '';
        const detail = meta?.detail || {};
        const actionSet = new Set(meta?.actions || []);
        const copySource = detail.referralLink?.listingReferralUrl || detail.referral?.referralUrl || detail.referralLink?.marketplaceReferralUrl || label || meta?.label || '';
        const shareUrl = detail.referralLink?.whatsappShare || detail.referral?.whatsappShare || '';
        const copyBtn = actionSet.has('copy') || actionSet.has('share') ? `<button class="tinyBtn" data-copy-value="${escapeHtml(copySource)}" title="Copy reference/link"><i class="fa-regular fa-copy"></i></button>` : '';
        const shareBtn = shareUrl ? `<a class="tinyBtn" href="${escapeHtml(shareUrl)}" target="_blank" rel="noopener" title="Share on WhatsApp"><i class="fa-brands fa-whatsapp"></i></a>` : '';
        const exportBtn = `<button class="tinyBtn" data-export-row="${type}" data-label="${safeLabel}"${detailAttr} title="Export PDF"><i class="fa-solid fa-file-export"></i></button>`;
        const archiveUrl = rawType === 'referral_link' && meta?.id ? `/promoter/links/${encodeURIComponent(meta.id)}/archive` : '';
        const archiveBtn = archiveUrl ? `<button class="tinyBtn danger" data-delete-url="${escapeHtml(archiveUrl)}" data-delete-label="${safeLabel}" title="Archive link"><i class="fa-solid fa-box-archive"></i></button>` : '';
        return `<div class="rowActions">
          <button class="tinyBtn" data-modal="view" data-type="${type}" data-label="${safeLabel}"${detailAttr} title="View full details"><i class="fa-regular fa-eye"></i></button>
          ${copyBtn}${shareBtn}${exportBtn}${archiveBtn}
        </div>`;
      }

      function emptyRow(cols, text='No matching records found'){
        return `<tr><td colspan="${cols}" style="text-align:center;color:var(--muted);border-radius:16px;border:1px solid var(--line2);background:var(--table);padding:18px">${escapeHtml(text)}</td></tr>`;
      }

      function renderRows(tbody, rows, opts = {}){
        if(!tbody) return;
        const cols = opts.cols || 7;
        rows = Array.isArray(rows) ? rows : [];
        if(!rows.length){ tbody.innerHTML = emptyRow(cols); return; }
        tbody.innerHTML = rows.map((r)=>{
          const meta = rowMeta(r);
          const row = rowCells(r);
          const cells = row.map((cell, i)=> opts.statusIndex === i ? `<td>${badge(cell)}</td>` : `<td>${escapeHtml(cell)}</td>`).join('');
          return `<tr data-row-text="${escapeHtml(row.join(' '))}">${cells}<td>${actions(row[0], meta)}</td></tr>`;
        }).join('');
      }

      function sameStatus(actual, requested) {
        const a = String(actual || '').toLowerCase();
        const r = String(requested || '').toLowerCase();
        if (!r) return true;
        if (r === 'active') return /active|available|running|earned|paid|successful/.test(a);
        if (r === 'paid') return /paid|earned|released|completed|successful/.test(a);
        if (r === 'review') return /review|hold|pending/.test(a);
        return a.includes(r);
      }

      function renderBars(selector, items){
        const root = $(selector);
        if(!root) return;
        root.innerHTML = (items || []).map(([label, val]) => `<div class="bar" style="height:${Number(val) || 1}%"><span>${escapeHtml(label)}</span></div>`).join('');
      }

      function fillOverview(){
        const profile = data.profile || {};
        const welcome = $('#overview .welcome h2');
        if (welcome && profile.name) welcome.textContent = `Welcome ${profile.name}. Your referral links generated ${(data.bookings || []).length} bookings.`;
        const liveItems = $$('#overview .liveItem');
        (data.liveActivity || []).slice(0, liveItems.length).forEach((item, index) => {
          const span = liveItems[index]?.querySelector('span');
          const strong = liveItems[index]?.querySelector('strong');
          if (span) span.textContent = item[0];
          if (strong) strong.textContent = item[1];
        });
        const cards = $$('#overview .statsGrid .statCard');
        (data.overviewStats || []).slice(0, cards.length).forEach((stat, index) => {
          const card = cards[index];
          const number = card.querySelector('.statNumber');
          const label = card.querySelector('.statLabel');
          const trend = card.querySelector('.trend');
          const icon = card.querySelector('.statIcon i');
          if (number) number.textContent = stat.value || '-';
          if (label) label.textContent = stat.label || 'Metric';
          if (trend) trend.innerHTML = `<i class="fa-solid fa-circle-info"></i> ${escapeHtml(stat.hint || 'Live')}`;
          if (icon && stat.icon) icon.className = `fa-solid ${stat.icon}`;
        });
      }

      function fillProfile(){
        const profile = data.profile || {};
        const inputs = $$('#profileForm input');
        if (inputs[0]) inputs[0].value = profile.name || inputs[0].value;
        if (inputs[1]) inputs[1].value = profile.phone || inputs[1].value;
        if (inputs[2]) inputs[2].value = profile.email || inputs[2].value;
        if (inputs[3]) inputs[3].value = profile.mainReferralCode || inputs[3].value;
        const payoutInputs = $$('#payoutAccountForm input');
        if (payoutInputs[0]) payoutInputs[0].value = profile.payoutAccount?.method || payoutInputs[0].value;
        if (payoutInputs[1]) payoutInputs[1].value = profile.payoutAccount?.account || payoutInputs[1].value;
        const profileName = $('.miniProfile .profileMeta strong');
        const profileStatus = $('.miniProfile .profileMeta span');
        if (profileName) profileName.textContent = profile.name || profileName.textContent;
        if (profileStatus) profileStatus.textContent = `${profile.verificationStatus || profile.status || 'active'} promoter`;
      }

      function renderAll(){
        fillOverview();
        fillProfile();
        renderRows($('#recentBookings'), (data.bookings || []).slice(0,5), {statusIndex:5, cols:7});
        renderRows($('#linksTable'), data.links || [], {statusIndex:5, cols:7});
        renderRows($('#shareTable'), data.share || [], {statusIndex:5, cols:7});
        renderRows($('#commissionsTable'), data.commissions || [], {statusIndex:5, cols:7});
        renderRows($('#withdrawalsTable'), data.withdrawals || [], {statusIndex:5, cols:7});
        renderRows($('#bookingsTable'), data.bookings || [], {statusIndex:5, cols:7});
        renderRows($('#campaignsTable'), data.campaigns || [], {statusIndex:6, cols:8});
        renderRows($('#payoutsTable'), data.payouts || [], {statusIndex:5, cols:7});
        renderRows($('#fraudTable'), data.fraud || [], {statusIndex:4, cols:6});
        renderRows($('#supportTable'), data.support || [], {statusIndex:3, cols:6});

        $$('[data-filter-table]').forEach(tbody => {
          const table = tbody.dataset.filterTable;
          const filter = tbody.dataset.filter;
          let rows = [];
          if(table === 'links-status') rows = (data.links || []).filter(r => sameStatus(rowCells(r)[5], filter));
          if(table === 'commissions-status') rows = (data.commissions || []).filter(r => sameStatus(rowCells(r)[5], filter));
          if(table === 'bookings-status') rows = (data.bookings || []).filter(r => sameStatus(rowCells(r)[5], filter));

          if(table.startsWith('links')) renderRows(tbody, rows, {statusIndex:5, cols:7});
          if(table.startsWith('commissions')) renderRows(tbody, rows, {statusIndex:5, cols:7});
          if(table.startsWith('bookings')) renderRows(tbody, rows, {statusIndex:5, cols:7});
        });

        renderBars('#performanceBars', data.performance?.bars || [['Mon',44],['Tue',58],['Wed',70],['Thu',62],['Fri',84],['Sat',92],['Sun',76]]);
        enhanceTables();
      }

      function enhanceTables() {
        $$('.tableWrap').forEach((wrap, index) => {
          if (wrap.dataset.enhanced === 'true') return;
          const table = wrap.querySelector('table');
          if (!table) return;
          wrap.dataset.enhanced = 'true';
          const tools = document.createElement('div');
          tools.className = 'tableTools';
          tools.innerHTML = `
            <div class="control"><i class="fa-solid fa-magnifying-glass"></i><input data-table-search placeholder="Search this table"></div>
            <div class="control"><i class="fa-solid fa-filter"></i><select data-table-status><option value="">All statuses</option><option>active</option><option>paid</option><option>pending</option><option>review</option><option>paused</option><option>available</option><option>cancelled</option></select></div>
            <div class="control"><i class="fa-regular fa-calendar"></i><input data-table-date type="date"></div>
            <button class="btn" type="button" data-export-table><i class="fa-solid fa-download"></i> Export CSV</button>`;
          wrap.parentNode.insertBefore(tools, wrap);
          const runFilter = () => {
            const q = tools.querySelector('[data-table-search]').value.toLowerCase().trim();
            const status = tools.querySelector('[data-table-status]').value.toLowerCase().trim();
            const date = tools.querySelector('[data-table-date]').value;
            Array.from(table.tBodies[0]?.rows || []).forEach(row => {
              const text = row.textContent.toLowerCase();
              const okQ = !q || text.includes(q);
              const okS = !status || text.includes(status);
              const okD = !date || text.includes(date);
              row.style.display = okQ && okS && okD ? '' : 'none';
            });
          };
          tools.addEventListener('input', runFilter);
          tools.addEventListener('change', runFilter);
          tools.querySelector('[data-export-table]').addEventListener('click', () => {
            const rows = Array.from(table.rows).filter(row => row.style.display !== 'none').map(row => Array.from(row.cells).map(cell => cell.textContent.trim()));
            const csv = rows.map(row => row.map(cell => `"${cell.replace(/"/g, '""')}"`).join(',')).join('\n');
            downloadText(`classic-trip-promoter-table-${index + 1}.csv`, csv, 'text/csv');
            showToast('Table CSV exported');
          });
        });
      }

      function openPage(page){
        $$('.section').forEach(s => s.classList.remove('is-open'));
        const section = $('#' + page);
        if(section) section.classList.add('is-open');

        $$('.navBtn').forEach(b => b.classList.toggle('is-active', b.dataset.page === page));
        const meta = pageMeta[page] || pageMeta.overview;
        els.pageHeading.textContent = meta[0];
        els.pageSub.textContent = meta[1];

        document.body.classList.remove('menu-open');
        requestAnimationFrame(() => {
          window.scrollTo({ top: 0, behavior: 'auto' });
          setTimeout(() => window.scrollTo({ top: 0, behavior: 'auto' }), 30);
        });
      }

      function showToast(text){
        els.toastText.textContent = text;
        els.toast.classList.add('show');
        clearTimeout(showToast.t);
        showToast.t = setTimeout(() => els.toast.classList.remove('show'), 2300);
      }

      function csrfField(){
        const token = document.querySelector('meta[name="csrf-token"]')?.getAttribute('content') || '';
        return token ? `<input type="hidden" name="_csrf" value="${escapeHtml(token)}">` : '';
      }

      function listingOptions(){
        const rows = (data.share || []).map(row => {
          const meta = rowMeta(row);
          const cells = rowCells(row);
          return { value: meta.id || cells[0], label: cells[0] || meta.label || meta.id };
        }).filter(item => item.value);
        return rows.length ? rows : [{ value:'', label:'Select listing' }];
      }

      function selectOptions(items, selected = ''){
        return (items || []).map(item => {
          const value = typeof item === 'string' ? item : item.value;
          const label = typeof item === 'string' ? item : item.label;
          return `<option value="${escapeHtml(value)}"${String(value) === String(selected) ? ' selected' : ''}>${escapeHtml(label)}</option>`;
        }).join('');
      }

      function fieldHtml(field, readonly = false, disabled = false){
        const ro = readonly ? 'readonly' : '';
        const dis = disabled ? 'disabled' : '';
        const required = field.required ? 'required' : '';
        if(field.type === 'textarea'){
          return `<div class="field ${field.full ? 'full' : ''}"><label>${escapeHtml(field.label)}</label><div class="control"><textarea name="${escapeHtml(field.name)}" placeholder="${escapeHtml(field.placeholder || '')}" ${ro} ${required}>${escapeHtml(field.value || '')}</textarea></div></div>`;
        }
        if(field.type === 'select'){
          return `<div class="field ${field.full ? 'full' : ''}"><label>${escapeHtml(field.label)}</label><div class="control"><i class="fa-solid ${field.icon || 'fa-list'}"></i><select name="${escapeHtml(field.name)}" ${dis} ${required}>${selectOptions(field.options, field.value || '')}</select></div></div>`;
        }
        return `<div class="field ${field.full ? 'full' : ''}"><label>${escapeHtml(field.label)}</label><div class="control"><i class="fa-solid ${field.icon || 'fa-pen'}"></i><input name="${escapeHtml(field.name)}" type="${escapeHtml(field.type || 'text')}" value="${escapeHtml(field.value || '')}" placeholder="${escapeHtml(field.placeholder || '')}" ${ro} ${required}></div></div>`;
      }

      function promoterFormConfig(type){
        const key = String(type || '').toLowerCase();
        const listings = listingOptions();
        if(key.includes('referral')) return {
          action:'/promoter/links',
          submit:'Create link',
          fields:[
            { name:'listingId', label:'Listing', type:'select', icon:'fa-layer-group', options:listings, required:true },
            { name:'code', label:'Referral code', icon:'fa-link', placeholder:'MY-CODE' }
          ]
        };
        if(key.includes('withdrawal')) return {
          action:'/promoter/withdrawals',
          submit:'Request withdrawal',
          fields:[
            { name:'amount', label:'Amount', type:'number', icon:'fa-coins', required:true, placeholder:'85000' },
            { name:'currency', label:'Currency', type:'select', icon:'fa-money-bill', options:['UGX','KES','RWF','TZS','USD'] },
            { name:'method', label:'Method', type:'select', icon:'fa-wallet', options:['Mobile Money','Bank','Wallet'] }
          ]
        };
        if(key.includes('campaign')) return {
          action:'/promoter/campaigns',
          submit:'Create campaign',
          fields:[
            { name:'listingId', label:'Listing', type:'select', icon:'fa-layer-group', options:listings, required:true },
            { name:'name', label:'Campaign name', icon:'fa-bullhorn', required:true, placeholder:'Weekend referral push' },
            { name:'placement', label:'Placement', type:'select', icon:'fa-rectangle-ad', options:['promoter_share','whatsapp','social','email','marketplace_boost'] },
            { name:'budget', label:'Budget', type:'number', icon:'fa-coins', placeholder:'50000' },
            { name:'status', label:'Status', type:'select', icon:'fa-toggle-on', options:['active','draft','paused'] }
          ]
        };
        if(key.includes('support')) return {
          action:'/promoter/support',
          submit:'Create case',
          fields:[
            { name:'category', label:'Category', type:'select', icon:'fa-tags', options:['Commission','Withdrawal','Referral links','Campaigns','Account'] },
            { name:'priority', label:'Priority', type:'select', icon:'fa-flag', options:['normal','high','urgent'] },
            { name:'message', label:'Message', type:'textarea', full:true, required:true, placeholder:'Tell support what you need' }
          ]
        };
        if(key.includes('verification')) return {
          action:'/promoter/verification',
          submit:'Update verification',
          fields:[
            { name:'documentType', label:'Document type', type:'select', icon:'fa-id-card', options:['national_id','passport','business_license','tax_id'] },
            { name:'documentReference', label:'Document reference', icon:'fa-hashtag', placeholder:'ID number or file reference' },
            { name:'payoutMethod', label:'Payout method', type:'select', icon:'fa-wallet', options:['Mobile Money','Bank','Wallet'], value:data.profile?.payoutAccount?.method || 'Mobile Money' },
            { name:'payoutAccount', label:'Payout account', icon:'fa-building-columns', value:data.profile?.payoutAccount?.account || '', placeholder:'Phone or account number' },
            { name:'message', label:'Verification note', type:'textarea', full:true, placeholder:'Anything the verification team should know' }
          ]
        };
        return null;
      }

      function openCrud(mode, type, label = ''){
        const nice = String(type || 'record');
        const readonly = mode === 'view';
        const disabled = mode === 'view';
        const title = mode === 'view' ? `View ${nice}` : mode === 'edit' ? `Edit ${nice}` : `Create ${nice}`;
        const config = promoterFormConfig(nice);
        els.crudTitle.textContent = title;
        els.crudSub.textContent = mode === 'view' ? 'Promoter scoped details and safe actions.' : 'Submit this promoter workflow to Classic Trip.';
        if(!config && mode !== 'view'){
          els.crudBody.innerHTML = `<div class="notice">This promoter action is available from row details or reports.</div><div style="display:flex;gap:8px;justify-content:flex-end;flex-wrap:wrap"><button class="btn btnBlue" type="button" data-close-modal>Done</button></div>`;
          els.crudModal.classList.add('is-open');
          return;
        }
        const fields = config ? config.fields.map(field => fieldHtml(field, readonly, disabled)).join('') : '';
        els.crudBody.innerHTML = `
          <form class="formPanel" data-dashboard-form method="POST" action="${escapeHtml(config?.action || '')}">
            ${csrfField()}
            <div class="formGrid">${fields}</div>
            <div style="display:flex;gap:8px;justify-content:flex-end;flex-wrap:wrap">
              <button class="btn" type="button" data-close-modal>Cancel</button>
              ${mode === 'view' ? `<button class="btn btnBlue" type="button" data-close-modal>Done</button>` : `<button class="btn btnPrimary" type="submit"><i class="fa-solid fa-paper-plane"></i> ${escapeHtml(config.submit || 'Submit')}</button>`}
            </div>
          </form>
        `;
        els.crudModal.classList.add('is-open');
      }

      function closeModals(){
        $$('.modal').forEach(m => m.classList.remove('is-open'));
      }

      $('#sideNav').addEventListener('click', e => {
        const btn = e.target.closest('.navBtn');
        if(btn) openPage(btn.dataset.page);
      });

      $$('[data-jump]').forEach(btn => {
        btn.addEventListener('click', () => openPage(btn.dataset.jump));
      });

      document.addEventListener('click', e => {
        const tabBtn = e.target.closest('.tabBtn');
        if(tabBtn){
          const group = tabBtn.closest('[data-tabs]');
          const tab = tabBtn.dataset.tab;
          $$('.tabBtn', group).forEach(b => b.classList.toggle('is-on', b === tabBtn));
          $$('.tabPane', group).forEach(p => p.classList.toggle('is-on', p.dataset.pane === tab));
          requestAnimationFrame(() => window.scrollTo({ top: 0, behavior: 'auto' }));
          return;
        }

        const copyBtn = e.target.closest('[data-copy-value]');
        if(copyBtn){
          e.preventDefault();
          navigator.clipboard?.writeText(copyBtn.dataset.copyValue || '').catch(() => {});
          showToast('Copied reference/link');
          return;
        }

        const exportRowBtn = e.target.closest('[data-export-row]');
        if(exportRowBtn){
          e.preventDefault();
          const detail = parseDetailFromElement(exportRowBtn) || { label: exportRowBtn.dataset.label || '' };
          exportDetailPdf(detail, exportRowBtn.dataset.exportRow || exportRowBtn.dataset.label || 'record');
          showToast('PDF export opened');
          return;
        }

        const deleteBtn = e.target.closest('[data-delete-url]');
        if(deleteBtn){
          e.preventDefault();
          pendingArchive = {
            url: deleteBtn.dataset.deleteUrl,
            label: deleteBtn.dataset.deleteLabel || 'this referral link'
          };
          if(els.deleteText) els.deleteText.textContent = `Archive ${pendingArchive.label}?`;
          if(els.deleteModal) els.deleteModal.classList.add('is-open');
          return;
        }

        const modalBtn = e.target.closest('[data-modal]');
        if(modalBtn){
          e.preventDefault();
          const detail = parseDetailFromElement(modalBtn);
          if (modalBtn.dataset.modal === 'view' && detail) openDetailModal(modalBtn.dataset.type, modalBtn.dataset.label || '', detail);
          else openCrud(modalBtn.dataset.modal, modalBtn.dataset.type, modalBtn.dataset.label || '');
          return;
        }

        if(e.target.closest('[data-close-modal]')) closeModals();
      });

      document.addEventListener('submit', e => {
        if(e.target.matches('[data-dashboard-form]')){
          if(e.target.hasAttribute('action')) return;
          e.preventDefault();
          closeModals();
          showToast('Saved successfully');
        }
      });

      if(els.confirmDelete){
        els.confirmDelete.addEventListener('click', () => {
          if(!pendingArchive?.url){
            closeModals();
            showToast('No referral link selected');
            return;
          }
          const form = document.createElement('form');
          form.method = 'POST';
          form.action = pendingArchive.url;
          const csrf = document.querySelector('meta[name="csrf-token"]')?.getAttribute('content') || '';
          if(csrf){
            const input = document.createElement('input');
            input.type = 'hidden';
            input.name = '_csrf';
            input.value = csrf;
            form.appendChild(input);
          }
          document.body.appendChild(form);
          els.confirmDelete.disabled = true;
          form.submit();
        });
      }

      if(els.btnNew) els.btnNew.addEventListener('click', () => openCrud('create', 'referral link'));
      if(els.btnExport) els.btnExport.addEventListener('click', () => {
        exportDetailPdf({
          profile: data.profile || {},
          stats: data.stats || {},
          referralLinks: data.links || [],
          shareListings: data.share || [],
          commissions: data.commissions || [],
          withdrawals: data.withdrawals || [],
          referralBookings: data.bookings || [],
          payouts: data.payouts || [],
          campaigns: data.campaigns || []
        }, 'Promoter dashboard');
        showToast('PDF export opened');
      });
      if(els.btnCopyMain) els.btnCopyMain.addEventListener('click', () => {
        navigator.clipboard?.writeText(data.profile?.mainReferralUrl || data.profile?.mainReferralCode || '').catch(() => {});
        showToast('Top referral link copied');
      });
      if(els.btnCopyLink) els.btnCopyLink.addEventListener('click', () => {
        navigator.clipboard?.writeText(data.profile?.mainReferralUrl || data.profile?.mainReferralCode || '').catch(() => {});
        showToast('Referral link copied');
      });
      if(els.btnDownloadPayouts) els.btnDownloadPayouts.addEventListener('click', () => {
        const rows = [['Payout','Period/Date','Currency','Amount','Reference','Status'], ...(data.payouts || []).map(rowCells)];
        const csv = rows.map(row => row.map(cell => `"${String(cell ?? '').replace(/"/g, '""')}"`).join(',')).join('\n');
        downloadText(`classic-trip-promoter-payouts-${Date.now()}.csv`, csv, 'text/csv');
        showToast('Payout history CSV downloaded');
      });
      if(els.openMenu) els.openMenu.addEventListener('click', () => document.body.classList.add('menu-open'));
      if(els.sideBackdrop) els.sideBackdrop.addEventListener('click', () => document.body.classList.remove('menu-open'));

      if(els.btnTheme){
        els.btnTheme.addEventListener('click', () => {
          const html = document.documentElement;
          const next = html.dataset.theme === 'dark' ? 'light' : 'dark';
          html.dataset.theme = next;
          els.themeIcon.className = next === 'dark' ? 'fa-solid fa-moon' : 'fa-solid fa-sun';
        });
      }

      if(els.sideSearch){
        els.sideSearch.addEventListener('input', () => {
          const q = els.sideSearch.value.trim().toLowerCase();
          $$('.navBtn').forEach(btn => {
            const text = btn.textContent.toLowerCase();
            btn.style.display = text.includes(q) ? 'flex' : 'none';
          });
        });
      }

      document.addEventListener('keydown', e => {
        if(e.key === 'Escape'){
          closeModals();
          document.body.classList.remove('menu-open');
        }
      });

      renderAll();
      openPage('overview');
    });
  </script>
</body>
</html>
