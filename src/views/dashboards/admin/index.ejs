            <div class="miniStat"><span>Booked</span><strong><%= (dashboardData?.seatMaps || []).reduce((sum,m)=>sum + Number(m.soldSeats || m.bookedSeats || (m.seats || []).filter(s=>/booked|taken|sold/i.test(s.status||'')).length || 0),0) %></strong></div>
            <div class="miniStat"><span>Held / blocked</span><strong><%= (dashboardData?.seatMaps || []).reduce((sum,m)=>sum + Number(m.blockedSeats || m.heldSeats || (m.seats || []).filter(s=>/block|hold|lock|maintenance/i.test(s.status||'')).length || 0),0) %></strong></div>
          </div>

          <div class="seatOpsPanel card">
            <div class="seatOpsHeader">
              <div>
                <strong>Select route / schedule</strong>
                <span>Only the selected departure seat map and table rows are shown, so actions stay scoped and safe.</span>
              </div>
              <span class="badge info">Company scoped</span>
            </div>
            <div class="seatMapSelectorPanel is-redesigned">
              <div class="field seatMapSelectField"><label>Route / schedule</label><div class="control"><i class="fa-solid fa-route"></i><select id="seatMapRouteSelector" data-seat-map-select><% previewMaps.forEach(function(map, idx){ const mapId = map.scheduleId || map.id || ('seat-map-' + idx); const total = Number(map.totalSeats || (map.seats || []).length || 0); const booked = Number(map.soldSeats || map.bookedSeats || (map.seats || []).filter(function(seat){ return /booked|taken|sold/i.test(seat.status || ''); }).length || 0); const held = Number(map.heldSeats || (map.seats || []).filter(function(seat){ return /hold|lock/i.test(seat.status || ''); }).length || 0); const blocked = Number(map.blockedSeats || (map.seats || []).filter(function(seat){ return /block|maintenance|disabled/i.test(seat.status || ''); }).length || 0); %><option value="<%= mapId %>" data-total="<%= total %>" data-booked="<%= booked %>" data-held="<%= held %>" data-blocked="<%= blocked %>"><%= map.routeLabel || map.listingTitle || 'Route' %> · <%= map.vehicleName || 'Vehicle' %> · <%= map.departAt || map.travelDate || mapId %></option><% }) %></select></div></div>
              <div class="miniStat"><span>Total</span><strong data-seat-map-total><%= previewMaps[0] ? Number(previewMaps[0].totalSeats || (previewMaps[0].seats || []).length || 0) : 0 %></strong></div>
              <div class="miniStat"><span>Booked</span><strong data-seat-map-booked><%= previewMaps[0] ? Number(previewMaps[0].soldSeats || previewMaps[0].bookedSeats || (previewMaps[0].seats || []).filter(function(seat){ return /booked|taken|sold/i.test(seat.status || ''); }).length || 0) : 0 %></strong></div>
              <div class="miniStat"><span>Held</span><strong data-seat-map-held><%= previewMaps[0] ? Number(previewMaps[0].heldSeats || (previewMaps[0].seats || []).filter(function(seat){ return /hold|lock/i.test(seat.status || ''); }).length || 0) : 0 %></strong></div>
              <div class="miniStat"><span>Blocked</span><strong data-seat-map-blocked><%= previewMaps[0] ? Number(previewMaps[0].blockedSeats || (previewMaps[0].seats || []).filter(function(seat){ return /block|maintenance|disabled/i.test(seat.status || ''); }).length || 0) : 0 %></strong></div>
              <button class="btn" type="button" data-seat-map-focus-list><i class="fa-solid fa-table-list"></i> View table</button>
            </div>
          </div>

          <div class="card seatMapGridCard seatMapPreviewCard">
            <div class="cardHead seatPreviewCardHead">
              <div class="cardTitle"><h3>Visual seat preview</h3><p>The seat map below belongs only to the selected route/schedule.</p></div>
              <div class="seatLegend"><span class="available"><i></i> Available</span><span class="booked"><i></i> Booked</span><span class="held"><i></i> Held</span><span class="selected"><i></i> Selected</span><span class="blocked"><i></i> Blocked / maintenance</span></div>
            </div>
            <% if(previewMaps.length){ previewMaps.forEach(function(map, mapIndex){ %>
              <% const mapId = map.scheduleId || map.id || ('seat-map-' + mapIndex); const rawPreviewSeats = (map.seats || []).slice(0,96); const previewSeats = rawPreviewSeats.map(function(seat, seatIndex){ const clone = Object.assign({}, seat); clone.displaySeatNumber = String(seatIndex + 1); return clone; }); const rows = []; for(let i=0;i<previewSeats.length;i+=4){ rows.push(previewSeats.slice(i,i+4)); } %>
              <div class="seatPreviewPanel" data-seat-map-panel="<%= mapId %>" <%= mapIndex === 0 ? '' : 'hidden' %>>
                <div class="seatPreviewMetaCard">
                  <div>
                    <strong><%= map.routeLabel || map.listingTitle || map.scheduleId || 'Seat map' %></strong>
                    <span><%= map.vehicleName || 'Vehicle' %> · <%= map.departAt || map.travelDate || 'Departure pending' %></span>
                  </div>
                  <span class="badge info"><%= map.status || 'active' %></span>
                </div>
                <div class="busCabin" aria-label="Realistic bus cabin seat map">
