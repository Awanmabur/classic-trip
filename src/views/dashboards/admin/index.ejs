          <div class="card"><div class="cardHead"><div class="cardTitle"><h3>Settlement batches</h3><p>Batch-level summary for released earnings, statements, and payout readiness.</p></div><a class="btn" href="/company/reports/settlementBatches.csv"><i class="fa-solid fa-download"></i> Export</a></div><div class="tableWrap"><table><thead><tr><th>Batch</th><th>Start</th><th>End</th><th>Gross</th><th>Payable</th><th>Rows</th><th>Status</th><th></th></tr></thead><tbody id="companySettlementBatchTable"></tbody></table></div></div>
