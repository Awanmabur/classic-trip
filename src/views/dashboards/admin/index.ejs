      <section class="section" id="promoters"><div class="card"><div class="cardHead"><div class="cardTitle"><h3>Promoters</h3><p>Manage referral links, commissions, suspicious traffic, and withdrawals.</p></div><button class="btn btnBlue" data-modal="create" data-type="campaign"><i class="fa-solid fa-link"></i> Generate campaign</button></div><div class="tableWrap"><table><thead><tr><th>Promoter</th><th>Links shared</th><th>Bookings</th><th>Commission</th><th>Withdrawable</th><th>Status</th><th></th></tr></thead><tbody id="promotersTable"></tbody></table></div></div></section>

      <section class="section" id="customers"><div class="card"><div class="cardHead"><div class="cardTitle"><h3>Customers</h3><p>View customer booking history, receipts, saved items, refunds, and support activity.</p></div><button class="btn" data-modal="create" data-type="customer note"><i class="fa-solid fa-user-plus"></i> Add note</button></div><div class="tableWrap"><table><thead><tr><th>Customer</th><th>Email / phone</th><th>Bookings</th><th>Spent</th><th>Last activity</th><th>Status</th><th></th></tr></thead><tbody id="customersTable"></tbody></table></div></div></section>

      <section class="section" id="support"><div class="grid2"><div class="card"><div class="cardHead"><div class="cardTitle"><h3>Support & disputes</h3><p>Refunds, failed payments, missing tickets, partner complaints, and customer support.</p></div><span class="badge bad"><i class="fa-solid fa-triangle-exclamation"></i> 11 urgent</span></div><div class="tableWrap"><table><thead><tr><th>Ticket</th><th>Customer</th><th>Issue</th><th>Priority</th><th>Status</th><th>Opened</th><th></th></tr></thead><tbody id="supportTable"></tbody></table></div></div><div class="card"><div class="cardHead"><div class="cardTitle"><h3>Create support notice</h3><p>Send a message to affected customers or partners.</p></div></div><form class="formPanel" id="noticeForm" method="POST" action="<%= isCompanyDashboard ? '/company/support/notices' : isEmployeeDashboard ? '/employee/support/notice' : '/admin/notices' %>"><div class="formGrid"><div class="field"><label>Audience</label><div class="control"><i class="fa-solid fa-users"></i><select name="audience"><option value="customers">Customers</option><option value="partners">Partners</option><option value="promoters">Promoters</option><option value="employees">Employees</option></select></div></div><div class="field"><label>Priority</label><div class="control"><i class="fa-solid fa-flag"></i><select name="priority"><option value="normal">Normal</option><option value="high">High</option><option value="urgent">Urgent</option></select></div></div><div class="field full"><label>Message</label><div class="control"><textarea name="message" placeholder="Write notice message..." required></textarea></div></div></div><button class="btn btnPrimary" type="submit"><i class="fa-solid fa-paper-plane"></i> Send notice</button></form></div><div class="card"><div class="cardHead"><div class="cardTitle"><h3>Correspondence timeline</h3><p>Linked customer-visible messages, internal notes, delivery attempts, and booking activity.</p></div><span class="badge info">Section H</span></div><div class="splitGrid"><div class="splitItem"><div class="splitTop"><span>Message center</span><span class="badge ok">Linked</span></div></div><div class="splitItem"><div class="splitTop"><span>Internal notes</span><span class="badge warn">Private</span></div></div><div class="splitItem"><div class="splitTop"><span>Delivery attempts</span><span class="badge info">Logged</span></div></div></div></div><div class="card"><div class="cardHead"><div class="cardTitle"><h3>Reschedule queue</h3><p>Review pending customer schedule-change requests and keep decisions on the booking timeline.</p></div></div><a class="btn btnBlue" href="/admin/reports/reschedule.csv"><i class="fa-solid fa-download"></i> Download queue</a></div></div></section>

      <section class="section" id="ads"><div class="card"><div class="cardHead"><div class="cardTitle"><h3>Ads & promotions</h3><p>Paid boosts, top placement, route ads, hotel ads, banner ads, and partner campaigns.</p></div><button class="btn btnPrimary" data-modal="create" data-type="ad campaign"><i class="fa-solid fa-plus"></i> New campaign</button></div><div class="tableWrap"><table><thead><tr><th>Campaign</th><th>Partner</th><th>Placement</th><th>Budget</th><th>Clicks</th><th>Bookings</th><th>Status</th><th></th></tr></thead><tbody id="adsTable"></tbody></table></div></div></section>

