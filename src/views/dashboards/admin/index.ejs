          <div class="card"><div class="cardHead"><div class="cardTitle"><h3>Wallet / settlement ledger</h3><p>Every company credit, debit, payout, refund reversal, and settlement transaction.</p></div><a class="btn" href="/company/reports/settlementLedger.csv"><i class="fa-solid fa-file-csv"></i> Export ledger</a></div><div class="dashboardFilters" data-filter-target="#companySettlementLedgerTable"><div class="field"><label>Search ledger</label><div class="control"><i class="fa-solid fa-magnifying-glass"></i><input data-filter-search placeholder="Transaction, booking, payout, status"></div></div><div class="field"><label>Status</label><div class="control"><i class="fa-solid fa-circle-check"></i><select data-filter-select><option value="">All statuses</option><option value="pending">Pending</option><option value="released">Released</option><option value="paid">Paid</option><option value="refund">Refund</option></select></div></div><div class="filterActions"><button class="btn" type="button" data-filter-reset><i class="fa-solid fa-rotate-left"></i> Reset</button></div></div><div class="tableWrap"><table><thead><tr><th>Txn</th><th>Reference</th><th>Type</th><th>Direction</th><th>Amount</th><th>Batch</th><th>Payout</th><th>Status</th><th></th></tr></thead><tbody id="companySettlementLedgerTable"></tbody></table></div><div class="filterEmpty" data-empty-for="#companySettlementLedgerTable">No ledger rows match the current filters.</div></div>
          <div class="card"><div class="cardHead"><div class="cardTitle"><h3>Finance statements</h3><p>Generated statement history and printable/exportable summary rows.</p></div><a class="btn" href="/company/reports/financeStatements.csv"><i class="fa-solid fa-file-lines"></i> Export statements</a></div><div class="tableWrap"><table><thead><tr><th>Statement</th><th>Start</th><th>End</th><th>Gross</th><th>Closing / earning</th><th>Refunds</th><th>Status</th><th></th></tr></thead><tbody id="companyFinanceStatementTable"></tbody></table></div></div>
        </div>
      </section>


