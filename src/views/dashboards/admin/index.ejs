              <div class="miniStat"><span>In-house</span><strong><%= (dashboardData?.hotelInHouse || []).length %></strong></div>
              <div class="miniStat"><span>Departures</span><strong><%= (dashboardData?.hotelDepartures || []).length %></strong></div>
            </div>
            <div class="dashboardFilters" data-filter-target="#companyHotelManifestTable"><div class="field"><label>Search guests</label><div class="control"><i class="fa-solid fa-magnifying-glass"></i><input data-filter-search placeholder="Guest, booking, room, date"></div></div><div class="field"><label>Status</label><div class="control"><i class="fa-solid fa-circle-check"></i><select data-filter-select><option value="">All statuses</option><option value="booked">Booked</option><option value="checked-in">Checked-in</option><option value="checked-out">Checked-out</option><option value="completed">Completed</option></select></div></div><div class="filterActions"><button class="btn" type="button" data-filter-reset><i class="fa-solid fa-rotate-left"></i> Reset</button></div></div>
            <div class="innerTabs" data-tab-group="hotel-manifest-tabs"><button type="button" class="tabBtn is-on" data-tab-target="hotel-manifest-all"><i class="fa-solid fa-list"></i> All guests</button><button type="button" class="tabBtn" data-tab-target="hotel-manifest-arrivals"><i class="fa-solid fa-person-walking-luggage"></i> Arrivals</button><button type="button" class="tabBtn" data-tab-target="hotel-manifest-inhouse"><i class="fa-solid fa-door-closed"></i> In-house</button><button type="button" class="tabBtn" data-tab-target="hotel-manifest-departures"><i class="fa-solid fa-door-open"></i> Departures</button></div>
