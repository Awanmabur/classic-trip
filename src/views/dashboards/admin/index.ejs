            <strong><%= dashboardShell?.profileName || 'Super Admin' %></strong>
            <span><%= dashboardShell?.profileMeta || 'Full platform access' %></span>
          </div>
        </div>
      </div>
    </aside>

    <main class="main">
      <header class="topbar legacyDashboardChrome">
        <div class="topLeft">
          <button class="iconBtn menuBtn" id="openMenu" aria-label="Open menu"><i class="fa-solid fa-bars"></i></button>
