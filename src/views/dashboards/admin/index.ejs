      const seatNo = encodeURIComponent(String(parts[1] || detail?.inventory?.seatNumber || detail?.seat?.seatNumber || '').replace(/^seat\s*(no\.?|number)?\s*/i, '').replace(/^[A-Za-z](\d+)$/, '$1'));
