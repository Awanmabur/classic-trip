            <div class="tabPane" id="hotel-manifest-arrivals"><div class="tableWrap"><table><thead><tr><th>Ref</th><th>Guest</th><th>Listing</th><th>Room</th><th>Check-in</th><th>Check-out</th><th>Status</th><th></th></tr></thead><tbody id="companyHotelArrivalsTable"></tbody></table></div></div>
            <div class="tabPane" id="hotel-manifest-inhouse"><div class="tableWrap"><table><thead><tr><th>Ref</th><th>Guest</th><th>Listing</th><th>Room</th><th>Check-in</th><th>Check-out</th><th>Status</th><th></th></tr></thead><tbody id="companyHotelInHouseTable"></tbody></table></div></div>
            <div class="tabPane" id="hotel-manifest-departures"><div class="tableWrap"><table><thead><tr><th>Ref</th><th>Guest</th><th>Listing</th><th>Room</th><th>Check-in</th><th>Check-out</th><th>Status</th><th></th></tr></thead><tbody id="companyHotelDeparturesTable"></tbody></table></div></div>
          </div>
