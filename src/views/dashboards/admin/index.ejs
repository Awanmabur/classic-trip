                <button class="quickCard" data-modal="create" data-type="notice"><div class="quickIcon"><i class="fa-solid fa-paper-plane"></i></div><strong>Send notice</strong><span>Notify customers, partners, or promoters.</span></button>
                <% } %>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section class="section" id="analytics">
        <div class="analyticsPanel">
          <div class="grid4">
            <article class="statCard"><div class="statTop"><div class="statIcon"><i class="fa-solid fa-eye"></i></div><span class="trend">+24%</span></div><div class="statNumber">98.4K</div><div class="statLabel">Marketplace visits</div></article>
            <article class="statCard"><div class="statTop"><div class="statIcon"><i class="fa-solid fa-cart-shopping"></i></div><span class="trend">+9%</span></div><div class="statNumber">4.8%</div><div class="statLabel">Booking conversion</div></article>
            <article class="statCard"><div class="statTop"><div class="statIcon"><i class="fa-solid fa-money-bill-wave"></i></div><span class="trend">+13%</span></div><div class="statNumber">UGX 62K</div><div class="statLabel">Average order value</div></article>
            <article class="statCard"><div class="statTop"><div class="statIcon"><i class="fa-solid fa-headset"></i></div><span class="trend">-6%</span></div><div class="statNumber">2h 18m</div><div class="statLabel">Avg support response</div></article>
