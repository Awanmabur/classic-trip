        </div>
      </section>

      <section class="section" id="bookings"><div class="card"><div class="cardHead"><div class="cardTitle"><h3><%= isCompanyDashboard ? (companyServiceProfile.primaryLabel || 'Company') + ' bookings' : isEmployeeDashboard ? 'Assigned bookings' : 'All bookings' %></h3><p><%= isCompanyDashboard ? (companySupportsHotel ? 'Monitor hotel stays, room-night holds, refunds, and confirmations.' : companySupportsBus ? 'Monitor bus tickets, seats, passenger holds, refunds, and confirmations.' : 'Monitor this company service bookings, holds, refunds, and confirmations.') : isEmployeeDashboard ? 'Create desk bookings, check in passengers or guests, record payments, and request refunds in your assigned company scope.' : 'Monitor tickets, reservations, rooms, seats, held items, refunds, and confirmations.' %></p></div><button class="btn btnBlue" data-modal="create" data-type="booking"><i class="fa-solid fa-plus"></i> Create booking</button></div><div class="innerTabs" data-tab-group="bookings-tabs"><button type="button" class="tabBtn is-on" data-tab-target="bookings-all"><i class="fa-solid fa-ticket"></i> <%= isCompanyDashboard ? (companyServiceProfile.primaryLabel || 'Service') : isEmployeeDashboard ? 'Assigned' : 'All' %></button><% if(!isCompanyDashboard || companySupportsBus){ %><button type="button" class="tabBtn" data-tab-target="bookings-bus"><i class="fa-solid fa-bus"></i> Bus</button><% } %><% if(!isCompanyDashboard || companySupportsHotel){ %><button type="button" class="tabBtn" data-tab-target="bookings-hotel"><i class="fa-solid fa-hotel"></i> Hotel</button><% } %><% if(!isCompanyDashboard){ %><button type="button" class="tabBtn" data-tab-target="bookings-flight"><i class="fa-solid fa-plane"></i> Flight</button><button type="button" class="tabBtn" data-tab-target="bookings-train"><i class="fa-solid fa-train"></i> Train</button><% } %><button type="button" class="tabBtn" data-tab-target="bookings-hold"><i class="fa-regular fa-clock"></i> On hold</button><button type="button" class="tabBtn" data-tab-target="bookings-refunded"><i class="fa-solid fa-rotate-left"></i> Refunded</button></div><div class="tabPane is-open" id="bookings-all"><div class="tableWrap"><table><thead><tr><th>Booking</th><th>Service</th><th>Customer</th><th>Date</th><th>Hold</th><th>Status</th><th>Amount</th><th></th></tr></thead><tbody id="bookingsTable"></tbody></table></div></div><% if(!isCompanyDashboard || companySupportsBus){ %><div class="tabPane" id="bookings-bus"><div class="tableWrap"><table><thead><tr><th>Booking</th><th>Service</th><th>Customer</th><th>Date</th><th>Hold</th><th>Status</th><th>Amount</th><th></th></tr></thead><tbody id="bookingsBusTable"></tbody></table></div></div><% } %><% if(!isCompanyDashboard || companySupportsHotel){ %><div class="tabPane" id="bookings-hotel"><div class="tableWrap"><table><thead><tr><th>Booking</th><th>Service</th><th>Customer</th><th>Date</th><th>Hold</th><th>Status</th><th>Amount</th><th></th></tr></thead><tbody id="bookingsHotelTable"></tbody></table></div></div><% } %><% if(!isCompanyDashboard){ %><div class="tabPane" id="bookings-flight"><div class="tableWrap"><table><thead><tr><th>Booking</th><th>Service</th><th>Customer</th><th>Date</th><th>Hold</th><th>Status</th><th>Amount</th><th></th></tr></thead><tbody id="bookingsFlightTable"></tbody></table></div></div><div class="tabPane" id="bookings-train"><div class="tableWrap"><table><thead><tr><th>Booking</th><th>Service</th><th>Customer</th><th>Date</th><th>Hold</th><th>Status</th><th>Amount</th><th></th></tr></thead><tbody id="bookingsTrainTable"></tbody></table></div></div><% } %><div class="tabPane" id="bookings-hold"><div class="tableWrap"><table><thead><tr><th>Booking</th><th>Service</th><th>Customer</th><th>Date</th><th>Hold</th><th>Status</th><th>Amount</th><th></th></tr></thead><tbody id="bookingsHoldTable"></tbody></table></div></div><div class="tabPane" id="bookings-refunded"><div class="tableWrap"><table><thead><tr><th>Booking</th><th>Service</th><th>Customer</th><th>Date</th><th>Hold</th><th>Status</th><th>Amount</th><th></th></tr></thead><tbody id="bookingsRefundedTable"></tbody></table></div></div></div></section>

      <section class="section" id="partners"><div class="grid2"><div class="card"><div class="cardHead"><div class="cardTitle"><h3>Partner companies</h3><p>Approve, suspend, verify, and monitor companies.</p></div><button class="btn btnPrimary" data-modal="create" data-type="partner"><i class="fa-solid fa-building-circle-check"></i> Add partner</button></div><div class="innerTabs" data-tab-group="partners-tabs"><button type="button" class="tabBtn is-on" data-tab-target="partners-all"><i class="fa-solid fa-building"></i> All</button><button type="button" class="tabBtn" data-tab-target="partners-bus"><i class="fa-solid fa-bus"></i> Bus</button><button type="button" class="tabBtn" data-tab-target="partners-hotel"><i class="fa-solid fa-hotel"></i> Hotel</button><button type="button" class="tabBtn" data-tab-target="partners-airline"><i class="fa-solid fa-plane"></i> Airline</button><button type="button" class="tabBtn" data-tab-target="partners-train"><i class="fa-solid fa-train"></i> Train</button><button type="button" class="tabBtn" data-tab-target="partners-pending"><i class="fa-regular fa-hourglass-half"></i> Pending</button></div><div class="tabPane is-open" id="partners-all"><div class="tableWrap"><table><thead><tr><th>Partner</th><th>Type</th><th>Country</th><th>Listings</th><th>Verification</th><th>Revenue</th><th></th></tr></thead><tbody id="partnersTable"></tbody></table></div></div><div class="tabPane" id="partners-bus"><div class="tableWrap"><table><thead><tr><th>Partner</th><th>Type</th><th>Country</th><th>Listings</th><th>Verification</th><th>Revenue</th><th></th></tr></thead><tbody id="partnersBusTable"></tbody></table></div></div><div class="tabPane" id="partners-hotel"><div class="tableWrap"><table><thead><tr><th>Partner</th><th>Type</th><th>Country</th><th>Listings</th><th>Verification</th><th>Revenue</th><th></th></tr></thead><tbody id="partnersHotelTable"></tbody></table></div></div><div class="tabPane" id="partners-airline"><div class="tableWrap"><table><thead><tr><th>Partner</th><th>Type</th><th>Country</th><th>Listings</th><th>Verification</th><th>Revenue</th><th></th></tr></thead><tbody id="partnersAirlineTable"></tbody></table></div></div><div class="tabPane" id="partners-train"><div class="tableWrap"><table><thead><tr><th>Partner</th><th>Type</th><th>Country</th><th>Listings</th><th>Verification</th><th>Revenue</th><th></th></tr></thead><tbody id="partnersTrainTable"></tbody></table></div></div><div class="tabPane" id="partners-pending"><div class="tableWrap"><table><thead><tr><th>Partner</th><th>Type</th><th>Country</th><th>Listings</th><th>Verification</th><th>Revenue</th><th></th></tr></thead><tbody id="partnersPendingTable"></tbody></table></div></div></div><div class="card"><div class="cardHead"><div class="cardTitle"><h3>Partner onboarding</h3><p>Checks before approval.</p></div></div><div class="splitGrid"><div class="splitItem"><div class="splitTop"><span>Business license</span><span class="badge ok">Required</span></div><div class="progress"><i style="width:88%"></i></div></div><div class="splitItem"><div class="splitTop"><span>Payout account</span><span class="badge warn">Review</span></div><div class="progress"><i style="width:72%"></i></div></div><div class="splitItem"><div class="splitTop"><span>Service inventory</span><span class="badge info">Setup</span></div><div class="progress"><i style="width:64%"></i></div></div><div class="notice">Partners should not receive payouts until business verification, payout account, and service inventory are approved.</div></div></div></div></section>

      <section class="section" id="listings"><div class="card"><div class="cardHead"><div class="cardTitle"><h3><%= isCompanyDashboard ? (companyServiceProfile.primaryLabel || 'Company') + ' inventory' : 'Listings & inventory' %></h3><p><%= isCompanyDashboard ? 'Only modules for this company service type are shown here.' : 'Routes, rooms, houses, flights, trains, cars, tours, ferries, seat maps, room maps, and price rules.' %></p></div><button class="btn btnBlue" data-modal="create" data-type="<%= companySupportsHotel ? 'hotel property' : 'listing' %>"><i class="fa-solid fa-plus"></i> <%= companySupportsHotel ? 'Add hotel property' : companySupportsBus ? 'Create bus listing' : 'Create listing' %></button></div><div class="innerTabs" data-tab-group="inventory"><button type="button" class="tabBtn is-on" data-tab-target="inventory-all"><i class="fa-solid fa-layer-group"></i> <%= isCompanyDashboard ? (companyServiceProfile.primaryLabel || 'Service') + ' inventory' : 'All inventory' %></button><% if(!isCompanyDashboard || companySupportsTransport){ %><button type="button" class="tabBtn" data-tab-target="inventory-routes"><i class="fa-solid fa-bus"></i> Routes & seats</button><% } %><% if(!isCompanyDashboard || companySupportsHotel){ %><button type="button" class="tabBtn" data-tab-target="inventory-stays"><i class="fa-solid fa-hotel"></i> Hotels & rooms</button><% } %><button type="button" class="tabBtn" data-tab-target="inventory-pricing"><i class="fa-solid fa-tags"></i> Price rules</button><button type="button" class="tabBtn" data-tab-target="inventory-review"><i class="fa-solid fa-triangle-exclamation"></i> Needs review</button></div><div class="tabPane is-open" id="inventory-all"><div class="tableWrap"><table><thead><tr><th>Listing</th><th>Type</th><th>Partner</th><th>Inventory</th><th>Country route</th><th>Badge</th><th>Price from</th><th></th></tr></thead><tbody id="listingsTable"></tbody></table></div></div><% if(!isCompanyDashboard || companySupportsTransport){ %><div class="tabPane" id="inventory-routes"><div class="tableWrap"><table><thead><tr><th>Route</th><th>Vehicle</th><th>Partner</th><th>Seats</th><th>Schedule</th><th>Status</th><th>Price</th><th></th></tr></thead><tbody id="routeInventoryTable"></tbody></table></div></div><% } %><% if(!isCompanyDashboard || companySupportsHotel){ %><div class="tabPane" id="inventory-stays"><div class="tableWrap"><table><thead><tr><th>Property</th><th>Room type</th><th>Partner</th><th>Rooms</th><th>City</th><th>Status</th><th>Price</th><th></th></tr></thead><tbody id="stayInventoryTable"></tbody></table></div></div><% } %><div class="tabPane" id="inventory-pricing"><div class="splitGrid"><div class="splitItem"><div class="splitTop"><span><%= companySupportsHotel ? 'Seasonal room pricing' : companySupportsBus ? 'Dynamic route pricing' : 'Service pricing rules' %></span><span class="badge ok">Enabled</span></div><div class="progress"><i style="width:82%"></i></div></div><div class="splitItem"><div class="splitTop"><span><%= companySupportsHotel ? 'Weekend/nightly rules' : 'Holiday surge rules' %></span><span class="badge warn">Review</span></div><div class="progress"><i style="width:54%"></i></div></div><div class="splitItem"><div class="splitTop"><span>Low stock price alerts</span><span class="badge info">Active</span></div><div class="progress"><i style="width:68%"></i></div></div><button class="btn btnBlue" data-modal="edit" data-type="price rule"><i class="fa-solid fa-pen-to-square"></i> Edit price rule</button></div></div><div class="tabPane" id="inventory-review"><div class="tableWrap"><table><thead><tr><th>Item</th><th>Partner</th><th>Reason</th><th>Risk</th><th>Submitted</th><th>Status</th><th></th></tr></thead><tbody id="reviewInventoryTable"></tbody></table></div></div></div></section>



      <section class="section" id="routes"><div class="card"><div class="cardHead"><div class="cardTitle"><h3>Routes</h3><p>All transport routes across partner companies, linked listings, stops, schedules, and route status.</p></div><button class="btn btnBlue" data-modal="create" data-type="route"><i class="fa-solid fa-plus"></i> Create route</button></div><div class="tableWrap"><table><thead><tr><th>Route</th><th>Listing</th><th>Partner</th><th>Stops</th><th>Schedules</th><th>Status</th><th></th></tr></thead><tbody id="adminRoutesTable"></tbody></table></div></div></section>

      <section class="section" id="vehicles"><div class="card"><div class="cardHead"><div class="cardTitle"><h3>Vehicles</h3><p>All partner vehicles, aircraft, and fleet inventory linked to listings and schedules.</p></div><button class="btn btnBlue" data-modal="create" data-type="vehicle"><i class="fa-solid fa-plus"></i> Add vehicle</button></div><div class="tableWrap"><table><thead><tr><th>Vehicle</th><th>Partner</th><th>Type</th><th>Plate / Code</th><th>Seats</th><th>Status</th><th></th></tr></thead><tbody id="adminVehiclesTable"></tbody></table></div></div></section>

      <section class="section" id="schedules"><div class="card"><div class="cardHead"><div class="cardTitle"><h3><%= isEmployeeDashboard ? 'Assigned schedules' : 'Schedules' %></h3><p><%= isEmployeeDashboard ? 'Review assigned departures, manifests, seat maps, availability, and delay notices.' : 'Departures, assigned vehicles, available capacity, prices, and publishing status.' %></p></div><button class="btn btnBlue" data-modal="create" data-type="<%= isEmployeeDashboard ? 'delay notice' : 'schedule' %>"><i class="fa-solid <%= isEmployeeDashboard ? 'fa-triangle-exclamation' : 'fa-plus' %>"></i> <%= isEmployeeDashboard ? 'Send delay notice' : 'Create schedule' %></button></div><div class="tableWrap"><table><thead><tr><th>Schedule</th><th>Route / Listing</th><th>Partner</th><th>Vehicle</th><th>Availability</th><th>Status</th><th></th></tr></thead><tbody id="adminSchedulesTable"></tbody></table></div></div></section>

      <% const featureServices = Array.isArray(dashboardData?.dashboardFeatures?.services) ? dashboardData.dashboardFeatures.services : []; %>
      <% featureServices.forEach(function(service){ %>
      <section class="section" id="<%= service.key %>">
        <div class="hero">
          <div class="heroGrid">
            <div class="welcome">
              <div>
                <span class="badge <%= /core/i.test(service.status || '') ? 'ok' : 'warn' %>"><i class="fa-solid <%= service.icon || 'fa-layer-group' %>"></i> <%= service.status || 'service dashboard' %></span>
                <h2><%= service.label %></h2>
                <p><%= service.overview %></p>
              </div>
              <div class="heroActions">
                <button class="btn btnPrimary" data-modal="create" data-type="listing"><i class="fa-solid fa-plus"></i> Add inventory</button>
                <button class="btn" data-jump="bookings"><i class="fa-solid fa-ticket"></i> View bookings</button>
                <button class="btn" data-jump="reports"><i class="fa-solid fa-file-lines"></i> Reports</button>
              </div>
            </div>
            <div class="livePanel">
              <div class="liveHeader"><strong>Service modules</strong><span class="badge info"><%= service.serviceType %></span></div>
              <div class="liveList">
                <% (service.modules || []).slice(0, 8).forEach(function(moduleName){ %>
                  <div class="liveItem"><span><%= moduleName %></span><strong>Ready</strong></div>
                <% }) %>
              </div>
            </div>
          </div>
        </div>
        <div class="grid2" style="margin-top:14px">
          <div class="card">
            <div class="cardHead"><div class="cardTitle"><h3><%= service.label %> features</h3><p>Feature checklist for this service category using the same admin dashboard UI.</p></div></div>
            <div class="splitGrid">
              <% (service.features || []).forEach(function(feature){ %>
                <div class="splitItem"><div class="splitTop"><span><%= feature %></span><span class="badge <%= /feature flagged/i.test(service.status || '') ? 'warn' : 'ok' %>"><%= /feature flagged/i.test(service.status || '') ? 'Flagged' : 'Core' %></span></div></div>
              <% }) %>
            </div>
          </div>
          <div class="card">
            <div class="cardHead"><div class="cardTitle"><h3>Operational flow</h3><p>Every category follows the same controlled marketplace path.</p></div></div>
            <div class="metricList">
              <div class="metricRow"><div><strong>1. Provider admission</strong><span>Lead/session/agreement/invitation/verification before publishing.</span></div><b class="badge info">Gate</b></div>
              <div class="metricRow"><div><strong>2. Inventory setup</strong><span>Listings, capacity, pricing, policies, documents, and publish checks.</span></div><b class="badge warn">Setup</b></div>
              <div class="metricRow"><div><strong>3. Customer booking</strong><span>Search, hold, details, payment, ticket/voucher, receipt, notification.</span></div><b class="badge ok">Booking</b></div>
              <div class="metricRow"><div><strong>4. Operations</strong><span>Manifest, check-in/completion, support, refund, settlement, reports.</span></div><b class="badge ok">Complete</b></div>
            </div>
          </div>
        </div>
        <div class="card" style="margin-top:14px">
          <div class="cardHead"><div class="cardTitle"><h3><%= service.label %> records</h3><p>Filtered service records. Future categories stay feature-flagged until fully wired end to end.</p></div></div>
          <div class="tableWrap"><table><thead><tr><th>Record</th><th>Type</th><th>Partner</th><th>Inventory</th><th>Status</th><th>Rule</th><th></th></tr></thead><tbody id="<%= service.key.replace(/-/g, '') %>Table"></tbody></table></div>
        </div>
      </section>
      <% }) %>

      <section class="section" id="company-profile">
        <% const companyProfile = dashboardData?.company || {}; const companyStats = dashboardData?.stats || {}; %>
        <div class="grid2">
          <div class="card"><div class="cardHead"><div class="cardTitle"><h3>Company Profile</h3><p>Company-owned profile, branches, policies, support contacts, payout identity, and verification state.</p></div><div class="heroActions"><span class="badge <%= companyProfile.verificationStatus === 'verified' ? 'ok' : 'warn' %>"><%= companyProfile.verificationStatus || 'pending' %></span><button class="btn" data-modal="edit" data-type="profile"><i class="fa-solid fa-pen"></i> Edit profile</button></div></div>
            <div class="metricList">
              <div class="metricRow"><div><strong><%= companyProfile.name || 'Company partner' %></strong><span><%= [companyProfile.city, companyProfile.country].filter(Boolean).join(', ') || 'Location pending' %></span></div><b class="badge info"><%= companyProfile.type || 'partner' %></b></div>
              <div class="metricRow"><div><strong>Support</strong><span><%= companyProfile.supportEmail || companyProfile.supportPhone || companyProfile.supportWhatsapp || 'Support contact pending' %></span></div><b class="badge info">Scoped</b></div>
              <div class="metricRow"><div><strong>Payout account</strong><span><%= companyProfile.payoutAccount || 'Payout account pending' %></span></div><b class="badge warn"><%= companyProfile.defaultCurrency || 'UGX' %></b></div>
            </div>
          </div>
          <div class="card"><div class="cardHead"><div class="cardTitle"><h3>Company readiness</h3><p>Publishing should stay blocked until Super Admin verification, policies, inventory, and payout details are complete.</p></div></div>
            <div class="splitGrid"><div class="splitItem"><div class="splitTop"><span>Can publish</span><span class="badge <%= companyProfile.canPublish ? 'ok' : 'bad' %>"><%= companyProfile.canPublish ? 'Yes' : 'No' %></span></div></div><div class="splitItem"><div class="splitTop"><span>Active listings</span><strong><%= companyStats.activeListings || '0' %></strong></div></div><% if(!isCompanyDashboard || companySupportsTransport){ %><div class="splitItem"><div class="splitTop"><span>Routes</span><strong><%= companyStats.routeCount || '0' %></strong></div></div><% } %><% if(!isCompanyDashboard || companySupportsHotel){ %><div class="splitItem"><div class="splitTop"><span>Room types</span><strong><%= companyStats.roomTypes || '0' %></strong></div></div><% } %></div>
          </div>
        </div>
        <%
          const companyDocs = Array.isArray(companyProfile.documents) ? companyProfile.documents : [];
          const companyMediaOptions = dashboardData?.options || {};
          const mediaListings = companyMediaOptions.listings || [];
          const mediaVehicles = companyMediaOptions.vehicles || [];
          const mediaDrivers = companyMediaOptions.drivers || [];
          const mediaHotelProperties = companyMediaOptions.hotelProperties || [];
          const mediaRoomTypes = companyMediaOptions.roomTypes || [];
          const mediaRoomUnits = companyMediaOptions.roomUnits || [];
        %>
        <div class="mediaUploadGrid" data-dashboard-media-upload="true">
          <div class="mediaUploadCard">
            <h4><i class="fa-solid fa-cloud-arrow-up"></i> Media & verification uploads</h4>
            <p>Upload company documents, bus/vehicle documents, driver documents, hotel photos, room photos, and verification files without leaving the dashboard.</p>
            <form class="mediaUploadForm" method="POST" action="/company/media" enctype="multipart/form-data">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>">
              <input type="hidden" name="next" value="/company/profile">
              <div class="field"><label>Upload target</label><div class="control"><i class="fa-solid fa-folder-open"></i><select name="target" required>
                <option value="companyLogo">Company logo</option>
                <option value="companyCover">Company cover/banner</option>
                <option value="companyDocument">Business / tax document</option>
                <option value="companyVerificationDocument">Company verification document</option>
                <% if(companySupportsBus){ %><option value="busListing">Bus listing image</option><option value="vehiclePhoto">Vehicle photo</option><option value="vehicleDocument">Vehicle registration / insurance</option><option value="driverDocument">Driver license / ID</option><% } %>
                <% if(companySupportsHotel){ %><option value="hotelListing">Hotel listing image</option><option value="hotelPropertyMedia">Hotel property photo/document</option><option value="roomTypeMedia">Room type photo</option><option value="roomUnitMedia">Room unit photo</option><option value="guestDocument">Guest ID document</option><% } %>
              </select></div></div>
              <div class="field"><label>Linked record</label><div class="control"><i class="fa-solid fa-link"></i><select name="targetId">
                <option value="">Company profile / general</option>
                <% mediaListings.forEach(function(item){ %><option value="<%= item.value || item.id %>">Listing: <%= item.label || item.value || item.id %></option><% }) %>
                <% mediaVehicles.forEach(function(item){ %><option value="<%= item.value || item.id %>">Vehicle: <%= item.label || item.value || item.id %></option><% }) %>
                <% mediaDrivers.forEach(function(item){ %><option value="<%= item.value || item.id %>">Driver: <%= item.label || item.value || item.id %></option><% }) %>
                <% mediaHotelProperties.forEach(function(item){ %><option value="<%= item.value || item.id %>">Property: <%= item.label || item.value || item.id %></option><% }) %>
                <% mediaRoomTypes.forEach(function(item){ %><option value="<%= item.value || item.id %>">Room type: <%= item.label || item.value || item.id %></option><% }) %>
                <% mediaRoomUnits.forEach(function(item){ %><option value="<%= item.value || item.id %>">Room unit: <%= item.label || item.value || item.id %></option><% }) %>
              </select></div><small class="fieldHelp">Choose the related listing, vehicle, driver, property, room type, or room unit when applicable.</small></div>
              <div class="field"><label>Document type</label><div class="control"><i class="fa-regular fa-id-card"></i><select name="documentType">
                <option value="business_license">Business license</option><option value="tax_certificate">Tax certificate</option><option value="operator_permit">Operator permit</option><option value="vehicle_registration">Vehicle registration</option><option value="vehicle_insurance">Vehicle insurance</option><option value="driver_license">Driver license</option><option value="driver_identity">Driver ID</option><option value="hotel_license">Hotel license</option><option value="property_verification">Property verification</option><option value="guest_identity">Guest ID</option><option value="photo">Photo / gallery image</option>
              </select></div></div>
              <div class="field"><label>Reference</label><div class="control"><i class="fa-solid fa-hashtag"></i><input name="documentReference" placeholder="License, permit, policy, or ID number"></div></div>
              <div class="field full"><label>Upload file</label><div class="control"><i class="fa-solid fa-file-arrow-up"></i><input type="file" name="imageFile" accept="image/*,application/pdf" required></div><small class="fieldHelp">Images and PDF documents are accepted. Files are stored through the configured Cloudinary/local media adapter.</small></div>
              <div class="field full"><label>Note</label><div class="control"><textarea name="note" placeholder="Internal note for Super Admin review"></textarea></div></div>
              <button class="btn btnPrimary" type="submit"><i class="fa-solid fa-cloud-arrow-up"></i> Upload for review</button>
            </form>
          </div>
          <div class="mediaUploadCard">
            <h4><i class="fa-solid fa-file-shield"></i> Company review documents</h4>
            <p>Pending files remain visible here so the company and Super Admin can review document state.</p>
            <div class="documentList">
              <% if(companyDocs.length){ companyDocs.slice(0,8).forEach(function(doc){ %>
                <div class="documentItem">
                  <div><strong><%= doc.label || doc.documentType || 'Company document' %></strong><span><%= doc.documentReference || doc.publicId || 'No reference' %> · <%= doc.status || 'pending_review' %></span></div>
                  <div class="documentActions"><% if(doc.secureUrl || doc.url){ %><a class="btn tiny" href="<%= doc.secureUrl || doc.url %>" target="_blank" rel="noopener"><i class="fa-solid fa-eye"></i> View</a><% } %><span class="badge <%= /approved|verified/i.test(doc.status || '') ? 'ok' : /reject/i.test(doc.status || '') ? 'bad' : 'warn' %>"><%= doc.status || 'pending' %></span></div>
                </div>
              <% }) } else { %>
                <div class="notice">No company documents uploaded yet. Upload business license, tax certificate, payout proof, or service verification documents.</div>
              <% } %>
            </div>
          </div>
        </div>
        <div class="grid2" style="margin-top:14px"><div class="card"><div class="cardHead"><div class="cardTitle"><h3>Branches / terminals</h3><p><%= companySupportsHotel ? 'Hotel branches, front desks, and property desks.' : companySupportsBus ? 'Company branches, terminals, pickup points, and offices.' : 'Company branches, stations, and service desks.' %></p></div><button class="btn btnBlue" data-modal="create" data-type="branch"><i class="fa-solid fa-plus"></i> Add branch</button></div><div class="tableWrap"><table><thead><tr><th>Name</th><th>Type</th><th>Location</th><th>Services</th><th>Hours</th><th>Status</th><th></th></tr></thead><tbody id="companyBranchesTable"></tbody></table></div></div><div class="card"><div class="cardHead"><div class="cardTitle"><h3>Policies</h3><p><%= companySupportsHotel ? 'Cancellation, refund, stay, check-in/out, support, and operational policies.' : companySupportsBus ? 'Cancellation, baggage, refund, boarding, support, and route policies.' : 'Cancellation, refund, support, and operational policies.' %></p></div><button class="btn" data-modal="create" data-type="policy"><i class="fa-solid fa-plus"></i> Add policy</button></div><div class="tableWrap"><table><thead><tr><th>Policy</th><th>Type</th><th>Service</th><th>Visibility</th><th>Summary</th><th>Status</th><th></th></tr></thead><tbody id="companyPoliciesTable"></tbody></table></div></div></div>
      </section>
      <section class="section" id="staff"><div class="grid2"><div class="card"><div class="cardHead"><div class="cardTitle"><h3>Staff</h3><p>Company employees are scoped to this company, branch, schedule, and permission group.</p></div><button class="btn btnBlue" data-modal="create" data-type="staff"><i class="fa-solid fa-user-plus"></i> Invite staff</button></div><div class="tableWrap"><table><thead><tr><th>Name</th><th>Role</th><th>Branch</th><th>Permissions</th><th>Last login</th><th>Status</th><th></th></tr></thead><tbody id="companyStaffTable"></tbody></table></div></div><% if(!isCompanyDashboard || companySupportsTransport){ %><div class="card"><div class="cardHead"><div class="cardTitle"><h3>Driver requests / assignments</h3><p>Drivers remain Super Admin approved, then assigned to vehicles and schedules.</p></div><button class="btn" data-modal="create" data-type="driver"><i class="fa-solid fa-id-card"></i> Request driver</button></div><div class="tableWrap"><table><thead><tr><th>Driver</th><th>License</th><th>Safety</th><th>Permissions</th><th>Branch / fleet</th><th>Status</th><th></th></tr></thead><tbody id="companyDriversTable"></tbody></table></div></div><% } else { %><div class="card"><div class="cardHead"><div class="cardTitle"><h3>Hotel staff roles</h3><p>Front desk, housekeeping, inventory, finance, support, and report-viewer permissions only.</p></div><button class="btn" data-modal="create" data-type="hotel staff"><i class="fa-solid fa-user-plus"></i> Invite hotel staff</button></div><div class="metricList"><div class="metricRow"><div><strong>Front desk</strong><span>Arrivals, check-ins, guest support</span></div><b class="badge info">Scoped</b></div><div class="metricRow"><div><strong>Housekeeping</strong><span>Room status and cleaning workflow</span></div><b class="badge info">Scoped</b></div><div class="metricRow"><div><strong>Finance</strong><span>Revenue and settlement visibility</span></div><b class="badge warn">Limited</b></div></div></div><% } %></div></section>
      <% if(companyCanShow('seat-maps')){ %>
      <section class="section" id="seat-maps">
        <% const allSeatMaps = (dashboardData?.seatMaps || []); const previewMaps = allSeatMaps.slice(0,12); const selectedSeatMapId = previewMaps[0] ? (previewMaps[0].scheduleId || previewMaps[0].id || 'seat-map-0') : ''; %>
        <div class="seatPageShell">
          <div class="seatPageHero card">
            <div class="seatPageHeroText">
              <span class="eyebrow"><i class="fa-solid fa-chair"></i> Bus seat operations</span>
              <h3>Seat Maps</h3>
              <p>Choose one route or schedule, review the real visual seat map, then use the scoped table and actions below. This page only manages bus seat templates, schedule snapshots, blocked seats, booked seats, holds, and ticket access.</p>
            </div>
            <div class="seatPageHeroActions">
              <button class="btn btnBlue" data-modal="edit" data-type="vehicle seat template"><i class="fa-solid fa-wand-magic-sparkles"></i> Template builder</button>
