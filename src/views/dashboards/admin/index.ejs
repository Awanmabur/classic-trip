      <section class="section" id="audit"><div class="card"><div class="cardHead"><div class="cardTitle"><h3>Audit logs</h3><p>Track every sensitive action by admins, employees, partners, and automated jobs.</p></div><button class="btn" data-modal="view" data-type="audit export"><i class="fa-solid fa-download"></i> Export logs</button></div><div class="innerTabs" data-tab-group="audit-tabs"><button type="button" class="tabBtn is-on" data-tab-target="audit-admin"><i class="fa-solid fa-user-shield"></i> Admin actions</button><button type="button" class="tabBtn" data-tab-target="audit-finance"><i class="fa-solid fa-wallet"></i> Finance actions</button><button type="button" class="tabBtn" data-tab-target="audit-security"><i class="fa-solid fa-lock"></i> Security alerts</button></div><div class="tabPane is-open" id="audit-admin"><div class="tableWrap"><table><thead><tr><th>Time</th><th>Actor</th><th>Action</th><th>Target</th><th>IP / device</th><th>Result</th><th></th></tr></thead><tbody id="auditTable"></tbody></table></div></div><div class="tabPane" id="audit-finance"><div class="tableWrap"><table><thead><tr><th>Time</th><th>Actor</th><th>Action</th><th>Amount</th><th>Risk</th><th>Result</th><th></th></tr></thead><tbody id="financeAuditTable"></tbody></table></div></div><div class="tabPane" id="audit-security"><div class="tableWrap"><table><thead><tr><th>Time</th><th>Alert</th><th>User</th><th>Device</th><th>Severity</th><th>Status</th><th></th></tr></thead><tbody id="securityAuditTable"></tbody></table></div></div></div></section>

