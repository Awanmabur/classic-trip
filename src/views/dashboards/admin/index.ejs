          </div>
          <% } else { %>
          <div class="card">
            <div class="cardHead"><div class="cardTitle"><h3>Settlement batches</h3><p>Create period settlements and finance statements for companies and promoters.</p></div></div>
            <form class="formPanel" method="POST" action="/admin/settlements">
              <div class="formGrid">
                <div class="field"><label>Period start</label><div class="control"><i class="fa-regular fa-calendar"></i><input type="date" name="periodStart" /></div></div>
                <div class="field"><label>Period end</label><div class="control"><i class="fa-regular fa-calendar-check"></i><input type="date" name="periodEnd" /></div></div>
                <div class="field full"><label>Notes</label><div class="control"><textarea name="notes" placeholder="Settlement notes"></textarea></div></div>
              </div>
              <button class="btn btnPrimary" type="submit"><i class="fa-solid fa-file-invoice-dollar"></i> Create settlement</button>
            </form>
            <a class="btn btnBlue" href="/admin/reports/settlements.csv"><i class="fa-solid fa-download"></i> Export settlements</a>
          </div>
          <div class="card">
            <div class="cardHead"><div class="cardTitle"><h3>Payout requests and batches</h3><p>Sync withdrawal requests, review payout risk, and export provider batches.</p></div></div>
            <div class="heroActions">
              <form method="POST" action="/admin/payouts/sync"><button class="btn" type="submit"><i class="fa-solid fa-rotate"></i> Sync requests</button></form>
