            </div>
            <div class="tableWrap"><table><thead><tr><th>Transaction</th><th>Booking</th><th>Customer paid</th><th>Partner</th><th>Platform 7%</th><th>Promoter 3%</th><th>Status</th><th></th></tr></thead><tbody id="paymentsTable"></tbody></table></div>
          </div>
          <% if(isEmployeeDashboard){ %>
          <div class="card">
            <div class="cardHead"><div class="cardTitle"><h3>Staff payment actions</h3><p>Use these controls for bookings handled during the current shift.</p></div></div>
            <div class="heroActions"><button class="btn btnBlue" data-modal="create" data-type="payment"><i class="fa-solid fa-wallet"></i> Record payment</button><button class="btn" data-modal="create" data-type="refund"><i class="fa-solid fa-rotate-left"></i> Request refund</button><button class="btn" data-modal="create" data-type="handover"><i class="fa-solid fa-clipboard-list"></i> Shift handover</button></div>
          </div>
