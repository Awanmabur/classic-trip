              <div class="splitGrid">
                <div class="splitItem"><div class="splitTop"><span>Shared links</span><strong>18,420</strong></div><div class="progress"><i style="width:100%"></i></div></div>
                <div class="splitItem"><div class="splitTop"><span>Link visits</span><strong>8,610</strong></div><div class="progress"><i style="width:72%"></i></div></div>
                <div class="splitItem"><div class="splitTop"><span>Checkout starts</span><strong>1,284</strong></div><div class="progress"><i style="width:34%"></i></div></div>
                <div class="splitItem"><div class="splitTop"><span>Paid bookings</span><strong>748</strong></div><div class="progress"><i style="width:22%"></i></div></div>
