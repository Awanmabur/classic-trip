            </div>
            <div class="tableWrap"><table><thead><tr><th>Schedule</th><th>Route</th><th>Vehicle</th><th>Date / departure</th><th>Booked</th><th>Held</th><th>Status</th><th></th></tr></thead><tbody id="companyBusManifestTable"></tbody></table></div>
            <div class="filterEmpty" data-empty-for="#companyBusManifestTable">No manifests match the current filters.</div>
