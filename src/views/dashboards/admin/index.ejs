                  <div class="busCabinDeck">
                    <% rows.forEach(function(row){ %>
                      <div class="busSeatRow">
                        <% [0,1].forEach(function(idx){ const seat = row[idx]; %>
                          <% if(seat){ const seatDetail = { entity:'seat', id:[seat.scheduleId || map.scheduleId, seat.seatNumber || seat.id].filter(Boolean).join(':'), seat: seat, seatMap: { scheduleId: map.scheduleId, routeLabel: map.routeLabel, vehicleName: map.vehicleName, status: map.status }, schedule: { id: map.scheduleId, departAt: map.departAt, status: map.status } }; %>
                            <button class="seat <%= String(seat.status || 'available').toLowerCase() %> <%= seat.bookingRef ? 'has-ticket' : '' %>" data-modal="view" data-type="seat" data-label="Seat No <%= seat.displaySeatNumber || seat.seatNumber || seat.id %>" data-row-id="<%= seatDetail.id %>" data-row-detail="<%= encodeURIComponent(JSON.stringify(seatDetail)) %>" title="Seat No <%= seat.displaySeatNumber || seat.seatNumber || seat.id %> - <%= seat.status || 'available' %>"><small>Seat No</small><b><%= seat.displaySeatNumber || seat.seatNumber || seat.id %></b></button>
                          <% } else { %><span></span><% } %>
                        <% }) %>
                        <span class="busAisle" aria-hidden="true"></span>
                        <% [2,3].forEach(function(idx){ const seat = row[idx]; %>
                          <% if(seat){ const seatDetail = { entity:'seat', id:[seat.scheduleId || map.scheduleId, seat.seatNumber || seat.id].filter(Boolean).join(':'), seat: seat, seatMap: { scheduleId: map.scheduleId, routeLabel: map.routeLabel, vehicleName: map.vehicleName, status: map.status }, schedule: { id: map.scheduleId, departAt: map.departAt, status: map.status } }; %>
                            <button class="seat <%= String(seat.status || 'available').toLowerCase() %> <%= seat.bookingRef ? 'has-ticket' : '' %>" data-modal="view" data-type="seat" data-label="Seat No <%= seat.displaySeatNumber || seat.seatNumber || seat.id %>" data-row-id="<%= seatDetail.id %>" data-row-detail="<%= encodeURIComponent(JSON.stringify(seatDetail)) %>" title="Seat No <%= seat.displaySeatNumber || seat.seatNumber || seat.id %> - <%= seat.status || 'available' %>"><small>Seat No</small><b><%= seat.displaySeatNumber || seat.seatNumber || seat.id %></b></button>
                          <% } else { %><span></span><% } %>
                        <% }) %>
                      </div>
                    <% }) %>
                  </div>
                  <div class="busCabinRear"><span class="busRearBadge"><i class="fa-solid fa-person-walking-arrow-right"></i> Rear / emergency exit</span><span><%= previewSeats.length %> seats shown</span></div>
                </div>
              </div>
            <% }) } else { %>
              <div class="notice">No seat-map preview yet. Create a vehicle seat template and publish a schedule to see visual seats here.</div>
            <% } %>
          </div>

          <div class="card seatMapListCard" id="seatMapListCard">
            <div class="cardHead"><div class="cardTitle"><h3>Selected seat-map list</h3><p>This table follows the selected route/schedule above.</p></div><div class="heroActions"><button class="btn" data-modal="edit" data-type="seat status"><i class="fa-solid fa-pen-to-square"></i> Bulk update seat</button></div></div>
            <div class="tableWrap"><table><thead><tr><th>Seat map</th><th>Route / listing</th><th>Vehicle</th><th>Total</th><th>Booked</th><th>Held / blocked</th><th>Status</th><th></th></tr></thead><tbody id="companySeatMapsTable"></tbody></table></div>
            <div class="filterEmpty" data-empty-for="#companySeatMapsTable">No seat maps match the current filters.</div>
          </div>

          <details class="card seatTemplateWorkbench compactSeatTools">
            <summary><span><i class="fa-solid fa-bus-simple"></i> Vehicle seat templates</span><em>Edit reusable vehicle layouts without crowding the seat preview.</em></summary>
            <div class="templateToolHeader"><p>Build the reusable seat template first, then publish schedules from it. This avoids entering seats one by one for every departure.</p><button class="btn" data-modal="edit" data-type="vehicle seat template"><i class="fa-solid fa-wand-magic-sparkles"></i> Template builder</button></div>
            <% const vehicleTemplates = (dashboardData?.vehicles || []).filter(function(vehicle){ return /bus|transport|vehicle|coach/i.test([vehicle.serviceType, vehicle.type, vehicle.category, vehicle.name].filter(Boolean).join(' ')) || companySupportsBus; }).slice(0,6); %>
            <% if(vehicleTemplates.length){ %>
              <div class="templateCards">
                <% vehicleTemplates.forEach(function(vehicle){ const vDetail = { entity:'vehicle', id: vehicle.id, vehicle: vehicle }; const seats = (vehicle.seats || []).slice(0,48); %>
                  <article class="templateCard"><div class="templateCardTop"><div><strong><%= vehicle.name || vehicle.plateOrCode || 'Vehicle template' %></strong><span><%= vehicle.layoutName || vehicle.layout || '2x2' %> · <%= vehicle.totalSeats || (vehicle.seats || []).length || 0 %> seats · <%= vehicle.status || 'active' %></span></div><button class="tinyBtn" data-modal="edit" data-type="vehicle seat template" data-label="<%= vehicle.name || vehicle.plateOrCode || 'Vehicle' %>" data-row-id="<%= vehicle.id %>" data-row-detail="<%= encodeURIComponent(JSON.stringify(vDetail)) %>" title="Edit seat template"><i class="fa-solid fa-pen"></i></button></div><div class="seatPreviewMini"><% if(seats.length){ seats.forEach(function(seat, seatIndex){ %><span class="seatChip <%= String(seat.seatClass || seat.seatType || '').toLowerCase() %> <%= String(seat.status || '').toLowerCase() %>">Seat No <%= seatIndex + 1 %></span><% }) } else { %><span class="muted">No template seats yet.</span><% } %></div></article>
                <% }) %>
              </div>
            <% } else { %><div class="notice">No vehicle templates yet. Add a bus/vehicle, then build its seat template.</div><% } %>
          </details>
        </div>
      </section>
      <% } %>
      <% if(companyCanShow('hotel-rooms')){ %>
