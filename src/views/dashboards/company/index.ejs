      function renderBookedGroups(container, groups, kind){
        if(!container) return;
        if(!groups.length){
          container.innerHTML = `<div class="notice">${kind === 'seat' ? 'No booked or held seats for the selected bus schedules yet.' : 'No booked or held rooms for the selected hotel dates yet.'}</div>`;
          return;
        }
        container.innerHTML = groups.map((group, groupIndex) => {
          const title = kind === 'seat' ? group.routeLabel || 'Route' : group.propertyName || 'Hotel';
          const sub = kind === 'seat'
            ? `${group.vehicleName || 'Vehicle'} - ${group.travelDate || 'Date pending'} - ${group.scheduleId || 'Schedule pending'}`
            : `${group.roomTypeName || 'Room type'} - ${group.dateRange || 'Date range pending'}`;
          const items = (kind === 'seat' ? group.seats || [] : group.rooms || []).map((item, itemIndex) => {
            const label = kind === 'seat' ? item.seatNumber : item.unitNumber;
            const person = kind === 'seat' ? item.passengerName : item.guestName;
            const ref = item.bookingRef || 'Hold';
            return `<button class="bookedItem" type="button" data-booked-kind="${kind}" data-booked-group="${groupIndex}" data-booked-index="${itemIndex}">
              <strong>${escapeHtml(label || 'Selected')}</strong>
              <span>${escapeHtml(ref)} - ${escapeHtml(item.status || 'status pending')}</span>
              <span>${escapeHtml(person || 'Customer pending')}</span>
            </button>`;
          }).join('');
          return `<section class="bookedGroup">
            <div class="bookedGroupHead">
              <div><h4>${escapeHtml(title)}</h4><p>${escapeHtml(sub)}</p></div>
              <div class="bookedChips"><span class="bookedChip">${escapeHtml(group.totalBooked || 0)} booked</span><span class="bookedChip">${escapeHtml(group.totalHeld || 0)} held</span></div>
            </div>
            <div class="bookedItems">${items}</div>
          </section>`;
        }).join('');
      }

      function renderCompanyShell(){
        const company = data.company || {};
        const stats = data.stats || {};
        const name = company.name || 'Company partner';
        const verification = company.verificationStatus || 'pending';
        const profileName = $('.profileMeta strong');
        const profileStatus = $('.profileMeta span');
        const avatar = $('.avatar');
        if(profileName) profileName.textContent = name;
        if(profileStatus) profileStatus.textContent = `${verification} ${company.type || 'partner'}`;
        if(avatar) avatar.textContent = initials(name);

        const welcomeBadge = $('.welcome .badge');
        if(welcomeBadge){
          welcomeBadge.className = verification === 'verified' ? 'badge ok' : 'badge warn';
          welcomeBadge.innerHTML = `<i class="fa-solid fa-circle-check"></i> ${escapeHtml(verification === 'verified' ? 'Company account active' : 'Company account pending')}`;
        }
        const welcomeTitle = $('.welcome h2');
        const welcomeText = $('.welcome p');
        if(welcomeTitle) welcomeTitle.textContent = `Welcome back, ${name}. Your dashboard is connected to live partner data.`;
        const inventoryLabel = (serviceProfile.inventoryLabel || 'inventory').toLowerCase();
        if(welcomeText) welcomeText.textContent = `Manage ${stats.activeListings || data.listings.length} ${serviceProfile.primaryLabel || 'company'} services, ${inventoryLabel}, bookings, staff, payouts, promotions, and support from one company console.`;

        const liveItems = $$('.liveList .liveItem');
        [
          ['Confirmed bookings', stats.confirmedBookings || data.bookings.length],
          [serviceProfile.supportsHotel && !serviceProfile.supportsBus ? 'Rooms on hold' : serviceProfile.supportsBus ? 'Seats on hold' : 'Inventory holds', stats.seatsOnHold || '0'],
          [serviceProfile.supportsHotel && !serviceProfile.supportsTransport ? 'Upcoming stays' : 'Upcoming schedules', stats.upcomingTrips || data.schedules.length],
          ['Open support cases', stats.openSupportCases || data.support.length]
        ].forEach(([label, value], index) => {
          const item = liveItems[index];
          if(!item) return;
          const span = item.querySelector('span');
          const strong = item.querySelector('strong');
          if(span) span.textContent = label;
          if(strong) strong.textContent = value;
        });

        const statCards = $$('.statsGrid .statCard');
        [
          [stats.earnings || 'UGX 0', 'Partner earnings', stats.grossRevenue || 'UGX 0 gross'],
          [stats.confirmedBookings || '0', 'Confirmed bookings', `${stats.activeListings || data.listings.length} listings`],
          [stats.fillRate || '0%', serviceProfile.supportsHotel && !serviceProfile.supportsBus ? 'Room occupancy rate' : 'Average seat fill rate', `${stats.blockedSeats || '0'} blocked`],
          [stats.rating || '0.0/5', 'Customer rating', `${data.reviews.length} reviews`]
        ].forEach(([value, label, trend], index) => {
          const card = statCards[index];
          if(!card) return;
          const number = card.querySelector('.statNumber');
          const statLabel = card.querySelector('.statLabel');
          const trendNode = card.querySelector('.trend');
          if(number) number.textContent = value;
          if(statLabel) statLabel.textContent = label;
          if(trendNode) trendNode.textContent = trend;
        });

        const healthItems = $$('#seatrooms .splitGrid .splitItem');
        data.inventory.slice(0, 3).forEach((row, index) => {
          const item = healthItems[index];
          if(!item) return;
          const cells = rowCells(row);
          const total = Number(cells[2] || 0);
          const booked = Number(cells[3] || 0);
          const percent = total ? Math.min(100, Math.round((booked / total) * 100)) : 0;
          const label = item.querySelector('.splitTop span');
          const strong = item.querySelector('.splitTop strong');
          const bar = item.querySelector('.progress i');
          if(label) label.textContent = cells[0] || 'Inventory';
          if(strong) strong.textContent = `${booked} / ${total}`;
          if(bar) bar.style.width = `${percent}%`;
        });

        const settingsForm = $('#settingsForm');
        const unnamedPayout = settingsForm?.querySelector('input:not([type="hidden"]):not([name])');
        if(unnamedPayout) unnamedPayout.name = 'payoutAccount';
        const nameInput = settingsForm?.querySelector('[name="name"]');
        const companyTypeInput = settingsForm?.querySelector('[name="companyType"]');
        const currencyInput = settingsForm?.querySelector('[name="defaultCurrency"]');
        const payoutInput = settingsForm?.querySelector('[name="payoutAccount"]');
        const supportEmailInput = settingsForm?.querySelector('[name="supportEmail"]');
        const supportPhoneInput = settingsForm?.querySelector('[name="supportPhone"]');
        const supportMessageInput = settingsForm?.querySelector('[name="supportMessage"]');
        if(nameInput) nameInput.value = name;
        if(companyTypeInput) companyTypeInput.value = company.type || company.companyType || companyTypeInput.value;
        if(currencyInput) currencyInput.value = company.defaultCurrency || currencyInput.value;
        if(payoutInput) payoutInput.value = company.payoutAccount || payoutInput.value || '';
        if(supportEmailInput) supportEmailInput.value = company.supportEmail || '';
        if(supportPhoneInput) supportPhoneInput.value = company.supportPhone || '';
        if(supportMessageInput) supportMessageInput.value = company.supportMessage || `${name} support: ${company.supportEmail || company.supportPhone || 'contact the company team'}`;

        const checked = data.checkins.filter(row => /checked/i.test(String(rowCells(row)[5] || ''))).length;
        const pending = Math.max(0, data.checkins.length - checked);
        const checkedNode = $('#checkedInCount');
        const pendingNode = $('#pendingCheckinCount');
        const checkinBars = $$('#checkins .progress i');
        if(checkedNode) checkedNode.textContent = String(checked);
        if(pendingNode) pendingNode.textContent = String(pending);
        const totalCheckins = Math.max(1, data.checkins.length);
        if(checkinBars[0]) checkinBars[0].style.width = `${Math.round((checked / totalCheckins) * 100)}%`;
        if(checkinBars[1]) checkinBars[1].style.width = `${Math.round((pending / totalCheckins) * 100)}%`;
      }

