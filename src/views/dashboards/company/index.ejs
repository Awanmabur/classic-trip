<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Classic Trip | Company Workspace</title>
  <meta name="description" content="Classic Trip Partner / Company Dashboard for managing listings, schedules, bookings, inventory, staff, payouts, promotions, support, and reports." />
  <meta name="csrf-token" content="<%= csrfToken || '' %>" />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
  <script src="/js/csrf.js" defer></script>
  <script src="/js/employee-qr-scanner.js" defer></script>

  <style>
    :root{
      --container:min(1420px,94%);
      --sidebar:284px;
      --topbar:66px;
      --radius:28px;
      --radius2:20px;
      --pill:999px;
      --primary:#4f8cff;
      --primary2:#2f6bff;
      --accent:#ffb703;
      --hot:#ff5a1f;
      --ok:#22c55e;
      --warn:#f59e0b;
      --bad:#ef4444;
      --shadow:0 22px 70px rgba(0,0,0,.24);
      --shadow2:0 12px 38px rgba(0,0,0,.18);
    }

    html[data-theme="dark"]{
      --bg0:#03050b;
      --bg1:#060914;
      --cardA:rgba(255,255,255,.068);
      --cardB:rgba(255,255,255,.034);
      --soft:rgba(255,255,255,.048);
      --line:rgba(255,255,255,.105);
      --line2:rgba(255,255,255,.065);
      --text:#f7f9ff;
      --muted:rgba(247,249,255,.64);
      --muted2:rgba(247,249,255,.42);
      --input:rgba(255,255,255,.055);
      --table:rgba(255,255,255,.035);
      --panel:rgba(7,10,20,.94);
      --active:rgba(255,183,3,.26);
      --activeLine:rgba(255,183,3,.46);
      --selectBg:#0d1222;
    }

    html[data-theme="light"]{
      --bg0:#eef3ff;
      --bg1:#e9eef8;
      --cardA:rgba(255,255,255,.94);
      --cardB:rgba(255,255,255,.78);
      --soft:rgba(15,23,42,.045);
      --line:rgba(15,23,42,.105);
      --line2:rgba(15,23,42,.065);
      --text:#0f172a;
      --muted:rgba(15,23,42,.62);
      --muted2:rgba(15,23,42,.43);
      --input:rgba(15,23,42,.045);
      --table:rgba(15,23,42,.03);
      --panel:rgba(255,255,255,.96);
      --active:rgba(255,183,3,.28);
      --activeLine:rgba(255,183,3,.50);
      --selectBg:#ffffff;
      --shadow:0 22px 70px rgba(15,23,42,.11);
      --shadow2:0 12px 38px rgba(15,23,42,.08);
    }

    *{box-sizing:border-box}
    html{scroll-behavior:auto}
    body{
      margin:0;
      min-height:100vh;
      font-family:Inter,system-ui,-apple-system,Segoe UI,Roboto,Arial,sans-serif;
      color:var(--text);
      background:
        radial-gradient(650px 390px at 8% -12%, rgba(79,140,255,.055), transparent 68%),
        radial-gradient(560px 340px at 94% -10%, rgba(255,183,3,.03), transparent 70%),
        linear-gradient(180deg,var(--bg0),var(--bg1));
      overflow-x:hidden;
    }

    a{color:inherit;text-decoration:none}
    button,input,select,textarea{font:inherit}
    button{cursor:pointer}
    :focus,:focus-visible{outline:none!important;box-shadow:none!important}

    ::-webkit-scrollbar{width:10px;height:10px}
    ::-webkit-scrollbar-track{background:rgba(255,255,255,.035);border-radius:20px}
    ::-webkit-scrollbar-thumb{background:rgba(255,255,255,.14);border-radius:20px;border:2px solid transparent;background-clip:content-box}

    .app{
      width:var(--container);
      margin:0 auto;
      display:grid;
      grid-template-columns:var(--sidebar) minmax(0,1fr);
      gap:16px;
      padding:14px 0 24px;
    }

    .sideBackdrop{display:none}

    .sidebar{
      position:sticky;
      top:14px;
      height:calc(100vh - 28px);
      border:1px solid var(--line);
      background:linear-gradient(180deg,var(--cardA),var(--cardB));
      border-radius:30px;
      box-shadow:var(--shadow2);
      backdrop-filter:blur(16px);
      -webkit-backdrop-filter:blur(16px);
      overflow:hidden;
      display:flex;
      flex-direction:column;
      z-index:80;
    }

    .sideTop{
      padding:14px;
      border-bottom:1px solid var(--line);
      display:flex;
      align-items:center;
      gap:10px;
    }

    .mark{
      width:42px;
      height:42px;
      border-radius:16px;
      display:grid;
      place-items:center;
      color:#081026;
      background:linear-gradient(135deg,rgba(79,140,255,.96),rgba(255,183,3,.96));
      font-weight:1000;
      flex:0 0 auto;
      box-shadow:0 12px 28px rgba(79,140,255,.14);
    }

    .brandText{min-width:0}
    .brandText strong{
      display:block;
      font-size:14px;
      letter-spacing:-.2px;
      white-space:nowrap;
      overflow:hidden;
      text-overflow:ellipsis;
    }

    .brandText span{
      display:block;
      margin-top:2px;
      font-size:11px;
      color:var(--muted);
      font-weight:850;
      white-space:nowrap;
      overflow:hidden;
      text-overflow:ellipsis;
    }

    .sideSearch{padding:12px 14px 8px}

    .searchBox,.control{
      border:1px solid var(--line);
      background:var(--input);
      border-radius:22px;
      display:flex;
      align-items:center;
      gap:10px;
      padding:10px 13px;
      min-width:0;
    }

    .searchBox input,.control input,.control select,.control textarea{
      width:100%;
      border:0;
      background:transparent;
      color:var(--text);
      min-width:0;
      font-weight:850;
      font-size:12px;
    }

    select option{
      background:var(--selectBg);
      color:var(--text);
    }

    .searchBox input::placeholder,.control input::placeholder,.control textarea::placeholder{color:var(--muted2)}

    .sideNav{
      padding:9px;
      display:grid;
      gap: 10px;
      overflow:auto;
      flex:1;
      align-content:start;
    }

    .navBtn{
      width:100%;
      min-width:0;
      border:1px solid transparent;
      background:transparent;
      color:var(--muted);
      border-radius:18px;
      padding: 11px 12px;
      display:flex;
      align-items:center;
      gap:10px;
      font-size:12.2px;
      font-weight:900;
      text-align:left;
      white-space:nowrap;
      overflow:hidden;
      transition:.16s ease;
    }

    .navBtn span{
      min-width:0;
      overflow:hidden;
      text-overflow:ellipsis;
      white-space:nowrap;
      display:block;
    }

    .navBtn i{
      width:20px;
      height:20px;
      display:grid;
      place-items:center;
      font-size:13px;
      color:var(--muted);
      flex:0 0 auto;
    }

    .navBtn:hover{
      background:rgba(79,140,255,.13);
      border-color:rgba(79,140,255,.32);
      color:var(--text);
      border-radius:24px;
      
      padding-top:15px;
      padding-bottom:15px;transform:translateY(-1px);
    }

    .navBtn.is-active{
      background:var(--active);
      border-color:var(--activeLine);
      color:var(--accent);
      border-radius:28px;
      box-shadow:0 12px 28px rgba(255,183,3,.13);
      padding-top: 15px;
      padding-bottom:15px;
    }

    .navBtn.is-active i{color:var(--accent)}

    .sideFoot{
      border-top:1px solid var(--line);
      padding:12px;
      display:grid;
      gap:10px;
    }

    .miniProfile{
      display:flex;
      align-items:center;
      gap:9px;
      padding:9px;
      border-radius:22px;
      background:var(--soft);
      border:1px solid var(--line2);
    }

    .avatar{
      width:36px;
      height:36px;
      border-radius:14px;
      background:linear-gradient(135deg,rgba(79,140,255,.92),rgba(255,90,31,.82));
      display:grid;
      place-items:center;
      color:#fff;
      font-weight:1000;
      flex:0 0 auto;
      font-size:12px;
    }

    .profileMeta strong{display:block;font-size:12px}
    .profileMeta span{display:block;color:var(--muted);font-size:10px;font-weight:850;margin-top:2px}

    .main{
      min-width:0;
      display:flex;
      flex-direction:column;
      gap:10px;
    }

    .topbar{
      position:sticky;
      top:14px;
      z-index:50;
      min-height:var(--topbar);
      max-height:var(--topbar);
      border:1px solid var(--line);
      border-radius:28px;
      background:linear-gradient(180deg,var(--cardA),var(--cardB));
      backdrop-filter:blur(18px);
      -webkit-backdrop-filter:blur(18px);
      box-shadow:var(--shadow2);
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:10px;
      padding:10px 12px;
      overflow:hidden;
    }

    .topLeft{
      min-width:0;
      display:flex;
      align-items:center;
      gap:10px;
    }

    .menuBtn{display:none!important}

    .pageTitle{min-width:0}
    .pageTitle h1{
      margin:0;
      font-size:18px;
      line-height:1.1;
      letter-spacing:-.35px;
      white-space:nowrap;
      overflow:hidden;
      text-overflow:ellipsis;
    }

    .pageTitle p{
      margin:4px 0 0;
      color:var(--muted);
      font-size:11.5px;
      font-weight:800;
      white-space:nowrap;
      overflow:hidden;
      text-overflow:ellipsis;
      max-width:660px;
    }

    .topActions{
      display:flex;
      align-items:center;
      gap:7px;
      flex-wrap:nowrap;
      justify-content:flex-end;
      min-width:max-content;
    }

    .btn,.iconBtn,.chip{
      border:1px solid var(--line);
      background:var(--soft);
      color:var(--text);
      border-radius:999px;
      height:39px;
      padding:0 13px;
      display:inline-flex;
      align-items:center;
      justify-content:center;
      gap:8px;
      font-weight:950;
      font-size:12px;
      white-space:nowrap;
      transition:.15s ease;
    }

    .btn:hover,.iconBtn:hover,.chip:hover{
      transform:translateY(-1px);
      border-color:rgba(79,140,255,.26);
      background:rgba(79,140,255,.08);
    }

    .iconBtn{
      width:39px;
      padding:0;
      flex:0 0 auto;
    }

    .btnPrimary{
      border-color:transparent;
      color:#071226;
      background:linear-gradient(135deg,var(--accent),var(--hot));
      box-shadow:0 14px 34px rgba(255,90,31,.12);
    }

    .btnBlue{
      border-color:transparent;
      background:linear-gradient(135deg,rgba(79,140,255,.94),rgba(47,107,255,.94));
      color:#eef5ff;
      box-shadow:0 14px 34px rgba(79,140,255,.12);
    }

    .btnDanger{
      background:rgba(239,68,68,.12);
      color:#ff8b8b;
      border-color:rgba(239,68,68,.22);
    }

    .badge{
      display:inline-flex;
      align-items:center;
      gap:7px;
      border-radius:999px;
      border:1px solid var(--line);
      background:var(--soft);
      padding:6px 9px;
      font-size:11px;
      font-weight:950;
      color:var(--muted);
      white-space:nowrap;
    }

    .badge.ok{background:rgba(34,197,94,.105);border-color:rgba(34,197,94,.22);color:#42d77a}
    .badge.warn{background:rgba(255,183,3,.105);border-color:rgba(255,183,3,.24);color:#ffc847}
    .badge.bad{background:rgba(239,68,68,.105);border-color:rgba(239,68,68,.22);color:#ff8b8b}
    .badge.info{background:rgba(79,140,255,.115);border-color:rgba(79,140,255,.32);color:#7fb0ff}

    .content{
      display:flex;
      flex-direction:column;
      gap:14px;
      scroll-margin-top:84px;
    }

    .section{
      display:none;
      animation:fadeIn .20s ease both;
      scroll-margin-top:84px;
    }
    .section.is-open{display:block}

    @keyframes fadeIn{
      from{opacity:0;transform:translateY(6px)}
      to{opacity:1;transform:translateY(0)}
    }

    .hero,.card{
      border:1px solid var(--line);
      border-radius:30px;
      background:linear-gradient(180deg,var(--cardA),var(--cardB));
      box-shadow:var(--shadow2);
      overflow:hidden;
    }

    .hero{padding:16px}

    .heroGrid{
      display:grid;
      grid-template-columns:minmax(0,1.1fr) 360px;
      gap:14px;
      align-items:stretch;
    }

    .welcome{
      min-height:190px;
      border-radius:25px;
      padding:18px;
      border:1px solid var(--line2);
      background:rgba(255,255,255,.026);
      display:flex;
      flex-direction:column;
      justify-content:space-between;
      gap:20px;
    }

    html[data-theme="light"] .welcome{background:rgba(15,23,42,.025)}

    .welcome h2{
      margin:12px 0 0;
      font-size:27px;
      line-height:1.06;
      letter-spacing:-.8px;
      max-width:720px;
    }

    .welcome p{
      margin:8px 0 0;
      color:var(--muted);
      font-size:13px;
      font-weight:800;
      max-width:780px;
      line-height:1.55;
    }

    .heroActions{display:flex;gap:9px;flex-wrap:wrap}

    .livePanel{
      border-radius:25px;
      padding:16px;
      border:1px solid var(--line2);
      background:rgba(255,255,255,.026);
      display:grid;
      gap:12px;
    }

    .liveHeader{
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:10px;
    }

    .liveHeader strong{font-size:14px}
    .pulse{
      width:9px;height:9px;border-radius:50%;
      background:var(--ok);
      box-shadow:0 0 0 8px rgba(34,197,94,.12);
    }

    .liveList{display:grid;gap:10px}
    .liveItem{
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:10px;
      padding:10px;
      border-radius:18px;
      background:var(--soft);
      border:1px solid var(--line2);
    }
    .liveItem span:first-child{font-size:12px;color:var(--muted);font-weight:850}
    .liveItem strong{font-size:13px}

    .statsGrid{
      display:grid;
      grid-template-columns:repeat(4,minmax(0,1fr));
      gap:12px;
      margin-top:14px;
    }

    .statCard{
      border:1px solid var(--line);
      border-radius:24px;
      background:linear-gradient(180deg,var(--cardA),var(--cardB));
      box-shadow:var(--shadow2);
      padding:14px;
      min-width:0;
      overflow:hidden;
    }

    .statTop{
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:8px;
    }

    .statIcon{
      width:38px;height:38px;border-radius:15px;
      display:grid;place-items:center;
      background:rgba(79,140,255,.115);
      color:#7fb0ff;
      border:1px solid rgba(79,140,255,.20);
      flex:0 0 auto;
    }

    .trend{
      display:inline-flex;align-items:center;gap:5px;
      font-size:11px;font-weight:950;
      color:#42d77a;
      padding:5px 8px;border-radius:999px;
      background:rgba(34,197,94,.10);
      border:1px solid rgba(34,197,94,.18);
    }

    .statNumber{
      font-size:22px;
      font-weight:1000;
      letter-spacing:-.7px;
      margin-top:12px;
    }

    .statLabel{
      margin-top:3px;
      color:var(--muted);
      font-size:12px;
      font-weight:850;
    }

    .grid2{display:grid;grid-template-columns:1.15fr .85fr;gap:14px}
    .grid3{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:14px}
    .grid4{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:12px}

    .cardPad{padding:16px}
    .cardHead{
      display:flex;
      align-items:flex-start;
      justify-content:space-between;
      gap:12px;
      padding:16px 16px 0;
      flex-wrap:wrap;
    }

    .cardTitle h3{
      margin:0;
      font-size:16px;
      letter-spacing:-.25px;
    }
    .cardTitle p{
      margin:5px 0 0;
      color:var(--muted);
      font-size:12px;
      font-weight:800;
      line-height:1.45;
    }

    .tabs{
      display:flex;
      gap:7px;
      flex-wrap:wrap;
      padding:12px 16px 0;
    }

    .tabBtn,.chip{
      height:33px;
      padding:0 11px;
      color:var(--muted);
      font-size:11.5px;
      border-radius:999px;
    }

    .tabBtn{
      border:1px solid var(--line);
      background:var(--soft);
      display:inline-flex;
      align-items:center;
      justify-content:center;
      gap:7px;
      font-weight:950;
      white-space:nowrap;
      transition:.15s ease;
    }

    .tabBtn:hover{background:rgba(79,140,255,.08);border-color:rgba(79,140,255,.32);transform:translateY(-1px)}
    .tabBtn.is-on,.chip.is-on{
      background:var(--active);
      border-color:var(--activeLine);
      color:var(--accent);
    }

    .tabPane{display:none}
    .tabPane.is-on{display:block}

    .tableWrap{overflow:auto;padding:12px 16px 16px}

    table{
      width:100%;
      border-collapse:separate;
      border-spacing:0 8px;
      min-width:760px;
    }

    th{
      text-align:left;
      color:var(--muted);
      font-size:10px;
      text-transform:uppercase;
      letter-spacing:.08em;
      padding:0 10px;
      white-space:nowrap;
    }

    td{
      background:var(--table);
      border-top:1px solid var(--line2);
      border-bottom:1px solid var(--line2);
      padding:10px;
      font-size:12px;
      font-weight:800;
      vertical-align:middle;
      white-space:nowrap;
    }

    td:first-child{border-left:1px solid var(--line2);border-radius:16px 0 0 16px}
    td:last-child{border-right:1px solid var(--line2);border-radius:0 16px 16px 0}

    .nameCell{display:flex;align-items:center;gap:10px}

    .miniLogo{
      width:34px;height:34px;border-radius:13px;
      display:grid;place-items:center;
      background:rgba(79,140,255,.115);
      color:#7fb0ff;
      border:1px solid rgba(79,140,255,.20);
      flex:0 0 auto;
      font-weight:1000;
    }

    .nameCell strong{display:block;font-size:12px}
    .nameCell span{display:block;color:var(--muted);font-size:11px;margin-top:2px}

    .rowActions{display:flex;gap:6px;justify-content:flex-end}

    .tinyBtn{
      width:33px;height:33px;border-radius:999px;
      display:grid;place-items:center;
      border:1px solid var(--line);
      background:var(--soft);
      color:var(--text);
      transition:.15s ease;
      font-size:12px;
    }
    .tinyBtn:hover{transform:translateY(-1px);background:rgba(79,140,255,.08);border-color:rgba(79,140,255,.25)}
    .tinyBtn.danger{color:#ff8b8b;background:rgba(239,68,68,.10);border-color:rgba(239,68,68,.20)}

    .quickGrid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:10px}

    .quickCard{
      border:1px solid var(--line2);
      background:var(--soft);
      border-radius:22px;
      padding:13px;
      display:grid;
      gap:9px;
      min-height:112px;
      transition:.15s ease;
      color:var(--text);
      text-align:left;
    }

    .quickCard:hover{transform:translateY(-2px);border-color:rgba(79,140,255,.23);background:rgba(79,140,255,.07)}

    .quickIcon{
      width:36px;height:36px;border-radius:14px;
      display:grid;place-items:center;
      background:rgba(255,183,3,.12);
      color:var(--accent);
      border:1px solid rgba(255,183,3,.20);
    }

    .quickCard strong{font-size:13px}
    .quickCard span{font-size:11px;color:var(--muted);font-weight:800;line-height:1.45}

    .chart{padding:16px;display:grid;gap:10px}

    .bars{
      display:flex;
      align-items:end;
      gap:9px;
      height:185px;
      padding:12px;
      border-radius:22px;
      border:1px solid var(--line2);
      background:var(--soft);
    }

    .bar{
      flex:1;
      min-width:22px;
      border-radius:14px 14px 8px 8px;
      background:linear-gradient(180deg,rgba(79,140,255,.95),rgba(255,183,3,.72));
      position:relative;
      transition:.18s ease;
    }

    .bar:hover{filter:brightness(1.06);transform:translateY(-3px)}
    .bar span{
      position:absolute;
      left:50%;
      bottom:-26px;
      transform:translateX(-50%);
      color:var(--muted);
      font-size:10px;
      font-weight:900;
    }

    .splitGrid{display:grid;gap:10px;padding:16px}

    .splitItem{
      display:grid;
      gap:8px;
      padding:12px;
      border:1px solid var(--line2);
      border-radius:20px;
      background:var(--soft);
    }

    .splitTop{
      display:flex;align-items:center;justify-content:space-between;gap:10px;
      font-size:12px;font-weight:900;
    }

    .progress{
      height:9px;
      border-radius:999px;
      background:rgba(255,255,255,.07);
      overflow:hidden;
      border:1px solid var(--line2);
    }

    html[data-theme="light"] .progress{background:rgba(15,23,42,.06)}
    .progress i{
      display:block;height:100%;border-radius:999px;
      background:linear-gradient(90deg,var(--primary),var(--accent));
    }

    .seatMapShell{padding:16px;display:grid;gap:13px}
    .seatMapToolbar{display:grid;grid-template-columns:minmax(0,1fr) auto;gap:10px;align-items:center}
    .seatMapToolbar .control{min-width:0}
    .seatLegend{display:flex;align-items:center;gap:8px;flex-wrap:wrap}
    .seatState{display:inline-flex;align-items:center;gap:6px;font-size:11px;font-weight:950;color:var(--muted);white-space:nowrap}
    .seatDot{width:12px;height:12px;border-radius:4px;border:1px solid var(--line2)}
    .seatDot.available{background:rgba(34,197,94,.32)}
    .seatDot.booked{background:rgba(79,140,255,.36)}
    .seatDot.hold{background:rgba(255,183,3,.42)}
    .seatDot.blocked{background:rgba(239,68,68,.28)}
    .seatMapStats{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:8px}
    .seatStat{border:1px solid var(--line2);background:var(--soft);border-radius:16px;padding:9px 10px;display:grid;gap:2px;min-width:0}
    .seatStat span{color:var(--muted);font-size:10px;font-weight:950;text-transform:uppercase;letter-spacing:.04em}
    .seatStat b{font-size:16px}
    .seatMapWorkspace{display:grid;grid-template-columns:minmax(275px,1fr) minmax(230px,.76fr);gap:12px;align-items:start}
    .vehicleMap{border:1px solid var(--line2);background:var(--table);border-radius:22px;padding:14px;overflow:auto;min-height:310px}
    .vehicleDeck{display:grid;gap:8px;width:max-content;min-width:100%}
    .vehicleDeckHeader{height:34px;border-radius:999px;border:1px solid var(--line2);background:linear-gradient(135deg,rgba(79,140,255,.18),rgba(255,183,3,.12));display:grid;place-items:center;color:var(--muted);font-size:11px;font-weight:950;text-transform:uppercase}
    .seatMapRow{display:grid;gap:8px;align-items:center;justify-content:center}
    .seatCell,.seatSpacer{width:42px;aspect-ratio:1;border-radius:13px}
    .seatSpacer{border:1px dashed transparent}
    .seatAisle{width:18px;height:42px;display:grid;place-items:center;color:var(--muted);font-size:9px;font-weight:950;opacity:.55}
    .seatCell{border:1px solid var(--line2);display:grid;place-items:center;font-size:11px;font-weight:1000;color:var(--text);background:rgba(34,197,94,.16);cursor:pointer;box-shadow:none;transition:.14s ease}
    .seatCell:hover{transform:translateY(-1px);border-color:rgba(255,183,3,.4)}
    .seatCell.is-selected{outline:2px solid rgba(255,183,3,.72);outline-offset:2px}
    .seatCell.is-booked{background:rgba(79,140,255,.22);color:#a8c8ff}
    .seatCell.is-hold{background:rgba(255,183,3,.20);color:#ffd873}
    .seatCell.is-blocked{background:rgba(239,68,68,.16);color:#ffaaaa;text-decoration:line-through}
    .seatInfoPanel{border:1px solid var(--line2);background:var(--soft);border-radius:22px;padding:13px;display:grid;gap:10px;min-height:310px}
    .seatInfoTop{display:flex;justify-content:space-between;gap:8px;align-items:flex-start}
    .seatInfoTop h4{margin:0;font-size:15px}
    .seatInfoTop p{margin:3px 0 0;color:var(--muted);font-size:12px;font-weight:800}
    .seatInfoGrid{display:grid;gap:7px}
    .seatInfoGrid div{border:1px solid var(--line2);background:var(--field);border-radius:14px;padding:8px 10px;display:grid;gap:2px;min-width:0}
    .seatInfoGrid span{font-size:10px;color:var(--muted);font-weight:950;text-transform:uppercase;letter-spacing:.04em}
    .seatInfoGrid b{font-size:12px;overflow-wrap:anywhere}
    .roomMapGrid{display:grid;grid-template-columns:repeat(auto-fill,minmax(132px,1fr));gap:10px;min-width:100%}
    .roomCard{border:1px solid var(--line2);border-radius:18px;background:rgba(34,197,94,.13);padding:11px;text-align:left;color:var(--text);display:grid;gap:7px;cursor:pointer;transition:.14s ease;min-height:104px}
    .roomCard:hover{transform:translateY(-1px);border-color:rgba(255,183,3,.4)}
    .roomCard.is-selected{outline:2px solid rgba(255,183,3,.72);outline-offset:2px}
    .roomCard.is-hold{background:rgba(255,183,3,.18);color:#ffd873}
    .roomCard.is-booked,.roomCard.is-occupied{background:rgba(79,140,255,.20);color:#a8c8ff}
    .roomCard.is-checkedout{background:rgba(148,163,184,.16);color:var(--muted)}
    .roomCard.is-maintenance{background:rgba(239,68,68,.14);color:#ffaaaa}
    .roomCard.is-cancelled,.roomCard.is-refunded{background:rgba(244,114,182,.14);color:#ffc4df}
    .roomCard strong{font-size:14px}
    .roomCard span{font-size:10px;font-weight:950;color:var(--muted);text-transform:uppercase;letter-spacing:.04em}
    .roomCard small{font-size:11px;font-weight:900;line-height:1.4;color:inherit}
    .bookedGroupList{padding:0 16px 16px;display:grid;gap:10px}
    .bookedGroup{border:1px solid var(--line2);background:var(--soft);border-radius:20px;padding:12px;display:grid;gap:10px}
    .bookedGroupHead{display:flex;align-items:flex-start;justify-content:space-between;gap:10px;flex-wrap:wrap}
    .bookedGroupHead h4{margin:0;font-size:13px}
    .bookedGroupHead p{margin:3px 0 0;color:var(--muted);font-size:11px;font-weight:850}
    .bookedChips{display:flex;gap:7px;flex-wrap:wrap}
    .bookedChip{border:1px solid var(--line2);border-radius:999px;background:var(--field);padding:7px 9px;font-size:11px;font-weight:950;color:var(--muted)}
    .bookedItems{display:grid;grid-template-columns:repeat(auto-fill,minmax(170px,1fr));gap:8px}
    .bookedItem{border:1px solid var(--line2);background:var(--table);border-radius:16px;padding:9px;text-align:left;color:var(--text);display:grid;gap:4px;cursor:pointer}
    .bookedItem strong{font-size:12px}
    .bookedItem span{font-size:11px;color:var(--muted);font-weight:850;overflow-wrap:anywhere}
    [hidden]{display:none!important}

    .formPanel{padding:16px;display:grid;gap:12px}
    .formGrid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:10px}
    .field label{display:block;color:var(--muted);font-size:11px;font-weight:950;margin:0 0 6px}
    .control{min-height:45px;border-radius:22px;padding:10px 13px}
    .control textarea{resize:vertical;min-height:92px;padding:4px 0}
    .full{grid-column:1/-1}

    .notice{
      padding:13px;
      border-radius:22px;
      border:1px solid rgba(255,183,3,.22);
      background:rgba(255,183,3,.10);
      color:var(--text);
      font-size:12px;
      font-weight:850;
      line-height:1.55;
    }

    .scannerBox{border:1px solid var(--line2);border-radius:22px;background:var(--soft);padding:12px;display:none;gap:10px;margin:0 16px 12px}
    .scannerBox.is-open{display:grid}
    .qrPlaceholder{min-height:210px;border:1px dashed var(--line2);border-radius:18px;display:grid;place-items:center;text-align:center;color:var(--muted);font-size:12px;font-weight:900;line-height:1.5;padding:20px}
    .qrPlaceholder i{font-size:28px;color:var(--primary);display:block;margin-bottom:8px}
    .scanResult{margin:0 16px 12px;border:1px solid var(--line2);border-radius:20px;background:var(--soft);padding:13px;font-size:12px;font-weight:850;line-height:1.55;color:var(--text)}
    .scanResult.is-empty{color:var(--muted)}
    .scanResult.is-error{border-color:rgba(239,68,68,.38);background:rgba(239,68,68,.10)}
    .scanResult h4{margin:0 0 8px;font-size:14px}
    .scanResult .detailGrid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:8px;margin-top:10px}
    .scanResult .detailItem{padding:9px;border-radius:14px;background:var(--table);border:1px solid var(--line2);display:grid;gap:3px}
    .scanResult .detailItem span{color:var(--muted);font-size:10px;text-transform:uppercase;letter-spacing:0;font-weight:950}
    .scanActions{display:flex;gap:8px;flex-wrap:wrap;justify-content:flex-end;padding:0 16px 16px}

    .reportGrid{
      display:grid;
      grid-template-columns:repeat(3,minmax(0,1fr));
      gap:14px;
      padding:16px;
    }

    .reportCard{
      padding:16px;
      border-radius:24px;
      border:1px solid var(--line2);
      background:var(--soft);
      display:grid;
      gap:12px;
    }

    .reportCard h4{margin:0;font-size:15px}
    .reportCard p{margin:0;color:var(--muted);font-size:12px;font-weight:800;line-height:1.55}

    .modal{
      display:none;
      position:fixed;
      inset:0;
      z-index:160;
      background:rgba(0,0,0,.62);
      padding:18px;
      place-items:center;
    }

    .modal.is-open{display:grid}

    .modalCard{
      width:min(860px,96vw);
      max-height:92vh;
      overflow:auto;
      border:1px solid var(--line);
      border-radius:30px;
      background:linear-gradient(180deg,var(--panel),rgba(9,13,26,.96));
      box-shadow:var(--shadow);
      backdrop-filter:blur(18px);
      -webkit-backdrop-filter:blur(18px);
    }

    html[data-theme="light"] .modalCard{
      background:linear-gradient(180deg,rgba(255,255,255,.96),rgba(255,255,255,.90));
    }

    .modalHead{
      padding:16px;
      border-bottom:1px solid var(--line);
      display:flex;
      align-items:flex-start;
      justify-content:space-between;
      gap:12px;
    }

    .modalHead h3{margin:0;font-size:18px}
    .modalHead p{margin:5px 0 0;color:var(--muted);font-size:12px;font-weight:800}
    .modalBody{padding:16px}

    .detailBlock{display:grid;gap:12px}
    .detailGroup{border:1px solid var(--line2);background:var(--table);border-radius:20px;padding:12px;display:grid;gap:9px}
    .detailGroup h4{margin:0;font-size:12px;letter-spacing:.04em;text-transform:uppercase;color:var(--muted)}
    .detailGrid{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:8px}
    .detailItem{min-width:0;border:1px solid var(--line2);background:var(--soft);border-radius:14px;padding:8px 10px;display:grid;gap:3px}
    .detailItem span{font-size:10px;color:var(--muted);font-weight:950;text-transform:uppercase;letter-spacing:.05em}
    .detailItem b{font-size:12px;white-space:normal;overflow-wrap:anywhere}
    .modalActionBar{display:flex;gap:8px;flex-wrap:wrap;justify-content:flex-end;margin-top:14px;padding-top:12px;border-top:1px solid var(--line2)}
    .tableTools{display:flex;gap:9px;flex-wrap:wrap;padding:12px 16px 0;align-items:center}
    .tableTools .control{min-width:190px;flex:1 1 210px;max-width:320px;border-radius:16px;background:var(--input);border-color:var(--line)}
    .tableTools .control:focus-within,.searchBox:focus-within,.topSearch:focus-within{border-color:rgba(79,140,255,.58);background:rgba(79,140,255,.09);box-shadow:0 0 0 3px rgba(79,140,255,.12)!important}
    .tableTools button{min-height:45px}
    tbody tr[data-clickable-row="true"]{cursor:pointer}
    tbody tr[data-clickable-row="true"]:hover{background:rgba(79,140,255,.08)}
    .tinyBtn[disabled]{opacity:.48;cursor:not-allowed;filter:grayscale(.4)}
    @media(max-width:980px){.detailGrid{grid-template-columns:repeat(2,minmax(0,1fr))}}
    @media(max-width:760px){.detailGrid{grid-template-columns:1fr}.tableTools .control{max-width:none}}

    .deleteBox{
      display:grid;
      gap:12px;
      padding:16px;
      border-radius:24px;
      background:rgba(239,68,68,.10);
      border:1px solid rgba(239,68,68,.22);
    }

    .toast{
      position:fixed;
      right:18px;
      bottom:18px;
      z-index:200;
      display:none;
      border:1px solid var(--line);
      border-radius:22px;
      background:linear-gradient(180deg,var(--cardA),var(--cardB));
      box-shadow:var(--shadow);
      padding:12px 14px;
      font-weight:900;
      font-size:13px;
      backdrop-filter:blur(16px);
    }

    .toast.show{display:flex;gap:10px;align-items:center;animation:toastIn .2s ease both}
    @keyframes toastIn{from{opacity:0;transform:translateY(12px)}to{opacity:1;transform:translateY(0)}}

    @media (max-width:1180px){
      :root{--sidebar:252px}
      .heroGrid{grid-template-columns:1fr}
      .statsGrid,.grid4{grid-template-columns:repeat(2,minmax(0,1fr))}
      .grid2{grid-template-columns:1fr}
      .grid3,.reportGrid{grid-template-columns:1fr}
      .seatMapWorkspace{grid-template-columns:1fr}
      .pageTitle p{max-width:420px}
    }

    @media (max-width:760px){
      .app{
        width:min(100% - 22px,760px);
        grid-template-columns:1fr;
        padding:10px 0 20px;
      }

      .sideBackdrop{
        display:none;
        position:fixed;
        inset:0;
        background:rgba(0,0,0,.58);
        z-index:74;
      }

      body.menu-open .sideBackdrop{display:block}

      .sidebar{
        display:flex;
        position:fixed;
        left:50%;
        top:78px;
        transform:translateX(-50%) translateY(10px);
        width:min(420px,calc(100vw - 22px));
        height:min(76vh,680px);
        border-radius:30px;
        opacity:0;
        pointer-events:none;
        transition:.18s ease;
      }

      body.menu-open .sidebar{
        opacity:1;
        pointer-events:auto;
        transform:translateX(-50%) translateY(0);
      }

      .menuBtn{display:grid!important}
      .topbar{
        top:10px;
        border-radius:26px;
        min-height:62px;
        max-height:62px;
      }
      .pageTitle h1{font-size:16px}
      .pageTitle p{display:none}
      .topActions .hideMobile{display:none}
      .welcome h2{font-size:23px}
      .statsGrid{grid-template-columns:repeat(2,minmax(0,1fr))}
      .quickGrid{grid-template-columns:1fr 1fr}
      .formGrid{grid-template-columns:1fr}
      .seatMapToolbar,.seatMapStats{grid-template-columns:1fr}
      table{min-width:680px}
    }

    @media (max-width:560px){
      .app{width:min(100% - 18px,440px);padding-top:10px}
      .topbar{border-radius:24px;padding:9px}
      .pageTitle h1{font-size:15px}
      .iconBtn{width:39px;height:39px}
      .btn{height:39px;padding:0 12px}
      .topActions #btnNew span,.topActions #btnExport span{display:none}
      .hero{padding:12px;border-radius:25px}
      .welcome{padding:14px;min-height:auto;border-radius:22px}
      .welcome h2{font-size:21px}
      .welcome p{font-size:12px}
      .statsGrid{grid-template-columns:1fr 1fr;gap:9px}
      .statCard{padding:12px;border-radius:21px}
      .statNumber{font-size:20px}
      .statLabel{font-size:11px}
      .card{border-radius:24px}
      .cardHead{padding:14px 14px 0}
      .tableWrap{padding:10px 12px 14px}
      .quickGrid{grid-template-columns:1fr}
      .bars{height:150px;gap:6px}
      .modal{padding:10px}
      .modalCard{border-radius:25px}
      .toast{right:10px;left:10px;bottom:10px}
    }
  </style>
</head>

<body>
  <!-- Clean dashboard chrome dashboardShellSidebar transform:none !important padding:12px 0 20px 10px !important navLogout -->
  <div class="sideBackdrop" id="sideBackdrop"></div>

  <div class="app" id="appTop">
    <%- include('../../partials/dashboard-sidebar', { dashboardShell }) %>
    <aside class="sidebar legacyDashboardChrome" style="display:none !important" id="sidebar" aria-label="Partner company navigation">
      <div class="sideTop">
        <div class="mark">CT</div>
        <div class="brandText">
          <strong>Classic Trip</strong>
          <span>Partner Company Console</span>
        </div>
      </div>

      <div class="sideSearch">
        <label class="searchBox">
          <i class="fa-solid fa-magnifying-glass"></i>
          <input id="sideSearch" placeholder="Search menu..." />
        </label>
      </div>

      <nav class="sideNav" id="sideNav">
        <button class="navBtn is-active" data-page="overview"><i class="fa-solid fa-chart-line"></i><span>Overview</span></button>
        <button class="navBtn" data-page="listings"><i class="fa-solid fa-layer-group"></i><span>Listings & Inventory</span></button>
        <button class="navBtn" data-page="routes"><i class="fa-solid fa-route"></i><span>Routes</span></button>
        <button class="navBtn" data-page="vehicles"><i class="fa-solid fa-bus-simple"></i><span>Vehicles</span></button>
        <button class="navBtn" data-page="schedules"><i class="fa-solid fa-calendar-days"></i><span>Schedules & Availability</span></button>
        <button class="navBtn" data-page="bookings"><i class="fa-solid fa-ticket"></i><span>Bookings</span></button>
        <button class="navBtn" data-page="checkins"><i class="fa-solid fa-qrcode"></i><span>Check-ins</span></button>
        <button class="navBtn" data-page="seatrooms"><i class="fa-solid fa-chair"></i><span>Service Inventory</span></button>
        <button class="navBtn" data-page="staff"><i class="fa-solid fa-user-tie"></i><span>Staff & Roles</span></button>
        <button class="navBtn" data-page="payouts"><i class="fa-solid fa-wallet"></i><span>Payouts & Earnings</span></button>
        <button class="navBtn" data-page="billing"><i class="fa-solid fa-credit-card"></i><span>Plans & Billing</span></button>
        <button class="navBtn" data-page="promotions"><i class="fa-solid fa-rectangle-ad"></i><span>Promotions & Ads</span></button>
        <button class="navBtn" data-page="reviews"><i class="fa-solid fa-star"></i><span>Reviews</span></button>
        <button class="navBtn" data-page="support"><i class="fa-solid fa-headset"></i><span>Support Cases</span></button>
        <button class="navBtn" data-page="reports"><i class="fa-solid fa-file-lines"></i><span>Reports</span></button>
        <button class="navBtn" data-page="settings"><i class="fa-solid fa-gear"></i><span>Company Settings</span></button>
      </nav>

      <div class="sideFoot">
        <div class="miniProfile">
          <div class="avatar">CP</div>
          <div class="profileMeta">
            <strong>Company partner</strong>
            <span>Partner account</span>
          </div>
        </div>
      </div>
    </aside>

    <main class="main">
      <%- include('../../partials/dashboard-topbar', { dashboardShell }) %>
      <header class="topbar legacyDashboardChrome" style="display:none !important">
        <div class="topLeft">
          <button class="iconBtn menuBtn" id="openMenu" aria-label="Open menu"><i class="fa-solid fa-bars"></i></button>
          <div class="pageTitle">
            <h1 id="pageHeading">Company Workspace</h1>
            <p id="pageSub">Manage listings, schedules, inventory, bookings, staff, payouts, promotions, and support.</p>
          </div>
        </div>

        <div class="topActions">
          <button class="iconBtn" id="btnTheme" title="Toggle theme" aria-label="Toggle theme"><i class="fa-solid fa-moon" id="themeIcon"></i></button>
          <button class="btn hideMobile" id="btnExport"><i class="fa-solid fa-download"></i><span>Export</span></button>
          <button class="btn btnBlue" id="btnNew"><i class="fa-solid fa-plus"></i><span>Create</span></button>
          <button class="btn btnPrimary hideMobile"><i class="fa-solid fa-building-circle-check"></i> Verified</button>
        </div>
      </header>

      <div class="content" id="contentTop">
        <section class="section is-open" id="overview">
          <div class="hero">
            <div class="heroGrid">
              <div class="welcome">
                <div>
                  <span class="badge ok"><i class="fa-solid fa-circle-check"></i> Company account active</span>
                  <h2>Welcome back. Your dashboard is connected to live partner data.</h2>
                  <p>Control your bookings, trips, route schedules, seat inventory, staff permissions, payout balance, paid boosts, and customer support from one clean partner dashboard.</p>
                </div>
                <div class="heroActions">
                  <button class="btn btnPrimary" data-jump="listings"><i class="fa-solid fa-plus"></i> Add listing</button>
                  <button class="btn" data-jump="bookings"><i class="fa-solid fa-ticket"></i> View bookings</button>
                  <button class="btn" data-jump="payouts"><i class="fa-solid fa-wallet"></i> Payouts</button>
                </div>
              </div>

              <div class="livePanel">
                <div class="liveHeader">
                  <strong>Live status</strong>
                  <span class="badge ok"><span class="pulse"></span> Online</span>
                </div>
                <div class="liveList">
                  <div class="liveItem"><span>Bookings today</span><strong>184</strong></div>
                  <div class="liveItem"><span>Seats on hold</span><strong>27</strong></div>
                  <div class="liveItem"><span>Upcoming trips</span><strong>16</strong></div>
                  <div class="liveItem"><span>Open support cases</span><strong>5</strong></div>
                </div>
              </div>
            </div>

            <div class="statsGrid">
              <article class="statCard">
                <div class="statTop"><div class="statIcon"><i class="fa-solid fa-money-bill-trend-up"></i></div><span class="trend"><i class="fa-solid fa-arrow-trend-up"></i> 11%</span></div>
                <div class="statNumber">UGX 76.5M</div>
                <div class="statLabel">Partner earnings</div>
              </article>
              <article class="statCard">
                <div class="statTop"><div class="statIcon"><i class="fa-solid fa-ticket"></i></div><span class="trend"><i class="fa-solid fa-arrow-trend-up"></i> 8%</span></div>
                <div class="statNumber">2,482</div>
                <div class="statLabel">Confirmed bookings</div>
              </article>
              <article class="statCard">
                <div class="statTop"><div class="statIcon"><i class="fa-solid fa-chair"></i></div><span class="trend"><i class="fa-solid fa-arrow-trend-up"></i> 6%</span></div>
                <div class="statNumber">83%</div>
                <div class="statLabel">Average seat fill rate</div>
              </article>
              <article class="statCard">
                <div class="statTop"><div class="statIcon"><i class="fa-solid fa-star"></i></div><span class="trend"><i class="fa-solid fa-arrow-trend-up"></i> 4.8</span></div>
                <div class="statNumber">4.8/5</div>
                <div class="statLabel">Customer rating</div>
              </article>
            </div>
          </div>

          <div class="grid2">
            <div class="card">
              <div class="cardHead">
                <div class="cardTitle"><h3>Recent bookings</h3><p>Latest paid, held, and checked-in customer bookings.</p></div>
                <button class="btn" data-jump="bookings"><i class="fa-regular fa-eye"></i> View all</button>
              </div>
              <div class="tableWrap">
                <table>
                  <thead><tr><th>Booking</th><th>Trip</th><th>Customer</th><th>Seat</th><th>Status</th><th>Total</th><th></th></tr></thead>
                  <tbody id="recentBookings"></tbody>
                </table>
              </div>
            </div>

            <div class="card">
