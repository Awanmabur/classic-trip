          return `<div class="rowActions">
            <button class="tinyBtn" data-modal="view" data-type="${safeLabel}"${detailAttr} title="View full details"><i class="fa-regular fa-eye"></i></button>
            <button class="tinyBtn" data-modal="edit" data-type="${safeLabel}" data-entity="${escapeHtml(meta.entity)}" data-id="${safeId}" title="Edit"><i class="fa-regular fa-pen-to-square"></i></button>
            <button class="tinyBtn" data-export-row="${safeLabel}"${detailAttr} title="Export PDF"><i class="fa-solid fa-file-export"></i></button>
            <button class="tinyBtn danger" data-delete="${safeLabel}" data-delete-url="${archiveUrls[meta.entity]}" title="Archive"><i class="fa-regular fa-trash-can"></i></button>
