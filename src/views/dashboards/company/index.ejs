      function escapeHtml(value){
        return String(value ?? '').replace(/[&<>"']/g, ch => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[ch]));
      }

      function optionItems(items, emptyLabel){
        const source = Array.isArray(items) ? items : [];
        const mapped = source.map(item => ({
          value: item.value ?? item.id ?? item.slug ?? item.label ?? '',
          label: item.label ?? item.title ?? item.name ?? item.id ?? item.value ?? 'Option'
        }));
        return emptyLabel ? [{value:'', label: emptyLabel}, ...mapped] : mapped;
      }

      function firstValue(items){
        const first = (Array.isArray(items) ? items : [])[0];
        return first ? (first.value ?? first.id ?? first.slug ?? '') : '';
