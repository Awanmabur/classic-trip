      function actions(label, meta = null){
        const safeLabel = escapeHtml(label);
        const safeId = meta?.id ? encodeURIComponent(meta.id) : '';
        const detailAttr = meta?.detail ? ` data-row-detail="${escapeHtml(encodeDetail(meta.detail))}"` : '';
