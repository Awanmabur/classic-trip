              {name:'status', label:'Status', kind:'select', options:[{value:'active',label:'Active'},{value:'maintenance',label:'Maintenance'},{value:'paused',label:'Paused'}], value:'active'}
            ]
          };
        }
        if(key.includes('schedule') || key.includes('trip') || key.includes('departure')){
          return {
            action:'/company/schedules',
            fields:[
              {name:'routeId', label:'Route', kind:'select', required:true, options:routeOptions, value:firstValue(data.options.routes)},
              {name:'vehicleId', label:'Vehicle', kind:'select', required:true, options:vehicleOptions, value:firstValue(data.options.vehicles)},
              {name:'departAt', label:'Departure', type:'datetime-local', required:true},
              {name:'arriveAt', label:'Arrival', type:'datetime-local'},
              {name:'basePrice', label:'Base price', type:'number', placeholder:'85000'},
              {name:'currency', label:'Currency', kind:'select', options:currencyOptions, value:'UGX'},
              {name:'driverName', label:'Driver / captain', placeholder:'Assigned staff'},
              {name:'blockedSeats', label:'Blocked seats', placeholder:'A1,A2'},
              {name:'status', label:'Status', kind:'select', options:[{value:'active',label:'Active'},{value:'paused',label:'Paused'},{value:'delayed',label:'Delayed'}]}
            ]
          };
        }
        if(key.includes('seat')){
          return {
            action:'/company/seats/status',
            fields:[
              {name:'scheduleId', label:'Schedule', kind:'select', required:true, options:scheduleOptions, value:firstValue(data.options.schedules)},
              {name:'seatNumber', label:'Seat number', required:true, placeholder:'A1'},
              {name:'status', label:'Seat status', kind:'select', options:[{value:'available',label:'Available'},{value:'blocked',label:'Blocked'},{value:'locked',label:'Held'},{value:'taken',label:'Booked'}]},
              {name:'seatClass', label:'Seat class', placeholder:'Standard'},
              {name:'priceDelta', label:'Price delta', type:'number', placeholder:'0'}
            ]
          };
        }
        if(key.includes('inventory') || key.includes('room') || key.includes('vehicle')){
          return {
            action:'/company/rooms',
            fields:[
              {name:'listingId', label:'Hotel listing', kind:'select', required:true, options:hotelListingOptions, value:firstValue(data.options.hotelListings)},
              {name:'roomType', label:'Room type', required:true, placeholder:'Standard Room'},
              {name:'imageFile', label:'Room image', type:'file', accept:'image/*'},
              {name:'capacity', label:'Capacity', type:'number', value:'2'},
              {name:'nightlyPrice', label:'Nightly price', type:'number', placeholder:'180000'},
              {name:'inventory', label:'Room stock', type:'number', value:'1'},
              {name:'amenities', label:'Amenities', placeholder:'Wi-Fi, Breakfast, Parking'},
              {name:'status', label:'Status', kind:'select', options:[{value:'active',label:'Active'},{value:'paused',label:'Paused'}]}
            ]
          };
        }
        if(key.includes('staff')){
          return {
            action:'/company/employees/invite',
            fields:[
              {name:'fullName', label:'Full name', required:true, placeholder:'Grace N.'},
              {name:'email', label:'Email', type:'email', required:true, placeholder:'grace@example.com'},
              {name:'phone', label:'Phone', placeholder:'+256700000000'},
              {name:'roleTitle', label:'Role', kind:'select', options:[{value:'Booking Agent',label:'Booking Agent'},{value:'Ticket Checker',label:'Ticket Checker'},{value:'Finance',label:'Finance'},{value:'Route Manager',label:'Route Manager'}]},
              {name:'branch', label:'Branch', placeholder:'Kampala Gate'},
              {name:'permissions', label:'Permissions', placeholder:'check_in,view_bookings'}
            ]
          };
        }
        if(key.includes('promotion')){
          return {
            action:'/company/promotions',
            fields:[
              {name:'listingId', label:'Listing', kind:'select', required:true, options:listingOptions, value:firstValue(data.options.listings)},
              {name:'name', label:'Campaign name', required:true, placeholder:'Weekend route boost'},
              {name:'placement', label:'Placement', kind:'select', options:[{value:'search_top',label:'Search top'},{value:'homepage',label:'Homepage'},{value:'route_boost',label:'Route boost'}]},
              {name:'budget', label:'Budget', type:'number', placeholder:'50000'}
            ]
          };
        }
        return null;
      }

      function detailValue(meta, ...paths){
        const detail = meta?.detail || {};
        for(const path of paths){
          const value = String(path).split('.').reduce((acc, key) => (acc && typeof acc === 'object' ? acc[key] : undefined), detail);
          if(value !== undefined && value !== null && value !== '') return value;
        }
        return '';
      }

      function detailList(value){
        if(Array.isArray(value)) return value.join(', ');
        return value || '';
      }

      function toLocalDateTime(value){
        if(!value) return '';
        const date = new Date(value);
        if(Number.isNaN(date.getTime())) return '';
        const offset = date.getTimezoneOffset() * 60000;
        return new Date(date.getTime() - offset).toISOString().slice(0, 16);
      }

      function editConfigFor(meta, nice){
        if(!meta) return formConfigFor(nice);
        const routeOptions = optionItems(data.options.routes, 'Keep current route');
        const vehicleOptions = optionItems(data.options.vehicles, 'Keep current vehicle');
        if(meta.entity === 'listing'){
          return {
            action: `/company/listings/${encodeURIComponent(meta.id)}`,
            fields: [
              {name:'title', label:'Listing title', required:true, value: detailValue(meta, 'listing.title') || nice},
              {name:'imageFile', label:'Replace service image', type:'file', accept:'image/*'},
              {name:'from', label:'From / origin', value: detailValue(meta, 'service.from')},
              {name:'to', label:'To / destination', value: detailValue(meta, 'service.to')},
              {name:'city', label:'City / location', value: detailValue(meta, 'service.city')},
              {name:'address', label:'Address', value: detailValue(meta, 'service.address')},
              {name:'country', label:'Country', value: detailValue(meta, 'service.country', 'owner.country')},
              {name:'priceFrom', label:'Price from', type:'number', placeholder:'85000', value: detailValue(meta, 'inventory.basePrice')},
              {name:'currency', label:'Currency', value: detailValue(meta, 'inventory.currency', 'owner.currency')},
              {name:'status', label:'Status', kind:'select', value: detailValue(meta, 'listing.status'), options:[{value:'draft',label:'Draft'},{value:'active',label:'Active'},{value:'paused',label:'Paused'}]},
              {name:'sub', label:'Description', kind:'textarea', value: detailValue(meta, 'listing.sub', 'service.summary'), placeholder:'Short customer-facing summary'}
            ]
          };
        }
        if(meta.entity === 'route'){
          return {
            action: `/company/routes/${encodeURIComponent(meta.id)}`,
            fields: [
              {name:'origin', label:'Origin', value: detailValue(meta, 'route.origin')},
              {name:'destination', label:'Destination', value: detailValue(meta, 'route.destination')},
              {name:'boardingPoints', label:'Boarding points', value: detailList(detailValue(meta, 'route.boardingPoints')), placeholder:'Comma-separated stops'},
              {name:'dropoffPoints', label:'Dropoff points', value: detailList(detailValue(meta, 'route.dropoffPoints')), placeholder:'Comma-separated stops'},
              {name:'status', label:'Status', kind:'select', value: detailValue(meta, 'route.status'), options:[{value:'active',label:'Active'},{value:'paused',label:'Paused'},{value:'archived',label:'Archived'}]}
            ]
          };
        }
        if(meta.entity === 'schedule'){
          return {
            action: `/company/schedules/${encodeURIComponent(meta.id)}`,
            fields: [
              {name:'routeId', label:'Route', kind:'select', options:routeOptions, value: detailValue(meta, 'schedule.routeId')},
              {name:'vehicleId', label:'Vehicle', kind:'select', options:vehicleOptions, value: detailValue(meta, 'vehicle.id', 'schedule.vehicleId')},
              {name:'departAt', label:'Departure', type:'datetime-local', value: toLocalDateTime(detailValue(meta, 'schedule.departure'))},
              {name:'arriveAt', label:'Arrival', type:'datetime-local', value: toLocalDateTime(detailValue(meta, 'schedule.arrival'))},
              {name:'basePrice', label:'Base price', type:'number', placeholder:'85000', value: detailValue(meta, 'schedule.basePrice')},
              {name:'currency', label:'Currency', value: detailValue(meta, 'schedule.currency')},
              {name:'driverName', label:'Driver / captain', value: detailValue(meta, 'schedule.driverName'), placeholder:'Assigned staff'},
              {name:'status', label:'Status', kind:'select', value: detailValue(meta, 'schedule.status'), options:[{value:'active',label:'Active'},{value:'paused',label:'Paused'},{value:'delayed',label:'Delayed'},{value:'archived',label:'Archived'}]}
            ]
          };
        }
        if(meta.entity === 'vehicle'){
          return {
            action: `/company/vehicles/${encodeURIComponent(meta.id)}`,
            fields: [
              {name:'name', label:'Vehicle name', value: detailValue(meta, 'vehicle.name') || nice},
              {name:'imageFile', label:'Replace vehicle image', type:'file', accept:'image/*'},
              {name:'plateOrCode', label:'Plate / code', value: detailValue(meta, 'vehicle.plateOrCode'), placeholder:'UAX 000A'},
              {name:'layoutName', label:'Seat layout', kind:'select', value: detailValue(meta, 'vehicle.layoutName'), options:[{value:'2x2',label:'Bus 2 x 2'},{value:'2x1',label:'VIP 2 x 1'},{value:'2x3',label:'Coach 2 x 3'},{value:'sleeper',label:'Sleeper'},{value:'flight-3x3',label:'Flight 3 x 3'}]},
              {name:'rows', label:'Rows', type:'number', value: detailValue(meta, 'vehicle.rows'), placeholder:'12'},
              {name:'totalSeats', label:'Total seats', type:'number', value: detailValue(meta, 'vehicle.totalSeats')},
              {name:'amenities', label:'Amenities', value: detailList(detailValue(meta, 'vehicle.amenities')), placeholder:'USB charging, Reclining seats'},
              {name:'status', label:'Status', kind:'select', value: detailValue(meta, 'vehicle.status'), options:[{value:'active',label:'Active'},{value:'maintenance',label:'Maintenance'},{value:'paused',label:'Paused'},{value:'archived',label:'Archived'}]}
            ]
          };
        }
        if(meta.entity === 'room'){
          return {
            action: `/company/rooms/${encodeURIComponent(meta.id)}/inventory`,
            fields: [
              {name:'roomType', label:'Room type', value: detailValue(meta, 'room.roomType') || nice},
              {name:'imageFile', label:'Replace room image', type:'file', accept:'image/*'},
              {name:'capacity', label:'Capacity', type:'number', value: detailValue(meta, 'room.capacity'), placeholder:'2'},
              {name:'nightlyPrice', label:'Nightly price', type:'number', value: detailValue(meta, 'room.nightlyPrice'), placeholder:'180000'},
              {name:'inventory', label:'Room stock', type:'number', value: detailValue(meta, 'room.inventory'), placeholder:'1'},
              {name:'amenities', label:'Amenities', value: detailList(detailValue(meta, 'room.amenities')), placeholder:'Wi-Fi, Breakfast, Parking'},
              {name:'status', label:'Status', kind:'select', value: detailValue(meta, 'room.status'), options:[{value:'active',label:'Active'},{value:'paused',label:'Paused'},{value:'archived',label:'Archived'}]}
            ]
          };
        }
        if(meta.entity === 'support'){
          return {
            action: `/company/support/${encodeURIComponent(meta.id)}`,
            fields: [
              {name:'status', label:'Status', kind:'select', value: detailValue(meta, 'case.status'), options:[{value:'open',label:'Open'},{value:'waiting_finance',label:'Waiting finance'},{value:'resolved',label:'Resolved'},{value:'closed',label:'Closed'}]},
              {name:'priority', label:'Priority', kind:'select', value: detailValue(meta, 'case.priority'), options:[{value:'normal',label:'Normal'},{value:'high',label:'High'},{value:'urgent',label:'Urgent'}]},
              {name:'response', label:'Response', kind:'textarea', placeholder:'Write the customer or internal response'}
            ]
          };
        }
        if(meta.entity === 'review'){
          return {
            action: `/company/reviews/${encodeURIComponent(meta.id)}/reply`,
            fields: [
              {name:'reply', label:'Public reply', kind:'textarea', required:true, value: detailValue(meta, 'review.companyReply.message'), placeholder:'Thank the customer and explain the follow-up'},
              {name:'status', label:'Status', kind:'select', options:[{value:'replied',label:'Replied'},{value:'published',label:'Published'},{value:'hidden',label:'Hidden'}], value: detailValue(meta, 'review.status') || 'replied'}
            ]
          };
        }
        return formConfigFor(nice);
      }

      function openCrud(mode, type, meta = null){
        const nice = String(type || 'record');
        if(mode === 'create' && nice.toLowerCase().includes('manual booking')){ openBookingPreview(); return; }
        const title = mode === 'view' ? `View ${nice}` : mode === 'edit' ? `Edit ${nice}` : `Create ${nice}`;
        const config = mode === 'view' ? null : mode === 'edit' ? editConfigFor(meta, nice) : formConfigFor(nice);
        els.crudTitle.textContent = title;
        els.crudSub.textContent = mode === 'view' ? 'Preview this item before taking action.' : 'Fill the details below. This form follows the backend data model.';
        if(config){
          const formEnctype = config.fields.some(field => field.type === 'file') ? ' enctype="multipart/form-data"' : '';
          els.crudBody.innerHTML = `
            <form class="formPanel" method="POST" action="${config.action}"${formEnctype} data-dashboard-form>
              <input type="hidden" name="_csrf" value="${csrfToken}">
              <div class="formGrid">${config.fields.map(field => fieldHtml(field, false)).join('')}</div>
              <div style="display:flex;gap:8px;justify-content:flex-end;flex-wrap:wrap">
                <button class="btn" type="button" data-close-modal>Cancel</button>
                <button class="btn btnPrimary" type="submit"><i class="fa-solid fa-floppy-disk"></i> Save</button>
              </div>
            </form>
          `;
          els.crudModal.classList.add('is-open');
          bindConditionalForm($('[data-dashboard-form]', els.crudBody));
          return;
        }
        els.crudBody.innerHTML = `
          <form class="formPanel" data-dashboard-form>
            <div class="formGrid">
              <div class="field"><label>Name / title</label><div class="control"><i class="fa-solid fa-pen"></i><input value="${mode === 'create' ? '' : nice}" placeholder="Enter title" ${mode === 'view' ? 'readonly' : ''}></div></div>
              <div class="field"><label>Status</label><div class="control"><i class="fa-solid fa-toggle-on"></i><select ${mode === 'view' ? 'disabled' : ''}><option>Active</option><option>Pending</option><option>Review</option><option>Paused</option></select></div></div>
              <div class="field"><label>Category</label><div class="control"><i class="fa-solid fa-layer-group"></i><select ${mode === 'view' ? 'disabled' : ''}><option>Bus</option><option>Hotel</option><option>Flight</option><option>Train</option><option>Tour</option><option>Ferry</option><option>Car rental</option></select></div></div>
              <div class="field"><label>Amount / price</label><div class="control"><i class="fa-solid fa-coins"></i><input placeholder="UGX 85,000" ${mode === 'view' ? 'readonly' : ''}></div></div>
              <div class="field full"><label>Notes</label><div class="control"><textarea placeholder="Add internal notes..." ${mode === 'view' ? 'readonly' : ''}></textarea></div></div>
            </div>
            <div style="display:flex;gap:8px;justify-content:flex-end;flex-wrap:wrap">
              <button class="btn" type="button" data-close-modal>Cancel</button>
              ${mode === 'view' ? `<button class="btn btnBlue" type="button" data-close-modal>Done</button>` : `<button class="btn btnPrimary" type="submit"><i class="fa-solid fa-floppy-disk"></i> Save</button>`}
            </div>
          </form>
        `;
        els.crudModal.classList.add('is-open');
      }

      function closeModals(){
        $$('.modal').forEach(m => m.classList.remove('is-open'));
      }

      $('#sideNav').addEventListener('click', e => {
        const btn = e.target.closest('.navBtn');
        if(btn) openPage(btn.dataset.page);
      });

      $$('[data-jump]').forEach(btn => {
        btn.addEventListener('click', () => openPage(btn.dataset.jump));
      });

      document.addEventListener('click', e => {
        const tabBtn = e.target.closest('.tabBtn');
        if(tabBtn){
          const group = tabBtn.closest('[data-tabs]');
          const tab = tabBtn.dataset.tab;
          $$('.tabBtn', group).forEach(b => b.classList.toggle('is-on', b === tabBtn));
          $$('.tabPane', group).forEach(p => p.classList.toggle('is-on', p.dataset.pane === tab));
          requestAnimationFrame(() => {
            window.scrollTo({ top: 0, behavior: 'auto' });
          });
        }

        const exportRowBtn = e.target.closest('[data-export-row]');
        if(exportRowBtn){
          const detail = parseDetailFromElement(exportRowBtn) || { label: exportRowBtn.dataset.exportRow || '' };
          exportDetailPdf(detail, exportRowBtn.dataset.exportRow || exportRowBtn.dataset.label || 'company-row');
          showToast('PDF export opened');
          return;
        }

        const previewRow = e.target.closest('tr[data-clickable-row="true"]');
        if(previewRow && !e.target.closest('button,a,form,input,select,textarea,.rowActions')){
          const detail = parseDetailFromElement(previewRow);
          if(detail) openDetailModal(previewRow.dataset.rowLabel || 'record', detail);
          return;
        }

        const modalBtn = e.target.closest('[data-modal]');
        if(modalBtn){
          const detail = parseDetailFromElement(modalBtn);
          if(modalBtn.dataset.modal === 'view' && detail) {
            openDetailModal(modalBtn.dataset.type, detail);
          } else {
            const inferred = detail ? inferEntityFromDetail(detail) : null;
            const meta = modalBtn.dataset.entity ? { entity: modalBtn.dataset.entity, id: modalBtn.dataset.id, detail } : (inferred ? { ...inferred, detail } : null);
            openCrud(modalBtn.dataset.modal, modalBtn.dataset.type, meta);
          }
        }

        const delBtn = e.target.closest('[data-delete]');
        if(delBtn){
          pendingDeleteUrl = delBtn.dataset.deleteUrl || '';
          els.deleteText.textContent = `Are you sure you want to delete "${delBtn.dataset.delete}"?`;
          els.deleteModal.classList.add('is-open');
        }

        if(e.target.closest('[data-close-modal]')) closeModals();
      });

      document.addEventListener('submit', e => {
        if(e.target.matches('#companyScannerForm')){
          e.preventDefault();
          validateCompanyTicket(companyScanValue());
          return;
        }
        if(e.target.matches('[data-dashboard-form], #noticeForm, #settingsForm')){
          if(e.target.hasAttribute('action')){
            return;
          }
          e.preventDefault();
          closeModals();
          showToast('Saved successfully');
        }
      });

      function on(el, event, handler){
        if(el) el.addEventListener(event, handler);
      }

      on(els.confirmDelete, 'click', () => {
        if(pendingDeleteUrl){
          const form = document.createElement('form');
          form.method = 'POST';
          form.action = pendingDeleteUrl;
          form.innerHTML = `<input type="hidden" name="_csrf" value="${csrfToken}">`;
          document.body.appendChild(form);
          form.submit();
          return;
        }
        closeModals();
        showToast('Record deleted');
      });

      on(els.btnNew, 'click', () => openCrud('create', 'listing'));
      on(els.btnExport, 'click', () => showToast('Export started'));
      on(els.btnCompanyLookupTicket, 'click', () => lookupCompanyTicket(companyScanValue()));
      on(els.btnCompanyCheckIn, 'click', () => validateCompanyTicket(companyScanValue()));
      on(els.btnCompanyNoShow, 'click', () => markCompanyNoShow(companyScanValue()));
      on(els.btnCompanyOpenCamera, 'click', startCompanyCameraScanner);
      on(els.btnCompanyStopCamera, 'click', stopCompanyCameraScanner);
      on(els.btnCompanyQr, 'click', () => {
        const bookingRef = currentCompanyScan?.detail?.booking?.bookingRef || currentCompanyScan?.booking?.bookingRef || companyScanValue();
        if(!bookingRef){ showToast('Lookup a ticket first'); return; }
        window.open(`/company/bookings/${encodeURIComponent(bookingRef)}/qr.svg`, '_blank', 'noopener');
      });
      on(els.seatMapScheduleSelect, 'change', renderVisualSeatMap);
      on(els.roomMapTypeSelect, 'change', renderVisualRoomMap);
      on(els.companyCheckSearch, 'keydown', (event) => {
        if(event.key === 'Enter'){
          event.preventDefault();
          lookupCompanyTicket(companyScanValue());
        }
      });
      on(els.openMenu, 'click', () => document.body.classList.add('menu-open'));
      on(els.sideBackdrop, 'click', () => document.body.classList.remove('menu-open'));

      on(els.btnTheme, 'click', () => {
        const html = document.documentElement;
        const next = html.dataset.theme === 'dark' ? 'light' : 'dark';
        html.dataset.theme = next;
        if(els.themeIcon) els.themeIcon.className = next === 'dark' ? 'fa-solid fa-moon' : 'fa-solid fa-sun';
      });

      on(els.sideSearch, 'input', () => {
        const q = els.sideSearch.value.trim().toLowerCase();
        $$('.navBtn').forEach(btn => {
          const text = btn.textContent.toLowerCase();
          btn.style.display = text.includes(q) ? 'flex' : 'none';
        });
      });

      document.addEventListener('keydown', e => {
        if(e.key === 'Escape'){
          closeModals();
          document.body.classList.remove('menu-open');
        }
      });

      document.addEventListener('click', e => {
        const seatButton = e.target.closest('[data-seat-map-seat]');
        if(!seatButton) return;
        const map = (data.seatMaps || []).find(item => item.scheduleId === seatButton.dataset.seatMapSchedule);
        const seat = (map?.seats || []).find(item => String(item.seatNumber) === String(seatButton.dataset.seatMapSeat));
        if(!map || !seat) return;
        $$('[data-seat-map-seat]', els.visualSeatMap).forEach(button => button.classList.remove('is-selected'));
        seatButton.classList.add('is-selected');
        renderSeatMapDetail(seat, map);
        if(['booked','hold'].includes(seatStatusGroup(seat))) openDetailModal(`Seat ${seat.seatNumber || ''}`.trim(), seatBookingDetail(seat, map));
      });

      document.addEventListener('click', e => {
        const roomButton = e.target.closest('[data-room-map-unit]');
        if(!roomButton) return;
        const map = (data.roomVisualMaps || []).find(item => item.roomTypeId === roomButton.dataset.roomMapType);
        const room = (map?.rooms || []).find(item => String(item.roomUnitId) === String(roomButton.dataset.roomMapUnit));
        if(!map || !room) return;
        $$('[data-room-map-unit]', els.visualRoomMap).forEach(button => button.classList.remove('is-selected'));
        roomButton.classList.add('is-selected');
        renderRoomMapDetail(room, map);
        if(['booked','occupied','hold'].includes(roomStatusGroup(room))) openDetailModal(`Room ${room.unitNumber || ''}`.trim(), roomBookingDetail(room, map));
      });

      document.addEventListener('click', e => {
        const item = e.target.closest('[data-booked-kind]');
        if(!item) return;
        const kind = item.dataset.bookedKind;
        const groupIndex = Number(item.dataset.bookedGroup || 0);
        const itemIndex = Number(item.dataset.bookedIndex || 0);
        if(kind === 'seat'){
          const group = data.bookedSeatGroups[groupIndex] || {};
          const seat = (group.seats || [])[itemIndex] || {};
          openDetailModal(`Seat ${seat.seatNumber || ''}`.trim(), seatBookingDetail(seat, group));
        } else {
          const group = data.bookedRoomGroups[groupIndex] || {};
          const room = (group.rooms || [])[itemIndex] || {};
          openDetailModal(`Room ${room.unitNumber || ''}`.trim(), roomBookingDetail(room, group));
        }
      });

      function initialPageFromLocation(){
        const hash = String(location.hash || '').replace('#', '');
        if(pageMeta[hash] && visiblePages.has(hash)) return hash;
        const leaf = location.pathname.split('/').filter(Boolean).pop() || 'dashboard';
        const map = { dashboard:'overview', rooms:'seatrooms', employees:'staff' };
        const page = map[leaf] || leaf;
        return pageMeta[page] && visiblePages.has(page) ? page : 'overview';
      }

      applyServiceProfile();
      renderAll();
      enhanceTables();
      openPage(initialPageFromLocation());
      const scanMessage = new URLSearchParams(location.search).get('message');
      if(scanMessage) showToast(scanMessage);
    });
  </script>
</body>
</html>
