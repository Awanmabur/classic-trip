      async function startCompanyCameraScanner(){
        if(!els.companyScannerBox) return;
        els.companyScannerBox.classList.add('is-open');
        if(els.companyScannerStatus) els.companyScannerStatus.innerHTML = '<i class="fa-solid fa-camera"></i> Requesting camera permission';
        if(els.companyQrReader) els.companyQrReader.innerHTML = '<div class="qrPlaceholder"><i class="fa-solid fa-spinner fa-spin"></i><span>Opening camera...</span></div>';
        if(!window.isSecureContext && !['localhost','127.0.0.1'].includes(location.hostname)){
          if(els.companyScannerStatus) els.companyScannerStatus.innerHTML = '<i class="fa-solid fa-lock"></i> Camera needs HTTPS';
          showToast('Camera access requires HTTPS or localhost. Manual lookup still works.');
          return;
        }
        try{
          await stopCompanyCameraScanner(false);
          if(!window.ClassicTripQrScanner) throw new Error('Local QR scanner script did not load');
          companyCameraStream = await window.ClassicTripQrScanner.start('companyQrReader', {
            onStatus(message){ if(els.companyScannerStatus) els.companyScannerStatus.innerHTML = `<i class="fa-solid fa-camera"></i> ${escapeHtml(message)}`; },
            onDecode(decodedText){
              if(decodedText && decodedText !== lastCompanyScanValue){
                lastCompanyScanValue = decodedText;
                if(els.companyCheckSearch) els.companyCheckSearch.value = decodedText;
                if(els.companyScannerStatus) els.companyScannerStatus.innerHTML = '<i class="fa-solid fa-circle-check"></i> QR scanned';
                lookupCompanyTicket(decodedText);
              }
            }
          });
          if(els.companyScannerStatus) els.companyScannerStatus.innerHTML = '<i class="fa-solid fa-camera"></i> Camera open and scanning';
        } catch(error){
          if(els.companyScannerStatus) els.companyScannerStatus.innerHTML = '<i class="fa-solid fa-triangle-exclamation"></i> Camera unavailable';
          if(els.companyQrReader) els.companyQrReader.innerHTML = '<div class="qrPlaceholder"><i class="fa-solid fa-triangle-exclamation"></i><span>Camera could not start. Check permission, HTTPS/localhost, and whether another app is using the camera.</span></div>';
          showToast(error?.message || 'Camera scanner could not start');
        }
      }

      async function stopCompanyCameraScanner(closeBox = true){
        try{
          if(window.ClassicTripQrScanner) await window.ClassicTripQrScanner.stop();
        } catch(error){/* ignore stop errors */}
        if(companyCameraStream && companyCameraStream.getTracks) companyCameraStream.getTracks().forEach(track => track.stop());
        companyCameraStream = null;
        if(els.companyQrReader) els.companyQrReader.innerHTML = '<div class="qrPlaceholder"><i class="fa-solid fa-camera"></i><span>Press Open QR scanner to start the camera.</span></div>';
        if(els.companyScannerStatus) els.companyScannerStatus.innerHTML = '<i class="fa-solid fa-circle-info"></i> Camera closed';
        if(closeBox && els.companyScannerBox) els.companyScannerBox.classList.remove('is-open');
      }

      function fieldHtml(field, readonly){
        const valueAttr = typeof field.value !== 'undefined' ? ` value="${escapeHtml(field.value)}"` : '';
        const attrs = `${field.name ? ` name="${escapeHtml(field.name)}"` : ''}${field.placeholder ? ` placeholder="${escapeHtml(field.placeholder)}"` : ''}${valueAttr}${field.required ? ' required' : ''}${readonly ? ' readonly' : ''}`;
        const fieldClass = `field${field.full ? ' full' : ''}`;
        const showFor = field.showFor ? ` data-show-for="${escapeHtml([].concat(field.showFor).join(','))}"` : '';
        const dataRequired = field.required ? ' data-required="true"' : '';
        if(field.kind === 'select'){
          const selected = typeof field.value !== 'undefined' ? String(field.value) : '';
          const options = Array.isArray(field.options) ? field.options : [];
          return `<div class="${fieldClass}"${showFor}><label>${escapeHtml(field.label)}</label><div class="control"><i class="${escapeHtml(field.icon || 'fa-solid fa-list')}"></i><select name="${escapeHtml(field.name)}"${dataRequired} ${field.required ? 'required' : ''} ${readonly ? 'disabled' : ''}>${options.map(option => {
            const value = String(option.value ?? '');
            return `<option value="${escapeHtml(value)}"${value === selected ? ' selected' : ''}>${escapeHtml(option.label)}</option>`;
          }).join('')}</select></div></div>`;
        }
        if(field.kind === 'textarea'){
          return `<div class="field full"${showFor}><label>${escapeHtml(field.label)}</label><div class="control"><textarea${attrs}${dataRequired}>${escapeHtml(field.text || field.value || '')}</textarea></div></div>`;
        }
        if(field.type === 'file'){
          const accept = field.accept ? ` accept="${escapeHtml(field.accept)}"` : '';
          return `<div class="${fieldClass}"${showFor}><label>${escapeHtml(field.label)}</label><div class="control"><i class="${escapeHtml(field.icon || 'fa-solid fa-cloud-arrow-up')}"></i><input type="file"${field.name ? ` name="${escapeHtml(field.name)}"` : ''}${accept}${field.required ? ' required' : ''}${dataRequired}></div></div>`;
        }
        return `<div class="${fieldClass}"${showFor}><label>${escapeHtml(field.label)}</label><div class="control"><i class="${escapeHtml(field.icon || 'fa-solid fa-pen')}"></i><input type="${escapeHtml(field.type || 'text')}"${attrs}${dataRequired}></div></div>`;
      }

      function updateConditionalFields(form){
        const service = form.querySelector('[name="serviceType"]')?.value || '';
        $$('[data-show-for]', form).forEach(field => {
          const allowed = String(field.dataset.showFor || '').split(',').map(item => item.trim()).filter(Boolean);
          const isVisible = !allowed.length || allowed.includes(service);
          field.hidden = !isVisible;
          $$('input, select, textarea', field).forEach(input => {
            input.disabled = !isVisible;
            if(input.dataset.required === 'true') input.required = isVisible;
          });
        });
      }

      function bindConditionalForm(form){
        if(!form) return;
        updateConditionalFields(form);
        const serviceSelect = form.querySelector('[name="serviceType"]');
        if(serviceSelect) serviceSelect.addEventListener('change', () => updateConditionalFields(form));
      }

