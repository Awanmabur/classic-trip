              <div class="tabPane" data-pane="tomorrow"><div class="tableWrap"><table><thead><tr><th>Schedule</th><th>Route</th><th>Time</th><th>Vehicle</th><th>Booked</th><th>Status</th><th></th></tr></thead><tbody data-filter-table="schedules" data-filter="Tomorrow"></tbody></table></div></div>
              <div class="tabPane" data-pane="week"><div class="tableWrap"><table><thead><tr><th>Schedule</th><th>Route</th><th>Time</th><th>Vehicle</th><th>Booked</th><th>Status</th><th></th></tr></thead><tbody data-filter-table="schedules" data-filter="Week"></tbody></table></div></div>
              <div class="tabPane" data-pane="delayed"><div class="tableWrap"><table><thead><tr><th>Schedule</th><th>Route</th><th>Time</th><th>Vehicle</th><th>Booked</th><th>Status</th><th></th></tr></thead><tbody data-filter-table="schedules-status" data-filter="Delayed"></tbody></table></div></div>
            </div>

            <div class="card">
              <div class="cardHead"><div class="cardTitle"><h3>Operational quality</h3><p>Signals customers care about most.</p></div></div>
              <div class="splitGrid">
                <div class="splitItem"><div class="splitTop"><span>On-time departure</span><strong>91%</strong></div><div class="progress"><i style="width:91%"></i></div></div>
                <div class="splitItem"><div class="splitTop"><span>Ticket check-in success</span><strong>98%</strong></div><div class="progress"><i style="width:98%"></i></div></div>
                <div class="splitItem"><div class="splitTop"><span>Seat map accuracy</span><strong>94%</strong></div><div class="progress"><i style="width:94%"></i></div></div>
                <div class="notice">Keep departure times accurate. Delays, vehicle changes, or seat blocks should be updated before customers arrive.</div>
              </div>
            </div>
          </div>
        </section>

        <section class="section" id="bookings">
          <div class="card" data-tabs>
            <div class="cardHead">
              <div class="cardTitle"><h3>Bookings</h3><p>Monitor confirmed bookings, held seats, check-ins, cancellations, and customer tickets.</p></div>
              <button class="btn btnBlue" data-modal="create" data-type="manual booking"><i class="fa-solid fa-plus"></i> Manual booking</button>
            </div>
            <div class="tabs">
              <button class="tabBtn is-on" data-tab="all">All</button>
              <button class="tabBtn" data-tab="paid">Paid</button>
              <button class="tabBtn" data-tab="hold">On hold</button>
              <button class="tabBtn" data-tab="checked">Checked in</button>
              <button class="tabBtn" data-tab="cancelled">Cancelled</button>
              <button class="tabBtn" data-tab="refund">Refund</button>
            </div>
            <div class="tabPane is-on" data-pane="all"><div class="tableWrap"><table><thead><tr><th>Booking</th><th>Trip</th><th>Customer</th><th>Seat / room</th><th>Date</th><th>Status</th><th>Amount</th><th></th></tr></thead><tbody id="bookingsTable"></tbody></table></div></div>
            <div class="tabPane" data-pane="paid"><div class="tableWrap"><table><thead><tr><th>Booking</th><th>Trip</th><th>Customer</th><th>Seat / room</th><th>Date</th><th>Status</th><th>Amount</th><th></th></tr></thead><tbody data-filter-table="bookings-status" data-filter="Paid"></tbody></table></div></div>
            <div class="tabPane" data-pane="hold"><div class="tableWrap"><table><thead><tr><th>Booking</th><th>Trip</th><th>Customer</th><th>Seat / room</th><th>Date</th><th>Status</th><th>Amount</th><th></th></tr></thead><tbody data-filter-table="bookings-status" data-filter="Hold"></tbody></table></div></div>
            <div class="tabPane" data-pane="checked"><div class="tableWrap"><table><thead><tr><th>Booking</th><th>Trip</th><th>Customer</th><th>Seat / room</th><th>Date</th><th>Status</th><th>Amount</th><th></th></tr></thead><tbody data-filter-table="bookings-status" data-filter="Checked in"></tbody></table></div></div>
            <div class="tabPane" data-pane="cancelled"><div class="tableWrap"><table><thead><tr><th>Booking</th><th>Trip</th><th>Customer</th><th>Seat / room</th><th>Date</th><th>Status</th><th>Amount</th><th></th></tr></thead><tbody data-filter-table="bookings-status" data-filter="Cancelled"></tbody></table></div></div>
            <div class="tabPane" data-pane="refund"><div class="tableWrap"><table><thead><tr><th>Booking</th><th>Trip</th><th>Customer</th><th>Seat / room</th><th>Date</th><th>Status</th><th>Amount</th><th></th></tr></thead><tbody data-filter-table="bookings-status" data-filter="Refund"></tbody></table></div></div>
          </div>
        </section>

        <section class="section" id="checkins">
          <div class="grid2">
            <div class="card">
              <div class="cardHead">
                <div class="cardTitle"><h3>Ticket check-ins</h3><p>Validate bookings at boarding, hotel reception, tour start, or counter service handoff.</p></div>
                <button class="btn btnPrimary" data-modal="create" data-type="check-in"><i class="fa-solid fa-qrcode"></i> Check in ticket</button>
              </div>
              <div class="tableWrap">
                <table>
                  <thead><tr><th>Booking</th><th>Customer</th><th>Service</th><th>Seat / room</th><th>Checked at</th><th>Status</th><th></th></tr></thead>
                  <tbody id="checkinsTable"></tbody>
                </table>
              </div>
            </div>
            <div class="card">
              <div class="cardHead"><div class="cardTitle"><h3>Manual scanner</h3><p>Enter the booking reference printed on the customer ticket.</p></div></div>
              <form class="formPanel" method="POST" action="/company/checkins">
                <input type="hidden" name="_csrf" value="<%= csrfToken || '' %>">
                <div class="formGrid">
                  <div class="field full"><label>Booking reference</label><div class="control"><i class="fa-solid fa-barcode"></i><input name="bookingRef" placeholder="CT-BUS-0001" required></div></div>
                  <div class="field full"><label>Counter note</label><div class="control"><textarea name="note" placeholder="Optional staff note for the check-in log"></textarea></div></div>
                </div>
                <button class="btn btnPrimary" type="submit"><i class="fa-solid fa-circle-check"></i> Validate and check in</button>
              </form>
              <div class="splitGrid">
                <div class="splitItem"><div class="splitTop"><span>Checked in</span><strong id="checkedInCount">0</strong></div><div class="progress"><i style="width:0%"></i></div></div>
                <div class="splitItem"><div class="splitTop"><span>Pending arrivals</span><strong id="pendingCheckinCount">0</strong></div><div class="progress"><i style="width:0%"></i></div></div>
              </div>
            </div>
          </div>
        </section>

        <section class="section" id="seatrooms">
          <div class="grid2">
            <div class="card">
              <div class="cardHead">
                <div class="cardTitle"><h3>Seats / rooms inventory</h3><p>Control vehicle seats, hotel rooms, cabins, slots, and blocked inventory.</p></div>
                <button class="btn btnPrimary" data-modal="edit" data-type="seat map"><i class="fa-solid fa-pen"></i> Edit map</button>
              </div>
              <div class="tableWrap">
                <table>
                  <thead><tr><th>Inventory</th><th>Linked listing</th><th>Total</th><th>Booked</th><th>Held</th><th>Blocked</th><th>Status</th><th></th></tr></thead>
                  <tbody id="inventoryTable"></tbody>
                </table>
              </div>
            </div>
            <div class="card">
              <div class="cardHead"><div class="cardTitle"><h3>Seat layout health</h3><p>Useful for buses, trains, flights, ferries, and rooms.</p></div></div>
              <div class="splitGrid">
                <div class="splitItem"><div class="splitTop"><span>Executive coach A</span><strong>44 / 49</strong></div><div class="progress"><i style="width:90%"></i></div></div>
                <div class="splitItem"><div class="splitTop"><span>Standard coach B</span><strong>31 / 49</strong></div><div class="progress"><i style="width:63%"></i></div></div>
                <div class="splitItem"><div class="splitTop"><span>VIP coach C</span><strong>20 / 32</strong></div><div class="progress"><i style="width:62%"></i></div></div>
                <button class="btn btnBlue" data-modal="create" data-type="room"><i class="fa-solid fa-plus"></i> Add room group</button>
              </div>
            </div>
          </div>
        </section>

        <section class="section" id="staff">
          <div class="card" data-tabs>
            <div class="cardHead">
              <div class="cardTitle"><h3>Staff & roles</h3><p>Add employees and limit what each person can do inside the company dashboard.</p></div>
              <button class="btn btnBlue" data-modal="create" data-type="staff member"><i class="fa-solid fa-user-plus"></i> Add staff</button>
            </div>
            <div class="tabs">
              <button class="tabBtn is-on" data-tab="all">All staff</button>
              <button class="tabBtn" data-tab="agents">Booking agents</button>
              <button class="tabBtn" data-tab="checkers">Ticket checkers</button>
              <button class="tabBtn" data-tab="finance">Finance</button>
              <button class="tabBtn" data-tab="managers">Managers</button>
            </div>
            <div class="tabPane is-on" data-pane="all"><div class="tableWrap"><table><thead><tr><th>Staff</th><th>Role</th><th>Branch</th><th>Permissions</th><th>Last login</th><th>Status</th><th></th></tr></thead><tbody id="staffTable"></tbody></table></div></div>
            <div class="tabPane" data-pane="agents"><div class="tableWrap"><table><thead><tr><th>Staff</th><th>Role</th><th>Branch</th><th>Permissions</th><th>Last login</th><th>Status</th><th></th></tr></thead><tbody data-filter-table="staff-role" data-filter="Booking Agent"></tbody></table></div></div>
            <div class="tabPane" data-pane="checkers"><div class="tableWrap"><table><thead><tr><th>Staff</th><th>Role</th><th>Branch</th><th>Permissions</th><th>Last login</th><th>Status</th><th></th></tr></thead><tbody data-filter-table="staff-role" data-filter="Ticket Checker"></tbody></table></div></div>
            <div class="tabPane" data-pane="finance"><div class="tableWrap"><table><thead><tr><th>Staff</th><th>Role</th><th>Branch</th><th>Permissions</th><th>Last login</th><th>Status</th><th></th></tr></thead><tbody data-filter-table="staff-role" data-filter="Finance"></tbody></table></div></div>
            <div class="tabPane" data-pane="managers"><div class="tableWrap"><table><thead><tr><th>Staff</th><th>Role</th><th>Branch</th><th>Permissions</th><th>Last login</th><th>Status</th><th></th></tr></thead><tbody data-filter-table="staff-role" data-filter="Route Manager"></tbody></table></div></div>
          </div>
        </section>

        <section class="section" id="payouts">
          <div class="grid2">
            <div class="card">
              <div class="cardHead">
                <div class="cardTitle"><h3>Payouts & earnings</h3><p>Track settlement balance after platform fees and promoter commissions.</p></div>
                <button class="btn btnPrimary" data-modal="create" data-type="withdrawal request"><i class="fa-solid fa-money-bill-transfer"></i> Request payout</button>
              </div>
              <div class="tableWrap">
                <table>
                  <thead><tr><th>Transaction</th><th>Booking</th><th>Customer paid</th><th>Company earning</th><th>Platform fee</th><th>Promoter</th><th>Status</th><th></th></tr></thead>
                  <tbody id="payoutsTable"></tbody>
                </table>
              </div>
            </div>

            <div class="card">
              <div class="cardHead"><div class="cardTitle"><h3>Settlement summary</h3><p>Current company earning rules.</p></div></div>
              <div class="splitGrid">
                <div class="splitItem"><div class="splitTop"><span>Company payout share</span><strong>90%</strong></div><div class="progress"><i style="width:90%"></i></div></div>
                <div class="splitItem"><div class="splitTop"><span>Platform fee</span><strong>7%</strong></div><div class="progress"><i style="width:7%"></i></div></div>
                <div class="splitItem"><div class="splitTop"><span>Promoter commission</span><strong>3%</strong></div><div class="progress"><i style="width:3%"></i></div></div>
                <div class="notice">If there is no promoter referral, the platform can keep the extra 3%, depending on the final finance rule you choose.</div>
              </div>
            </div>
          </div>
        </section>

        <section class="section" id="promotions">
          <div class="grid2">
            <div class="card">
              <div class="cardHead">
                <div class="cardTitle"><h3>Promotions & ads</h3><p>Pay to boost routes, hotels, flights, cars, tours, and more in search results.</p></div>
                <button class="btn btnBlue" data-modal="create" data-type="promotion campaign"><i class="fa-solid fa-plus"></i> New campaign</button>
              </div>
              <div class="tableWrap">
                <table>
                  <thead><tr><th>Campaign</th><th>Listing</th><th>Placement</th><th>Budget</th><th>Clicks</th><th>Bookings</th><th>Status</th><th></th></tr></thead>
                  <tbody id="promotionsTable"></tbody>
                </table>
              </div>
            </div>
            <div class="card">
              <div class="cardHead"><div class="cardTitle"><h3>Promotion performance</h3><p>Bookings generated from paid visibility.</p></div></div>
              <div class="chart"><div class="bars" id="promoBars"></div></div>
            </div>
          </div>
        </section>

        <section class="section" id="reviews">
          <div class="card">
            <div class="cardHead">
              <div class="cardTitle"><h3>Customer reviews</h3><p>Read customer feedback and reply to public reviews.</p></div>
              <span class="badge ok"><i class="fa-solid fa-star"></i> 4.8 average</span>
            </div>
            <div class="tableWrap">
              <table>
                <thead><tr><th>Customer</th><th>Service</th><th>Rating</th><th>Review</th><th>Date</th><th>Status</th><th></th></tr></thead>
                <tbody id="reviewsTable"></tbody>
              </table>
            </div>
          </div>
        </section>

        <section class="section" id="support">
          <div class="grid2">
            <div class="card">
              <div class="cardHead">
                <div class="cardTitle"><h3>Support cases</h3><p>Handle customer complaints, refunds, missed tickets, delays, and staff issues.</p></div>
                <span class="badge bad"><i class="fa-solid fa-triangle-exclamation"></i> 5 open</span>
              </div>
              <div class="tableWrap">
                <table>
                  <thead><tr><th>Case</th><th>Customer</th><th>Issue</th><th>Priority</th><th>Status</th><th>Opened</th><th></th></tr></thead>
                  <tbody id="supportTable"></tbody>
                </table>
              </div>
            </div>
            <div class="card">
              <div class="cardHead"><div class="cardTitle"><h3>Send customer notice</h3><p>Notify passengers about trip changes or delays.</p></div></div>
              <form class="formPanel" id="noticeForm" method="POST" action="/company/support/notices">
                <input type="hidden" name="_csrf" value="<%= csrfToken || '' %>">
                <div class="formGrid">
                  <div class="field"><label>Audience</label><div class="control"><i class="fa-solid fa-users"></i><select name="audience"><option>Customers on selected trip</option><option>All customers today</option><option>Staff only</option></select></div></div>
                  <div class="field"><label>Priority</label><div class="control"><i class="fa-solid fa-flag"></i><select name="priority"><option>Normal</option><option>High</option><option>Urgent</option></select></div></div>
                  <div class="field full"><label>Message</label><div class="control"><textarea name="message" placeholder="Write notice message..." required></textarea></div></div>
                </div>
                <button class="btn btnPrimary" type="submit"><i class="fa-solid fa-paper-plane"></i> Send notice</button>
              </form>
            </div>
          </div>
        </section>

        <section class="section" id="reports">
          <div class="card">
            <div class="cardHead">
              <div class="cardTitle"><h3>Reports</h3><p>Download clean company reports for finance, bookings, schedules, staff, promotions, and support.</p></div>
              <button class="btn btnBlue" data-modal="create" data-type="custom report"><i class="fa-solid fa-file-circle-plus"></i> Custom report</button>
            </div>
            <div class="reportGrid">
              <article class="reportCard"><span class="badge ok">Ready</span><h4>Bookings report</h4><p>Paid, held, checked-in, cancelled, refunded, and manually created bookings.</p><a class="btn btnBlue" href="/company/reports/bookings.csv"><i class="fa-solid fa-download"></i> Download</a></article>
              <article class="reportCard"><span class="badge info">Ready</span><h4>Finance report</h4><p>Company earnings, platform fees, promoter commission, payout balance, and refunds.</p><a class="btn btnBlue" href="/company/reports/payouts.csv"><i class="fa-solid fa-download"></i> Download</a></article>
              <article class="reportCard"><span class="badge warn">Ready</span><h4>Schedule report</h4><p>Departures, delays, route performance, trip fill rate, and vehicle usage.</p><a class="btn btnBlue" href="/company/reports/schedules.csv"><i class="fa-solid fa-download"></i> Download</a></article>
              <article class="reportCard"><span class="badge ok">Ready</span><h4>Inventory report</h4><p>Seats, rooms, blocked inventory, held items, no-stock items, and sold-out dates.</p><a class="btn btnBlue" href="/company/reports/inventory.csv"><i class="fa-solid fa-download"></i> Download</a></article>
              <article class="reportCard"><span class="badge info">Ready</span><h4>Staff report</h4><p>Employee activity, check-ins, manual bookings, refunds, and permission usage.</p><a class="btn btnBlue" href="/company/reports/staff.csv"><i class="fa-solid fa-download"></i> Download</a></article>
              <article class="reportCard"><span class="badge bad">Ready</span><h4>Support report</h4><p>Open cases, customer complaints, delays, refund reasons, and SLA tracking.</p><a class="btn btnBlue" href="/company/reports/support.csv"><i class="fa-solid fa-download"></i> Download</a></article>
            </div>
          </div>
        </section>

        <section class="section" id="billing">
          <% const billingSummary = dashboardData.billing || { plans: [], orders: [] }; const activeSub = billingSummary.subscription || null; const pendingOrder = billingSummary.pendingOrder || null; %>
          <div class="grid2">
            <div class="card">
              <div class="cardHead"><div class="cardTitle"><h3>Plan status</h3><p>Current subscription, billing period, and pending upgrade orders.</p></div></div>
              <div class="cardPad">
                <% if (activeSub) { %>
                  <div class="splitGrid">
                    <div class="splitItem"><div class="splitTop"><span>Current plan</span><strong><%= activeSub.planName %></strong></div></div>
                    <div class="splitItem"><div class="splitTop"><span>Status</span><span class="badge ok"><%= activeSub.status %></span></div></div>
                    <div class="splitItem"><div class="splitTop"><span>Period end</span><strong><%= new Date(activeSub.currentPeriodEnd).toLocaleDateString() %></strong></div></div>
                    <div class="splitItem"><div class="splitTop"><span>Order ref</span><strong><%= activeSub.orderRef %></strong></div></div>
                  </div>
                <% } else { %>
                  <div class="deleteBox">
                    <span class="badge info"><i class="fa-solid fa-clock"></i> No active plan</span>
                    <strong>Select a plan to activate billing for this company.</strong>
                    <p style="margin:0;color:var(--muted);font-size:12px;font-weight:800;line-height:1.55">The checkout page will collect payment and activate the plan automatically for mock payments, or after webhook confirmation for external providers.</p>
                  </div>
                <% } %>
                <% if (pendingOrder) { %>
                  <div class="notice" style="margin-top:12px">Pending order <%= pendingOrder.orderRef %> for <%= pendingOrder.planName %>. <a href="/billing/checkout/<%= pendingOrder.orderRef %>">Continue payment</a></div>
                <% } %>
                <div style="display:flex;gap:10px;flex-wrap:wrap;margin-top:12px">
                  <a class="btn btnBlue" href="/company/billing"><i class="fa-solid fa-arrow-up-right-from-square"></i> Full billing page</a>
                  <a class="btn" href="/pricing"><i class="fa-solid fa-table-list"></i> Public plan page</a>
                </div>
              </div>
            </div>
            <div class="card">
              <div class="cardHead"><div class="cardTitle"><h3>Upgrade plan</h3><p>Select a plan and continue to secure payment.</p></div></div>
              <div class="cardPad">
                <div class="quickGrid">
                  <% (billingSummary.plans || []).forEach(plan => { const active = activeSub && activeSub.planId === plan.id; %>
                    <form class="quickCard" method="POST" action="/company/billing/upgrade" style="align-items:flex-start;text-align:left">
                      <input type="hidden" name="_csrf" value="<%= csrfToken || '' %>">
                      <input type="hidden" name="planId" value="<%= plan.id %>">
                      <div class="quickIcon"><i class="fa-solid <%= active ? 'fa-circle-check' : 'fa-layer-group' %>"></i></div>
                      <strong><%= plan.name %> - <%= money(plan.amount, plan.currency) %>/<%= plan.interval %></strong>
                      <span><%= active ? 'Current active plan' : plan.tagline %></span>
                      <button class="btn <%= active ? '' : 'btnPrimary' %>" type="submit" <%= active ? 'disabled' : '' %>><i class="fa-solid fa-lock"></i> <%= active ? 'Active' : 'Select' %></button>
                    </form>
                  <% }) %>
                </div>
              </div>
            </div>
          </div>
        </section>

        <section class="section" id="settings">
          <div class="grid2">
            <div class="card">
              <div class="cardHead"><div class="cardTitle"><h3>Company settings</h3><p>Business profile, payout account, support details, and default service settings.</p></div></div>
              <form class="formPanel" id="settingsForm" method="POST" action="/company/settings">
                <input type="hidden" name="_csrf" value="<%= csrfToken || '' %>">
                <div class="formGrid">
                  <div class="field"><label>Company name</label><div class="control"><i class="fa-solid fa-building"></i><input name="name" value="Company partner" /></div></div>
                  <div class="field"><label>Business type</label><div class="control"><i class="fa-solid fa-briefcase"></i><select name="companyType"><option value="bus">Bus company</option><option value="hotel">Hotel</option><option value="flight">Airline</option><option value="train">Train company</option><option value="tour">Tour operator</option><option value="car_rental">Car rental</option></select></div></div>
                  <div class="field"><label>Default currency</label><div class="control"><i class="fa-solid fa-coins"></i><select name="defaultCurrency"><option>UGX</option><option>KES</option><option>RWF</option><option>TZS</option><option>USD</option></select></div></div>
                  <div class="field"><label>Payout account</label><div class="control"><i class="fa-solid fa-building-columns"></i><input value="Stanbic Bank •••• 2109" /></div></div>
                  <div class="field"><label>Support email</label><div class="control"><i class="fa-solid fa-envelope"></i><input name="supportEmail" type="email" placeholder="support@example.com" /></div></div>
                  <div class="field"><label>Support phone</label><div class="control"><i class="fa-solid fa-phone"></i><input name="supportPhone" placeholder="+256700000000" /></div></div>
                  <div class="field full"><label>Customer support message</label><div class="control"><textarea name="supportMessage">Company support helps with ticket check-in, lost tickets, delay updates, luggage, and refunds.</textarea></div></div>
                </div>
                <button class="btn btnPrimary" type="submit"><i class="fa-solid fa-floppy-disk"></i> Save settings</button>
              </form>
            </div>
            <div class="card">
              <div class="cardHead"><div class="cardTitle"><h3>Verification controls</h3><p>Requirements before services can be fully promoted.</p></div></div>
              <form class="formPanel" method="POST" action="/company/media" enctype="multipart/form-data">
                <input type="hidden" name="_csrf" value="<%= csrfToken || '' %>">
                <div class="formGrid">
                  <div class="field"><label>Upload target</label><div class="control"><i class="fa-solid fa-folder-open"></i><select name="target"><option value="companyLogo">Company logo</option><option value="companyCover">Cover image</option><option value="companyDocument">Business document</option></select></div></div>
                  <div class="field"><label>Cloudinary file</label><div class="control"><i class="fa-solid fa-cloud-arrow-up"></i><input type="file" name="imageFile" accept="image/*,application/pdf" required></div></div>
                </div>
                <button class="btn btnBlue" type="submit"><i class="fa-solid fa-upload"></i> Upload media</button>
              </form>
              <div class="splitGrid">
                <div class="splitItem"><div class="splitTop"><span>Business license</span><span class="badge ok">Verified</span></div></div>
                <div class="splitItem"><div class="splitTop"><span>Payout account</span><span class="badge ok">Verified</span></div></div>
                <div class="splitItem"><div class="splitTop"><span>Support contact</span><span class="badge ok">Active</span></div></div>
                <div class="splitItem"><div class="splitTop"><span>Promotion access</span><span class="badge info">Enabled</span></div></div>
                <button class="btn btnBlue" data-modal="edit" data-type="verification documents"><i class="fa-solid fa-file-pen"></i> Update documents</button>
              </div>
            </div>
          </div>
        </section>
      </div>
    </main>
  </div>

  <footer style="width:var(--container,min(1220px,92%));margin:0 auto 24px;border:1px solid var(--line);border-radius:24px;background:linear-gradient(180deg,var(--cardA),var(--cardB));box-shadow:var(--shadow2);padding:14px;display:flex;align-items:center;justify-content:space-between;gap:12px;flex-wrap:wrap;color:var(--muted);font-size:12px;font-weight:820">
    <div>
      <strong style="color:var(--text)">Classic Trip</strong>
      <div style="margin-top:4px">Marketplace, dashboards, routes, tickets, promoters, partners, and payments.</div>
    </div>
    <div style="display:flex;gap:8px;flex-wrap:wrap">
      <a class="btn" href="/">Home</a>
      <a class="btn" href="/routes">Routes</a>
      <a class="btn" href="/tickets">Tickets</a>
      <a class="btn" href="/promoters">Promoters</a>
    </div>
  </footer>

  <div class="modal" id="crudModal">
    <div class="modalCard">
      <div class="modalHead">
        <div><h3 id="crudTitle">Create item</h3><p id="crudSub">Manage company data cleanly.</p></div>
        <button class="iconBtn" data-close-modal><i class="fa-solid fa-xmark"></i></button>
      </div>
      <div class="modalBody" id="crudBody"></div>
    </div>
  </div>

  <div class="modal" id="deleteModal">
    <div class="modalCard">
      <div class="modalHead">
        <div><h3>Delete record</h3><p>This confirms the delete workflow before any record is changed.</p></div>
        <button class="iconBtn" data-close-modal><i class="fa-solid fa-xmark"></i></button>
      </div>
      <div class="modalBody">
        <div class="deleteBox">
          <span class="badge bad"><i class="fa-solid fa-triangle-exclamation"></i> Delete action</span>
          <strong id="deleteText">Are you sure you want to delete this record?</strong>
          <p style="margin:0;color:var(--muted);font-size:12px;font-weight:800;line-height:1.55">Soft delete keeps the record recoverable and preserves the audit trail.</p>
          <div style="display:flex;gap:8px;flex-wrap:wrap;justify-content:flex-end">
            <button class="btn" data-close-modal>Cancel</button>
            <button class="btn btnDanger" id="confirmDelete"><i class="fa-solid fa-trash"></i> Delete</button>
          </div>
        </div>
      </div>
