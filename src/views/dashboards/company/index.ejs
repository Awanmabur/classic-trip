              <button class="tabBtn" data-tab="hotel">Hotels</button>
              <button class="tabBtn" data-tab="flight">Flights</button>
              <button class="tabBtn" data-tab="tour">Tours</button>
              <button class="tabBtn" data-tab="review">Needs review</button>
            </div>
            <div class="tabPane is-on" data-pane="all"><div class="tableWrap"><table><thead><tr><th>Listing</th><th>Type</th><th>Route / location</th><th>Inventory</th><th>Price from</th><th>Status</th><th></th></tr></thead><tbody id="listingsTable"></tbody></table></div></div>
            <div class="tabPane" data-pane="bus"><div class="tableWrap"><table><thead><tr><th>Listing</th><th>Type</th><th>Route / location</th><th>Inventory</th><th>Price from</th><th>Status</th><th></th></tr></thead><tbody data-filter-table="listings" data-filter="Bus"></tbody></table></div></div>
            <div class="tabPane" data-pane="hotel"><div class="tableWrap"><table><thead><tr><th>Listing</th><th>Type</th><th>Route / location</th><th>Inventory</th><th>Price from</th><th>Status</th><th></th></tr></thead><tbody data-filter-table="listings" data-filter="Hotel"></tbody></table></div></div>
            <div class="tabPane" data-pane="flight"><div class="tableWrap"><table><thead><tr><th>Listing</th><th>Type</th><th>Route / location</th><th>Inventory</th><th>Price from</th><th>Status</th><th></th></tr></thead><tbody data-filter-table="listings" data-filter="Flight"></tbody></table></div></div>
            <div class="tabPane" data-pane="tour"><div class="tableWrap"><table><thead><tr><th>Listing</th><th>Type</th><th>Route / location</th><th>Inventory</th><th>Price from</th><th>Status</th><th></th></tr></thead><tbody data-filter-table="listings" data-filter="Tour"></tbody></table></div></div>
            <div class="tabPane" data-pane="review"><div class="tableWrap"><table><thead><tr><th>Listing</th><th>Type</th><th>Route / location</th><th>Inventory</th><th>Price from</th><th>Status</th><th></th></tr></thead><tbody data-filter-table="listings-status" data-filter="Review"></tbody></table></div></div>
