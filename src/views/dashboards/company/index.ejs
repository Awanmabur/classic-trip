      }

      async function postCompanyScanner(url, value){
        const response = await fetch(url, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
          body: JSON.stringify({ bookingRef: value, qrCodeValue: value, note: els.companyCheckNote?.value || '' })
        });
        const result = await response.json().catch(() => ({}));
        return { response, result };
      }

      function companyCheckinRowFromScan(result = {}){
        const detail = result.detail || {};
        const booking = detail.booking || result.booking || {};
        const customer = detail.customer || {};
        const service = detail.service || result.listing || {};
        const checkIn = detail.checkIn || {};
        const status = booking.bookingStatus || checkIn.status || result.result || 'checked_in';
        return [
          booking.bookingRef || result.booking?.bookingRef || companyScanValue(),
          customer.name || booking.customerName || 'Customer',
          service.title || result.listing?.title || 'Service',
          (booking.seats || []).join(', ') || booking.seatOrRoom || 'Selected',
          checkIn.checkedInAt || booking.checkedInAt ? new Date(checkIn.checkedInAt || booking.checkedInAt).toLocaleDateString('en-GB', { day:'2-digit', month:'short', year:'numeric' }) : 'Pending',
          status,
          { entity:'checkin', id: booking.bookingRef || companyScanValue(), label: booking.bookingRef || companyScanValue(), status, detail }
        ];
      }

      async function lookupCompanyTicket(value = companyScanValue()){
        const lookup = String(value || '').trim();
        if(!lookup){ showToast('Enter or scan a ticket first'); return; }
        const oldLabel = els.btnCompanyLookupTicket?.innerHTML;
        try{
          if(els.btnCompanyLookupTicket){ els.btnCompanyLookupTicket.disabled = true; els.btnCompanyLookupTicket.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Looking up'; }
          const payload = await postCompanyScanner('/company/scanner/lookup', lookup);
          currentCompanyScan = payload.result;
          renderCompanyScanResult(payload.result, payload.response.ok);
          setCompanyCheckButtons(payload.result);
          if(payload.response.ok) showToast('Ticket found');
          else showToast(payload.result.message || 'Ticket not found');
        } catch(error){
          currentCompanyScan = null;
          setCompanyCheckButtons({});
          renderCompanyScanResult({ message: error.message || 'Lookup failed' }, false);
          showToast('Lookup failed');
        } finally {
          if(els.btnCompanyLookupTicket){ els.btnCompanyLookupTicket.innerHTML = oldLabel; els.btnCompanyLookupTicket.disabled = false; }
        }
      }

      async function validateCompanyTicket(value = companyScanValue()){
        const lookup = String(value || '').trim();
        if(!lookup){ showToast('Enter or scan a ticket first'); return; }
        const oldLabel = els.btnCompanyCheckIn?.innerHTML;
        try{
          if(els.btnCompanyCheckIn){ els.btnCompanyCheckIn.disabled = true; els.btnCompanyCheckIn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Checking in'; }
          const payload = await postCompanyScanner('/company/scanner/validate', lookup);
          currentCompanyScan = payload.result;
          renderCompanyScanResult(payload.result, payload.response.ok);
          setCompanyCheckButtons(payload.result);
          if(payload.response.ok){
            const row = companyCheckinRowFromScan(payload.result);
            data.checkins = [row].concat(data.checkins.filter(item => rowCells(item)[0] !== row[0]));
            renderAll();
            showToast('Ticket checked in');
          } else {
            showToast(payload.result.message || 'Check-in blocked');
          }
        } catch(error){
          renderCompanyScanResult({ message: error.message || 'Check-in failed' }, false);
          showToast('Check-in failed');
        } finally {
          if(els.btnCompanyCheckIn){ els.btnCompanyCheckIn.innerHTML = oldLabel; setCompanyCheckButtons(currentCompanyScan || {}); }
        }
      }

