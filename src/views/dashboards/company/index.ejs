          </div>`;
        }
        return `<div class="rowActions">
          <button class="tinyBtn" data-modal="view" data-type="${safeLabel}"${detailAttr} title="View full details"><i class="fa-regular fa-eye"></i></button>
          <button class="tinyBtn" data-export-row="${safeLabel}"${detailAttr} title="Export PDF"><i class="fa-solid fa-file-export"></i></button>
        </div>`;
