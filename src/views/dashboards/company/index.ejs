      function downloadText(filename,text,mime='text/plain'){
        const blob = new Blob([text], {type:mime});
        const url = URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = url; a.download = filename; document.body.appendChild(a); a.click(); a.remove(); URL.revokeObjectURL(url);
      }


  function exportDetailPdf(detail, name){
    const title = String(name || 'dashboard-record');
    const win = window.open('', '_blank', 'noopener,noreferrer,width=900,height=720');
    if(!win){ if(typeof toast === 'function') toast('Allow popups to export PDF'); else if(typeof showToast === 'function') showToast('Allow popups to export PDF'); return; }
    const body = detailMarkup(detail || {});
    win.document.write(`<!doctype html><html><head><meta charset="utf-8"><title>${escapeHtml(title)} PDF</title><style>
      body{font-family:Inter,Arial,sans-serif;margin:28px;color:#111827;background:#fff}.brand{display:flex;justify-content:space-between;gap:16px;border-bottom:2px solid #e5e7eb;padding-bottom:14px;margin-bottom:18px}.brand h1{font-size:22px;margin:0}.brand p{margin:4px 0 0;color:#6b7280}.detailGroup{break-inside:avoid;margin:0 0 16px}.detailGroup h4{font-size:14px;margin:0 0 8px;color:#111827}.detailGrid{display:grid;grid-template-columns:repeat(3,1fr);gap:8px}.detailItem{border:1px solid #e5e7eb;border-radius:10px;padding:8px;min-width:0}.detailItem span{display:block;font-size:9px;letter-spacing:.06em;text-transform:uppercase;color:#6b7280;font-weight:800}.detailItem b{display:block;font-size:12px;word-break:break-word}.detailItem.full{grid-column:1/-1}@media print{button{display:none}body{margin:14mm}}
    </style></head><body><div class="brand"><div><h1>Classic Trip Dashboard Record</h1><p>${escapeHtml(title)} · ${new Date().toLocaleString()}</p></div><button onclick="window.print()">Print / Save PDF</button></div>${body}<script>setTimeout(()=>window.print(),300)<\/script></body></html>`);
    win.document.close();
  }

      function enhanceTables(){
        $$('.tableWrap').forEach((wrap,index)=>{
          if(wrap.dataset.enhanced === 'true') return;
          const table = wrap.querySelector('table');
          if(!table) return;
          wrap.dataset.enhanced = 'true';
          const tools = document.createElement('div');
          tools.className = 'tableTools';
          tools.innerHTML = `<div class="control"><i class="fa-solid fa-magnifying-glass"></i><input placeholder="Search this table" data-table-search></div><div class="control"><i class="fa-solid fa-filter"></i><select data-table-status><option value="">All statuses</option><option>active</option><option>confirmed</option><option>pending</option><option>review</option><option>refund</option><option>paused</option></select></div><div class="control"><i class="fa-regular fa-calendar"></i><input type="date" data-table-date></div><button class="btn" type="button" data-export-table><i class="fa-solid fa-download"></i> Export CSV</button>`;
          wrap.parentNode.insertBefore(tools, wrap);
          const filter = ()=>{
            const q = tools.querySelector('[data-table-search]').value.toLowerCase().trim();
            const status = tools.querySelector('[data-table-status]').value.toLowerCase().trim();
            const date = tools.querySelector('[data-table-date]').value;
            Array.from(table.tBodies[0]?.rows || []).forEach(row=>{
              const text = row.textContent.toLowerCase();
              row.style.display = (!q || text.includes(q)) && (!status || text.includes(status)) && (!date || text.includes(date)) ? '' : 'none';
            });
          };
          tools.addEventListener('input', filter);
          tools.addEventListener('change', filter);
          tools.querySelector('[data-export-table]').addEventListener('click', ()=>{
            const rows = Array.from(table.rows).filter(row=>row.style.display !== 'none').map(row=>Array.from(row.cells).map(cell=>cell.textContent.trim()));
            const csv = rows.map(row=>row.map(cell=>`"${cell.replace(/"/g,'""')}"`).join(',')).join('\n');
            downloadText(`classic-trip-company-table-${index+1}.csv`, csv, 'text/csv');
            showToast('Table CSV exported');
          });
        });
      }

      function emptyRow(cols, text='No matching records found'){
        return `<tr><td colspan="${cols}" style="text-align:center;color:var(--muted);border-radius:16px;border:1px solid var(--line2);background:var(--table);padding:18px">${text}</td></tr>`;
      }

      function renderSimpleRows(tbody, rows, opts = {}){
        if(!tbody) return;
        const cols = opts.cols || 7;
        if(!rows.length){ tbody.innerHTML = emptyRow(cols); return; }
        tbody.innerHTML = rows.map((r)=>{
          const meta = rowMeta(r);
          const row = rowCells(r);
          const first = opts.avatar ? `<div class="nameCell"><div class="miniLogo">${escapeHtml(initials(row[0]))}</div><div><strong>${escapeHtml(row[0])}</strong><span>${escapeHtml(row[1] || '')}</span></div></div>` : escapeHtml(row[0]);
          const cells = row.map((cell, i)=>{
            if(i === 0) return `<td>${first}</td>`;
            if(i === row.length-1 && opts.statusLast) return `<td>${badge(cell)}</td>`;
            if(opts.statusIndex === i) return `<td>${badge(cell)}</td>`;
            return `<td>${escapeHtml(cell)}</td>`;
          }).join('');
          return `<tr>${cells}<td>${actions(row[0], meta)}</td></tr>`;
        }).join('');
      }

      function renderRecent(){
        renderSimpleRows($('#recentBookings'), data.recentBookings, {statusIndex:4, cols:7});
