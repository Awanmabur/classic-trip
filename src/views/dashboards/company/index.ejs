      function seatStatusGroup(seat = {}){
        const status = String(seat.status || 'available').toLowerCase();
        if(['taken','booked','checked-in','checked_in','confirmed'].includes(status)) return 'booked';
        if(['locked','held','hold','selected','reserved'].includes(status)) return 'hold';
        if(['blocked','maintenance','disabled','cancelled','refunded','voided'].includes(status)) return 'blocked';
        return 'available';
      }

      function seatMapLabel(map = {}){
        return [map.routeLabel || map.listingTitle || 'Schedule', map.departAt || '', map.vehicleName || 'Vehicle'].filter(Boolean).join(' - ');
      }

      function renderSeatMapDetail(seat = {}, map = {}){
        if(!els.seatMapDetail) return;
        const group = seatStatusGroup(seat);
        const rows = [
          ['Seat', seat.seatNumber || '-'],
          ['Status', seat.status || group],
          ['Class', seat.seatClass || seat.seatType || 'Standard'],
          ['Schedule', map.scheduleId || '-'],
          ['Route', map.routeLabel || map.listingTitle || '-'],
          ['Vehicle', map.vehicleName || '-']
        ];
        if(group === 'booked'){
          rows.push(
            ['Booking ref', seat.bookingRef || '-'],
            ['Passenger', seat.passengerName || '-'],
            ['Phone', seat.passengerPhone || '-'],
            ['Email', seat.passengerEmail || '-'],
            ['Ticket', seat.ticketNumber || '-'],
            ['Payment', seat.paymentStatus || '-'],
            ['Check-in', seat.checkInStatus || '-']
          );
        } else if(group === 'hold'){
          rows.push(
            ['Hold ID', seat.lockId || '-'],
            ['Locked until', seat.lockedUntil ? new Date(seat.lockedUntil).toLocaleString() : '-'],
            ['Booking ref', seat.bookingRef || 'Not converted'],
            ['Passenger', seat.passengerName || 'Pending checkout']
          );
        } else if(group === 'blocked'){
          rows.push(['Reason', seat.blockedReason || 'Operational block']);
        } else {
          rows.push(['Action', 'Available for checkout or manual booking']);
        }
        els.seatMapDetail.innerHTML = `
          <div class="seatInfoTop">
            <div><h4>${escapeHtml(seat.seatNumber || 'Seat')}</h4><p>${escapeHtml(group === 'booked' ? 'Booked seat detail' : group === 'hold' ? 'Active hold detail' : group === 'blocked' ? 'Unavailable seat' : 'Available seat')}</p></div>
            ${badge(seat.status || group)}
          </div>
          <div class="seatInfoGrid">${rows.map(([label,value]) => `<div><span>${escapeHtml(label)}</span><b>${escapeHtml(value || '-')}</b></div>`).join('')}</div>
          ${seat.bookingRef ? `<a class="btn btnBlue" href="/tickets/${encodeURIComponent(seat.bookingRef)}" target="_blank" rel="noopener"><i class="fa-solid fa-ticket"></i> Open ticket</a>` : ''}
        `;
      }

      function renderVisualSeatMap(){
        if(!els.visualSeatMap || !els.seatMapScheduleSelect) return;
        const maps = Array.isArray(data.seatMaps) ? data.seatMaps : [];
        if(!maps.length){
          els.seatMapScheduleSelect.innerHTML = '<option>No seat maps yet</option>';
          els.visualSeatMap.innerHTML = '<div class="vehicleDeckHeader">Create a vehicle and schedule to generate seats</div>';
          if(els.seatMapSummary) els.seatMapSummary.innerHTML = '<div class="seatStat"><span>Total</span><b>0</b></div><div class="seatStat"><span>Booked</span><b>0</b></div><div class="seatStat"><span>Held</span><b>0</b></div><div class="seatStat"><span>Available</span><b>0</b></div>';
          return;
        }
        const previous = els.seatMapScheduleSelect.value;
        els.seatMapScheduleSelect.innerHTML = maps.map(map => `<option value="${escapeHtml(map.scheduleId)}">${escapeHtml(seatMapLabel(map))}</option>`).join('');
        const current = maps.find(map => map.scheduleId === previous) || maps[0];
        els.seatMapScheduleSelect.value = current.scheduleId;
        const seats = Array.isArray(current.seats) ? current.seats.slice() : [];
        const totals = current.totals || {};
        if(els.seatMapSummary){
          els.seatMapSummary.innerHTML = [
            ['Total', totals.total ?? seats.length],
            ['Booked', totals.booked ?? seats.filter(seat => seatStatusGroup(seat) === 'booked').length],
            ['Held', totals.held ?? seats.filter(seat => seatStatusGroup(seat) === 'hold').length],
            ['Available', totals.available ?? seats.filter(seat => seatStatusGroup(seat) === 'available').length]
          ].map(([label,value]) => `<div class="seatStat"><span>${escapeHtml(label)}</span><b>${escapeHtml(value)}</b></div>`).join('');
        }
        const rows = [...new Set(seats.map(seat => Number(seat.row || 1)))].sort((a,b)=>a-b);
        const maxCol = Math.max(4, ...seats.map(seat => Number(seat.col || 1)));
        const rowHtml = (rows.length ? rows : [1]).map(row => {
          const cells = [];
          for(let col = 1; col <= maxCol; col += 1){
            if(col === 3) cells.push('<span class="seatAisle">AISLE</span>');
            const seat = seats.find(item => Number(item.row || 1) === row && Number(item.col || 1) === col);
            if(!seat){
              cells.push('<span class="seatSpacer" aria-hidden="true"></span>');
              continue;
            }
            const group = seatStatusGroup(seat);
            const title = `${seat.seatNumber || ''} ${seat.status || group}${seat.passengerName ? ` - ${seat.passengerName}` : ''}`;
            cells.push(`<button class="seatCell is-${group}" type="button" data-seat-map-seat="${escapeHtml(seat.seatNumber)}" data-seat-map-schedule="${escapeHtml(current.scheduleId)}" title="${escapeHtml(title)}">${escapeHtml(seat.seatNumber || '')}</button>`);
          }
          return `<div class="seatMapRow" style="grid-template-columns:repeat(2,42px) 18px repeat(${Math.max(1, maxCol - 2)},42px)">${cells.join('')}</div>`;
        }).join('');
        els.visualSeatMap.innerHTML = `<div class="vehicleDeckHeader">${escapeHtml(current.vehicleName || current.routeLabel || 'Vehicle')} - ${escapeHtml(current.status || 'schedule')}</div>${rowHtml}`;
        const firstBookedOrHold = seats.find(seat => ['booked','hold'].includes(seatStatusGroup(seat))) || seats[0] || {};
        renderSeatMapDetail(firstBookedOrHold, current);
        const firstButton = $$('[data-seat-map-seat]', els.visualSeatMap).find(button => button.dataset.seatMapSeat === String(firstBookedOrHold.seatNumber || ''));
        if(firstButton) firstButton.classList.add('is-selected');
      }

      function roomStatusGroup(room = {}){
        const status = String(room.status || 'available').toLowerCase().replace(/_/g, '-');
        if(['held','hold','reserved'].includes(status)) return 'hold';
        if(['booked','confirmed'].includes(status)) return 'booked';
        if(['occupied','checked-in','in-house'].includes(status)) return 'occupied';
        if(['checked-out','completed'].includes(status)) return 'checkedout';
        if(['maintenance','cleaning','blocked','disabled'].includes(status)) return 'maintenance';
        if(['cancelled','canceled'].includes(status)) return 'cancelled';
        if(['refunded','refund'].includes(status)) return 'refunded';
        return 'available';
      }

      function roomMapLabel(map = {}){
        return [map.roomTypeName || 'Room type', map.propertyName || map.listingTitle || 'Hotel', map.status || 'active'].filter(Boolean).join(' - ');
      }

      function renderRoomMapDetail(room = {}, map = {}){
        if(!els.roomMapDetail) return;
        const group = roomStatusGroup(room);
        const rows = [
          ['Room unit', room.unitNumber || '-'],
          ['Room type', room.roomTypeName || map.roomTypeName || '-'],
          ['Status', room.status || group],
          ['Date range', room.dateRange || room.date || '-'],
          ['Housekeeping', room.housekeepingStatus || '-'],
          ['Floor / wing', [room.floor && `Floor ${room.floor}`, room.wing].filter(Boolean).join(' / ') || '-']
        ];
        if(['booked','occupied','checkedout','hold'].includes(group)){
          rows.push(
            ['Booking ref', room.bookingRef || 'Not converted'],
            ['Guest', room.guestName || '-'],
            ['Phone', room.guestPhone || '-'],
            ['Email', room.guestEmail || '-'],
            ['Check-in', room.checkIn || '-'],
            ['Check-out', room.checkOut || '-']
          );
        }
        if(group === 'maintenance') rows.push(['Operational note', room.status === 'cleaning' ? 'Cleaning in progress' : 'Maintenance block']);
        els.roomMapDetail.innerHTML = `
          <div class="seatInfoTop">
            <div><h4>${escapeHtml(room.unitNumber || 'Room')}</h4><p>${escapeHtml(map.propertyName || map.listingTitle || 'Hotel room-night detail')}</p></div>
            ${badge(room.status || group)}
          </div>
          <div class="seatInfoGrid">${rows.map(([label,value]) => `<div><span>${escapeHtml(label)}</span><b>${escapeHtml(value || '-')}</b></div>`).join('')}</div>
          ${room.bookingRef ? `<a class="btn btnBlue" href="/driver/tickets/${encodeURIComponent(room.bookingRef)}" target="_blank" rel="noopener"><i class="fa-solid fa-ticket"></i> Open stay detail</a>` : ''}
        `;
      }

      function renderVisualRoomMap(){
        if(!els.visualRoomMap || !els.roomMapTypeSelect) return;
        const maps = Array.isArray(data.roomVisualMaps) ? data.roomVisualMaps : [];
        if(!maps.length){
          els.roomMapTypeSelect.innerHTML = '<option>No room maps yet</option>';
          els.visualRoomMap.innerHTML = '<div class="vehicleDeckHeader">Create hotel room types, units, and nightly inventory</div>';
          if(els.roomMapSummary) els.roomMapSummary.innerHTML = '<div class="seatStat"><span>Total</span><b>0</b></div><div class="seatStat"><span>Available</span><b>0</b></div><div class="seatStat"><span>Booked</span><b>0</b></div><div class="seatStat"><span>Maintenance</span><b>0</b></div>';
          return;
        }
        const previous = els.roomMapTypeSelect.value;
        els.roomMapTypeSelect.innerHTML = maps.map(map => `<option value="${escapeHtml(map.roomTypeId)}">${escapeHtml(roomMapLabel(map))}</option>`).join('');
        const current = maps.find(map => map.roomTypeId === previous) || maps[0];
        els.roomMapTypeSelect.value = current.roomTypeId;
        const rooms = Array.isArray(current.rooms) ? current.rooms.slice() : [];
        const totals = current.totals || {};
        if(els.roomMapSummary){
          els.roomMapSummary.innerHTML = [
            ['Total', totals.total ?? rooms.length],
            ['Available', totals.available ?? rooms.filter(room => roomStatusGroup(room) === 'available').length],
            ['Booked', totals.booked ?? rooms.filter(room => ['booked','occupied'].includes(roomStatusGroup(room))).length],
            ['Maintenance', totals.maintenance ?? rooms.filter(room => roomStatusGroup(room) === 'maintenance').length]
          ].map(([label,value]) => `<div class="seatStat"><span>${escapeHtml(label)}</span><b>${escapeHtml(value)}</b></div>`).join('');
        }
        if(!rooms.length){
          els.visualRoomMap.innerHTML = '<div class="vehicleDeckHeader">No room units for this room type</div>';
          renderRoomMapDetail({}, current);
          return;
        }
        els.visualRoomMap.innerHTML = rooms.map((room) => {
          const group = roomStatusGroup(room);
          const title = `${room.unitNumber || ''} ${room.status || group}${room.guestName ? ` - ${room.guestName}` : ''}`;
          return `<button class="roomCard is-${group}" type="button" data-room-map-unit="${escapeHtml(room.roomUnitId)}" data-room-map-type="${escapeHtml(current.roomTypeId)}" title="${escapeHtml(title)}">
            <span>${escapeHtml(room.roomTypeName || current.roomTypeName || 'Room')}</span>
            <strong>${escapeHtml(room.unitNumber || '')}</strong>
            <small>${escapeHtml(room.status || group)}${room.bookingRef ? ` - ${room.bookingRef}` : ''}</small>
            <small>${escapeHtml(room.date || room.dateRange || '')}</small>
          </button>`;
        }).join('');
        const firstBookedOrHold = rooms.find(room => ['booked','occupied','hold'].includes(roomStatusGroup(room))) || rooms[0] || {};
        renderRoomMapDetail(firstBookedOrHold, current);
        const firstButton = $$('[data-room-map-unit]', els.visualRoomMap).find(button => button.dataset.roomMapUnit === String(firstBookedOrHold.roomUnitId || ''));
        if(firstButton) firstButton.classList.add('is-selected');
      }

