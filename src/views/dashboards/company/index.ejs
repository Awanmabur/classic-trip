      }

      function isUsefulDetail(label, value){
        if(value === undefined || value === null || value === '') return false;
        if(Array.isArray(value) && !value.length) return false;
        const key = String(label || '').split('.').pop();
        const lowered = key.toLowerCase();
        if(['id','_id','__v','createdat','updatedat','deletedat','qrcodevalue','qrtoken','qrtokenhash','qrtokenpreview','token','hash','password','metadata','meta','bookingitems','bookinglegs','ticketlegs','raw','payload'].includes(lowered)) return false;
        if(/(^|\.)(id|_id|token|hash|password|secret|internal|metadata|meta|raw|payload)$/i.test(String(label || ''))) return false;
        return DETAIL_ALLOWLIST.has(key) || DETAIL_ALLOWLIST.has(lowered);
      }

      function flattenEntries(obj={}, prefix=''){
        return Object.entries(obj || {}).flatMap(([key,value])=>{
          const label = prefix ? `${prefix}.${key}` : key;
          if(value && typeof value === 'object' && !Array.isArray(value)) return flattenEntries(value,label);
          if(Array.isArray(value)){
            const display = value.map(item => {
              if(item && typeof item === 'object'){
                return [item.fullName || item.name || item.passengerName, item.seatOrRoom || item.seatNumber || item.roomNumber || item.unitNumber || item.ticketNumber, item.phone || item.email, item.status || item.checkInStatus].filter(Boolean).join(' / ');
              }
              return item;
            }).filter(Boolean).join('; ');
            return [[label, display]];
          }
          return [[label, value]];
        });
