      function renderBars(selector, items){
        const root = $(selector);
        if(!root) return;
        root.innerHTML = items.map(([label, val]) => `<div class="bar" style="height:${val}%"><span>${label}</span></div>`).join('');
      }

      function openPage(page){
        $$('.section').forEach(s => s.classList.remove('is-open'));
        const section = $('#' + page);
        if(section) section.classList.add('is-open');

        $$('.navBtn').forEach(b => b.classList.toggle('is-active', b.dataset.page === page));
        const meta = pageMeta[page] || pageMeta.overview;
        els.pageHeading.textContent = meta[0];
        els.pageSub.textContent = meta[1];

        document.body.classList.remove('menu-open');

        requestAnimationFrame(() => {
          window.scrollTo({ top: 0, behavior: 'auto' });
          setTimeout(() => window.scrollTo({ top: 0, behavior: 'auto' }), 30);
        });
      }

      function showToast(text){
        els.toastText.textContent = text;
        els.toast.classList.add('show');
        clearTimeout(showToast.t);
        showToast.t = setTimeout(() => els.toast.classList.remove('show'), 2300);
      }

      function fieldHtml(field, readonly){
        const valueAttr = typeof field.value !== 'undefined' ? ` value="${escapeHtml(field.value)}"` : '';
        const attrs = `${field.name ? ` name="${escapeHtml(field.name)}"` : ''}${field.placeholder ? ` placeholder="${escapeHtml(field.placeholder)}"` : ''}${valueAttr}${field.required ? ' required' : ''}${readonly ? ' readonly' : ''}`;
        const fieldClass = `field${field.full ? ' full' : ''}`;
        const showFor = field.showFor ? ` data-show-for="${escapeHtml([].concat(field.showFor).join(','))}"` : '';
        const dataRequired = field.required ? ' data-required="true"' : '';
        if(field.kind === 'select'){
          const selected = typeof field.value !== 'undefined' ? String(field.value) : '';
          const options = Array.isArray(field.options) ? field.options : [];
          return `<div class="${fieldClass}"${showFor}><label>${escapeHtml(field.label)}</label><div class="control"><i class="${escapeHtml(field.icon || 'fa-solid fa-list')}"></i><select name="${escapeHtml(field.name)}"${dataRequired} ${field.required ? 'required' : ''} ${readonly ? 'disabled' : ''}>${options.map(option => {
            const value = String(option.value ?? '');
            return `<option value="${escapeHtml(value)}"${value === selected ? ' selected' : ''}>${escapeHtml(option.label)}</option>`;
          }).join('')}</select></div></div>`;
        }
        if(field.kind === 'textarea'){
          return `<div class="field full"${showFor}><label>${escapeHtml(field.label)}</label><div class="control"><textarea${attrs}${dataRequired}>${escapeHtml(field.text || field.value || '')}</textarea></div></div>`;
        }
        if(field.type === 'file'){
          const accept = field.accept ? ` accept="${escapeHtml(field.accept)}"` : '';
          return `<div class="${fieldClass}"${showFor}><label>${escapeHtml(field.label)}</label><div class="control"><i class="${escapeHtml(field.icon || 'fa-solid fa-cloud-arrow-up')}"></i><input type="file"${field.name ? ` name="${escapeHtml(field.name)}"` : ''}${accept}${field.required ? ' required' : ''}${dataRequired}></div></div>`;
        }
        return `<div class="${fieldClass}"${showFor}><label>${escapeHtml(field.label)}</label><div class="control"><i class="${escapeHtml(field.icon || 'fa-solid fa-pen')}"></i><input type="${escapeHtml(field.type || 'text')}"${attrs}${dataRequired}></div></div>`;
      }

      function updateConditionalFields(form){
        const service = form.querySelector('[name="serviceType"]')?.value || '';
        $$('[data-show-for]', form).forEach(field => {
          const allowed = String(field.dataset.showFor || '').split(',').map(item => item.trim()).filter(Boolean);
          const isVisible = !allowed.length || allowed.includes(service);
          field.hidden = !isVisible;
          $$('input, select, textarea', field).forEach(input => {
            input.disabled = !isVisible;
            if(input.dataset.required === 'true') input.required = isVisible;
          });
        });
      }

      function bindConditionalForm(form){
        if(!form) return;
        updateConditionalFields(form);
        const serviceSelect = form.querySelector('[name="serviceType"]');
        if(serviceSelect) serviceSelect.addEventListener('change', () => updateConditionalFields(form));
      }

