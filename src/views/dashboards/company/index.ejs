            <div class="tableWrap">
              <table>
                <thead><tr><th>Vehicle</th><th>Type</th><th>Plate / code</th><th>Seats</th><th>Layout</th><th>Status</th><th></th></tr></thead>
                <tbody id="vehiclesTable"></tbody>
              </table>
            </div>
          </div>
        </section>

        <section class="section" id="schedules">
