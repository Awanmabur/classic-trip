          if(table === 'schedules') rows = data.schedules.filter(r => String(r[2] || '').includes(filter) || r[5] === filter);
          if(table === 'schedules-status') rows = data.schedules.filter(r => r[5] === filter);
          if(table === 'bookings-status') rows = data.bookings.filter(r => r[5] === filter);
          if(table === 'staff-role') rows = data.staff.filter(r => r[1] === filter);

          if(table.startsWith('listings')) renderListings(tbody, rows);
          if(table.startsWith('schedules')) renderSchedules(tbody, rows);
