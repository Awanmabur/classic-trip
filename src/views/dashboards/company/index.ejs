        <button class="navBtn" data-page="checkins"><i class="fa-solid fa-qrcode"></i><span>Check-ins</span></button>
        <button class="navBtn" data-page="seatrooms"><i class="fa-solid fa-chair"></i><span>Seats / Rooms</span></button>
        <button class="navBtn" data-page="staff"><i class="fa-solid fa-user-tie"></i><span>Staff & Roles</span></button>
        <button class="navBtn" data-page="payouts"><i class="fa-solid fa-wallet"></i><span>Payouts & Earnings</span></button>
        <button class="navBtn" data-page="billing"><i class="fa-solid fa-credit-card"></i><span>Plans & Billing</span></button>
        <button class="navBtn" data-page="promotions"><i class="fa-solid fa-rectangle-ad"></i><span>Promotions & Ads</span></button>
        <button class="navBtn" data-page="reviews"><i class="fa-solid fa-star"></i><span>Reviews</span></button>
        <button class="navBtn" data-page="support"><i class="fa-solid fa-headset"></i><span>Support Cases</span></button>
        <button class="navBtn" data-page="reports"><i class="fa-solid fa-file-lines"></i><span>Reports</span></button>
        <button class="navBtn" data-page="settings"><i class="fa-solid fa-gear"></i><span>Company Settings</span></button>
      </nav>

      <div class="sideFoot">
