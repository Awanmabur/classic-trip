      function badge(status){
        const label = String(status ?? '');
        const s = label.toLowerCase();
        let cls = 'info';
        if(['paid','active','verified','settled','healthy','published','running','boarding','open'].some(x=>s.includes(x))) cls='ok';
        if(['hold','pending','review','waiting','paused','delayed','tomorrow','week'].some(x=>s.includes(x))) cls='warn';
        if(['refund','cancelled','suspended','urgent','bad'].some(x=>s.includes(x))) cls='bad';
        return `<span class="badge ${cls}">${escapeHtml(label)}</span>`;
      }

      function initials(name){
        return String(name || '').split(' ').map(x=>x[0]).join('').slice(0,2).toUpperCase();
      }

      function rowMeta(row){
        const last = Array.isArray(row) ? row[row.length - 1] : null;
        return last && typeof last === 'object' && !Array.isArray(last) ? last : null;
      }

      function rowCells(row){
        const meta = rowMeta(row);
        return meta ? row.slice(0, -1) : row;
      }

      function encodeDetail(detail){
