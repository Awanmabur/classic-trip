      function renderBars(selector, items){
        const root = $(selector);
        if(!root) return;
        root.innerHTML = items.map(([label, val]) => `<div class="bar" style="height:${val}%"><span>${label}</span></div>`).join('');
      }

      function openPage(page){
        if(!visiblePages.has(page)) page = visiblePages.has('overview') ? 'overview' : Array.from(visiblePages)[0] || 'overview';
        $$('.section').forEach(s => s.classList.remove('is-open'));
        const section = $('#' + page);
        if(section) section.classList.add('is-open');

        $$('.navBtn').forEach(b => b.classList.toggle('is-active', b.dataset.page === page));
        const meta = pageMeta[page] || pageMeta.overview;
        els.pageHeading.textContent = meta[0];
        els.pageSub.textContent = meta[1];

        document.body.classList.remove('menu-open');

        requestAnimationFrame(() => {
          window.scrollTo({ top: 0, behavior: 'auto' });
          setTimeout(() => window.scrollTo({ top: 0, behavior: 'auto' }), 30);
        });
      }

      function showToast(text){
        els.toastText.textContent = text;
        els.toast.classList.add('show');
        clearTimeout(showToast.t);
        showToast.t = setTimeout(() => els.toast.classList.remove('show'), 2300);
      }

      function companyScanValue(){
        return (els.companyCheckSearch?.value || currentCompanyScan?.detail?.booking?.bookingRef || currentCompanyScan?.booking?.bookingRef || '').trim();
      }

      function setCompanyCheckButtons(result = {}){
        const canCheckIn = Boolean(result.canCheckIn || (result.ok && result.result === 'ready'));
        const hasBooking = Boolean(result.booking || result.detail?.booking);
        if(els.btnCompanyCheckIn) els.btnCompanyCheckIn.disabled = !canCheckIn;
        if(els.btnCompanyNoShow) els.btnCompanyNoShow.disabled = !hasBooking || /checked|cancel|refund|void|complete|no_show|no show/.test(String(result.booking?.bookingStatus || result.detail?.booking?.bookingStatus || '').toLowerCase());
        if(els.btnCompanyQr) els.btnCompanyQr.disabled = !hasBooking;
      }

      function renderCompanyScanResult(result = {}, ok = Boolean(result.ok)){
        if(!els.companyScannerResult) return;
        const detail = result.detail || {};
        const booking = detail.booking || result.booking || {};
        const customer = detail.customer || {};
        const service = detail.service || detail.listing || result.listing || {};
        const checkIn = detail.checkIn || {};
        if(!booking.bookingRef && !result.message){
          els.companyScannerResult.className = 'scanResult is-empty';
          els.companyScannerResult.textContent = 'Lookup or scan a ticket to verify customer, service, payment, and check-in status before action.';
          return;
        }
        const qrUrl = booking.bookingRef ? `/company/bookings/${encodeURIComponent(booking.bookingRef)}/qr.svg` : '';
