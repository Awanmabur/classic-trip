          <div class="avatar">CP</div>
          <div class="profileMeta">
            <strong>Company partner</strong>
            <span>Partner account</span>
          </div>
        </div>
      </div>
    </aside>

    <main class="main">
      <header class="topbar">
        <div class="topLeft">
          <button class="iconBtn menuBtn" id="openMenu" aria-label="Open menu"><i class="fa-solid fa-bars"></i></button>
          <div class="pageTitle">
            <h1 id="pageHeading">Partner Company Dashboard</h1>
            <p id="pageSub">Manage listings, schedules, inventory, bookings, staff, payouts, promotions, and support.</p>
          </div>
        </div>

        <div class="topActions">
          <button class="iconBtn" id="btnTheme" title="Toggle theme" aria-label="Toggle theme"><i class="fa-solid fa-moon" id="themeIcon"></i></button>
          <button class="btn hideMobile" id="btnExport"><i class="fa-solid fa-download"></i><span>Export</span></button>
          <button class="btn btnBlue" id="btnNew"><i class="fa-solid fa-plus"></i><span>Create</span></button>
          <button class="btn btnPrimary hideMobile"><i class="fa-solid fa-building-circle-check"></i> Verified</button>
        </div>
      </header>

      <div class="content" id="contentTop">
        <section class="section is-open" id="overview">
          <div class="hero">
            <div class="heroGrid">
              <div class="welcome">
                <div>
                  <span class="badge ok"><i class="fa-solid fa-circle-check"></i> Company account active</span>
                  <h2>Welcome back. Your dashboard is connected to live partner data.</h2>
                  <p>Control your bookings, trips, route schedules, seat inventory, staff permissions, payout balance, paid boosts, and customer support from one clean partner dashboard.</p>
                </div>
                <div class="heroActions">
                  <button class="btn btnPrimary" data-jump="listings"><i class="fa-solid fa-plus"></i> Add listing</button>
                  <button class="btn" data-jump="bookings"><i class="fa-solid fa-ticket"></i> View bookings</button>
                  <button class="btn" data-jump="payouts"><i class="fa-solid fa-wallet"></i> Payouts</button>
                </div>
              </div>

              <div class="livePanel">
                <div class="liveHeader">
                  <strong>Live status</strong>
                  <span class="badge ok"><span class="pulse"></span> Online</span>
                </div>
                <div class="liveList">
                  <div class="liveItem"><span>Bookings today</span><strong>184</strong></div>
                  <div class="liveItem"><span>Seats on hold</span><strong>27</strong></div>
                  <div class="liveItem"><span>Upcoming trips</span><strong>16</strong></div>
                  <div class="liveItem"><span>Open support cases</span><strong>5</strong></div>
                </div>
              </div>
            </div>

            <div class="statsGrid">
              <article class="statCard">
                <div class="statTop"><div class="statIcon"><i class="fa-solid fa-money-bill-trend-up"></i></div><span class="trend"><i class="fa-solid fa-arrow-trend-up"></i> 11%</span></div>
                <div class="statNumber">UGX 76.5M</div>
                <div class="statLabel">Partner earnings</div>
              </article>
              <article class="statCard">
                <div class="statTop"><div class="statIcon"><i class="fa-solid fa-ticket"></i></div><span class="trend"><i class="fa-solid fa-arrow-trend-up"></i> 8%</span></div>
                <div class="statNumber">2,482</div>
                <div class="statLabel">Confirmed bookings</div>
              </article>
              <article class="statCard">
                <div class="statTop"><div class="statIcon"><i class="fa-solid fa-chair"></i></div><span class="trend"><i class="fa-solid fa-arrow-trend-up"></i> 6%</span></div>
                <div class="statNumber">83%</div>
                <div class="statLabel">Average seat fill rate</div>
              </article>
              <article class="statCard">
                <div class="statTop"><div class="statIcon"><i class="fa-solid fa-star"></i></div><span class="trend"><i class="fa-solid fa-arrow-trend-up"></i> 4.8</span></div>
