        overview:['Company Employee Dashboard','Work dashboard for ticket checkers, booking agents, receptionists, finance staff, and route managers.'],
        checkin:['Ticket Check-in','Scan tickets, verify passengers, check in customers, and handle no-shows.'],
        bookings:['Bookings Desk','Create, update, print, and manage customer bookings.'],
        schedule:['Schedules','View trips, departure times, vehicles, rooms, and delays.'],
        inventory:['Seats / Rooms','Manage seat maps, rooms, held inventory, and passenger movement.'],
        customers:['Customers','Search customers, booking history, receipts, and support records.'],
        payments:['Payments','View payments, receipts, unpaid bookings, and cashier totals.'],
        refunds:['Refund Requests','Handle refund requests based on employee permissions.'],
        support:['Support Tasks','Resolve assigned support tickets and customer issues.'],
        handover:['Shift Handover','Create handover notes for the next employee or manager.'],
        reports:['My Reports','Download employee activity and shift reports.'],
        profile:['My Profile','View employee profile, branch, role, and permissions.']
      };

      function badge(status){
        const s = String(status).toLowerCase();
        let cls = 'info';
        if(['paid','active','verified','settled','healthy','published','running','boarding','open','checked in','completed','allowed','approved','resolved'].some(x=>s.includes(x))) cls='ok';
        if(['hold','pending','review','waiting','paused','delayed','tomorrow','manager','not checked','in progress'].some(x=>s.includes(x))) cls='warn';
        if(['refund','cancelled','suspended','urgent','denied','rejected'].some(x=>s.includes(x))) cls='bad';
        return `<span class="badge ${cls}">${escapeHtml(status)}</span>`;
      }

      function initials(name){
        return String(name).split(' ').map(x=>x[0]).join('').slice(0,2).toUpperCase();
      }

      function rowMeta(row){
        const last = Array.isArray(row) ? row[row.length - 1] : null;
        return last && typeof last === 'object' && !Array.isArray(last) ? last : null;
      }

      function rowCells(row){
        const meta = rowMeta(row);
        return meta ? row.slice(0, -1) : row;
      }

      function actions(label, meta = null){
        const safeLabel = escapeHtml(label);
        const safeId = meta?.id ? encodeURIComponent(meta.id) : '';
        const detailAttr = meta?.detail ? ` data-row-detail="${escapeHtml(encodeURIComponent(JSON.stringify(meta.detail)))}"` : '';
        const rowJson = meta?.detail ? escapeHtml(encodeURIComponent(JSON.stringify(meta.detail))) : '';
        const status = String(meta?.status || '').toLowerCase();
        const rowActions = Array.isArray(meta?.actions) ? meta.actions : [];
        const viewBtn = `<button class="tinyBtn" data-modal="view" data-type="${safeLabel}"${detailAttr} title="View full record"><i class="fa-regular fa-eye"></i></button>`;
        const exportBtn = rowJson ? `<button class="tinyBtn" data-export-row="${rowJson}" data-export-name="${safeLabel}" title="Export this row as PDF"><i class="fa-solid fa-file-pdf"></i></button>` : '';
        const disabled = (reason) => `<button class="tinyBtn" type="button" disabled title="${escapeHtml(reason)}"><i class="fa-solid fa-lock"></i></button>`;

        if(meta?.entity === 'checkin' || meta?.entity === 'booking'){
          const checked = status === 'checked_in' || status === 'completed';
          const invalid = ['cancelled','refunded','voided','no_show'].includes(status);
          const checkDisabled = checked || invalid;
          const noShowDisabled = checked || ['cancelled','refunded','voided','completed','no_show'].includes(status);
          return `<div class="rowActions">
            ${viewBtn}
            <form method="POST" action="/employee/bookings/${safeId}/check-in" style="margin:0">
              <input type="hidden" name="_csrf" value="${csrfToken}">
              <button class="tinyBtn ${checkDisabled ? '' : 'ok'}" type="submit" title="${checkDisabled ? 'Check-in unavailable for this status' : 'Check in'}" ${checkDisabled ? 'disabled' : ''}><i class="fa-solid fa-qrcode"></i></button>
            </form>
            <form method="POST" action="/employee/bookings/${safeId}/no-show" style="margin:0">
              <input type="hidden" name="_csrf" value="${csrfToken}">
              <button class="tinyBtn ${noShowDisabled ? '' : 'bad'}" type="submit" title="${noShowDisabled ? 'No-show unavailable for this status' : 'Mark no-show'}" ${noShowDisabled ? 'disabled' : ''}><i class="fa-solid fa-user-xmark"></i></button>
            </form>
            ${exportBtn}
          </div>`;
        }
        if(meta?.entity === 'support'){
          return `<div class="rowActions">
            ${viewBtn}
            <form method="POST" action="/employee/support/${safeId}" style="margin:0">
              <input type="hidden" name="_csrf" value="${csrfToken}">
              <input type="hidden" name="status" value="resolved">
              <button class="tinyBtn ok" type="submit" title="Resolve support task"><i class="fa-solid fa-circle-check"></i></button>
            </form>
            ${exportBtn}
          </div>`;
        }
        if(meta?.entity === 'payment'){
          return `<div class="rowActions">${viewBtn}<button class="tinyBtn" data-modal="create" data-type="payment" title="Record related payment"><i class="fa-solid fa-money-bill-transfer"></i></button>${exportBtn}</div>`;
        }
        if(meta?.entity === 'refund'){
          return `<div class="rowActions">${viewBtn}<button class="tinyBtn" data-modal="create" data-type="refund" title="Prepare refund request"><i class="fa-solid fa-rotate-left"></i></button>${exportBtn}</div>`;
        }
        if(meta?.entity === 'customer'){
          return `<div class="rowActions">${viewBtn}<button class="tinyBtn" data-modal="create" data-type="customer note" title="Add customer note"><i class="fa-solid fa-note-sticky"></i></button>${exportBtn}</div>`;
        }
        if(meta?.entity === 'schedule'){
          return `<div class="rowActions">${viewBtn}<button class="tinyBtn" data-modal="create" data-type="delay notice" title="Send delay notice"><i class="fa-solid fa-bell"></i></button>${exportBtn}</div>`;
        }
        if(meta?.entity === 'inventory'){
          return `<div class="rowActions">${viewBtn}<button class="tinyBtn" data-modal="edit" data-type="seat or room" title="Update seat or room"><i class="fa-solid fa-chair"></i></button>${exportBtn}</div>`;
        }
        if(rowActions.length && !rowActions.includes('edit')){
          return `<div class="rowActions">${viewBtn}${exportBtn}${disabled('No direct action is available for this record in the employee role')}</div>`;
        }
        return `<div class="rowActions">${viewBtn}${exportBtn}${disabled('Action hidden until a safe backend endpoint exists')}</div>`;
      }

      function emptyRow(cols, text='No matching records found'){
        return `<tr><td colspan="${cols}" style="text-align:center;color:var(--muted);border-radius:16px;border:1px solid var(--line2);background:var(--table);padding:18px">${text}</td></tr>`;
      }

      function renderRows(tbody, rows, opts = {}){
        if(!tbody) return;
        const cols = opts.cols || 7;
        if(!rows.length){ tbody.innerHTML = emptyRow(cols); return; }
        tbody.innerHTML = rows.map((r)=>{
          const meta = rowMeta(r);
          const row = rowCells(r);
          const first = opts.avatar ? `<div class="nameCell"><div class="miniLogo">${escapeHtml(initials(row[0]))}</div><div><strong>${escapeHtml(row[0])}</strong><span>${escapeHtml(row[1] || '')}</span></div></div>` : escapeHtml(row[0]);
          const cells = row.map((cell, i)=>{
            if(i === 0) return `<td>${first}</td>`;
            if(opts.statusIndex === i) return `<td>${badge(cell)}</td>`;
            return `<td>${escapeHtml(cell)}</td>`;
          }).join('');
          return `<tr>${cells}<td>${actions(row[0], meta)}</td></tr>`;
        }).join('');
      }

      function renderEmployeeShell(){
        const profile = data.profile || {};
        const stats = data.stats || {};
        const name = profile.fullName || 'Company employee';
        const role = profile.roleTitle || 'Ticket Checker';
        const avatar = $('.avatar');
        const profileName = $('.profileMeta strong');
        const profileStatus = $('.profileMeta span');
        if(avatar) avatar.textContent = initials(name);
        if(profileName) profileName.textContent = name;
        if(profileStatus) profileStatus.textContent = `${role} ${profile.branch || ''}`.trim();

        const welcomeTitle = $('.welcome h2');
        const welcomeText = $('.welcome p');
        if(welcomeTitle) welcomeTitle.textContent = `Welcome ${name}. Your desk has ${stats.openTasks || data.tasks.length} tasks waiting today.`;
        if(welcomeText) welcomeText.textContent = `Handle bookings, check-ins, inventory, notices, payments, refunds, support, and handovers for ${data.company?.name || 'your company'}.`;

        const liveItems = $$('.liveList .liveItem');
        [
          ['Tickets checked today', stats.checkedIn || data.checkins.filter(row => /checked/i.test(String(rowCells(row)[5] || ''))).length],
          ['Manual bookings', stats.manualBookings || data.bookings.filter(row => /employee/i.test(String(rowCells(row)[7] || ''))).length],
          ['Open tasks', stats.openTasks || data.tasks.length],
          ['Shift ends', stats.shiftEnds || '6:00 PM']
        ].forEach(([label, value], index) => {
          const item = liveItems[index];
          if(!item) return;
          const span = item.querySelector('span');
          const strong = item.querySelector('strong');
          if(span) span.textContent = label;
          if(strong) strong.textContent = value;
        });

        const statCards = $$('.statsGrid .statCard');
        [
          [stats.checkedIn || '0', 'Tickets checked'],
          [stats.manualBookings || '0', 'Manual bookings'],
          [stats.openTasks || '0', 'Support tasks handled'],
          [stats.deskSales || 'UGX 0', 'Desk sales today']
        ].forEach(([value, label], index) => {
          const card = statCards[index];
          if(!card) return;
          const number = card.querySelector('.statNumber');
          const statLabel = card.querySelector('.statLabel');
          if(number) number.textContent = value;
          if(statLabel) statLabel.textContent = label;
        });

        const profileForm = $('#profileForm');
        const unnamedShift = profileForm?.querySelector('input:not([type="hidden"]):not([name])');
        if(unnamedShift) unnamedShift.name = 'shift';
        const fullNameInput = profileForm?.querySelector('[name="fullName"]');
        const roleInput = profileForm?.querySelector('[name="roleTitle"]');
        const branchInput = profileForm?.querySelector('[name="branch"]');
        const shiftInput = profileForm?.querySelector('[name="shift"]');
        const notesInput = profileForm?.querySelector('[name="notes"]');
        if(fullNameInput) fullNameInput.value = name;
        if(roleInput) roleInput.value = role;
        if(branchInput) branchInput.value = profile.branch || '';
        if(shiftInput) shiftInput.value = profile.shift || shiftInput.value;
        if(notesInput) notesInput.value = profile.notes || notesInput.value;
      }

      function renderAll(){
        renderEmployeeShell();
        renderRows($('#tasksTable'), data.tasks, {statusIndex:4, cols:7});
        renderRows($('#checkinTable'), data.checkins, {statusIndex:5, cols:7});
        renderRows($('#bookingsTable'), data.bookings, {statusIndex:5, cols:8});
        renderRows($('#scheduleToday'), data.schedules, {statusIndex:5, cols:7});
        renderRows($('#inventoryTable'), data.inventory, {statusIndex:6, cols:8});
        renderRows($('#customersTable'), data.customers, {avatar:true, statusIndex:5, cols:7});
        renderRows($('#paymentsTable'), data.payments, {statusIndex:5, cols:7});
        renderRows($('#refundsTable'), data.refunds, {statusIndex:5, cols:7});
        renderRows($('#supportTable'), data.support, {statusIndex:4, cols:7});
        renderRows($('#handoverTable'), data.handovers, {statusIndex:3, cols:5});

        $$('[data-filter-table]').forEach(tbody => {
          const table = tbody.dataset.filterTable;
          const filter = tbody.dataset.filter;
          let rows = [];
          if(table === 'bookings-status') rows = data.bookings.filter(r => String(rowCells(r)[5]).toLowerCase().includes(String(filter).toLowerCase()));
          if(table === 'schedules-status') rows = data.schedules.filter(r => String(rowCells(r)[5]).toLowerCase().includes(String(filter).toLowerCase()));
          if(table === 'refunds-status') rows = data.refunds.filter(r => String(rowCells(r)[5]).toLowerCase().includes(String(filter).toLowerCase()));

          if(table.startsWith('bookings')) renderRows(tbody, rows, {statusIndex:5, cols:8});
          if(table.startsWith('schedules')) renderRows(tbody, rows, {statusIndex:5, cols:7});
          if(table.startsWith('refunds')) renderRows(tbody, rows, {statusIndex:5, cols:7});
        });
        enhanceTablesOnce();
      }

      function tableName(table){
        const card = table.closest('.card');
        return card?.querySelector('.cardTitle h3')?.textContent?.trim() || 'table';
      }

      function uniqueStatuses(table){
        const values = new Set();
        table.querySelectorAll('tbody tr').forEach(row => {
          const badgeText = row.querySelector('.badge')?.textContent?.trim();
          if(badgeText) values.add(badgeText);
        });
        return Array.from(values).sort();
      }

      function filterTable(table){
        const tools = table.closest('.card')?.querySelector(`.tableTools[data-for="${table.dataset.toolId}"]`);
        if(!tools) return;
        const q = tools.querySelector('[data-table-search]')?.value?.toLowerCase().trim() || '';
        const status = tools.querySelector('[data-table-status]')?.value?.toLowerCase().trim() || '';
        const date = tools.querySelector('[data-table-date]')?.value || '';
        table.querySelectorAll('tbody tr').forEach(row => {
          const text = row.textContent.toLowerCase();
          const badgeText = row.querySelector('.badge')?.textContent?.toLowerCase().trim() || '';
          const matches = (!q || text.includes(q)) && (!status || badgeText.includes(status)) && (!date || text.includes(date));
          row.style.display = matches ? '' : 'none';
        });
      }

      function csvEscape(value){
        const text = String(value ?? '').replace(/\s+/g, ' ').trim();
        return /[\",\n]/.test(text) ? `"${text.replace(/"/g, '""')}"` : text;
      }

      function exportTableCsv(table){
        const headers = Array.from(table.querySelectorAll('thead th')).map(th => th.textContent.trim()).filter(Boolean);
        const rows = Array.from(table.querySelectorAll('tbody tr')).filter(row => row.style.display !== 'none').map(row => Array.from(row.children).slice(0, headers.length).map(td => td.textContent.trim()));
        const csv = [headers, ...rows].map(row => row.map(csvEscape).join(',')).join('\n');
        const blob = new Blob([csv], { type: 'text/csv;charset=utf-8' });
        const a = document.createElement('a');
        a.href = URL.createObjectURL(blob);
        a.download = `${tableName(table).toLowerCase().replace(/[^a-z0-9]+/g, '-') || 'employee-table'}.csv`;
        document.body.appendChild(a);
        a.click();
        URL.revokeObjectURL(a.href);
        a.remove();
        showToast('CSV export downloaded');
      }

      function exportRowPdf(encoded, name){
        try{
          const detail = JSON.parse(decodeURIComponent(encoded));
          const title = String(name || 'employee-record');
          const win = window.open('', '_blank', 'noopener,noreferrer,width=900,height=720');
          if(!win){ showToast('Allow popups to export PDF'); return; }
          const body = detailMarkup(detail || {});
          win.document.write(`<!doctype html><html><head><meta charset="utf-8"><title>${escapeHtml(title)} PDF</title><style>
            body{font-family:Inter,Arial,sans-serif;margin:28px;color:#111827;background:#fff}.brand{display:flex;justify-content:space-between;gap:16px;border-bottom:2px solid #e5e7eb;padding-bottom:14px;margin-bottom:18px}.brand h1{font-size:22px;margin:0}.brand p{margin:4px 0 0;color:#6b7280}.detailGroup{break-inside:avoid;margin:0 0 16px}.detailGroup h4{font-size:14px;margin:0 0 8px;color:#111827}.detailGrid{display:grid;grid-template-columns:repeat(3,1fr);gap:8px}.detailItem{border:1px solid #e5e7eb;border-radius:10px;padding:8px;min-width:0}.detailItem span{display:block;font-size:9px;letter-spacing:.06em;text-transform:uppercase;color:#6b7280;font-weight:800}.detailItem b{display:block;font-size:12px;word-break:break-word}.detailItem.full{grid-column:1/-1}@media print{button{display:none}body{margin:14mm}}
          </style></head><body><div class="brand"><div><h1>Classic Trip Employee Record</h1><p>${escapeHtml(title)} · ${new Date().toLocaleString()}</p></div><button onclick="window.print()">Print / Save PDF</button></div>${body}<script>setTimeout(()=>window.print(),300)<\/script></body></html>`);
          win.document.close();
          showToast('PDF export opened');
        } catch(error){
          showToast('Could not export this row as PDF');
        }
      }

      function enhanceTablesOnce(){
        $$('table').forEach((table, index) => {
          const wrap = table.closest('.tableWrap');
          const card = table.closest('.card');
          if(!wrap || !card) return;
          if(!table.dataset.toolId) table.dataset.toolId = `employee-table-${index}`;
          if(card.querySelector(`.tableTools[data-for="${table.dataset.toolId}"]`)) return;
          const tools = document.createElement('div');
          tools.className = 'tableTools';
          tools.dataset.for = table.dataset.toolId;
          tools.innerHTML = `
            <div class="control tableSearch"><i class="fa-solid fa-magnifying-glass"></i><input data-table-search placeholder="Search ${escapeHtml(tableName(table))}"></div>
            <div class="control"><i class="fa-solid fa-filter"></i><select data-table-status><option value="">All statuses</option>${uniqueStatuses(table).map(status => `<option value="${escapeHtml(status)}">${escapeHtml(status)}</option>`).join('')}</select></div>
            <div class="control"><i class="fa-regular fa-calendar"></i><input data-table-date type="date"></div>
            <button class="btn" type="button" data-table-export><i class="fa-solid fa-file-csv"></i> CSV</button>
          `;
          card.insertBefore(tools, wrap);
          tools.addEventListener('input', () => filterTable(table));
          tools.addEventListener('change', () => filterTable(table));
          tools.querySelector('[data-table-export]')?.addEventListener('click', () => exportTableCsv(table));
        });
      }

      function openPage(page){
        currentPage = page || 'overview';
        $$('.section').forEach(s => s.classList.remove('is-open'));
        const section = $('#' + page);
        if(section) section.classList.add('is-open');

        $$('.navBtn').forEach(b => b.classList.toggle('is-active', b.dataset.page === page));
        const meta = pageMeta[page] || pageMeta.overview;
        els.pageHeading.textContent = meta[0];
        els.pageSub.textContent = meta[1];

        document.body.classList.remove('menu-open');
        requestAnimationFrame(() => {
          window.scrollTo({ top: 0, behavior: 'auto' });
          setTimeout(() => window.scrollTo({ top: 0, behavior: 'auto' }), 30);
        });
      }

      function showToast(text){
        els.toastText.textContent = text;
        els.toast.classList.add('show');
        clearTimeout(showToast.t);
        showToast.t = setTimeout(() => els.toast.classList.remove('show'), 2300);
      }

      function escapeHtml(value){
        return String(value ?? '').replace(/[&<>"']/g, char => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[char]));
      }

      function money(value, currency){
        const amount = Number(value || 0);
        if(!amount) return currency ? `${currency} 0` : '0';
        return `${currency || ''} ${Math.round(amount).toLocaleString()}`.trim();
      }

      function fmtDate(value){
        if(!value) return '-';
        const date = new Date(value);
        return Number.isNaN(date.getTime()) ? String(value) : date.toLocaleString([], {year:'numeric', month:'short', day:'2-digit', hour:'2-digit', minute:'2-digit'});
      }

      function bookingRowFromScan(result){
        const detail = result.detail || {};
        const booking = detail.booking || result.booking || {};
        const customer = detail.customer || booking.guestSnapshot || {};
        const service = detail.service || result.listing || {};
        const seat = (booking.seats || [])[0] || (booking.passengers || [])[0]?.seatOrRoom || 'Selected';
        const checkedAt = detail.checkIn?.checkedInAt ? fmtDate(detail.checkIn.checkedInAt) : 'Pending';
        return [
          booking.bookingRef || 'Ticket',
          customer.name || customer.fullName || 'Guest customer',
          service.name || service.title || booking.serviceType || 'Classic Trip service',
          seat,
          checkedAt,
          booking.bookingStatus === 'checked_in' ? 'Checked in' : booking.bookingStatus || result.result || 'Review',
          { entity: 'checkin', id: booking.bookingRef, label: booking.bookingRef, status: booking.bookingStatus, detail }
        ];
      }

      function detailItem(label, value){
        return `<div class="detailItem"><span>${escapeHtml(label)}</span><b title="${escapeHtml(formatDetailValue(value))}">${escapeHtml(formatDetailValue(value))}</b></div>`;
      }

      function detailGroup(title, items){
        return `<div class="detailGroup"><h4>${escapeHtml(title)}</h4><div class="detailGrid">${items.map(([label, value]) => detailItem(label, value)).join('')}</div></div>`;
      }

      function humanize(key){
        return String(key || '')
          .replace(/([a-z0-9])([A-Z])/g, '$1 $2')
          .replace(/[_-]+/g, ' ')
          .replace(/\s+/g, ' ')
          .trim()
          .replace(/^./, char => char.toUpperCase());
      }

      function formatDetailValue(value){
        if(value === null || typeof value === 'undefined' || value === '') return '-';
        if(Array.isArray(value)){
          if(!value.length) return '-';
          if(value.every(item => ['string','number','boolean'].includes(typeof item))) return value.join(', ');
          return `${value.length} item${value.length === 1 ? '' : 's'}`;
        }
        if(typeof value === 'object') return JSON.stringify(value);
        const text = String(value);
        if(/^\d{4}-\d{2}-\d{2}T/.test(text)) return fmtDate(text);
        return text;
      }

      function objectEntriesForDetails(obj){
        if(!obj || typeof obj !== 'object') return [];
        return Object.entries(obj).filter(([, value]) => typeof value !== 'undefined' && value !== null && value !== '');
      }

      function detailMarkup(detail = {}){
        const groups = objectEntriesForDetails(detail);
        if(!groups.length) return '<div class="notice">No extra details are available for this record yet.</div>';
        return `<div class="detailBlock">${groups.map(([groupName, groupValue]) => {
          if(Array.isArray(groupValue)){
            const summaryItems = groupValue.slice(0, 8).map((item, index) => [String(index + 1), typeof item === 'object' ? JSON.stringify(item) : item]);
            return detailGroup(humanize(groupName), summaryItems.length ? summaryItems : [['Items', 'None']]);
          }
          if(groupValue && typeof groupValue === 'object'){
            return detailGroup(humanize(groupName), objectEntriesForDetails(groupValue).map(([key, value]) => [humanize(key), value]));
          }
          return detailGroup(humanize(groupName), [[humanize(groupName), groupValue]]);
        }).join('')}</div>`;
      }

      function setCheckButtons(result = {}){
        currentScan = result && result.booking ? result : null;
        const canCheckIn = Boolean(result.canCheckIn || (result.ok && result.result === 'ready'));
        const checkTitle = canCheckIn ? 'Mark this booking as checked in' : (result.disabledReason || result.message || 'Lookup a valid paid ticket first');
        [els.btnCheckIn, els.btnCheckInBottom].forEach(btn => {
          if(!btn) return;
          btn.disabled = !canCheckIn;
          btn.title = checkTitle;
        });
        const status = String(result.detail?.booking?.bookingStatus || result.booking?.bookingStatus || '').toLowerCase();
        const noShowDisabled = !result.booking || ['checked_in','completed','cancelled','refunded','voided'].includes(status);
        [els.btnNoShow, els.btnNoShowBottom].forEach(btn => {
          if(!btn) return;
          btn.disabled = noShowDisabled;
          btn.title = noShowDisabled ? 'No-show is unavailable for this ticket status' : 'Mark this passenger as no-show';
        });
      }

      function renderScanResult(result, ok){
        if(!els.scannerResult) return;
        const detail = result.detail || {};
        const booking = detail.booking || result.booking || {};
        const customer = detail.customer || booking.guestSnapshot || {};
        const service = detail.service || result.listing || {};
        const payment = detail.payment || {};
        const statusOk = Boolean(ok && !result.disabledReason);
        els.scannerResult.className = `scanResult ${statusOk ? 'is-ok' : 'is-bad'}`;
        els.scannerResult.innerHTML = `
          <div style="display:flex;align-items:center;justify-content:space-between;gap:10px;flex-wrap:wrap">
            <span class="badge ${statusOk ? 'ok' : 'bad'}"><i class="fa-solid ${statusOk ? 'fa-circle-check' : 'fa-triangle-exclamation'}"></i> ${escapeHtml(result.message || result.disabledReason || result.result || 'Scanner result')}</span>
            <div style="display:flex;gap:8px;flex-wrap:wrap">
              ${booking.bookingRef ? `<button class="btn" type="button" data-copy-value="${escapeHtml(booking.bookingRef)}"><i class="fa-regular fa-copy"></i> Copy ref</button>` : ''}
              ${booking.bookingRef ? `<a class="btn" href="/tickets/${encodeURIComponent(booking.bookingRef)}" target="_blank" rel="noopener"><i class="fa-solid fa-ticket"></i> Open ticket</a>` : ''}
            </div>
          </div>
          <div class="scanGrid">
            <div class="scanItem"><span>Booking</span><b>${escapeHtml(booking.bookingRef || '-')}</b></div>
            <div class="scanItem"><span>Customer</span><b>${escapeHtml(customer.name || customer.fullName || '-')}</b></div>
            <div class="scanItem"><span>Service</span><b>${escapeHtml(service.name || service.title || booking.serviceType || '-')}</b></div>
            <div class="scanItem"><span>Seats</span><b>${escapeHtml((booking.seats || []).join(', ') || '-')}</b></div>
            <div class="scanItem"><span>Payment</span><b>${escapeHtml(payment.status || booking.paymentStatus || '-')}</b></div>
            <div class="scanItem"><span>Status</span><b>${escapeHtml(booking.bookingStatus || '-')}</b></div>
          </div>
          ${detailMarkup(detail)}
        `;
        setCheckButtons(result);
      }

      async function postScanner(endpoint, value){
        const code = String(value || '').trim();
        if(!code){
          showToast('Enter a booking reference, QR value, email, phone, payment ref, or seat first');
          els.checkSearch?.focus();
          return null;
        }
        const response = await fetch(endpoint, {
          method:'POST',
          headers:{'Content-Type':'application/json'},
          body:JSON.stringify({ qrCodeValue: code, bookingRef: code, query: code, note: els.checkNote?.value || '' })
        });
        const result = await response.json();
        renderScanResult(result, response.ok);
        return { response, result };
      }

      async function lookupTicketFromDashboard(value){
        const oldLabel = els.btnLookupTicket?.innerHTML;
        try{
          if(els.btnLookupTicket){ els.btnLookupTicket.disabled = true; els.btnLookupTicket.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Searching'; }
          const payload = await postScanner('/employee/scanner/lookup', value);
          if(!payload) return;
          showToast(payload.response.ok ? 'Ticket found' : (payload.result.message || 'Ticket not found'));
        } catch(error){
          renderScanResult({ message: error.message || 'Scanner lookup failed' }, false);
          showToast('Scanner lookup failed');
        } finally {
          if(els.btnLookupTicket){ els.btnLookupTicket.disabled = false; els.btnLookupTicket.innerHTML = oldLabel; }
        }
      }

      async function validateTicketFromDashboard(value){
        const oldLabel = els.btnCheckIn?.innerHTML;
        try{
          if(els.btnCheckIn){ els.btnCheckIn.disabled = true; els.btnCheckIn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Checking in'; }
          const payload = await postScanner('/employee/scanner/validate', value);
          if(!payload) return;
          if(payload.response.ok){
            data.checkins = [bookingRowFromScan(payload.result)].concat(data.checkins.filter(row => rowCells(row)[0] !== payload.result.detail?.booking?.bookingRef));
            renderRows($('#checkinTable'), data.checkins, {statusIndex:5, cols:7});
            showToast('Ticket checked in successfully');
          } else {
            showToast(payload.result.message || 'Ticket could not be checked in');
          }
        } catch(error){
          renderScanResult({ message: error.message || 'Scanner request failed' }, false);
          showToast('Scanner request failed');
        } finally {
          if(els.btnCheckIn){ els.btnCheckIn.innerHTML = oldLabel; setCheckButtons(currentScan || {}); }
        }
      }

      async function markNoShowFromDashboard(value){
        const oldLabel = els.btnNoShow?.innerHTML;
        try{
          if(els.btnNoShow){ els.btnNoShow.disabled = true; els.btnNoShow.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Saving'; }
          const payload = await postScanner('/employee/scanner/no-show', value);
          if(!payload) return;
          if(payload.response.ok){
            data.checkins = [bookingRowFromScan(payload.result)].concat(data.checkins.filter(row => rowCells(row)[0] !== payload.result.detail?.booking?.bookingRef));
            renderRows($('#checkinTable'), data.checkins, {statusIndex:5, cols:7});
            showToast('Booking marked as no-show');
          } else {
            showToast(payload.result.message || 'No-show could not be saved');
          }
        } catch(error){
          renderScanResult({ message: error.message || 'No-show request failed' }, false);
          showToast('No-show request failed');
        } finally {
          if(els.btnNoShow){ els.btnNoShow.innerHTML = oldLabel; setCheckButtons(currentScan || {}); }
        }
      }

      function bookingPreviewUrl(){
        const listings = Array.isArray(data.options?.listings) ? data.options.listings : [];
        const first = listings.find(item => item && (item.slug || item.id || item.value));
        const serviceType = first?.serviceType || first?.type || 'bus';
        const slug = first?.slug || first?.id || first?.value;
        return slug ? `/listings/${encodeURIComponent(serviceType)}/${encodeURIComponent(slug)}` : '/search';
      }

      function openExistingBookingPreview(){
        window.location.href = bookingPreviewUrl();
      }

      async function startCameraScanner(){
        if(!els.scannerBox) return;
        els.scannerBox.classList.add('is-open');
        if(els.scannerStatus) els.scannerStatus.innerHTML = '<i class="fa-solid fa-camera"></i> Requesting camera permission';
        const qrReader = $('#qrReader');
        if(qrReader) qrReader.innerHTML = '<div class="qrPlaceholder"><i class="fa-solid fa-spinner fa-spin"></i><span>Opening camera...</span></div>';

        if(!window.isSecureContext && !['localhost','127.0.0.1'].includes(location.hostname)){
          if(els.scannerStatus) els.scannerStatus.innerHTML = '<i class="fa-solid fa-lock"></i> Camera needs HTTPS';
          showToast('Camera access requires HTTPS or localhost. Manual lookup still works.');
          return;
        }
        if(!navigator.mediaDevices?.getUserMedia){
          if(els.scannerStatus) els.scannerStatus.innerHTML = '<i class="fa-solid fa-triangle-exclamation"></i> Browser camera unavailable';
          showToast('This browser does not expose camera access. Manual lookup still works.');
          return;
        }

        try{
          await stopCameraScanner(false);
          const scanner = window.ClassicTripQrScanner;
          if(!scanner){ throw new Error('Local QR scanner script did not load'); }
          cameraStream = await scanner.start('qrReader', {
            onStatus(message){ if(els.scannerStatus) els.scannerStatus.innerHTML = `<i class="fa-solid fa-camera"></i> ${escapeHtml(message)}`; },
            onDecode(decodedText){
              if(decodedText && decodedText !== lastScannedValue){
                lastScannedValue = decodedText;
                if(els.checkSearch) els.checkSearch.value = decodedText;
                if(els.scannerStatus) els.scannerStatus.innerHTML = '<i class="fa-solid fa-circle-check"></i> QR scanned';
                lookupTicketFromDashboard(decodedText);
              }
            }
          });
          if(els.scannerStatus) els.scannerStatus.innerHTML = '<i class="fa-solid fa-camera"></i> Camera open and scanning';
        } catch(error){
          if(els.scannerStatus) els.scannerStatus.innerHTML = '<i class="fa-solid fa-triangle-exclamation"></i> Camera unavailable';
          if(qrReader) qrReader.innerHTML = '<div class="qrPlaceholder"><i class="fa-solid fa-triangle-exclamation"></i><span>Camera could not start. Check browser permission, HTTPS/localhost, and whether another app is using the camera.</span></div>';
          showToast(error?.message || 'Camera scanner could not start. Check browser camera permission.');
        }
      }

      async function stopCameraScanner(closeBox = true){
        try{
          if(window.ClassicTripQrScanner) await window.ClassicTripQrScanner.stop();
        } catch(error){/* ignore stop errors */}
        try{
          if(html5Qr && html5Qr.isScanning) await html5Qr.stop();
        } catch(error){/* ignore stop errors */}
        if(barcodeTimer){ window.clearInterval(barcodeTimer); barcodeTimer = null; }
        if(cameraStream && cameraStream.getTracks){ cameraStream.getTracks().forEach(track => track.stop()); }
        cameraStream = null;
        const qrReader = $('#qrReader');
        if(qrReader) qrReader.innerHTML = '<div class="qrPlaceholder"><i class="fa-solid fa-camera"></i><span>Press Open QR scanner to start the camera.</span></div>';
        if(closeBox && els.scannerBox) els.scannerBox.classList.remove('is-open');
      }

      function formConfigFor(type){
        const key = String(type || '').toLowerCase();
        const listingOptions = optionItems(data.options.listings, 'Select listing');
        const scheduleOptions = optionItems(data.options.schedules, 'Optional schedule');
        const roomOptions = optionItems(data.options.rooms, 'Optional room');
        if(key.includes('manual booking') || key.includes('employee item')){
          return {
            action:'/employee/bookings',
            fields:[
              {name:'listingId', label:'Listing', kind:'select', required:true, options:listingOptions, value:firstValue(data.options.listings)},
              {name:'scheduleId', label:'Schedule', kind:'select', options:scheduleOptions},
              {name:'roomId', label:'Room', kind:'select', options:roomOptions},
              {name:'seatNumber', label:'Seat number', placeholder:'A1'},
              {name:'fullName', label:'Customer name', required:true, placeholder:'Walk-in customer'},
              {name:'email', label:'Customer email', type:'email', placeholder:'customer@example.com'},
              {name:'phone', label:'Customer phone', placeholder:'+256700000000'},
              {name:'addons', label:'Add-ons', placeholder:'extra-luggage,sms-and-whatsapp-ticket'}
            ]
          };
        }
        if(key.includes('inventory') || key.includes('seat or room')){
          return {
            action:'/employee/inventory',
            fields:[
              {name:'scheduleId', label:'Schedule for seat update', kind:'select', options:scheduleOptions},
              {name:'seatNumber', label:'Seat number', placeholder:'A1'},
              {name:'status', label:'Status', kind:'select', options:[{value:'available',label:'Available'},{value:'blocked',label:'Blocked'},{value:'locked',label:'Held'},{value:'taken',label:'Booked'}], value:'blocked'},
              {name:'roomId', label:'Room for room update', kind:'select', options:roomOptions},
              {name:'inventory', label:'Room stock', type:'number', placeholder:'4'},
              {name:'note', label:'Internal note', kind:'textarea', placeholder:'Why inventory changed'}
            ]
          };
        }
        if(key.includes('delay')){
          return {
            action:'/employee/schedules/delay',
            fields:[
              {name:'scheduleId', label:'Schedule', kind:'select', required:true, options:scheduleOptions, value:firstValue(data.options.schedules)},
              {name:'priority', label:'Priority', kind:'select', options:[{value:'normal',label:'Normal'},{value:'high',label:'High'},{value:'urgent',label:'Urgent'}], value:'high'},
              {name:'message', label:'Notice message', kind:'textarea', required:true, placeholder:'Write the delay notice customers should receive'}
            ]
          };
        }
        if(key.includes('payment')){
          return {
            action:'/employee/payments',
            fields:[
              {name:'bookingRef', label:'Booking reference', required:true, placeholder:'CT-BUS-0001'},
              {name:'method', label:'Method', kind:'select', options:[{value:'cash',label:'Cash'},{value:'mobile_money',label:'Mobile money'},{value:'card',label:'Card'}], value:'cash'},
              {name:'amount', label:'Amount', type:'number', placeholder:'85000'},
              {name:'status', label:'Status', kind:'select', options:[{value:'successful',label:'Successful'},{value:'pending',label:'Pending'},{value:'failed',label:'Failed'}], value:'successful'}
            ]
          };
        }
        if(key.includes('refund')){
          return {
            action:'/employee/refunds',
            fields:[
              {name:'bookingRef', label:'Booking reference', required:true, placeholder:'CT-BUS-0001'},
              {name:'amount', label:'Amount', type:'number', placeholder:'85000'},
              {name:'reason', label:'Reason', kind:'textarea', required:true, placeholder:'Explain why this refund is requested'}
            ]
          };
        }
        if(key.includes('customer note')){
          return {
            action:'/employee/support/customer-note',
            fields:[
              {name:'bookingRef', label:'Booking reference', placeholder:'CT-BUS-0001'},
              {name:'customerName', label:'Customer name', placeholder:'Customer name'},
              {name:'message', label:'Note', kind:'textarea', required:true, placeholder:'Write the customer note'}
            ]
          };
        }
        if(key.includes('support') || key.includes('notice')){
          return {
            action:'/employee/support/notice',
            fields:[
              {name:'bookingRef', label:'Booking reference', placeholder:'CT-BUS-0001'},
              {name:'audience', label:'Audience', placeholder:'Customers on selected trip'},
              {name:'priority', label:'Priority', kind:'select', options:[{value:'normal',label:'Normal'},{value:'high',label:'High'},{value:'urgent',label:'Urgent'}], value:'normal'},
              {name:'message', label:'Message', kind:'textarea', required:true, placeholder:'Write notice or support task'}
            ]
          };
        }
        if(key.includes('handover')){
          return {
            action:'/employee/handovers',
            fields:[
              {name:'shift', label:'Shift', placeholder:'Morning shift'},
              {name:'nextStaff', label:'Next staff', placeholder:'Next employee or manager'},
              {name:'note', label:'Important notes', kind:'textarea', required:true, placeholder:'Write shift handover notes'}
            ]
          };
        }
        if(key.includes('employee report')){
          return {
            action:'/employee/reports/custom',
            fields:[
              {name:'type', label:'Report type', kind:'select', options:[{value:'checkins',label:'Check-ins'},{value:'sales',label:'Sales'},{value:'support',label:'Support'},{value:'handovers',label:'Handovers'},{value:'inventory',label:'Inventory'},{value:'exceptions',label:'Exceptions'}], value:'checkins'}
            ]
          };
        }
        return null;
      }

      function ticketCheckForm(){
        return `
          <form class="formPanel" id="scannerModalForm">
            <div class="formGrid">
              <div class="field full"><label>QR value or booking reference</label><div class="control"><i class="fa-solid fa-qrcode"></i><input id="modalScanInput" placeholder="Paste QR payload or booking reference" required></div></div>
            </div>
            <div class="modalFooter">
              <button class="btn" type="button" data-close-modal>Cancel</button>
              <button class="btn btnPrimary" type="submit"><i class="fa-solid fa-qrcode"></i> Validate ticket</button>
            </div>
          </form>
        `;
      }

      function openDetailModal(title, detail){
        els.crudTitle.textContent = title || 'Full details';
        els.crudSub.textContent = 'Full available production fields from the existing dashboard record.';
        els.crudBody.innerHTML = `${detailMarkup(detail || {})}<div class="modalFooter"><button class="btn" type="button" data-close-modal>Close</button><button class="btn btnBlue" type="button" data-export-row="${escapeHtml(encodeURIComponent(JSON.stringify(detail || {})))}" data-export-name="${escapeHtml(title || 'employee-record')}"><i class="fa-solid fa-file-pdf"></i> Export PDF</button></div>`;
        els.crudModal.classList.add('is-open');
      }

      function openCrud(mode, type){
        const nice = String(type || 'record');
        if(nice === 'ticket check'){
          els.crudTitle.textContent = 'Scan ticket';
          els.crudSub.textContent = 'Validate a paid QR ticket once and mark it checked in.';
          els.crudBody.innerHTML = ticketCheckForm();
          els.crudModal.classList.add('is-open');
          setTimeout(() => $('#modalScanInput')?.focus(), 50);
          return;
        }
        const config = mode === 'view' ? null : formConfigFor(nice);
        if(config){
          els.crudTitle.textContent = mode === 'edit' ? `Edit ${nice}` : `Create ${nice}`;
          els.crudSub.textContent = 'Fill the details below. This action is connected to the employee backend.';
          els.crudBody.innerHTML = `
            <form class="formPanel" method="POST" action="${config.action}" data-dashboard-form>
              <input type="hidden" name="_csrf" value="${csrfToken}">
              <div class="formGrid">${config.fields.map(field => fieldHtml(field, false)).join('')}</div>
              <div class="modalFooter">
                <button class="btn" type="button" data-close-modal>Cancel</button>
                <button class="btn btnPrimary" type="submit"><i class="fa-solid fa-floppy-disk"></i> Save</button>
              </div>
            </form>
          `;
          els.crudModal.classList.add('is-open');
          return;
        }
        const title = mode === 'view' ? `View ${nice}` : mode === 'edit' ? `Edit ${nice}` : `Create ${nice}`;
        els.crudTitle.textContent = title;
        els.crudSub.textContent = mode === 'view' ? 'Preview this item before taking action.' : 'Fill the details below. This form follows the backend data model.';
        els.crudBody.innerHTML = `
          <form class="formPanel" data-dashboard-form>
            <div class="formGrid">
              <div class="field"><label>Name / reference</label><div class="control"><i class="fa-solid fa-pen"></i><input value="${mode === 'create' ? '' : nice}" placeholder="Enter reference" ${mode === 'view' ? 'readonly' : ''}></div></div>
              <div class="field"><label>Status</label><div class="control"><i class="fa-solid fa-toggle-on"></i><select ${mode === 'view' ? 'disabled' : ''}><option>Open</option><option>Pending</option><option>Completed</option><option>Review</option></select></div></div>
              <div class="field"><label>Customer</label><div class="control"><i class="fa-solid fa-user"></i><input placeholder="Customer name" ${mode === 'view' ? 'readonly' : ''}></div></div>
              <div class="field"><label>Amount</label><div class="control"><i class="fa-solid fa-coins"></i><input placeholder="UGX 85,000" ${mode === 'view' ? 'readonly' : ''}></div></div>
              <div class="field full"><label>Notes</label><div class="control"><textarea placeholder="Add employee notes..." ${mode === 'view' ? 'readonly' : ''}></textarea></div></div>
            </div>
            <div class="modalFooter">
              <button class="btn" type="button" data-close-modal>Cancel</button>
              ${mode === 'view' ? `<button class="btn btnBlue" type="button" data-close-modal>Done</button>` : `<button class="btn btnPrimary" type="submit"><i class="fa-solid fa-floppy-disk"></i> Save</button>`}
            </div>
          </form>
        `;
        els.crudModal.classList.add('is-open');
      }

      function closeModals(){
        $$('.modal').forEach(m => m.classList.remove('is-open'));
      }

      $('#sideNav').addEventListener('click', e => {
        const btn = e.target.closest('.navBtn');
        if(btn) openPage(btn.dataset.page);
      });

      $$('[data-jump]').forEach(btn => {
        btn.addEventListener('click', () => openPage(btn.dataset.jump));
      });

      document.addEventListener('click', e => {
        const tabBtn = e.target.closest('.tabBtn');
        if(tabBtn){
          const group = tabBtn.closest('[data-tabs]');
          const tab = tabBtn.dataset.tab;
          $$('.tabBtn', group).forEach(b => b.classList.toggle('is-on', b === tabBtn));
          $$('.tabPane', group).forEach(p => p.classList.toggle('is-on', p.dataset.pane === tab));
          requestAnimationFrame(() => window.scrollTo({ top: 0, behavior: 'auto' }));
        }

        const bookingBtn = e.target.closest('[data-create-booking]');
        if(bookingBtn){
          e.preventDefault();
          openExistingBookingPreview();
          return;
        }

        const modalBtn = e.target.closest('[data-modal]');
        if(modalBtn){
          if(String(modalBtn.dataset.type || '').toLowerCase().includes('manual booking')){ openExistingBookingPreview(); return; }
          if(modalBtn.dataset.rowDetail){
            try{
              openDetailModal(modalBtn.dataset.type, JSON.parse(decodeURIComponent(modalBtn.dataset.rowDetail)));
            } catch(error){
              openCrud(modalBtn.dataset.modal, modalBtn.dataset.type);
            }
          } else {
            openCrud(modalBtn.dataset.modal, modalBtn.dataset.type);
          }
        }

        const exportRowBtn = e.target.closest('[data-export-row]');
        if(exportRowBtn){
          exportRowPdf(exportRowBtn.dataset.exportRow, exportRowBtn.dataset.exportName || 'employee-record');
          return;
        }

        const copyBtn = e.target.closest('[data-copy-value]');
        if(copyBtn){
          navigator.clipboard?.writeText(copyBtn.dataset.copyValue || '');
          showToast('Copied');
        }

        const delBtn = e.target.closest('[data-delete]');
        if(delBtn){
          els.deleteText.textContent = `Are you sure you want to delete "${delBtn.dataset.delete}"?`;
          els.deleteModal.classList.add('is-open');
        }

        if(e.target.closest('[data-close-modal]')) closeModals();
      });

      document.addEventListener('submit', e => {
        if(e.target.matches('#scannerModalForm')){
          e.preventDefault();
          const input = $('#modalScanInput');
          const value = input?.value || '';
          if(els.checkSearch) els.checkSearch.value = value;
          closeModals();
          lookupTicketFromDashboard(value);
          openPage('checkin');
          return;
        }
        if(e.target.matches('[data-dashboard-form], #noticeForm, #profileForm, #handoverForm')){
          if(e.target.hasAttribute('action')){
            return;
          }
          e.preventDefault();
          closeModals();
          showToast('Saved successfully');
        }
      });

      if(els.confirmDelete){
        els.confirmDelete.addEventListener('click', () => {
          closeModals();
          showToast('Record deleted');
        });
      }

      if(els.btnNew) els.btnNew.addEventListener('click', () => openCrud('create', 'employee item'));
      if(els.btnExport) els.btnExport.addEventListener('click', () => { const active = $('.section.is-open table'); if(active) exportTableCsv(active); else showToast('Open a table to export'); });
      if(els.btnLookupTicket) els.btnLookupTicket.addEventListener('click', () => lookupTicketFromDashboard(els.checkSearch?.value || ''));
      if(els.btnLookupTicketBottom) els.btnLookupTicketBottom.addEventListener('click', () => lookupTicketFromDashboard(els.checkSearch?.value || ''));
      if(els.btnCheckIn) els.btnCheckIn.addEventListener('click', () => validateTicketFromDashboard(els.checkSearch?.value || currentScan?.detail?.booking?.bookingRef || ''));
      if(els.btnCheckInBottom) els.btnCheckInBottom.addEventListener('click', () => validateTicketFromDashboard(els.checkSearch?.value || currentScan?.detail?.booking?.bookingRef || ''));
      if(els.btnNoShow) els.btnNoShow.addEventListener('click', () => markNoShowFromDashboard(els.checkSearch?.value || currentScan?.detail?.booking?.bookingRef || ''));
      if(els.btnNoShowBottom) els.btnNoShowBottom.addEventListener('click', () => markNoShowFromDashboard(els.checkSearch?.value || currentScan?.detail?.booking?.bookingRef || ''));
      if(els.btnRestartScan) els.btnRestartScan.addEventListener('click', () => { lastScannedValue = ''; if(els.checkSearch) els.checkSearch.value = ''; currentScan = null; setCheckButtons({}); if(els.scannerResult) { els.scannerResult.className='scanResult is-empty'; els.scannerResult.textContent='Search manually or scan a QR ticket. The full booking card appears here before check-in.'; } });
      if(els.btnOpenCamera) els.btnOpenCamera.addEventListener('click', startCameraScanner);
      if(els.btnStopCamera) els.btnStopCamera.addEventListener('click', stopCameraScanner);
      if(els.checkSearch) els.checkSearch.addEventListener('keydown', e => {
        if(e.key === 'Enter'){
          e.preventDefault();
          lookupTicketFromDashboard(els.checkSearch.value);
        }
      });
      if(els.openMenu) els.openMenu.addEventListener('click', () => document.body.classList.add('menu-open'));
      if(els.sideBackdrop) els.sideBackdrop.addEventListener('click', () => document.body.classList.remove('menu-open'));

      if(els.btnTheme){
        els.btnTheme.addEventListener('click', () => {
          const html = document.documentElement;
          const next = html.dataset.theme === 'dark' ? 'light' : 'dark';
          html.dataset.theme = next;
          els.themeIcon.className = next === 'dark' ? 'fa-solid fa-moon' : 'fa-solid fa-sun';
        });
      }

      if(els.sideSearch){
        els.sideSearch.addEventListener('input', () => {
          const q = els.sideSearch.value.trim().toLowerCase();
          $$('.navBtn').forEach(btn => {
            const text = btn.textContent.toLowerCase();
            btn.style.display = text.includes(q) ? 'flex' : 'none';
          });
        });
      }

      document.addEventListener('keydown', e => {
        if(e.key === 'Escape'){
          closeModals();
          document.body.classList.remove('menu-open');
        }
      });

      renderAll();
      openPage('overview');
    });
  </script>
</body>
</html>
