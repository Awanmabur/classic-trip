<%- include('../partials/site-head', { seo }) %>
<body>
<%- include('../partials/site-header') %>
<main class="container pageSection">
  <section class="heroCard">
    <span class="eyebrow">Architecture-ready future services</span>
    <h1>Future services are visible, but not broken booking flows.</h1>
    <p>Bus and hotel are the live checkout modules. These services are read-only behind feature flags until their full provider, inventory, payment, ticketing, refund, notification, support, and reporting workflows are ready end to end.</p>
  </section>
  <section class="gridCards">
    <% modules.forEach((module) => { %>
      <article class="card serviceCard">
        <div class="cardIcon"><i class="fa-solid <%= module.icon || 'fa-layer-group' %>"></i></div>
        <h2><%= module.label %></h2>
        <p><%= module.publicMessage %></p>
        <p><strong>Status:</strong> <%= module.releaseStatus %> / <strong>Checkout:</strong> Coming soon</p>
        <a class="btn btnGhost" href="/future-services/<%= module.key %>">View architecture</a>
      </article>
    <% }) %>
  </section>
</main>
<%- include('../partials/site-footer') %>
</body>
</html>
