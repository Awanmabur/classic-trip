<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/png" href="/images/favicon-48.png" />
  <title>Classic Trip | Multi-Tenant Booking Platform</title>
  <meta name="description" content="Classic Trip booking platform for buses and hotels with live seat and room inventory." />
  <meta name="csrf-token" content="<%= csrfToken || '' %>" />
  <meta name="theme-color" content="#070a12" />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

  <link rel="stylesheet" href="/css/pages/home.css?v=20260724-hotel-ui-final-1">
  <meta name="csrf-token" content="<%= csrfToken %>">
  <script src="/js/csrf.js?v=20260722-3" defer></script>
  <script src="/js/notifications.js" defer></script>
  <link rel="stylesheet" href="/css/accessibility.css?v=20260723-design-fares-payments-final-1" />
</head>
<body class="homePage" data-user-id="<%= currentUser?.id || '' %>">
  <header class="nav">
    <div class="navIn">
      <a class="brand" href="#home"><img class="mark" src="/images/logo-symbol-128.png" alt="Classic Trip"><span>Classic Trip</span></a>
      <nav class="navLinks" id="navLinks">
        <a href="#home" class="active">Home</a><a href="#bus">Buses</a><a href="#hotel">Hotels</a><a href="#coming-soon">Coming soon</a><a href="#ads">Promotions</a><a href="#blogs">Blogs</a><a href="/saved">Saved</a><a href="/my-bookings">My bookings</a>
      </nav>
      <div class="navActions">
        <button class="iconbtn" id="themeBtn" title="Toggle theme"><i class="fa-solid fa-moon" id="themeIcon"></i></button>
        <button class="iconbtn" id="menuBtn"><i class="fa-solid fa-bars"></i></button>
        <% if (currentUser) { %><a class="btn btnGhost" href="<%= dashboardUrl %>"><i class="fa-regular fa-user"></i> <%= (currentUser.fullName || currentUser.name || 'Account').split(' ')[0] %></a><% } else { %><a class="btn btnGhost login" href="/login"><i class="fa-regular fa-user"></i> Login</a><% } %>
        <% if (currentUser) { %><form method="POST" action="/logout" style="display:contents"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><button class="btn btnPrimary" type="submit"><i class="fa-solid fa-arrow-right-from-bracket"></i> Logout</button></form><% } else { %><button class="btn btnPrimary" type="button" data-home-action="scroll-section" data-section-id="bus"><i class="fa-solid fa-ticket"></i> Start</button><% } %>
      </div>
    </div>
  </header>


  <div class="drawer" id="drawer">
    <div class="drawerPanel">
      <div style="display:flex;align-items:center;justify-content:space-between;gap:10px">
        <div class="brand"><img class="mark" src="/images/logo-symbol-128.png" alt="Classic Trip"><span>Classic Trip</span></div>
        <button class="iconbtn" id="closeDrawer"><i class="fa-solid fa-xmark"></i></button>
      </div>
      <% if (currentUser) { %>
        <a class="drawerProfile" href="<%= dashboardUrl %>">
          <span class="drawerProfileAvatar"><i class="fa-solid fa-user"></i></span>
          <span class="drawerProfileText"><b><%= currentUser.fullName || currentUser.name || 'Account' %></b><span class="muted">View dashboard</span></span>
          <i class="fa-solid fa-chevron-right"></i>
        </a>
      <% } else { %>
        <a class="drawerProfile" href="/login">
          <span class="drawerProfileAvatar"><i class="fa-regular fa-user"></i></span>
          <span class="drawerProfileText"><b>Login / Sign up</b><span class="muted">Access your bookings & account</span></span>
          <i class="fa-solid fa-chevron-right"></i>
        </a>
      <% } %>
      <div class="drawerLinks">
        <a href="#home">Home</a><a href="#bus">Buses</a><a href="#hotel">Hotels</a><a href="#coming-soon">Coming soon</a><a href="#ads">Promotions</a><a href="#blogs">Blogs</a><a href="/saved">Saved</a><a href="/my-bookings">My bookings</a>
      </div>
      <div class="drawerFilters" id="drawerFilters"></div>
      <button class="btn btnPrimary" type="button" data-home-action="scroll-section" data-section-id="bus" data-close-drawer="true"><i class="fa-solid fa-bolt"></i> Start booking</button>
    </div>
  </div>

  <nav class="bottomNav" id="siteBottomNav">
    <button type="button" data-home-action="navigate" data-url="/" class="active" title="Home"><i class="fa-solid fa-house"></i><span>Home</span></button>
    <button type="button" data-home-action="navigate" data-url="/search" title="Search"><i class="fa-solid fa-magnifying-glass"></i><span>Search</span></button>
    <button type="button" data-home-action="navigate" data-url="/tickets" title="Tickets"><i class="fa-solid fa-ticket"></i><span>Tickets</span></button>
    <button type="button" data-home-action="navigate" data-url="/saved" title="Saved"><i class="fa-regular fa-heart"></i><span>Saved</span></button>
    <button type="button" data-home-action="drawer-toggle" title="Menu"><i class="fa-regular fa-user"></i><span>Profile</span></button>
  </nav>

  <main>
    <section class="container hero" id="home">
      <div class="card heroCard">
        <div class="heroTop">
          <div>
            <div class="chips heroBadgesTop">
              <span class="chip active"><i class="fa-solid fa-shield-halved"></i> Secure checkout</span>
              <span class="chip"><i class="fa-solid fa-clock"></i> <%= platformConfig.holdMinutes %> min hold</span>
              <span class="chip"><i class="fa-solid fa-users"></i> Promoter links</span>
              <span class="chip"><i class="fa-solid fa-building"></i> Partner dashboards</span>
            </div>
            <h1 class="heroTitle"><span class="keepLine">Book buses and stays</span> in one place.</h1>
            <p class="heroSub">Verified partners publish buses and hotels. Customers use live database inventory, select seats or rooms, hold them securely, and complete checkout.</p>
          </div>

          <div class="card searchBox">
            <div class="tabs" id="searchTabs">
              <button class="tab active" data-type="bus"><i class="fa-solid fa-bus"></i> Bus</button>
              <button class="tab" data-type="hotel"><i class="fa-solid fa-hotel"></i> Hotel</button>
              <% comingSoonServiceTypes.slice(0,3).forEach(function(key){ var service = serviceCatalog[key]; %><button class="tab" type="button" disabled title="Coming soon"><i class="fa-solid <%= service.icon %>"></i> <%= service.singular %> <small>Soon</small></button><% }) %>
            </div>
            <div class="formGrid">
              <div class="field" id="fromField"><label>From</label><div class="control"><i class="fa-solid fa-location-dot"></i><input id="fromInput" placeholder="From city"></div></div>
              <div class="field" id="toField"><label>To</label><div class="control"><i class="fa-solid fa-location-dot"></i><input id="toInput" placeholder="To city"></div></div>
              <div class="field hide" id="cityField"><label>City</label><div class="control"><i class="fa-solid fa-city"></i><input id="cityInput" placeholder="City or area"></div></div>
              <div class="field"><label>Date</label><div class="control"><i class="fa-regular fa-calendar"></i><input type="date" id="dateInput"></div></div>
              <div class="field"><label>Guests / seats</label><div class="control"><i class="fa-solid fa-user-group"></i><select><option>1</option><option>2</option><option>3</option><option>4</option></select></div></div>
            </div>
            <div style="display:flex;gap:10px;justify-content:space-between;flex-wrap:wrap">
              <button class="btn btnGhost" data-home-action="run-search"><i class="fa-solid fa-wand-magic-sparkles"></i> Smart search</button>
              <button class="btn btnBlue" data-home-action="run-search"><i class="fa-solid fa-magnifying-glass"></i> Search</button>
            </div>
          </div>
        </div>
        <div class="stats">
          <div class="stat"><b><%= bootstrap.heroStats.totalServices %></b><span>Marketplace services</span></div>
          <div class="stat"><b><%= bootstrap.heroStats.liveRoutes %></b><span>Live routes</span></div>
          <div class="stat"><b><%= bootstrap.heroStats.verifiedPartners %></b><span>Verified partners</span></div>
          <div class="stat"><b><%= bootstrap.heroStats.bookableInventory %></b><span>Bookable now</span></div>
          <div class="stat"><b><%= bootstrap.heroStats.availableNow || 0 %></b><span>Seats / rooms open</span></div>
          <div class="stat"><b><%= bootstrap.heroStats.departuresNext24h || 0 %></b><span>Next 24h departures</span></div>
          <div class="stat"><b><%= platformConfig.holdMinutes %> min</b><span>Inventory hold timer</span></div>
          <div class="stat"><b><%= platformConfig.supportedCurrencies.length %></b><span>Supported currencies</span></div>
        </div>
      </div>
    </section>

    <div class="container layout">
      <aside class="card side">
        <div>
          <div class="sideTitle">Categories</div>
          <div class="muted" style="font-size:13px;font-weight:800">Filter marketplace listings</div>
        </div>
        <div class="sideNav" id="categoryFilters">
          <button class="btn btnGhost active" data-home-action="filter-cards" data-filter="all"><i class="fa-solid fa-border-all"></i> All</button>
          <button class="btn btnGhost" data-home-action="filter-cards" data-filter="bus"><i class="fa-solid fa-bus"></i> Bus</button>
          <button class="btn btnGhost" data-home-action="filter-cards" data-filter="hotel"><i class="fa-solid fa-hotel"></i> Hotel</button>
          <button class="btn btnGhost" data-home-action="filter-cards" data-filter="more"><i class="fa-solid fa-plus"></i> More</button>
        </div>
        <div>
          <div class="sideTitle">Country routes</div>
          <div class="muted" style="font-size:12px;font-weight:760;margin:2px 0 8px">Filter by corridor, for example Kenya ⇄ Uganda.</div>
          <div class="routeFilters" id="routeFilters">
            <button class="btn btnGhost active" data-home-action="filter-route" data-filter="all"><i class="fa-solid fa-earth-africa"></i> All East Africa</button>
            <button class="btn btnGhost" data-home-action="filter-route" data-filter="ug-ke">Uganda ⇄ Kenya</button>
            <button class="btn btnGhost" data-home-action="filter-route" data-filter="ug-tz">Uganda ⇄ Tanzania</button>
            <button class="btn btnGhost" data-home-action="filter-route" data-filter="ug-rw">Uganda ⇄ Rwanda</button>
            <button class="btn btnGhost" data-home-action="filter-route" data-filter="ug-bi">Uganda ⇄ Burundi</button>
            <button class="btn btnGhost" data-home-action="filter-route" data-filter="ug-ss">Uganda ⇄ South Sudan</button>
            <button class="btn btnGhost" data-home-action="filter-route" data-filter="ke-tz">Kenya ⇄ Tanzania</button>
            <button class="btn btnGhost" data-home-action="filter-route" data-filter="ke-rw">Kenya ⇄ Rwanda</button>
            <button class="btn btnGhost" data-home-action="filter-route" data-filter="ke-ug">Kenya ⇄ Uganda</button>
            <button class="btn btnGhost" data-home-action="filter-route" data-filter="tz-rw">Tanzania ⇄ Rwanda</button>
            <button class="btn btnGhost" data-home-action="filter-route" data-filter="tz-bi">Tanzania ⇄ Burundi</button>
            <button class="btn btnGhost" data-home-action="filter-route" data-filter="rw-bi">Rwanda ⇄ Burundi</button>
            <button class="btn btnGhost" data-home-action="filter-route" data-filter="rw-drc">Rwanda ⇄ DR Congo</button>
            <button class="btn btnGhost" data-home-action="filter-route" data-filter="ss-et">South Sudan ⇄ Ethiopia</button>
            <button class="btn btnGhost" data-home-action="filter-route" data-filter="et-so">Ethiopia ⇄ Somalia</button>
            <button class="btn btnGhost" data-home-action="filter-route" data-filter="et-dj">Ethiopia ⇄ Djibouti</button>
            <button class="btn btnGhost" data-home-action="filter-route" data-filter="et-er">Ethiopia ⇄ Eritrea</button>
            <button class="btn btnGhost" data-home-action="filter-route" data-filter="regional">Regional / international</button>
            <button class="btn btnGhost" data-home-action="filter-route" data-filter="ug-local">Uganda local</button>
            <button class="btn btnGhost" data-home-action="filter-route" data-filter="ke-local">Kenya local</button>
            <button class="btn btnGhost" data-home-action="filter-route" data-filter="tz-local">Tanzania local</button>
            <button class="btn btnGhost" data-home-action="filter-route" data-filter="rw-local">Rwanda local</button>
            <button class="btn btnGhost" data-home-action="filter-route" data-filter="bi-local">Burundi local</button>
            <button class="btn btnGhost" data-home-action="filter-route" data-filter="ss-local">South Sudan local</button>
            <button class="btn btnGhost" data-home-action="filter-route" data-filter="et-local">Ethiopia local</button>
            <button class="btn btnGhost" data-home-action="filter-route" data-filter="so-local">Somalia local</button>
            <button class="btn btnGhost" data-home-action="filter-route" data-filter="dj-local">Djibouti local</button>
            <button class="btn btnGhost" data-home-action="filter-route" data-filter="er-local">Eritrea local</button>
            <button class="btn btnGhost" data-home-action="filter-route" data-filter="drc-local">DR Congo local</button>
          </div>
        </div>
        <div class="summaryCard">
          <h3>Tenant model</h3>
          <p class="muted" style="margin:0;font-size:12px;font-weight:760">Each partner controls listings, layouts, prices, policies, staff and payouts.</p>
        </div>
      </aside>

      <div>
        <section class="section" id="bus">
          <div class="sectionHead"><div><h2>Featured buses</h2><p>Dynamic seat layout: 2+2, 2+1, VIP, sleeper, or custom partner structure.</p></div><span class="badge badgeInfo"><i class="fa-solid fa-chair"></i> Seat selection</span></div>
          <% var initialBusListings = (bootstrap.listings || []).filter(function(item) { return item && (item.serviceType === 'bus' || item.group === 'bus'); }).slice(0, 6); %>
          <div class="gridCards" id="cards">
            <% if (initialBusListings.length) { initialBusListings.forEach(function(item) { %><%- include('../partials/listing-card', { listing: item }) %><% }); } else { %>
              <div class="card marketplaceEmptyCard" data-home-empty="bus"><strong>No published bus services yet</strong><p class="muted">Published departures will appear here automatically.</p></div>
            <% } %>
          </div>
          <div class="moreRow"><button class="btn btnGhost moreBtn" id="more-bus" data-home-action="show-more" data-group="bus"><i class="fa-solid fa-plus"></i> More</button></div>
        </section>

        <section class="section" id="hotel">
          <div class="sectionHead"><div><h2>Hotels, rooms & houses</h2><p>Customers can view floor/room structure before booking.</p></div><span class="badge badgeOk"><i class="fa-solid fa-door-open"></i> Room selection</span></div>
          <% var initialHotelListings = (bootstrap.listings || []).filter(function(item) { return item && (item.serviceType === 'hotel' || item.group === 'hotel'); }).slice(0, 6); %>
          <div class="gridCards" id="hotelCards">
            <% if (initialHotelListings.length) { initialHotelListings.forEach(function(item) { %><%- include('../partials/listing-card', { listing: item }) %><% }); } else { %>
              <div class="card marketplaceEmptyCard" data-home-empty="hotel"><strong>No published hotels yet</strong><p class="muted">Verified properties with dated room inventory will appear here automatically.</p></div>
            <% } %>
          </div>
          <div class="moreRow"><button class="btn btnGhost moreBtn" id="more-hotel" data-home-action="show-more" data-group="hotel"><i class="fa-solid fa-plus"></i> More</button></div>
        </section>

  
      <section class="section" id="coming-soon">
        <div class="sectionHead"><div><h2>More ways to travel are coming</h2><p>They remain part of Classic Trip while each workflow is built with its own inventory, pricing, verification and operations.</p></div><a class="btn btnGhost" href="/services#coming-soon">View roadmap</a></div>
        <div class="gridCards">
          <% comingSoonServiceTypes.forEach(function(key){ var service = serviceCatalog[key]; %>
            <article class="listing card" style="padding:14px"><span class="badge badgeInfo"><i class="fa-solid <%= service.icon %>"></i> Coming soon</span><h3 style="margin:10px 0 5px"><%= service.label %></h3><p class="muted" style="margin:0"><%= service.description %></p></article>
          <% }) %>
        </div>
      </section>
      <section class="section" id="ads">
          <div class="sectionHead">
            <div>
              <h2>Ads & promoted listings</h2>
              <p>Partners can promote published bus routes and hotel listings so they appear higher in search.</p>
            </div>
            <span class="badge badgeWarn"><i class="fa-solid fa-bullhorn"></i> Partner growth</span>
          </div>
          <div class="pageIntro">
            <div>
              <h3>Promotion center</h3>
              <p>Approved campaigns linked to published services appear here from the database.</p>
            </div>
            <% if (currentUser?.role === 'company_admin') { %><a class="btn btnPrimary" href="/company/dashboard#promotions"><i class="fa-solid fa-plus"></i> Promote listing</a><% } else { %><a class="btn btnGhost" href="/register?role=partner#partner"><i class="fa-solid fa-building"></i> Become a partner</a><% } %>
          </div>
          <div class="gridCards" id="adsCards">
<% var sponsored = (bootstrap.listings || []).filter(function(l) { return l.isSponsored; }).slice(0, 4); %>
<% if (sponsored.length) { sponsored.forEach(function(l) { var svcIcon = l.serviceType === 'hotel' ? 'fa-hotel' : 'fa-bus'; %>
            <article class="promoCard">
              <div class="promoIcon"><i class="fa-solid <%= svcIcon %>"></i></div>
              <span class="badge badgeWarn" style="width:max-content;margin-bottom:8px"><i class="fa-solid fa-star"></i> Promoted</span>
              <h3><%= l.title %></h3>
              <p><%= l.partner || l.companyName || '' %><% if (l.routeLabel || l.origin) { %> &bull; <%= l.routeLabel || l.origin %><% } %></p>
              <a class="btn btnGhost" href="<%= l.url %>"><i class="fa-regular fa-eye"></i> View listing</a>
            </article>
<% }); } else { %>
            <div class="card" data-home-empty="promotions" style="padding:20px"><strong>No active promotions yet</strong><p class="muted" style="margin:6px 0 0">Approved campaigns linked to published listings will appear here.</p></div>
<% } %>
          </div>
        </section>

        <section class="section" id="blogs">
          <div class="sectionHead">
            <div>
              <h2>Travel blogs & guides</h2>
              <p>Helpful content for routes, border travel, hotel stays, airport tips, partner promotions and customer education.</p>
            </div>
            <span class="badge badgeInfo"><i class="fa-regular fa-newspaper"></i> Travel stories</span>
          </div>
          <div class="pageIntro">
            <div>
              <h3>Content that helps customers book with confidence</h3>
              <p>Published articles appear here from the content database.</p>
            </div>
            <% if (currentUser?.role === 'super_admin') { %><a class="btn btnGhost" href="/admin/dashboard#content"><i class="fa-solid fa-pen-nib"></i> Write blog</a><% } %>
          </div>
          <div class="gridCards" id="blogCards">
<% if (bootstrap.blogs && bootstrap.blogs.length) { bootstrap.blogs.forEach(function(post) { var badgeCls = (post.tag||'').toLowerCase().includes('hotel') ? 'badgeOk' : (post.tag||'').toLowerCase().includes('promo') ? 'badgeWarn' : (post.tag||'').toLowerCase().includes('book') ? 'badgeHot' : 'badgeInfo'; %>
            <article class="promoCard blogCard">
              <div class="blogImage">
                <% if (post.image) { %><img src="<%= post.image %>" alt="<%= post.imageAlt || post.title %>"><% } else { %><div style="height:160px;background:var(--soft)"></div><% } %>
                <span class="badge <%= badgeCls %> blogTag"><%= post.tag || 'Guide' %></span>
                <div class="blogIconActions">
                  <a class="miniIcon" href="<%= post.url %>" title="Read"><i class="fa-regular fa-eye"></i></a>
                  <button class="miniIcon" title="Share" data-t="<%= post.title %>" data-u="<%= post.url %>" data-home-action="share-dataset"><i class="fa-solid fa-share-nodes"></i></button>
                </div>
              </div>
              <div class="blogBody">
                <h3><%= post.title %></h3>
                <div class="blogMeta"><% if (post.publishedAt) { %><span><i class="fa-regular fa-calendar"></i> <%= new Date(post.publishedAt).toLocaleDateString('en-GB',{day:'2-digit',month:'short',year:'numeric'}) %></span><% } %></div>
                <p><%= post.excerpt %></p>
                <div class="blogActions"><a class="btn btnGhost" href="<%= post.url %>"><i class="fa-regular fa-eye"></i> Read more</a></div>
              </div>
            </article>
<% }); } else { %>
            <div class="card" data-home-empty="blogs" style="padding:20px"><strong>No published articles yet</strong><p class="muted" style="margin:6px 0 0">Articles created and published by the Super Admin will appear here.</p></div>
<% } %>
          </div>
        </section>

      </div>
    </div>
  </main>

  <footer class="siteFooter">
    <div class="footerGrid">
      <div class="footerBrand">
        <div class="brand"><img class="mark" src="/images/logo-symbol-128.png" alt="Classic Trip"><span>Classic Trip</span></div>
        <p>Classic Trip is a database-backed marketplace for bus travel and hotel stays.</p>
        <span><i class="fa-solid fa-shield-halved"></i> Secure checkout</span>
        <span><i class="fa-solid fa-clock"></i> <%= platformConfig.holdMinutes %> minute inventory holds</span>
        <span><i class="fa-solid fa-headset"></i> Customer support</span>
      </div>

      <div class="footerCol">
        <h3>Book & manage</h3>
        <a href="/search?serviceType=bus"><i class="fa-solid fa-bus"></i> Buses</a>
        <a href="/search?serviceType=hotel"><i class="fa-solid fa-hotel"></i> Hotels</a>
        <a href="/tickets"><i class="fa-solid fa-ticket"></i> Find my ticket</a>
        <a href="/my-bookings"><i class="fa-solid fa-bookmark"></i> My bookings</a>
        <a href="/saved"><i class="fa-regular fa-heart"></i> Saved trips</a>
        <% if (currentUser) { %><a href="<%= dashboardUrl %>"><i class="fa-regular fa-user"></i> My account</a><% } else { %><a href="/login"><i class="fa-regular fa-user"></i> Login / Sign up</a><% } %>
      </div>

      <div class="footerCol">
        <h3>Partners & promoters</h3>
        <a href="/register?role=partner#partner"><i class="fa-solid fa-store"></i> Become a partner</a>
        <a href="/promoters"><i class="fa-solid fa-users"></i> Promoter program</a>
        <a href="/companies"><i class="fa-solid fa-building"></i> Browse partners</a>
        <a href="/company/dashboard"><i class="fa-solid fa-chart-line"></i> Partner dashboard</a>
        <a href="/partner-commission"><i class="fa-solid fa-percent"></i> Commission model</a>
      </div>

      <div class="footerCol">
        <h3>Legal & help</h3>
        <a href="/how-it-works"><i class="fa-solid fa-circle-info"></i> About Classic Trip</a>
        <a href="/terms"><i class="fa-solid fa-file-contract"></i> Terms & conditions</a>
        <a href="/privacy"><i class="fa-solid fa-user-shield"></i> Privacy policy</a>
        <a href="/terms#refunds"><i class="fa-solid fa-rotate-left"></i> Refund policy</a>
        <a href="/terms#cancellation"><i class="fa-solid fa-triangle-exclamation"></i> Cancellation rules</a>
        <a href="/support"><i class="fa-solid fa-envelope"></i> Contact support</a>
      </div>
    </div>
    <div class="footerBottom">
      <span>&copy; <%= new Date().getFullYear() %> Classic Trip. Marketplace for East Africa bookings.</span>
      <span>Secure payments • Transparent pricing • Partner payouts • Ticket access</span>
    </div>
  </footer>


  <div class="toast" id="toast">Ready</div>

  <script id="classicTripBootstrap" type="application/json" nonce="<%= cspNonce %>"><%- toScriptJson({ ...(bootstrap || {}), platformConfig: platformConfig || {} }) %></script>
  <script src="/js/home.js?v=20260724-hotel-ui-final-1" defer></script>
</body>
</html>

