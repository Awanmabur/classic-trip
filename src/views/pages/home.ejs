<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Classic Trip | Multi-Tenant Booking Platform</title>
  <meta name="description" content="Classic Trip multi-tenant booking platform for buses, hotels, flights, trains, ferries, car rentals, events and tours with seat/room selection and 10 minute holds." />
  <meta name="theme-color" content="#070a12" />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

  <link rel="stylesheet" href="/css/pages/home.css">
</head>
<body class="homePage">
  <header class="nav">
    <div class="navIn">
      <a class="brand" href="#home"><span class="mark">CT</span><span>Classic Trip</span></a>
      <nav class="navLinks" id="navLinks">
        <a href="#home" class="active">Home</a><a href="#bus">Buses</a><a href="#hotel">Hotels</a><a href="#flight">Flights</a><a href="#train">Trains</a><a href="#more">More</a><a href="#ads">Ads</a><a href="#blogs">Blogs</a><a href="#saved">Saved</a><a href="#my-bookings">My bookings</a>
      </nav>
      <div class="navActions">
        <button class="iconbtn" id="themeBtn" title="Toggle theme"><i class="fa-solid fa-moon" id="themeIcon"></i></button>
        <button class="iconbtn" id="menuBtn"><i class="fa-solid fa-bars"></i></button>
        <button class="btn btnGhost login" onclick="window.location.href='/login'"><i class="fa-regular fa-user"></i> Login</button>
        <button class="btn btnPrimary" onclick="scrollToSectionId('bus')"><i class="fa-solid fa-ticket"></i> Start</button>
      </div>
    </div>
  </header>

  <nav class="bottomNav" id="bottomNav" aria-label="Mobile bottom navigation">
    <button type="button" class="active" data-target="home" aria-label="Home"><i class="fa-solid fa-house"></i><span>Home</span></button>
    <button type="button" data-target="ads" aria-label="Ads"><i class="fa-solid fa-bullhorn"></i><span>Ads</span></button>
    <button type="button" data-target="saved" aria-label="Saved"><i class="fa-regular fa-heart"></i><span>Saved</span></button>
    <button type="button" data-target="my-bookings" aria-label="My bookings"><i class="fa-solid fa-ticket"></i><span>Bookings</span></button>
    <button type="button" data-action="menu" aria-label="Menu"><i class="fa-solid fa-bars"></i><span>Menu</span></button>
  </nav>


  <div class="drawer" id="drawer">
    <div class="drawerPanel">
      <div style="display:flex;align-items:center;justify-content:space-between;gap:10px">
        <div class="brand"><span class="mark">CT</span><span>Classic Trip</span></div>
        <button class="iconbtn" id="closeDrawer"><i class="fa-solid fa-xmark"></i></button>
      </div>
      <div class="drawerLinks">
        <a href="#home">Home</a><a href="#bus">Buses</a><a href="#hotel">Hotels</a><a href="#flight">Flights</a><a href="#train">Trains</a><a href="#more">More services</a><a href="#ads">Ads</a><a href="#blogs">Blogs</a><a href="#saved">Saved</a><a href="#my-bookings">My bookings</a>
      </div>
      <div class="drawerFilters" id="drawerFilters"></div>
      <button class="btn btnPrimary"><i class="fa-solid fa-bolt"></i> Start booking</button>
    </div>
  </div>

  <main>
    <section class="container hero" id="home">
      <div class="card heroCard">
        <div class="heroTop">
          <div>
            <div class="chips heroBadgesTop">
              <span class="chip active"><i class="fa-solid fa-shield-halved"></i> Secure checkout</span>
              <span class="chip"><i class="fa-solid fa-clock"></i> 10 min hold</span>
              <span class="chip"><i class="fa-solid fa-users"></i> Promoter links</span>
              <span class="chip"><i class="fa-solid fa-building"></i> Partner dashboards</span>
            </div>
            <h1 class="heroTitle"><span class="keepLine">Book transport, stays &amp; experiences</span> in one place.</h1>
            <p class="heroSub">Partners list buses, hotels, flights, trains and more. Customers can view the real structure, pick seats or rooms, hold them for 10 minutes, then complete checkout.</p>
          </div>

          <div class="card searchBox">
            <div class="tabs" id="searchTabs">
              <button class="tab active" data-type="bus"><i class="fa-solid fa-bus"></i> Bus</button>
              <button class="tab" data-type="hotel"><i class="fa-solid fa-hotel"></i> Hotel</button>
              <button class="tab" data-type="flight"><i class="fa-solid fa-plane"></i> Flight</button>
              <button class="tab" data-type="train"><i class="fa-solid fa-train"></i> Train</button>
            </div>
            <div class="formGrid">
              <div class="field" id="fromField"><label>From</label><div class="control"><i class="fa-solid fa-location-dot"></i><input id="fromInput" placeholder="From city"></div></div>
              <div class="field" id="toField"><label>To</label><div class="control"><i class="fa-solid fa-location-dot"></i><input id="toInput" placeholder="To city"></div></div>
              <div class="field hide" id="cityField"><label>City</label><div class="control"><i class="fa-solid fa-city"></i><input id="cityInput" placeholder="City or area"></div></div>
              <div class="field"><label>Date</label><div class="control"><i class="fa-regular fa-calendar"></i><input type="date" id="dateInput"></div></div>
              <div class="field"><label>Guests / seats</label><div class="control"><i class="fa-solid fa-user-group"></i><select><option>1</option><option>2</option><option>3</option><option>4</option></select></div></div>
            </div>
            <div style="display:flex;gap:10px;justify-content:space-between;flex-wrap:wrap">
              <button class="btn btnGhost" onclick="runSearch()"><i class="fa-solid fa-wand-magic-sparkles"></i> Smart search</button>
              <button class="btn btnBlue" onclick="runSearch()"><i class="fa-solid fa-magnifying-glass"></i> Search</button>
            </div>
          </div>
        </div>
        <div class="stats">
          <div class="stat"><b><%= bootstrap.heroStats.totalServices %></b><span>Marketplace services</span></div>
          <div class="stat"><b><%= bootstrap.heroStats.liveRoutes %></b><span>Live routes</span></div>
          <div class="stat"><b><%= bootstrap.heroStats.verifiedPartners %></b><span>Verified partners</span></div>
          <div class="stat"><b><%= bootstrap.heroStats.bookableInventory %></b><span>Bookable now</span></div>
          <div class="stat"><b><%= bootstrap.heroStats.availableNow || 0 %></b><span>Seats / rooms open</span></div>
          <div class="stat"><b><%= bootstrap.heroStats.departuresNext24h || 0 %></b><span>Next 24h departures</span></div>
          <div class="stat"><b>10 min</b><span>Seat / room hold timer</span></div>
          <div class="stat"><b>3%</b><span>Promoter commission ready</span></div>
        </div>
      </div>
    </section>

    <div class="container layout">
      <aside class="card side">
        <div>
          <div class="sideTitle">Categories</div>
          <div class="muted" style="font-size:13px;font-weight:800">Filter marketplace listings</div>
        </div>
        <div class="sideNav" id="categoryFilters">
          <button class="btn btnGhost active" onclick="filterCards('all', this)"><i class="fa-solid fa-border-all"></i> All</button>
          <button class="btn btnGhost" onclick="filterCards('bus', this)"><i class="fa-solid fa-bus"></i> Bus</button>
          <button class="btn btnGhost" onclick="filterCards('hotel', this)"><i class="fa-solid fa-hotel"></i> Hotel</button>
          <button class="btn btnGhost" onclick="filterCards('flight', this)"><i class="fa-solid fa-plane"></i> Flight</button>
          <button class="btn btnGhost" onclick="filterCards('train', this)"><i class="fa-solid fa-train"></i> Train</button>
          <button class="btn btnGhost" onclick="filterCards('more', this)"><i class="fa-solid fa-plus"></i> More</button>
        </div>
        <div>
          <div class="sideTitle">Country routes</div>
          <div class="muted" style="font-size:12px;font-weight:760;margin:2px 0 8px">Filter by corridor, for example Kenya ⇄ Uganda.</div>
          <div class="routeFilters" id="routeFilters">
            <button class="btn btnGhost active" onclick="filterRoute('all', this)"><i class="fa-solid fa-earth-africa"></i> All East Africa</button>
            <button class="btn btnGhost" onclick="filterRoute('ug-ke', this)">Uganda ⇄ Kenya</button>
            <button class="btn btnGhost" onclick="filterRoute('ug-tz', this)">Uganda ⇄ Tanzania</button>
            <button class="btn btnGhost" onclick="filterRoute('ug-rw', this)">Uganda ⇄ Rwanda</button>
            <button class="btn btnGhost" onclick="filterRoute('ug-bi', this)">Uganda ⇄ Burundi</button>
            <button class="btn btnGhost" onclick="filterRoute('ug-ss', this)">Uganda ⇄ South Sudan</button>
            <button class="btn btnGhost" onclick="filterRoute('ke-tz', this)">Kenya ⇄ Tanzania</button>
            <button class="btn btnGhost" onclick="filterRoute('ke-rw', this)">Kenya ⇄ Rwanda</button>
            <button class="btn btnGhost" onclick="filterRoute('ke-ug', this)">Kenya ⇄ Uganda</button>
            <button class="btn btnGhost" onclick="filterRoute('tz-rw', this)">Tanzania ⇄ Rwanda</button>
            <button class="btn btnGhost" onclick="filterRoute('tz-bi', this)">Tanzania ⇄ Burundi</button>
            <button class="btn btnGhost" onclick="filterRoute('rw-bi', this)">Rwanda ⇄ Burundi</button>
            <button class="btn btnGhost" onclick="filterRoute('rw-drc', this)">Rwanda ⇄ DR Congo</button>
            <button class="btn btnGhost" onclick="filterRoute('ss-et', this)">South Sudan ⇄ Ethiopia</button>
            <button class="btn btnGhost" onclick="filterRoute('et-so', this)">Ethiopia ⇄ Somalia</button>
            <button class="btn btnGhost" onclick="filterRoute('et-dj', this)">Ethiopia ⇄ Djibouti</button>
            <button class="btn btnGhost" onclick="filterRoute('et-er', this)">Ethiopia ⇄ Eritrea</button>
            <button class="btn btnGhost" onclick="filterRoute('regional', this)">Regional / international</button>
            <button class="btn btnGhost" onclick="filterRoute('ug-local', this)">Uganda local</button>
            <button class="btn btnGhost" onclick="filterRoute('ke-local', this)">Kenya local</button>
            <button class="btn btnGhost" onclick="filterRoute('tz-local', this)">Tanzania local</button>
            <button class="btn btnGhost" onclick="filterRoute('rw-local', this)">Rwanda local</button>
            <button class="btn btnGhost" onclick="filterRoute('bi-local', this)">Burundi local</button>
            <button class="btn btnGhost" onclick="filterRoute('ss-local', this)">South Sudan local</button>
            <button class="btn btnGhost" onclick="filterRoute('et-local', this)">Ethiopia local</button>
            <button class="btn btnGhost" onclick="filterRoute('so-local', this)">Somalia local</button>
            <button class="btn btnGhost" onclick="filterRoute('dj-local', this)">Djibouti local</button>
            <button class="btn btnGhost" onclick="filterRoute('er-local', this)">Eritrea local</button>
            <button class="btn btnGhost" onclick="filterRoute('drc-local', this)">DR Congo local</button>
          </div>
        </div>
        <div class="summaryCard">
          <h3>Tenant model</h3>
          <p class="muted" style="margin:0;font-size:12px;font-weight:760">Each partner controls listings, layouts, prices, policies, staff and payouts.</p>
        </div>
      </aside>

      <div>
        <section class="section" id="bus">
          <div class="sectionHead"><div><h2>Featured buses</h2><p>Dynamic seat layout: 2+2, 2+1, VIP, sleeper, or custom partner structure.</p></div><span class="badge badgeInfo"><i class="fa-solid fa-chair"></i> Seat selection</span></div>
          <div class="gridCards" id="cards"></div>
          <div class="moreRow"><button class="btn btnGhost moreBtn" id="more-bus" onclick="showMore('bus')"><i class="fa-solid fa-plus"></i> More</button></div>
        </section>

        <section class="section" id="hotel">
          <div class="sectionHead"><div><h2>Hotels, rooms & houses</h2><p>Customers can view floor/room structure before booking.</p></div><span class="badge badgeOk"><i class="fa-solid fa-door-open"></i> Room selection</span></div>
          <div class="gridCards" id="hotelCards"></div>
          <div class="moreRow"><button class="btn btnGhost moreBtn" id="more-hotel" onclick="showMore('hotel')"><i class="fa-solid fa-plus"></i> More</button></div>
        </section>

        <section class="section" id="flight">
          <div class="sectionHead"><div><h2>Flights</h2><p>Seat map, baggage, meals, class upgrade and passenger details.</p></div><span class="badge badgeWarn"><i class="fa-solid fa-suitcase"></i> Baggage addons</span></div>
          <div class="gridCards" id="flightCards"></div>
          <div class="moreRow"><button class="btn btnGhost moreBtn" id="more-flight" onclick="showMore('flight')"><i class="fa-solid fa-plus"></i> More</button></div>
        </section>

        <section class="section" id="train">
          <div class="sectionHead"><div><h2>Trains</h2><p>Coach, berth, cabin or seat selection with hold timer.</p></div><span class="badge badgeHot"><i class="fa-solid fa-train-subway"></i> Coach map</span></div>
          <div class="gridCards" id="trainCards"></div>
          <div class="moreRow"><button class="btn btnGhost moreBtn" id="more-train" onclick="showMore('train')"><i class="fa-solid fa-plus"></i> More</button></div>
        </section>

        <section class="section" id="more">
          <div class="sectionHead"><div><h2>More services to add</h2><p>Make Classic Trip bigger than transport only.</p></div><span class="badge badgeInfo"><i class="fa-solid fa-sparkles"></i> Expansion ready</span></div>
          <div class="gridCards" id="moreCards"></div>
          <div class="moreRow"><button class="btn btnGhost moreBtn" id="more-more" onclick="showMore('more')"><i class="fa-solid fa-plus"></i> More</button></div>
        </section>

        <section class="section" id="ads">
          <div class="sectionHead">
            <div>
              <h2>Ads & promoted listings</h2>
              <p>Partners can promote routes, hotels, flights, trains and packages so they appear higher in search.</p>
            </div>
            <span class="badge badgeWarn"><i class="fa-solid fa-bullhorn"></i> Partner growth</span>
          </div>
          <div class="pageIntro">
            <div>
              <h3>Promotion center</h3>
              <p>Use this page for featured campaigns, boosted listings, banners, partner offers and route ads.</p>
            </div>
            <a class="btn btnPrimary" href="/company/dashboard#promotions"><i class="fa-solid fa-plus"></i> Promote listing</a>
          </div>
          <div class="gridCards" id="adsCards">
            <article class="promoCard"><div class="promoIcon"><i class="fa-solid fa-bus"></i></div><h3>Boost bus route</h3><p>Move a bus route higher in search for selected corridors like Uganda ⇄ Kenya.</p><button class="btn btnGhost" onclick="scrollToSectionId('bus')">View buses</button></article>
            <article class="promoCard"><div class="promoIcon"><i class="fa-solid fa-hotel"></i></div><h3>Promote hotel rooms</h3><p>Advertise rooms, apartments, houses and special weekend offers.</p><button class="btn btnGhost" onclick="scrollToSectionId('hotel')">View hotels</button></article>
            <article class="promoCard"><div class="promoIcon"><i class="fa-solid fa-plane"></i></div><h3>Flight campaign</h3><p>Promote flights with baggage deals, class upgrades and seasonal prices.</p><button class="btn btnGhost" onclick="scrollToSectionId('flight')">View flights</button></article>
            <article class="promoCard"><div class="promoIcon"><i class="fa-solid fa-chart-line"></i></div><h3>Ad analytics</h3><p>Track views, clicks, bookings, promoter links and revenue share.</p><a class="btn btnGhost" href="/company/dashboard#promotions">Open analytics</a></article>
          </div>
        </section>

        <section class="section" id="blogs">
          <div class="sectionHead">
            <div>
              <h2>Travel blogs & guides</h2>
              <p>Helpful content for routes, border travel, hotel stays, airport tips, partner promotions and customer education.</p>
            </div>
            <span class="badge badgeInfo"><i class="fa-regular fa-newspaper"></i> Travel stories</span>
          </div>
          <div class="pageIntro">
            <div>
              <h3>Content that helps customers book with confidence</h3>
              <p>Use this section for SEO articles, route guides, city guides, partner announcements, safety notes and promotional stories.</p>
            </div>
            <a class="btn btnGhost" href="/admin/dashboard#content"><i class="fa-solid fa-pen-nib"></i> Write blog</a>
          </div>
          <div class="gridCards" id="blogCards">
            <article class="promoCard blogCard">
              <div class="blogImage">
                <img src="https://images.unsplash.com/photo-1517840901100-8179e982acb7?auto=format&fit=crop&w=1200&q=70" alt="Kampala to Nairobi route guide">
                <span class="badge badgeInfo blogTag"><i class="fa-solid fa-route"></i> Route guide</span>
                <div class="blogIconActions">
                  <button class="miniIcon" title="View" onclick="openBlog('route')"><i class="fa-regular fa-eye"></i></button>
                  <button class="miniIcon" title="Love" onclick="loveBlog('route')"><i class="fa-regular fa-heart"></i></button>
                  <button class="miniIcon" title="Share" onclick="shareBlog('route')"><i class="fa-solid fa-share-nodes"></i></button>
                </div>
              </div>
              <div class="blogBody">
                <h3>Kampala to Nairobi: what travelers should know</h3>
                <div class="blogMeta"><span><i class="fa-regular fa-calendar"></i> 06 May 2026</span><span><i class="fa-regular fa-clock"></i> 4 min read</span><span><i class="fa-solid fa-location-dot"></i> Uganda ⇄ Kenya</span></div>
                <p>Departure points, border documents, luggage tips, seat selection and how the 10-minute hold works.</p>
                <div class="blogActions"><button class="btn btnGhost" onclick="openBlog('route')"><i class="fa-regular fa-eye"></i> Read more</button></div>
              </div>
            </article>

            <article class="promoCard blogCard">
              <div class="blogImage">
                <img src="https://images.unsplash.com/photo-1566073771259-6a8506099945?auto=format&fit=crop&w=1200&q=70" alt="Hotel room booking tips">
                <span class="badge badgeOk blogTag"><i class="fa-solid fa-hotel"></i> Stay tips</span>
                <div class="blogIconActions">
                  <button class="miniIcon" title="View" onclick="openBlog('hotel')"><i class="fa-regular fa-eye"></i></button>
                  <button class="miniIcon" title="Love" onclick="loveBlog('hotel')"><i class="fa-regular fa-heart"></i></button>
                  <button class="miniIcon" title="Share" onclick="shareBlog('hotel')"><i class="fa-solid fa-share-nodes"></i></button>
                </div>
              </div>
              <div class="blogBody">
                <h3>How to choose rooms, houses and apartments safely</h3>
                <div class="blogMeta"><span><i class="fa-regular fa-calendar"></i> 04 May 2026</span><span><i class="fa-regular fa-clock"></i> 3 min read</span><span><i class="fa-solid fa-door-open"></i> Room map</span></div>
                <p>Compare rooms, view structures, check amenities, save favorites and open receipts later.</p>
                <div class="blogActions"><button class="btn btnGhost" onclick="openBlog('hotel')"><i class="fa-regular fa-eye"></i> Read more</button></div>
              </div>
            </article>

            <article class="promoCard blogCard">
              <div class="blogImage">
                <img src="https://images.unsplash.com/photo-1556761175-b413da4baf72?auto=format&fit=crop&w=1200&q=70" alt="Partner promotions dashboard">
                <span class="badge badgeWarn blogTag"><i class="fa-solid fa-bullhorn"></i> Promotion</span>
                <div class="blogIconActions">
                  <button class="miniIcon" title="View" onclick="openBlog('promo')"><i class="fa-regular fa-eye"></i></button>
                  <button class="miniIcon" title="Love" onclick="loveBlog('promo')"><i class="fa-regular fa-heart"></i></button>
                  <button class="miniIcon" title="Share" onclick="shareBlog('promo')"><i class="fa-solid fa-share-nodes"></i></button>
                </div>
              </div>
              <div class="blogBody">
                <h3>How partner promotions help companies get bookings</h3>
                <div class="blogMeta"><span><i class="fa-regular fa-calendar"></i> 01 May 2026</span><span><i class="fa-regular fa-clock"></i> 5 min read</span><span><i class="fa-solid fa-chart-line"></i> Ads</span></div>
                <p>Boosted listings, banners, referral links and ad analytics can grow partner sales.</p>
                <div class="blogActions"><button class="btn btnGhost" onclick="openBlog('promo')"><i class="fa-regular fa-eye"></i> Read more</button></div>
              </div>
            </article>

            <article class="promoCard blogCard">
              <div class="blogImage">
                <img src="https://images.unsplash.com/photo-1556742049-0cfed4f6a45d?auto=format&fit=crop&w=1200&q=70" alt="Gmail and WhatsApp ticket access">
                <span class="badge badgeHot blogTag"><i class="fa-solid fa-ticket"></i> Booking help</span>
                <div class="blogIconActions">
                  <button class="miniIcon" title="View" onclick="openBlog('tickets')"><i class="fa-regular fa-eye"></i></button>
                  <button class="miniIcon" title="Love" onclick="loveBlog('tickets')"><i class="fa-regular fa-heart"></i></button>
                  <button class="miniIcon" title="Share" onclick="shareBlog('tickets')"><i class="fa-solid fa-share-nodes"></i></button>
                </div>
              </div>
              <div class="blogBody">
                <h3>Where to find tickets after Gmail or WhatsApp delivery</h3>
                <div class="blogMeta"><span><i class="fa-regular fa-calendar"></i> 29 Apr 2026</span><span><i class="fa-regular fa-clock"></i> 2 min read</span><span><i class="fa-solid fa-envelope-circle-check"></i> My bookings</span></div>
                <p>Open receipts, resend tickets, view QR codes and access bookings from the customer dashboard.</p>
                <div class="blogActions"><button class="btn btnGhost" onclick="openBlog('tickets')"><i class="fa-regular fa-eye"></i> Read more</button></div>
              </div>
            </article>
          </div>
        </section>

        <section class="section" id="saved">
          <div class="sectionHead">
            <div>
              <h2>Saved / loved</h2>
              <p>Customers can save buses, hotels, flights, trains and offers they want to book later.</p>
            </div>
            <span class="badge badgeHot"><i class="fa-regular fa-heart"></i> Wishlist</span>
          </div>
          <div class="pageIntro">
            <div>
              <h3>Your saved travel picks</h3>
              <p>Saved items from your account appear here. Every heart button can save a listing to this page.</p>
            </div>
            <button class="btn btnGhost" onclick="toast('Saved picks refreshed from your account.')"><i class="fa-solid fa-cloud-arrow-up"></i> Sync saved</button>
          </div>
          <div class="gridCards" id="savedCards"></div>
        </section>

        <section class="section" id="my-bookings">
          <div class="sectionHead">
            <div>
              <h2>My bookings</h2>
              <p>Tickets sent through Gmail or WhatsApp can also be stored here for quick access.</p>
            </div>
            <span class="badge badgeOk"><i class="fa-solid fa-envelope-circle-check"></i> Email + WhatsApp ready</span>
          </div>
          <div class="gridCards" id="bookingCards"></div>
        </section>
      </div>
    </div>
  </main>

  <footer class="siteFooter">
    <div class="footerGrid">
      <div class="footerBrand">
        <div class="brand"><span class="mark">CT</span><span>Classic Trip</span></div>
        <p>Classic Trip is a multi-tenant travel marketplace for buses, hotels, flights, trains, ferries, tours, car rentals and partner services across East Africa.</p>
        <span><i class="fa-solid fa-shield-halved"></i> Secure checkout</span>
        <span><i class="fa-solid fa-clock"></i> 10 minute seat / room holds</span>
        <span><i class="fa-solid fa-headset"></i> 24/7 customer support ready</span>
      </div>

      <div class="footerCol">
        <h3>Book & manage</h3>
        <a href="#bus" onclick="scrollToSectionId('bus')"><i class="fa-solid fa-bus"></i> Buses</a>
        <a href="#hotel" onclick="scrollToSectionId('hotel')"><i class="fa-solid fa-hotel"></i> Hotels</a>
        <a href="#flight" onclick="scrollToSectionId('flight')"><i class="fa-solid fa-plane"></i> Flights</a>
        <a href="#train" onclick="scrollToSectionId('train')"><i class="fa-solid fa-train"></i> Trains</a>
        <a href="#my-bookings" onclick="scrollToSectionId('my-bookings')"><i class="fa-solid fa-ticket"></i> My bookings</a>
        <a href="#saved" onclick="scrollToSectionId('saved')"><i class="fa-regular fa-heart"></i> Saved trips</a>
        <a href="#blogs" onclick="scrollToSectionId('blogs')"><i class="fa-regular fa-newspaper"></i> Travel blogs</a>
      </div>

      <div class="footerCol">
        <h3>Promotions & partners</h3>
        <a href="#ads" onclick="scrollToSectionId('ads')"><i class="fa-solid fa-bullhorn"></i> Promoted listings</a>
        <span><i class="fa-solid fa-chart-line"></i> Boost company services</span>
        <span><i class="fa-solid fa-users"></i> Promoter referral links</span>
        <span><i class="fa-solid fa-percent"></i> 3% promoter commission</span>
        <span><i class="fa-solid fa-building"></i> Partner dashboards</span>
        <span><i class="fa-solid fa-wallet"></i> Payout tracking</span>
      </div>

      <div class="footerCol">
        <h3>Brand, legal & help</h3>
        <span><i class="fa-solid fa-circle-info"></i> About Classic Trip</span>
        <span><i class="fa-solid fa-book-open"></i> Brand story & media kit</span>
        <span><i class="fa-solid fa-file-contract"></i> Terms & conditions</span>
        <span><i class="fa-solid fa-user-shield"></i> Privacy policy</span>
        <span><i class="fa-solid fa-cookie-bite"></i> Cookie policy</span>
        <span><i class="fa-solid fa-rotate-left"></i> Refund policy</span>
        <span><i class="fa-solid fa-triangle-exclamation"></i> Cancellation rules</span>
        <span><i class="fa-solid fa-envelope"></i> Contact support</span>
      </div>
    </div>
    <div class="footerBottom">
      <span>© 2026 Classic Trip. Marketplace for East Africa bookings.</span>
      <span>3% promoter • 7% platform fee • Partner payout ready • Gmail & WhatsApp ticket access</span>
    </div>
  </footer>


  <div class="modal" id="viewModal">
    <div class="sheet">
      <div class="sheetTop">
        <div>
          <div class="badge badgeInfo" id="modalType">Bus</div>
          <div class="sheetTitle" id="modalTitle">Listing title</div>
          <div class="sheetSub" id="modalSub">Partner • route • date</div>
        </div>
        <div class="sheetTopActions">
          <button class="iconbtn" title="Save" onclick="saveListing(current?.id)"><i class="fa-regular fa-heart"></i></button>
          <button class="iconbtn" title="Share" onclick="shareListing(current?.id)"><i class="fa-solid fa-share-nodes"></i></button>
          <button class="iconbtn" onclick="closeModal()"><i class="fa-solid fa-xmark"></i></button>
        </div>
      </div>

      <div class="sheetBody">
        <div class="visual">
          <div class="visualHero">
            <img id="modalImg" src="" alt="Selected listing">
            <div class="visualText">
              <h3 id="modalHeroTitle">View structure</h3>
              <p id="modalHeroSub">Select available seats / rooms / slots.</p>
            </div>
          </div>

          <div class="selector">
            <div class="selectorTop">
              <div>
                <b id="layoutTitle">Choose your seat</b>
                <div class="muted" style="font-size:13px;font-weight:800" id="layoutHint">Click available seats to select. Taken seats cannot be selected.</div>
              </div>
              <div class="legend">
                <span class="leg"><i class="dot free"></i> Available</span>
                <span class="leg"><i class="dot selected"></i> Selected</span>
                <span class="leg"><i class="dot hold"></i> Held</span>
                <span class="leg"><i class="dot taken"></i> Taken</span>
              </div>
            </div>
            <div class="layoutBox" id="layoutBox"></div>
          </div>
        </div>

        <div class="sidePanel">
          <div class="summaryCard">
            <h3>Booking summary</h3>
            <div class="timer" id="timerBox"><span><i class="fa-regular fa-clock"></i> Hold expires in</span><b id="timer">10:00</b></div>
            <div class="kv" style="margin-top:10px">
              <div><span>Selected</span><b id="selectedOut">None</b></div>
              <div><span>Base price</span><b id="baseOut">UGX 0</b></div>
              <div><span>Service fee</span><b id="feeOut">UGX 0</b></div>
              <div><span>Total</span><b id="totalOut">UGX 0</b></div>
            </div>
          </div>

          <div class="summaryCard">
            <h3>Addons</h3>
            <div class="addons" id="addons"></div>
          </div>

          <div style="display:flex;gap:10px;flex-wrap:wrap;justify-content:flex-end">
            <button class="btn btnGhost" onclick="resetSelection()"><i class="fa-solid fa-rotate-left"></i> Reset</button>
            <button class="btn btnBlue" onclick="holdSelection()"><i class="fa-solid fa-clock"></i> Hold 10 mins</button>
            <button class="btn btnPrimary" onclick="goPaymentPage()"><i class="fa-solid fa-lock"></i> Proceed payment</button>
          </div>
        </div>
      </div>

      <div class="checkoutStep" id="checkoutStep">
        <div class="summaryCard">
          <h3>User information</h3>
          <div class="checkoutNotice">This page appears after Proceed payment. It keeps the selected seat/room/slot and collects customer information separately from the show page.</div>
          <div class="bookingForm" style="margin-top:10px">
            <input id="nameInput" placeholder="Full name">
            <input id="phoneInput" placeholder="Phone number">
            <input class="full" id="emailInput" placeholder="Email address">
            <select id="idInput"><option value="">ID type</option><option>National ID</option><option>Passport</option><option>Student ID</option></select>
            <input id="docInput" placeholder="ID / passport number">
            <textarea class="full" id="noteInput" placeholder="Special request, pickup point, hotel note, baggage note..."></textarea>
          </div>
        </div>

        <div class="summaryCard">
          <h3>Payment</h3>
          <div class="kv">
            <div><span>Listing</span><b id="checkoutListing">-</b></div>
            <div><span>Selected</span><b id="checkoutSelected">-</b></div>
            <div><span>Total to pay</span><b id="checkoutTotal">UGX 0</b></div>
          </div>
          <div class="payMethods">
            <label class="payMethod"><input type="radio" name="payMethod" value="Mobile Money" checked> Mobile Money</label>
            <label class="payMethod"><input type="radio" name="payMethod" value="Card"> Card</label>
            <label class="payMethod"><input type="radio" name="payMethod" value="Wallet"> Wallet</label>
            <label class="payMethod"><input type="radio" name="payMethod" value="Pay at office"> Pay at office</label>
          </div>
          <div class="bookingForm" style="margin-top:10px">
            <input id="paymentRefInput" class="full" placeholder="Mobile money number / card reference / wallet ID">
          </div>
          <div style="display:flex;gap:10px;flex-wrap:wrap;justify-content:flex-end;margin-top:12px">
            <button class="btn btnGhost" onclick="backToSelection()"><i class="fa-solid fa-arrow-left"></i> Back</button>
            <button class="btn btnPrimary" onclick="confirmBooking()"><i class="fa-solid fa-lock"></i> Pay & confirm</button>
          </div>
        </div>
      </div>
    </div>
  </div>



  <div class="modal" id="receiptModal">
    <div class="sheet" style="max-width:720px">
      <div class="sheetTop">
        <div>
          <div class="badge badgeOk"><i class="fa-solid fa-receipt"></i> Receipt</div>
          <div class="sheetTitle" id="receiptTitle">Booking receipt</div>
          <div class="sheetSub" id="receiptSub">Classic Trip ticket receipt</div>
        </div>
        <button class="iconbtn" onclick="closeReceipt()"><i class="fa-solid fa-xmark"></i></button>
      </div>
      <div class="receiptBody">
        <div class="receiptPaper" id="receiptPaper"></div>
        <div style="display:flex;gap:10px;flex-wrap:wrap;justify-content:flex-end">
          <button class="btn btnGhost" onclick="toast('Receipt email queued for delivery.')"><i class="fa-regular fa-envelope"></i> Gmail</button>
          <button class="btn btnGhost" onclick="toast('WhatsApp receipt queued for delivery.')"><i class="fa-brands fa-whatsapp"></i> WhatsApp</button>
          <button class="btn btnPrimary" onclick="closeReceipt()"><i class="fa-solid fa-check"></i> Done</button>
        </div>
      </div>
    </div>
  </div>

  <div class="modal" id="blogModal">
    <div class="sheet" style="max-width:860px">
      <div class="sheetTop">
        <div>
          <div class="badge badgeInfo" id="blogModalTag"><i class="fa-regular fa-newspaper"></i> Blog</div>
          <div class="sheetTitle" id="blogModalTitle">Blog title</div>
          <div class="sheetSub" id="blogModalSub">Date • read time</div>
        </div>
        <div class="sheetTopActions">
          <button class="iconbtn" title="Love" onclick="loveBlog(activeBlogId)"><i class="fa-regular fa-heart"></i></button>
          <button class="iconbtn" title="Share" onclick="shareBlog(activeBlogId)"><i class="fa-solid fa-share-nodes"></i></button>
          <button class="iconbtn" onclick="closeBlog()"><i class="fa-solid fa-xmark"></i></button>
        </div>
      </div>
      <div class="receiptBody">
        <div class="blogReadHero">
          <img id="blogModalImg" src="" alt="Blog image">
          <div class="blogReadText">
            <h3 id="blogHeroTitle">Blog title</h3>
            <p id="blogHeroIntro">Blog intro text</p>
          </div>
        </div>
        <article class="blogArticle" id="blogArticleBody"></article>
        <div style="display:flex;gap:10px;flex-wrap:wrap;justify-content:flex-end;padding:0 14px 14px">
          <button class="btn btnGhost" onclick="shareBlog(activeBlogId)"><i class="fa-solid fa-share-nodes"></i> Share</button>
          <button class="btn btnGhost" onclick="loveBlog(activeBlogId)"><i class="fa-regular fa-heart"></i> Save</button>
          <button class="btn btnPrimary" onclick="closeBlog()"><i class="fa-solid fa-check"></i> Done</button>
        </div>
      </div>
    </div>
  </div>

  <div class="toast" id="toast">Ready</div>

  <script>window.CLASSIC_TRIP_DATA = <%- JSON.stringify(bootstrap || {}) %>;</script>
  <script src="/js/home.js"></script>
</body>
</html>
