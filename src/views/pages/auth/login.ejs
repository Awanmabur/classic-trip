              <div class="checkLine"><label><input type="checkbox" required> I agree to Terms, Privacy Policy, Refund Policy and partner rules.</label></div>
              <button class="submit" type="submit"><i class="fa-solid fa-user-plus"></i>Create account</button>
              <div class="divider">or signup with</div>
              <div class="socialGrid"><a class="social" id="googleSignupLink" href="/auth/google?role=customer"><i class="fa-brands fa-google"></i>Google</a><button class="social" type="button"><i class="fa-brands fa-whatsapp"></i>WhatsApp</button></div>
            </form>
          </div>
          <div class="miniDash">
            <div class="stat"><strong>3%</strong><span>promoter commission ready</span></div>
            <div class="stat"><strong>7%</strong><span>platform fee ready</span></div>
            <div class="stat"><strong>10 min</strong><span>seat / room hold flow</span></div>
          </div>
        </div>

