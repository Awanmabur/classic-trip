<body>
  <div class="navWrap">
    <header class="nav">
      <a class="brand" href="/" aria-label="Classic Trip Home"><img class="mark" src="/images/logo-symbol-128.png" alt="Classic Trip"><span>Classic Trip</span></a>
      <div class="navActions">
        <a class="btn" href="/"><i class="fa-solid fa-house"></i><span style="font-size:13px">Home</span></a>
        <a class="btn" href="/search"><i class="fa-solid fa-magnifying-glass"></i><span style="font-size:13px">Search</span></a>
        <a class="btn" href="/tickets"><i class="fa-solid fa-ticket"></i><span style="font-size:13px">Tickets</span></a>
        <button class="iconBtn" id="themeBtn" aria-label="Toggle theme"><i class="fa-solid fa-moon" id="themeIcon"></i></button>
        <button class="iconBtn" id="menuBtn" aria-label="Open menu"><i class="fa-solid fa-bars"></i></button>
      </div>
    </header>
  </div>

  <main class="main container">
    <section class="grid">
      <aside class="card leftHero">
        <div class="badgeRow">
          <span class="badge ok"><i class="fa-solid fa-shield-halved"></i>Secure login</span>
          <span class="badge info"><i class="fa-solid fa-ticket"></i>My bookings</span>
          <span class="badge warn"><i class="fa-solid fa-bullhorn"></i>Promoter ready</span>
          <span class="badge"><i class="fa-solid fa-building"></i>Partner dashboards</span>
        </div>
        <div class="heroText">
          <div class="eyebrow">Classic Trip account access</div>
          <h1>Login or create your travel account.</h1>
          <p>Customers manage trips, promoters track referral commission, and verified bus or hotel partners onboard from the same secure account page.</p>
        </div>
        <div class="benefits">
          <div class="benefit"><i class="fa-solid fa-receipt"></i><strong>Receipts saved</strong><span>Access tickets from Gmail, WhatsApp, or My Bookings.</span></div>
          <div class="benefit"><i class="fa-solid fa-link"></i><strong>Promoter links</strong><span>Share services and track commission referrals.</span></div>
          <div class="benefit"><i class="fa-solid fa-bus"></i><strong>Partner access</strong><span>Manage routes, rooms, schedules, pricing and ads.</span></div>
          <div class="benefit"><i class="fa-solid fa-lock"></i><strong>Secure checkout</strong><span>Protected sessions, account-state checks, and role permissions.</span></div>
        </div>
      </aside>

      <section class="card authShell">
        <div class="authTop">
          <div>
            <h2 id="panelTitle">Welcome back</h2>
            <p id="panelSub">Login to manage bookings, saved trips, tickets and payments.</p>
          </div>
          <div class="toggle" aria-label="Account access switch">
            <button class="active" data-open-panel="login">Login</button>
            <button data-open-panel="signup">Signup</button>
            <button data-open-panel="partner">Partner</button>
          </div>
        </div>

        <% if (Array.isArray(flashMessages) && flashMessages.length) { %>
          <div class="flashStack" role="status" aria-live="polite">
            <% flashMessages.forEach(function(message){ %>
              <div class="flashMessage <%= message.type || 'info' %>"><i class="fa-solid <%= message.type === 'error' ? 'fa-circle-exclamation' : message.type === 'success' ? 'fa-circle-check' : 'fa-circle-info' %>"></i> <%= message.text %></div>
            <% }); %>
          </div>
        <% } %>
        <div id="successBox" class="successBox"><i class="fa-solid fa-circle-check"></i> Request sent.</div>

        <div class="panel active" id="loginPanel">
          <div class="formCard">
            <form class="form active" id="loginForm" action="/login" method="post"><input type="hidden" name="_csrf" value="<%= csrfToken || '' %>">
              <div class="field">
                <label>Email or phone number <a class="link" href="#" data-open-panel="forgot">Forgot?</a></label>
                <div class="control"><i class="fa-regular fa-envelope"></i><input type="text" name="identity" placeholder="Email or phone" autocomplete="username" required></div>
              </div>
              <div class="field">
                <label>Password</label>
                <div class="control"><i class="fa-solid fa-lock"></i><input type="password" name="password" placeholder="Enter password" autocomplete="current-password" required><button type="button" class="passwordToggle" aria-label="Show password"><i class="fa-regular fa-eye"></i></button></div>
              </div>
              <div class="checkLine">
                <label><input type="checkbox"> Keep me logged in</label>
                <a class="link" href="#" data-open-panel="forgot">Recover account</a>
              </div>
              <button class="submit" type="submit"><i class="fa-solid fa-right-to-bracket"></i>Login</button>
              <div class="divider">or continue with</div>
              <div class="socialGrid">
                <a class="social" id="googleLoginLink" href="/auth/google?intent=login"><i class="fa-brands fa-google"></i>Google</a>
                <button class="social" type="button"><i class="fa-brands fa-whatsapp"></i>WhatsApp</button>
              </div>
            </form>
          </div>
          <div class="notice"><strong>Tip:</strong> after login, customers go to My Bookings, promoters go to commission dashboard, and partners go to their company dashboard.</div>
        </div>

        <div class="panel" id="signupPanel">
          <div class="formCard">
            <div class="roleGrid" aria-label="Account type">
              <button class="role active" type="button" data-role="customer"><i class="fa-regular fa-user"></i>Customer</button>
              <button class="role" type="button" data-role="promoter"><i class="fa-solid fa-share-nodes"></i>Promoter</button>
            </div>
            <form class="form active" id="signupForm" action="/register" method="post"><input type="hidden" name="_csrf" value="<%= csrfToken || '' %>"><input type="hidden" name="role" id="roleInput" value="customer">
              <div class="row2">
                <div class="field"><label>First name</label><div class="control"><i class="fa-regular fa-user"></i><input name="firstName" placeholder="First name" autocomplete="given-name" required></div></div>
                <div class="field"><label>Last name</label><div class="control"><i class="fa-regular fa-user"></i><input name="lastName" placeholder="Last name" autocomplete="family-name" required></div></div>
              </div>
              <div class="row2">
                <div class="field"><label>Email</label><div class="control"><i class="fa-regular fa-envelope"></i><input type="email" name="email" placeholder="Email address" autocomplete="email" required></div></div>
                <div class="field"><label>Phone</label><div class="control"><i class="fa-brands fa-whatsapp"></i><input name="phone" placeholder="WhatsApp phone" autocomplete="tel" required></div></div>
              </div>
              <div class="row2">
                <div class="field"><label>Password</label><div class="control"><i class="fa-solid fa-lock"></i><input type="password" name="password" placeholder="Create password" autocomplete="new-password" minlength="8" maxlength="72" pattern="(?=.*[A-Za-z])(?=.*[0-9]).{8,72}" title="Use 8–72 characters with at least one letter and one number" required><button type="button" class="passwordToggle" aria-label="Show password"><i class="fa-regular fa-eye"></i></button></div></div>
                <div class="field"><label>Confirm password</label><div class="control"><i class="fa-solid fa-lock"></i><input type="password" name="confirmPassword" placeholder="Repeat password" autocomplete="new-password" minlength="8" maxlength="72" required></div></div>
              </div>
              <div class="checkLine"><label><input type="checkbox" name="termsAccepted" required> I agree to the Terms, Privacy Policy and Refund Policy.</label></div>
              <button class="submit" type="submit"><i class="fa-solid fa-user-plus"></i>Create account</button>
              <div class="divider">or signup with</div>
              <div class="socialGrid"><a class="social" id="googleSignupLink" href="/auth/google?role=customer"><i class="fa-brands fa-google"></i>Google</a><button class="social" type="button"><i class="fa-brands fa-whatsapp"></i>WhatsApp</button></div>
            </form>
            <div class="notice" style="margin-top:12px"><strong>Staff and drivers:</strong> employee, agent, finance, check-in, support, and driver accounts are created only through a secure company invitation.</div>
            <a class="partnerOnboardingLink" href="#partner" data-open-panel="partner"><i class="fa-solid fa-building-circle-check"></i><span><strong>Register a bus or hotel company</strong><small>Continue in this same secure account and onboarding page.</small></span><i class="fa-solid fa-arrow-right"></i></a>
          </div>
          <div class="miniDash">
            <div class="stat"><strong><%= platformConfig.supportedCurrencies.length %></strong><span>supported currencies</span></div>
            <div class="stat"><strong><%= platformConfig.holdMinutes %> min</strong><span>inventory hold rule</span></div>
            <div class="stat"><strong>1 source</strong><span>database-backed records</span></div>
          </div>
        </div>

        <div class="panel" id="supportPanel">
          <div class="formCard">
            <div class="authTop" style="margin-bottom:12px">
              <div>
                <h2 style="font-size:22px;margin:0;letter-spacing:-.45px">How can we help?</h2>
                <p>Support for bookings, payments, receipts, partner accounts and referral earnings.</p>
              </div>
              <span class="badge ok"><i class="fa-solid fa-headset"></i>24/7 support</span>
            </div>
            <div class="supportOptions">
              <button class="supportTile" type="button"><i class="fa-solid fa-ticket"></i>Booking help<span>Tickets, seats, rooms and schedules</span></button>
              <button class="supportTile" type="button"><i class="fa-solid fa-receipt"></i>Payment issue<span>Receipts, refunds and failed payments</span></button>
              <button class="supportTile" type="button"><i class="fa-solid fa-building"></i>Partner help<span>Listings, staff and dashboards</span></button>
            </div>
            <form class="form active" id="supportForm" action="/support" method="post"><input type="hidden" name="_csrf" value="<%= csrfToken || '' %>">
              <div class="row2">
                <div class="field"><label>Name</label><div class="control"><i class="fa-regular fa-user"></i><input name="name" placeholder="Your name" required></div></div>
                <div class="field"><label>Email or phone</label><div class="control"><i class="fa-regular fa-envelope"></i><input name="contact" placeholder="Email / WhatsApp" required></div></div>
              </div>
              <div class="row2">
                <div class="field"><label>Topic</label><div class="control"><i class="fa-solid fa-circle-question"></i><select name="category"><option>Booking support</option><option>Payment / receipt</option><option>Refund / cancellation</option><option>Promoter commission</option><option>Partner onboarding</option><option>Technical issue</option></select></div></div>
                <div class="field"><label>Booking reference</label><div class="control"><i class="fa-solid fa-hashtag"></i><input name="bookingRef" placeholder="Optional ticket ID"></div></div>
              </div>
              <div class="field"><label>Message</label><div class="control" style="height:auto;border-radius:22px;padding:12px 14px;align-items:flex-start"><i class="fa-regular fa-message" style="margin-top:4px"></i><input name="message" placeholder="Briefly explain the issue" required></div></div>
              <button class="submit" type="submit"><i class="fa-solid fa-paper-plane"></i>Send support request</button>
            </form>
          </div>
          <div class="faqList">
            <div class="faqItem"><strong>Where do customers find tickets?</strong><p>After confirmation, tickets can appear in My Bookings and can also be sent through Gmail or WhatsApp.</p></div>
            <div class="faqItem"><strong>Can partners add employees?</strong><p>Yes. The platform can support roles like company admin, finance, agent, check-in staff and support users.</p></div>
            <div class="faqItem"><strong>How do promoter links work?</strong><p>A promoter shares a service link. When a customer books through that link, commission tracking can credit the promoter account.</p></div>
          </div>
        </div>

        <div class="panel" id="forgotPanel">
          <div class="formCard">
            <form class="form active" id="forgotForm" action="/forgot-password" method="post"><input type="hidden" name="_csrf" value="<%= csrfToken || '' %>">
              <div class="field"><label>Recover your account</label><div class="control"><i class="fa-regular fa-envelope"></i><input type="text" name="identity" placeholder="Email or phone number" required></div></div>
              <button class="submit" type="submit"><i class="fa-solid fa-paper-plane"></i>Send reset link</button>
              <button class="social" type="button" data-open-panel="login"><i class="fa-solid fa-arrow-left"></i>Back to login</button>
            </form>
          </div>
          <div class="notice"><strong>Recovery:</strong> verified reset delivery is handled through the configured email or SMS channel.</div>
        </div>

        <div class="panel" id="partnerPanel">
          <%- include('./_partner-signup') %>
        </div>
      </section>
    </section>
  </main>


  <div class="drawer" id="drawer" aria-hidden="true">
    <div class="drawerPanel" role="dialog" aria-modal="true" aria-label="Menu">
      <div class="drawerTop"><div class="brand"><img class="mark" src="/images/logo-symbol-128.png" alt="Classic Trip"><span>Classic Trip</span></div><button class="iconBtn" id="closeDrawer"><i class="fa-solid fa-xmark"></i></button></div>
      <div class="drawerLinks">
        <a href="#login" data-open-panel="login"><i class="fa-solid fa-right-to-bracket"></i>Login</a>
        <a href="#signup" data-open-panel="signup"><i class="fa-solid fa-user-plus"></i>Customer / promoter signup</a>
        <a href="#partner" data-open-panel="partner"><i class="fa-solid fa-building"></i>Become a partner</a>
        <a href="#forgot" data-open-panel="forgot"><i class="fa-solid fa-key"></i>Forgot password</a>
        <a href="#support" data-open-panel="support"><i class="fa-solid fa-headset"></i>Support</a>
        <a href="/partner-commission"><i class="fa-solid fa-percent"></i>View partner commission</a>
        <a href="/"><i class="fa-solid fa-house"></i>Back to home</a>
        <a href="/search"><i class="fa-solid fa-magnifying-glass"></i>Search trips</a>
        <a href="/tickets"><i class="fa-solid fa-ticket"></i>Find my ticket</a>
      </div>
    </div>
  </div>

  <div class="toast" id="toast">Action completed</div>

  <script nonce="<%= cspNonce %>">
    const html = document.documentElement;
    const themeBtn = document.getElementById('themeBtn');
    const themeIcon = document.getElementById('themeIcon');
    const panels = { login: document.getElementById('loginPanel'), signup: document.getElementById('signupPanel'), partner: document.getElementById('partnerPanel'), support: document.getElementById('supportPanel'), forgot: document.getElementById('forgotPanel') };
    const panelTitle = document.getElementById('panelTitle');
    const panelSub = document.getElementById('panelSub');
    const drawer = document.getElementById('drawer');
    const successBox = document.getElementById('successBox');
    const toast = document.getElementById('toast');
    const roleInput = document.getElementById('roleInput');
    const googleSignupLink = document.getElementById('googleSignupLink');

    function showToast(message){ toast.textContent = message; toast.classList.add('show'); setTimeout(()=>toast.classList.remove('show'), 2200); }
    function setTheme(mode){ html.setAttribute('data-theme', mode); try { localStorage.setItem('classicTripTheme', mode); localStorage.removeItem('ct-theme'); localStorage.removeItem('ct_auth_theme'); } catch (_) {} themeIcon.className = mode === 'dark' ? 'fa-solid fa-moon' : 'fa-solid fa-sun'; }
    let savedTheme = 'dark'; try { savedTheme = localStorage.getItem('classicTripTheme') || localStorage.getItem('ct-theme') || localStorage.getItem('ct_auth_theme') || 'dark'; } catch (_) {} setTheme(savedTheme);
    themeBtn.addEventListener('click', ()=> setTheme(html.getAttribute('data-theme') === 'dark' ? 'light' : 'dark'));

    function openPanel(name){
      if (!panels[name]) name = 'login';
      Object.entries(panels).forEach(([key,p]) => { if (p) p.classList.toggle('active', key === name); });
      document.querySelectorAll('[data-open-panel]').forEach(btn => btn.classList.toggle('active', btn.dataset.openPanel === name));
      successBox.classList.remove('show');
      const copy = {
        login:['Welcome back','Login to manage bookings, saved trips, tickets and payments.'],
        signup:['Create your account','Choose customer or promoter access. Staff and drivers use secure invitations.'],
        partner:['Partner onboarding','Create one verified owner account for a bus or hotel company.'],
        support:['Support center','Get help with bookings, payments, refunds, receipts and partner accounts.'],
        forgot:['Recover account','Get a reset link or OTP for your Classic Trip account.']
      };
      if (panelTitle && copy[name]) panelTitle.textContent = copy[name][0];
      if (panelSub && copy[name]) panelSub.textContent = copy[name][1];
      history.replaceState(null,'','#' + name);
      if (drawer) { drawer.classList.remove('open'); drawer.setAttribute('aria-hidden','true'); }
    }
    document.querySelectorAll('[data-open-panel]').forEach(btn => btn.addEventListener('click', (e)=>{ e.preventDefault(); openPanel(btn.dataset.openPanel); if(btn.dataset.roleLink) setRole(btn.dataset.roleLink); }));

    function setRole(role){
      document.querySelectorAll('.role').forEach(btn => btn.classList.toggle('active', btn.dataset.role === role));
      if (!roleInput) return;
      roleInput.value = ['customer','promoter'].includes(role) ? role : 'customer';
      const submitText = {customer:'Create customer account', promoter:'Create promoter account'}[roleInput.value] || 'Create account';
      const signupSubmit = document.querySelector('#signupForm .submit');
      if (signupSubmit) signupSubmit.innerHTML = '<i class="fa-solid fa-user-plus"></i>' + submitText;
      updateGoogleSignupLink();
    }
    document.querySelectorAll('.role').forEach(btn => btn.addEventListener('click', ()=> setRole(btn.dataset.role)));
    function updateGoogleSignupLink(){
      if (!roleInput || !googleSignupLink) return;
      const params = new URLSearchParams({ role: ['customer','promoter'].includes(roleInput.value) ? roleInput.value : 'customer' });
      googleSignupLink.href = '/auth/google?' + params.toString();
    }
    updateGoogleSignupLink();

    document.querySelectorAll('.passwordToggle').forEach(btn => btn.addEventListener('click', ()=>{
      const input = btn.parentElement.querySelector('input');
      input.type = input.type === 'password' ? 'text' : 'password';
      btn.querySelector('i').className = input.type === 'password' ? 'fa-regular fa-eye' : 'fa-regular fa-eye-slash';
    }));

    document.querySelectorAll('form').forEach(form => form.addEventListener('submit', ()=>{
      const submitButton = form.querySelector('button[type="submit"]');
      if (submitButton) {
        submitButton.disabled = true;
        submitButton.setAttribute('aria-disabled', 'true');
      }
      const copy = {
        signupForm: 'Creating your account...',
        supportForm: 'Sending your support request...',
        forgotForm: 'Sending your reset link...',
        partnerOnboardingForm: 'Creating your partner account...'
      };
      if (!copy[form.id]) return;
      successBox.innerHTML = '<i class="fa-solid fa-circle-check"></i> ' + copy[form.id];
      successBox.classList.add('show');
      showToast(copy[form.id]);
    }));

    document.getElementById('menuBtn')?.addEventListener('click', ()=>{ drawer?.classList.add('open'); drawer?.setAttribute('aria-hidden','false'); });
    document.getElementById('closeDrawer')?.addEventListener('click', ()=>{ drawer?.classList.remove('open'); drawer?.setAttribute('aria-hidden','true'); });
    drawer?.addEventListener('click', e => { if(e.target === drawer){ drawer.classList.remove('open'); drawer.setAttribute('aria-hidden','true'); }});

    const requestedRole = new URLSearchParams(location.search).get('role');
    const start = location.hash.replace('#','');
    if (['partner','company','company_admin'].includes(String(requestedRole || '').toLowerCase())) openPanel('partner');
    else if (['login','signup','partner','support','forgot'].includes(start)) openPanel(start);
  </script>
</body>
</html>
