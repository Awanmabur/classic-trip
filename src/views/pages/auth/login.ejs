            <form class="form active" id="partnerForm" action="/partner-requests" method="post">
              <div class="row2">
                <div class="field"><label>Company name</label><div class="control"><i class="fa-solid fa-building"></i><input name="name" placeholder="Company / brand name" required></div></div>
                <div class="field"><label>Business type</label><div class="control"><i class="fa-solid fa-list"></i><select name="companyType" required><option>Bus company</option><option>Hotel / apartment</option><option>Airline</option><option>Train operator</option><option>Tour company</option><option>Car rental</option><option>Ferry / boat</option></select></div></div>
              </div>
              <div class="row2">
                <div class="field"><label>Country</label><div class="control"><i class="fa-solid fa-globe"></i><select name="country"><option>Uganda</option><option>Kenya</option><option>Tanzania</option><option>Rwanda</option><option>Burundi</option><option>South Sudan</option><option>Ethiopia</option><option>Somalia</option><option>DR Congo</option></select></div></div>
