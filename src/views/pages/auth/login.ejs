    @media(max-width:760px){.partnerPlanGrid{grid-template-columns:1fr}.partnerSteps{grid-template-columns:1fr 1fr}.partnerSectionTitle{align-items:flex-start;flex-direction:column}.partnerSectionTitle small{text-align:left}}
