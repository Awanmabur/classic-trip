              <div class="row2">
                <div class="field"><label>Name</label><div class="control"><i class="fa-regular fa-user"></i><input name="name" placeholder="Your name" required></div></div>
                <div class="field"><label>Email or phone</label><div class="control"><i class="fa-regular fa-envelope"></i><input name="contact" placeholder="Email / WhatsApp" required></div></div>
              </div>
