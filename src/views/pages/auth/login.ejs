                <div class="field"><label>WhatsApp phone</label><div class="control"><i class="fa-brands fa-whatsapp"></i><input name="phone" placeholder="WhatsApp number" required></div></div>
              </div>
              <button class="submit" type="submit"><i class="fa-solid fa-paper-plane"></i>Request partner access</button>
            </form>
