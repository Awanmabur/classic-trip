                <div class="field"><label>Topic</label><div class="control"><i class="fa-solid fa-circle-question"></i><select name="category"><option>Booking support</option><option>Payment / receipt</option><option>Refund / cancellation</option><option>Promoter commission</option><option>Partner onboarding</option><option>Technical issue</option></select></div></div>
