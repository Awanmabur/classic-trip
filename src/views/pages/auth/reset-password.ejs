<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= seo?.title || 'Reset password | Classic Trip' %></title>
  <meta name="csrf-token" content="<%= csrfToken || '' %>" />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800;900&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
  <script src="/js/csrf.js" defer></script>
  <style>
    :root{font-family:Inter,system-ui,sans-serif;color:#f8fafc;background:#070a12}
    body{margin:0;min-height:100vh;display:grid;place-items:center;padding:24px}
    .card{width:min(460px,100%);border:1px solid rgba(255,255,255,.12);border-radius:24px;background:linear-gradient(180deg,rgba(255,255,255,.09),rgba(255,255,255,.04));box-shadow:0 24px 80px rgba(0,0,0,.4);padding:22px}
    .brand{display:flex;align-items:center;gap:10px;font-weight:900;margin-bottom:20px}
    .mark{width:42px;height:42px;border-radius:14px;background:#ffb703;color:#0f172a;display:grid;place-items:center}
    h1{font-size:26px;margin:0 0 6px}
    p{color:#a8b3c7;margin:0 0 18px;font-weight:700}
    form{display:grid;gap:12px}
    label{font-size:12px;color:#cbd5e1;font-weight:900}
    .control{display:flex;align-items:center;gap:10px;border:1px solid rgba(255,255,255,.14);background:rgba(255,255,255,.06);border-radius:18px;padding:0 12px;height:50px}
    .control input{width:100%;border:0;outline:0;background:transparent;color:#fff;font:inherit;font-weight:800}
    button,.btn{height:48px;border:0;border-radius:18px;background:#4f8cff;color:white;font-weight:950;display:inline-flex;align-items:center;justify-content:center;gap:8px;text-decoration:none;cursor:pointer}
    .btn{background:rgba(255,255,255,.08);margin-top:8px}
  </style>
</head>
<body>
  <main class="card">
    <div class="brand"><span class="mark">CT</span><span>Classic Trip</span></div>
    <h1>Reset password</h1>
    <p>Create a new password for your Classic Trip account.</p>
    <form action="/reset-password" method="post">
      <input type="hidden" name="token" value="<%= token %>">
      <label>New password</label>
      <div class="control"><i class="fa-solid fa-lock"></i><input name="password" type="password" minlength="6" required autocomplete="new-password"></div>
      <label>Confirm password</label>
      <div class="control"><i class="fa-solid fa-lock"></i><input name="confirmPassword" type="password" minlength="6" required autocomplete="new-password"></div>
      <button type="submit"><i class="fa-solid fa-key"></i> Save new password</button>
    </form>
    <a class="btn" href="/login"><i class="fa-solid fa-arrow-left"></i> Back to login</a>
  </main>
</body>
</html>
