<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/png" href="/images/favicon-48.png" />
  <title><%= seo?.title || 'Verify phone number | Classic Trip' %></title>
  <meta name="csrf-token" content="<%= csrfToken || '' %>" />
  <link rel="stylesheet" href="/css/base.css" />
  <link rel="stylesheet" href="/css/components.css" />
  <script src="/js/csrf.js?v=20260722-3" defer></script>
  <style>
    body{min-height:100vh;display:grid;place-items:center;background:#070a12;color:#f4f7ff;font-family:Inter,system-ui,Arial,sans-serif;padding:24px}.verifyCard{width:min(520px,94vw);border:1px solid rgba(255,255,255,.14);border-radius:26px;background:rgba(255,255,255,.07);box-shadow:0 26px 80px rgba(0,0,0,.35);padding:28px}.badge{display:inline-flex;border-radius:999px;border:1px solid rgba(255,255,255,.14);padding:8px 12px;color:#b8c4dd}.muted{color:#b8c4dd}.form{display:grid;gap:12px;margin-top:16px}.control{border:1px solid rgba(255,255,255,.14);background:rgba(255,255,255,.08);border-radius:999px;padding:0 16px;height:52px}.control input{width:100%;height:100%;border:0;outline:0;background:transparent;color:#fff;font-size:20px;font-weight:800;letter-spacing:.2em;text-align:center}.actions{display:flex;gap:10px;flex-wrap:wrap}.btn{border:0;border-radius:999px;padding:14px 18px;background:#4f8cff;color:#fff;font-weight:800;text-decoration:none;cursor:pointer}.btn.secondary{background:rgba(255,255,255,.08)}
  </style>
  <link rel="stylesheet" href="/css/accessibility.css?v=20260723-design-fares-payments-final-1" />
</head>
<body>
  <main class="verifyCard">
    <span class="badge">Secure account verification</span>
    <h1>Verify your phone number</h1>
    <% if (user.phoneVerifiedAt) { %>
      <p class="muted"><strong><%= user.phone %></strong> is verified.</p>
      <a class="btn" href="<%= dashboardUrl || '/onboarding/status' %>">Return to your account</a>
    <% } else { %>
      <p class="muted">We will send a six-digit code to <strong><%= user.phone %></strong>. The code expires after ten minutes.</p>
      <form class="form" method="post" action="/account/phone-verification/request">
        <input type="hidden" name="_csrf" value="<%= csrfToken || '' %>">
        <button class="btn secondary" type="submit">Send verification code</button>
      </form>
      <form class="form" method="post" action="/account/phone-verification/verify">
        <input type="hidden" name="_csrf" value="<%= csrfToken || '' %>">
        <div class="control"><input name="code" inputmode="numeric" autocomplete="one-time-code" pattern="[0-9]{6}" maxlength="6" required placeholder="000000"></div>
        <div class="actions"><button class="btn" type="submit">Verify phone</button><a class="btn secondary" href="/onboarding/status">Back</a></div>
      </form>
    <% } %>
  </main>
</body>
</html>
