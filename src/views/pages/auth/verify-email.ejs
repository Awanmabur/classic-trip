<%- include('../../partials/site-head', { seo }) %>
<%- include('../../partials/site-header') %>
<main class="container" style="padding:40px 0;display:flex;justify-content:center;align-items:flex-start;min-height:60vh">
  <div class="card" style="padding:28px;max-width:480px;width:100%;display:grid;gap:16px;text-align:center">
    <% if (error) { %>
      <div class="badge badgeHot" style="margin:0 auto"><i class="fa-solid fa-triangle-exclamation"></i> Verification failed</div>
      <h1 style="font-size:22px;margin:0">Link invalid or expired</h1>
      <p class="muted" style="margin:0;font-size:14px;font-weight:780;line-height:1.65"><%= error %></p>
      <p class="muted" style="margin:0;font-size:13px;font-weight:780;line-height:1.6">Verification links expire after 24 hours. If you're logged in, you can request a new link from your account dashboard.</p>
      <div style="display:grid;gap:9px">
        <a class="btn btnPrimary" href="/account" style="height:46px"><i class="fa-solid fa-arrow-right"></i> Go to my account</a>
        <form action="/account/resend-verification" method="post" style="margin:0">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <button class="btn btnGhost" type="submit" style="width:100%;height:46px"><i class="fa-solid fa-envelope"></i> Resend verification email</button>
        </form>
        <a class="btn btnGhost" href="/login" style="height:46px"><i class="fa-regular fa-user"></i> Back to login</a>
      </div>
    <% } else { %>
      <div class="badge badgeOk" style="margin:0 auto"><i class="fa-solid fa-circle-check"></i> Email verified</div>
      <h1 style="font-size:22px;margin:0">Your email has been verified</h1>
      <p class="muted" style="margin:0;font-size:14px;font-weight:780;line-height:1.65">Your Classic Trip account is now fully verified. You can log in and access all features.</p>
      <a class="btn btnPrimary" href="/login" style="height:46px"><i class="fa-regular fa-user"></i> Login to your account</a>
    <% } %>
  </div>
</main>
<%- include('../../partials/site-footer') %>
