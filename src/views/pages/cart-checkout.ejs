<%- include('../partials/site-head', { seo }) %>
<%- include('../partials/site-header') %>
<main class="container py-4">
  <section class="rounded-4 border bg-white p-4 shadow-sm">
    <div class="d-flex flex-wrap justify-content-between align-items-start gap-3">
      <div>
        <p class="text-uppercase small text-muted mb-1">Multi-service cart</p>
        <h1 class="h3 mb-1"><%= cart.cartRef %></h1>
        <p class="text-muted mb-0">One Classic Trip checkout can contain live bus seats and hotel rooms.</p>
      </div>
      <div class="text-end">
        <span class="badge text-bg-<%= ['checked_out','validated'].includes(cart.status) ? 'success' : ['payment_failed','inventory_failed','validation_failed'].includes(cart.status) ? 'danger' : 'secondary' %>"><%= cart.status %></span>
        <div class="fs-4 fw-bold mt-2"><%= money(cart.pricing && cart.pricing.total, cart.pricing && cart.pricing.currency || platformConfig.defaultCurrency) %></div>
      </div>
    </div>
    <% if (recovery || cart.recoveryState) { %>
      <div class="alert alert-warning mt-4">
        <strong>Recovery state:</strong> <%= cart.recoveryState && cart.recoveryState.message || 'This cart needs review before checkout.' %>
        <form method="post" action="/cart/<%= cart.cartRef %>/recover" class="mt-3">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <button class="btn btn-sm btn-warning">Recover cart and revalidate</button>
        </form>
      </div>
    <% } %>
    <div class="row g-3 mt-3">
      <div class="col-lg-8">
        <h2 class="h5">Cart items</h2>
        <% if (!cart.items.length) { %>
          <div class="border rounded-3 p-4 text-muted">No services are in this cart yet. Add a bus seat, hotel room, or enabled add-on before checkout.</div>
        <% } %>
        <% cart.items.forEach((item) => { %>
          <article class="border rounded-3 p-3 mb-2">
            <div class="d-flex justify-content-between gap-3">
              <div>
                <strong><%= item.serviceType %></strong>
                <div class="text-muted small">Listing: <%= item.listingId %></div>
                <% if (item.serviceType === 'bus') { %><div>Schedule <%= item.scheduleId %> · Seats <%= item.selectedSeats.join(', ') %></div><% } %>
                <% if (item.serviceType === 'hotel') { %><div><%= item.roomCount %> room(s) · <%= item.checkIn %> to <%= item.checkOut %></div><% } %>
              </div>
              <span class="badge text-bg-light"><%= item.passengers.length %> guest detail(s)</span>
            </div>
          </article>
        <% }) %>
      </div>
      <aside class="col-lg-4">
        <div class="border rounded-3 p-3 bg-light">
          <h2 class="h5">Checkout summary</h2>
          <dl class="row small mb-0">
            <dt class="col-7">Subtotal</dt><dd class="col-5 text-end"><%= money(cart.pricing && cart.pricing.subtotal, cart.pricing && cart.pricing.currency || platformConfig.defaultCurrency) %></dd>
            <dt class="col-7">Discount</dt><dd class="col-5 text-end"><%= money(cart.pricing && cart.pricing.discount || 0, cart.pricing && cart.pricing.currency || platformConfig.defaultCurrency) %></dd>
            <dt class="col-7">Taxes / fees</dt><dd class="col-5 text-end"><%= money(cart.pricing && cart.pricing.fees, cart.pricing && cart.pricing.currency || platformConfig.defaultCurrency) %></dd>
            <dt class="col-7">Total</dt><dd class="col-5 text-end fw-bold"><%= money(cart.pricing && cart.pricing.total, cart.pricing && cart.pricing.currency || platformConfig.defaultCurrency) %></dd>
          </dl>
          <% if (cart.validation && cart.validation.messages) { %><p class="small mt-3 mb-0"><%= cart.validation.messages.join(' · ') %></p><% } %>
          <form method="post" action="/cart/<%= cart.cartRef %>/validate" class="mt-3">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <button class="btn btn-outline-primary w-100">Validate cart</button>
          </form>
          <form method="post" action="/cart/<%= cart.cartRef %>/checkout" class="mt-2">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <button class="btn btn-primary w-100" <%= cart.status === 'checked_out' ? 'disabled' : '' %>>Pay once for full cart</button>
          </form>
        </div>
      </aside>
    </div>
  </section>
</main>
<%- include('../partials/site-footer') %>
