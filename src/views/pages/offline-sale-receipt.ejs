<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/png" href="/images/favicon-48.png" />
  <title><%= sale.receiptRef %> | Classic Trip</title>
  <style>
    body{font-family:Inter,Arial,sans-serif;margin:0;background:#f3f4f6;color:#111827}.page{max-width:860px;margin:32px auto;background:#fff;border:1px solid #e5e7eb;border-radius:22px;padding:28px;box-shadow:0 18px 40px rgba(15,23,42,.08)}.head{display:flex;justify-content:space-between;gap:20px;border-bottom:2px solid #e5e7eb;padding-bottom:16px;margin-bottom:18px}.brand h1{margin:0;font-size:24px}.brand p,.muted{color:#6b7280}.badge{display:inline-block;border:1px solid #bbf7d0;background:#dcfce7;color:#166534;border-radius:999px;padding:7px 10px;font-weight:800;font-size:12px}.grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:14px}.item{border:1px solid #e5e7eb;border-radius:14px;padding:12px;background:#f9fafb}.item span{display:block;font-size:10px;color:#6b7280;text-transform:uppercase;font-weight:800;letter-spacing:.05em}.item b{display:block;margin-top:5px}.actions{display:flex;gap:10px;justify-content:flex-end;margin-top:20px}.btn{border:1px solid #d1d5db;background:#111827;color:#fff;border-radius:12px;padding:10px 14px;text-decoration:none;font-weight:800}.btn.alt{background:#fff;color:#111827}@media print{body{background:#fff}.page{box-shadow:none;border:0;margin:0;max-width:none}.actions{display:none}}
  </style>
  <link rel="stylesheet" href="/css/accessibility.css?v=20260723-design-fares-payments-final-1" />
</head>
<body>
<%
  const isBusSale = (listing?.serviceType || sale.serviceType) === 'bus';
  const formatSeatNo = (value) => {
    const raw = String(value || '').trim();
    if (!raw) return '-';
    if (!isBusSale) return raw;
    const withoutPrefix = raw.replace(/^seat\s*(no\.?|number)?\s*/i, '').trim();
    const prefixed = withoutPrefix.match(/^[A-Za-z](\d+)$/);
    const clean = prefixed ? prefixed[1] : withoutPrefix;
    return `Seat No ${clean || raw}`;
  };
%>
  <main class="page">
    <div class="head">
      <div class="brand">
        <h1>Classic Trip Offline Sales Receipt</h1>
        <p>Receipt issued for an agent/terminal sale.</p>
      </div>
      <div><span class="badge"><%= sale.status %></span></div>
    </div>
    <div class="grid">
      <div class="item"><span>Receipt</span><b><%= sale.receiptRef %></b></div>
      <div class="item"><span>Booking / ticket</span><b><%= sale.bookingRef %></b></div>
      <div class="item"><span>Passenger</span><b><%= sale.passengerName || sale.customerName %></b></div>
      <div class="item"><span>Contact</span><b><%= sale.customerPhone || sale.customerEmail || '-' %></b></div>
      <div class="item"><span>Listing</span><b><%= listing?.title || sale.listingId %></b></div>
      <div class="item"><span>Company</span><b><%= company?.name || sale.companyId %></b></div>
      <div class="item"><span><%= isBusSale ? 'Seat' : 'Seat / room' %></span><b><%= formatSeatNo(sale.seatNumber) %></b></div>
      <div class="item"><span>Payment</span><b><%= sale.currency %> <%= Number(sale.amountCollected || 0).toLocaleString() %> via <%= sale.paymentMethod %></b></div>
      <div class="item"><span>Payment reference</span><b><%= sale.paymentReference || payment?.providerReference || '-' %></b></div>
      <div class="item"><span>Agent</span><b><%= sale.agentName %> · <%= sale.agentLocation || 'Office/terminal' %></b></div>
    </div>
    <p class="muted">This receipt links to the real Classic Trip ticket, passenger manifest, payment record, ledger entries, and agent commission report.</p>
    <div class="actions">
      <a class="btn alt" href="/tickets/<%= encodeURIComponent(sale.bookingRef) %>">Open ticket</a>
      <button class="btn" type="button" data-page-action="print">Print / Save PDF</button>
    </div>
  </main>
  <script src="/js/page-actions.js" defer></script>
</body>
</html>
