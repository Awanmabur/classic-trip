<%- include('../partials/site-head', { seo }) %>
<%- include('../partials/site-header') %>
<main class="container" style="padding:16px 0 30px">

  <section class="card heroCard" style="margin-bottom:16px">
    <span class="badge badgeInfo"><i class="fa-solid fa-layer-group"></i> Partner plans</span>
    <h1 class="heroTitle" style="max-width:44ch">Simple, transparent pricing for every travel business.</h1>
    <p class="heroSub">Every plan includes partner dashboard access, secure payment collection, booking workflows, staff tools, manifests, support cases and payout reporting. No hidden fees.</p>
    <div class="actions" style="margin-top:14px">
      <a class="btn btnPrimary" href="/partner/onboarding?plan=<%= selectedPlanId %>"><i class="fa-solid fa-arrow-right"></i> Start onboarding</a>
      <a class="btn btnGhost" href="/company/billing"><i class="fa-solid fa-building"></i> Upgrade existing company</a>
      <a class="btn btnGhost" href="/how-it-works"><i class="fa-solid fa-circle-question"></i> How it works</a>
    </div>
  </section>

  <section style="display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:16px;margin-bottom:20px">
    <% plans.forEach(plan => { %>
      <article class="listing" style="padding:20px;display:flex;flex-direction:column;gap:14px;<%= plan.recommended ? 'border-color:rgba(79,140,255,.55);background:rgba(79,140,255,.04)' : '' %>">
        <div>
          <span class="badge <%= plan.recommended ? 'badgeInfo' : '' %>" style="margin-bottom:10px"><i class="fa-solid <%= plan.recommended ? 'fa-star' : 'fa-circle-check' %>"></i> <%= plan.badge %><% if (plan.recommended) { %> &nbsp;Most popular<% } %></span>
          <h2 style="margin:10px 0 4px;font-size:22px"><%= plan.name %></h2>
          <p class="muted" style="margin:0;font-size:13px"><%= plan.tagline %></p>
        </div>
        <div style="padding:12px 0;border-top:1px solid var(--line);border-bottom:1px solid var(--line)">
          <div class="price" style="font-size:28px"><%= money(plan.amount, plan.currency) %></div>
          <div class="muted" style="font-size:12px;font-weight:800;margin-top:2px">per <%= plan.interval %> &bull; billed at activation</div>
        </div>
        <div class="kv">
          <div><span>Listings</span><b><%= plan.limits.listings || 'Unlimited' %></b></div>
          <div><span>Staff accounts</span><b><%= plan.limits.staff || 'Unlimited' %></b></div>
          <div><span>Campaigns</span><b><%= plan.limits.campaigns || 'Unlimited' %></b></div>
        </div>
        <ul style="margin:0;padding-left:18px;font-size:13px;font-weight:800;line-height:2;color:var(--muted)">
          <% plan.features.forEach(feature => { %><li><%= feature %></li><% }) %>
        </ul>
        <a class="btn <%= plan.recommended ? 'btnBlue' : 'btnGhost' %>" href="/partner/onboarding?plan=<%= plan.id %>" style="margin-top:auto;height:46px;font-size:14px"><i class="fa-solid fa-lock"></i> Choose <%= plan.name %></a>
      </article>
    <% }) %>
  </section>

  <section class="card" style="padding:20px;margin-bottom:16px">
    <h2 style="margin:0 0 14px;font-size:18px">What's included in every plan</h2>
    <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:14px">
      <div><div class="badge badgeOk" style="margin-bottom:8px"><i class="fa-solid fa-ticket"></i> Booking engine</div><p class="muted" style="margin:0;font-size:12px;font-weight:780;line-height:1.6">Seat selection, room holds, QR tickets, manifest generation, boarding check-ins and passenger management.</p></div>
      <div><div class="badge badgeInfo" style="margin-bottom:8px"><i class="fa-solid fa-wallet"></i> Payments & payouts</div><p class="muted" style="margin:0;font-size:12px;font-weight:780;line-height:1.6">Mobile money, card, and bank integrations. Automated payout splitting with commission tracking and settlement.</p></div>
      <div><div class="badge badgeWarn" style="margin-bottom:8px"><i class="fa-solid fa-users"></i> Staff & driver tools</div><p class="muted" style="margin:0;font-size:12px;font-weight:780;line-height:1.6">Role-based staff dashboards, driver manifests, offline sales for agents, and branded QR cards for promoters.</p></div>
    </div>
  </section>

  <div style="text-align:center;padding:14px 0;color:var(--muted);font-size:13px;font-weight:820">
    Questions? <a href="/support" style="color:var(--primary)">Contact our partner team</a> &bull; All plans include a 14-day setup period &bull; Cancel anytime
  </div>
</main>
<%- include('../partials/site-footer') %>
