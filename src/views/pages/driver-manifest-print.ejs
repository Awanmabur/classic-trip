<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/png" href="/images/favicon-48.png" />
  <title><%= seo.title %></title>
  <style>
    :root{font-family:Inter,Arial,sans-serif;color:#111827;background:#f8fafc}
    body{margin:0;padding:24px;background:#f8fafc}
    .sheet{max-width:1120px;margin:0 auto;background:#fff;border:1px solid #e5e7eb;border-radius:22px;overflow:hidden;box-shadow:0 18px 50px rgba(15,23,42,.08)}
    .hero{display:flex;justify-content:space-between;gap:18px;padding:26px 28px;background:#111827;color:#fff}
    .hero h1{margin:0;font-size:28px}.hero p{margin:6px 0 0;color:#cbd5e1;font-weight:700}.badge{display:inline-block;border:1px solid rgba(255,255,255,.25);border-radius:999px;padding:7px 11px;font-weight:900;font-size:12px;text-transform:uppercase}
    .tools{display:flex;gap:10px;flex-wrap:wrap;padding:16px 28px;border-bottom:1px solid #e5e7eb;background:#f8fafc}.btn{border:1px solid #cbd5e1;border-radius:999px;padding:10px 14px;color:#111827;text-decoration:none;font-weight:900;background:#fff}.btn.primary{background:#2563eb;color:#fff;border-color:#2563eb}.btn.warn{background:#f59e0b;color:#111827;border-color:#f59e0b}
    .summary{display:grid;grid-template-columns:repeat(5,minmax(0,1fr));gap:12px;padding:18px 28px}.stat{border:1px solid #e5e7eb;border-radius:18px;padding:13px;background:#f8fafc}.stat span{display:block;font-size:11px;text-transform:uppercase;letter-spacing:.08em;color:#64748b;font-weight:900}.stat b{display:block;margin-top:5px;font-size:20px}
    .meta{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:12px;padding:0 28px 18px}.box{border:1px solid #e5e7eb;border-radius:18px;padding:14px}.box h3{margin:0 0 10px;font-size:13px;text-transform:uppercase;letter-spacing:.08em;color:#64748b}.box p{margin:4px 0;font-weight:800}.muted{color:#64748b}
    table{width:calc(100% - 56px);margin:0 28px 22px;border-collapse:collapse;font-size:12px}th{text-align:left;color:#64748b;text-transform:uppercase;letter-spacing:.06em;font-size:10px;background:#f8fafc}th,td{padding:10px;border-bottom:1px solid #e5e7eb}td{font-weight:750}.pill{border-radius:999px;background:#e0f2fe;color:#075985;padding:5px 8px;font-size:11px;font-weight:900}.pill.ok{background:#dcfce7;color:#166534}.pill.bad{background:#fee2e2;color:#991b1b}.pill.warn{background:#fef3c7;color:#92400e}
    .seatGrid{display:grid;grid-template-columns:repeat(auto-fill,minmax(88px,1fr));gap:8px;padding:0 28px 28px}.seat{border:1px solid #e5e7eb;border-radius:14px;padding:9px;background:#f8fafc}.seat b{display:block}.seat span{font-size:11px;color:#64748b;font-weight:800}.footer{padding:16px 28px;border-top:1px solid #e5e7eb;color:#64748b;font-size:11px;font-weight:800}
    @media print{body{padding:0;background:#fff}.sheet{max-width:none;border:0;border-radius:0;box-shadow:none}.tools{display:none}.hero{print-color-adjust:exact;-webkit-print-color-adjust:exact}.summary{grid-template-columns:repeat(5,1fr)}.meta{grid-template-columns:repeat(3,1fr)}a{color:inherit;text-decoration:none}}
  
    /* production print polish */
    .signatureGrid{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:14px;padding:0 28px 22px}.signatureBox{border:1px dashed #94a3b8;border-radius:14px;padding:13px;min-height:54px;font-size:11px;font-weight:900;color:#475569}.signatureLine{display:block;margin-top:18px;border-top:1px solid #94a3b8;padding-top:5px;color:#111827}.printOnly{display:none}.maskablePhone{white-space:nowrap}
    @media print{@page{size:A4 landscape;margin:10mm}.printOnly{display:block}.signatureGrid{break-inside:avoid}.seatGrid{break-inside:avoid}table{font-size:10px}th,td{padding:6px}.footer{break-inside:avoid}.sheet{overflow:visible}.pageBreak{break-before:page}}
  </style>
  <link rel="stylesheet" href="/css/accessibility.css?v=20260723-design-fares-payments-final-1" />
</head>
<body>
  <main class="sheet">
    <section class="hero">
      <div>
        <h1>Trip Manifest</h1>
        <p><%= manifest.title %> • <%= manifest.departureLabel %></p>
      </div>
      <div><span class="badge"><%= manifest.schedule.id %></span></div>
    </section>
    <nav class="tools">
      <button class="btn primary" type="button" data-page-action="print">Print manifest</button>
      <a class="btn" href="/driver/schedules/<%= encodeURIComponent(manifest.schedule.id) %>/manifest.pdf">Download PDF</a>
      <a class="btn" href="/driver/schedules/<%= encodeURIComponent(manifest.schedule.id) %>/manifest.csv">Download CSV</a>
      <a class="btn" href="/driver/schedules/<%= encodeURIComponent(manifest.schedule.id) %>/manifest.xls">Download Excel</a>
      <a class="btn warn" href="/driver/dashboard#driver-manifest">Back to driver dashboard</a>
    </nav>
    <section class="summary">
      <div class="stat"><span>Passengers</span><b><%= manifest.stats.passengers %></b></div>
      <div class="stat"><span>Checked in</span><b><%= manifest.stats.checkedIn %></b></div>
      <div class="stat"><span>Boarding</span><b><%= manifest.stats.boarding %></b></div>
      <div class="stat"><span>No-show</span><b><%= manifest.stats.noShows %></b></div>
      <div class="stat"><span>Total seats</span><b><%= manifest.stats.totalSeats %></b></div>
    </section>
    <section class="meta">
      <div class="box"><h3>Company</h3><p><%= manifest.company.name || '-' %></p><p class="muted"><%= manifest.company.city || '' %> <%= manifest.company.country || '' %></p></div>
      <div class="box"><h3>Vehicle / Driver</h3><p><%= manifest.vehicle.name || manifest.schedule.vehicleName || '-' %></p><p class="muted"><%= manifest.vehicle.plateOrCode || '' %> • <%= manifest.driverLabel || manifest.schedule.driverName || 'Driver not set' %></p></div>
      <div class="box"><h3>Route</h3><p><%= manifest.route.origin || manifest.listing.from || '-' %> → <%= manifest.route.destination || manifest.listing.to || '-' %></p><p class="muted"><%= manifest.schedule.gate || manifest.schedule.platform || 'Boarding gate not set' %></p></div>
    </section>
    <table>
      <thead><tr><th>#</th><th>Booking</th><th>Ticket</th><th>Passenger</th><th>Seat</th><th>Pickup</th><th>Dropoff</th><th>Contact</th><th>Payment</th><th>Check-in</th><th>Notes</th><th>Ticket</th></tr></thead>
      <tbody>
      <% manifest.passengers.forEach(function(row, index){ %>
        <% const statusClass = row.checkInStatus === 'Checked in' ? 'ok' : row.checkInStatus === 'No-show' ? 'bad' : 'warn'; %>
        <tr>
          <td><%= index + 1 %></td><td><%= row.bookingRef %></td><td><%= row.ticketNumber %></td><td><%= row.passengerName %></td><td><%= row.seat %></td><td><%= row.pickupPoint %></td><td><%= row.dropoffPoint %></td><td><%= row.contact %></td><td><%= row.paymentStatus %></td><td><span class="pill <%= statusClass %>"><%= row.checkInStatus %></span></td><td><%= row.notes || '-' %></td><td><a href="/driver/tickets/<%= encodeURIComponent(row.bookingRef) %>">Open</a></td>
        </tr>
      <% }) %>
      <% if(!manifest.passengers.length){ %><tr><td colspan="12">No passengers have booked this schedule yet.</td></tr><% } %>
      </tbody>
    </table>
    <section class="seatGrid">
      <% manifest.seats.forEach(function(seat){ %>
        <a class="seat" href="<%= seat.ticketUrl || '#' %>"><b><%= seat.seat %></b><span><%= seat.status %><% if(seat.bookingRef){ %> • <%= seat.bookingRef %><% } %></span></a>
      <% }) %>
    </section>
    <section class="signatureGrid"><div class="signatureBox">Generated by<span class="signatureLine"><%= manifest.generatedBy || 'System' %></span></div><div class="signatureBox">Boarding staff signature<span class="signatureLine">Name / Signature</span></div><div class="signatureBox">Driver / supervisor signature<span class="signatureLine">Name / Signature</span></div></section>
    <footer class="footer">Generated by <%= manifest.generatedBy %> at <%= new Date(manifest.generatedAt).toLocaleString('en-UG') %>. Schedule status: <%= manifest.scheduleStatus %>. Passenger signature: ____________________ Driver signature: ____________________. This page is print-ready before departure and after check-in, and can export PDF, CSV, or Excel.</footer>
  </main>
  <script src="/js/page-actions.js" defer></script>
</body>
</html>
