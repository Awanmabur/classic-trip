<%- include('../partials/site-head', { seo }) %>
<%- include('../partials/site-header') %>

<main class="container" style="padding:16px 0 40px">

  <section class="card heroCard" style="margin-bottom:20px">
    <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:12px;flex-wrap:wrap">
      <div>
        <span class="badge badgeOk" style="width:max-content;margin-bottom:10px"><i class="fa-solid fa-envelope-circle-check"></i> My bookings</span>
        <h1 class="heroTitle" style="font-size:clamp(24px,3.5vw,36px)">All your bookings</h1>
        <p class="heroSub">Your full Classic Trip booking history &mdash; buses, hotels, flights and more. Tickets delivered by Gmail and WhatsApp.</p>
        <div class="actions" style="margin-top:14px">
          <a class="btn btnGhost" href="/tickets"><i class="fa-solid fa-magnifying-glass"></i> Lookup a ticket</a>
          <a class="btn btnGhost" href="/saved"><i class="fa-regular fa-heart"></i> Saved trips</a>
          <a class="btn btnGhost" href="/account"><i class="fa-regular fa-user"></i> Full dashboard</a>
        </div>
      </div>
      <div style="display:grid;gap:8px;text-align:right;flex-shrink:0">
        <div class="badge badgeInfo"><i class="fa-solid fa-ticket"></i> <%= bookings.length %> booking<%= bookings.length !== 1 ? 's' : '' %></div>
      </div>
    </div>
  </section>

  <% if (bookings && bookings.length) { %>
  <div class="gridCards">
    <% bookings.forEach(function(b) { %>
    <article class="card" style="padding:16px;display:grid;gap:12px;align-content:start">
      <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:8px;flex-wrap:wrap">
        <span class="badge <%=
          /confirm/i.test(b.status) ? 'badgeOk' :
          /cancel|refund/i.test(b.status) ? 'badgeHot' :
          /pending/i.test(b.status) ? 'badgeWarn' : 'badgeInfo'
        %>"><%= b.status %></span>
        <span class="ticketCode" style="font-size:11px;letter-spacing:.05em"><%= b.code %></span>
      </div>

      <div>
        <div style="font-weight:950;font-size:14px;letter-spacing:-.2px;line-height:1.35;margin-bottom:6px"><%= b.title %></div>
        <div class="meta">
          <% var typeIcon = /hotel|room|house/i.test(b.type) ? 'fa-hotel' : /flight|air/i.test(b.type) ? 'fa-plane' : /train|rail/i.test(b.type) ? 'fa-train' : /ferry|ship|boat/i.test(b.type) ? 'fa-ship' : /tour/i.test(b.type) ? 'fa-map-location-dot' : /car|rent/i.test(b.type) ? 'fa-car' : 'fa-bus'; %>
          <% if (b.type) { %><span><i class="fa-solid <%= typeIcon %>"></i> <%= b.type %></span><% } %>
          <% if (b.selected && b.selected !== 'Selected inventory') { %><span><i class="fa-solid fa-chair"></i> <%= b.selected %></span><% } %>
        </div>
      </div>

      <div style="display:grid;gap:5px;font-size:12px;font-weight:820">
        <div style="display:flex;justify-content:space-between;gap:8px"><span class="muted">Total</span><b><%= b.total %></b></div>
        <div style="display:flex;justify-content:space-between;gap:8px"><span class="muted">Date</span><b><%= b.date %></b></div>
        <% if (b.customer) { %><div style="display:flex;justify-content:space-between;gap:8px"><span class="muted">Passenger</span><b><%= b.customer %></b></div><% } %>
        <div style="display:flex;justify-content:space-between;gap:8px"><span class="muted">Channel</span><b><%= b.channel %></b></div>
      </div>

      <div class="actions">
        <a class="btn btnPrimary" href="<%= b.ticketUrl %>" style="height:34px;padding:0 10px;font-size:12px"><i class="fa-solid fa-ticket"></i> Ticket</a>
        <a class="btn btnGhost" href="<%= b.lookupUrl %>" style="height:34px;padding:0 10px;font-size:12px"><i class="fa-solid fa-magnifying-glass"></i> Details</a>
      </div>
    </article>
    <% }) %>
  </div>
  <% } else { %>
  <div class="card" style="padding:56px 24px;text-align:center;display:grid;place-items:center;gap:16px">
    <i class="fa-solid fa-ticket" style="font-size:52px;color:var(--muted)"></i>
    <div>
      <h2 style="margin:0 0 8px;font-size:22px;letter-spacing:-.4px">No bookings yet</h2>
      <p class="muted" style="margin:0;font-size:14px;font-weight:760;max-width:44ch">When you complete a booking it will appear here. You can also look up any ticket by reference number.</p>
    </div>
    <div class="actions" style="justify-content:center">
      <a class="btn btnPrimary" href="/search"><i class="fa-solid fa-magnifying-glass"></i> Browse &amp; book</a>
      <a class="btn btnGhost" href="/tickets"><i class="fa-solid fa-ticket"></i> Lookup a ticket</a>
    </div>
  </div>
  <% } %>

</main>

<%- include('../partials/site-footer') %>
