<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/png" href="/images/favicon-48.png" />
  <title><%= seo.title %></title>
  <meta name="csrf-token" content="<%= csrfToken || '' %>" />
  <link rel="stylesheet" href="/css/base.css" />
  <link rel="stylesheet" href="/css/components.css" />
  <script src="/js/csrf.js?v=20260722-3" defer></script>
  <style>
    body{min-height:100vh;display:grid;place-items:center;background:#070a12;color:#f4f7ff;font-family:Inter,system-ui,Arial,sans-serif;padding:24px}.invite-card{width:min(720px,94vw);border:1px solid rgba(255,255,255,.14);border-radius:26px;background:rgba(255,255,255,.07);box-shadow:0 26px 80px rgba(0,0,0,.35);padding:28px}.badge{display:inline-flex;gap:8px;align-items:center;border-radius:999px;border:1px solid rgba(255,255,255,.14);padding:8px 12px;color:#b8c4dd}.grid{display:grid;grid-template-columns:1fr 1fr;gap:14px}.field{display:grid;gap:7px}.field.full{grid-column:1/-1}label{font-size:13px;color:#b8c4dd}input,select,textarea{width:100%;border:1px solid rgba(255,255,255,.14);background:rgba(255,255,255,.08);color:#fff;border-radius:16px;padding:13px}textarea{min-height:92px}.check{display:flex;align-items:flex-start;gap:10px;color:#dbe6ff}.check input{width:auto;margin-top:4px}.actions{display:flex;gap:12px;flex-wrap:wrap}.submit{border:0;border-radius:999px;padding:14px 18px;background:#4f8cff;color:#fff;font-weight:800}.danger{border:1px solid rgba(255,255,255,.16);border-radius:999px;padding:14px 18px;background:rgba(255,255,255,.06);color:#ffb5b5;font-weight:800}.muted{color:#b8c4dd}.summary,.errorBox{display:grid;gap:6px;margin:16px 0;padding:14px;border:1px solid rgba(255,255,255,.12);border-radius:18px;background:rgba(255,255,255,.045)}.errorBox{border-color:rgba(255,107,107,.45);color:#ffd0d0;background:rgba(255,107,107,.09)}@media(max-width:720px){.grid{grid-template-columns:1fr}}
  </style>
  <link rel="stylesheet" href="/css/accessibility.css?v=20260723-design-fares-payments-final-1" />
</head>
<body>
  <%
    const inviteType = invitation.type;
    const companyInvite = ['company','hotel','fleet_owner','service_provider'].includes(inviteType);
    const driverInvite = inviteType === 'driver';
    const promoterInvite = ['promoter','agent'].includes(inviteType);
    const adminInvite = inviteType === 'admin';
    const staffInvite = inviteType === 'staff';
    const value = (key, fallback = '') => (formData && formData[key] !== undefined ? formData[key] : fallback);
  %>
  <main class="invite-card">
    <span class="badge">Classic Trip secure invitation</span>
    <h1>Accept your <%= inviteType.replace(/_/g, ' ') %> invitation</h1>
    <p class="muted">Create the invited account only. Staff access stays limited to assigned permissions; drivers require licence and safety approval; company owners and promoters require business verification; platform administrators must configure multi-factor authentication.</p>
    <% if (formError) { %><div class="errorBox"><strong>Check the invitation form</strong><span><%= formError %></span></div><% } %>
    <div class="summary">
      <strong><%= invitation.fullName %></strong>
      <span class="muted"><%= invitation.email %> <% if (invitation.companyName) { %> · <%= invitation.companyName %><% } %></span>
      <span class="muted">Role: <%= invitation.roleTitle || invitation.role %> · Expires: <%= new Date(invitation.expiresAt).toLocaleString('en-GB') %></span>
      <% if (invitation.termsSummary) { %><span class="muted">Terms: <%= invitation.termsSummary %></span><% } %>
    </div>
    <form method="post" action="/invite/<%= inviteToken %>">
      <input type="hidden" name="_csrf" value="<%= csrfToken || '' %>">
      <div class="grid">
        <div class="field"><label>Full name</label><input name="fullName" value="<%= value('fullName', invitation.fullName) %>" required></div>
        <div class="field"><label>Phone<%= staffInvite || adminInvite ? ' (optional)' : '' %></label><input name="phone" value="<%= value('phone', invitation.phone || '') %>" <%= staffInvite || adminInvite ? '' : 'required' %>></div>
        <div class="field"><label>Password</label><input type="password" name="password" autocomplete="new-password" required minlength="8" maxlength="72" pattern="(?=.*[A-Za-z])(?=.*[0-9]).{8,72}"></div>
        <div class="field"><label>Confirm password</label><input type="password" name="confirmPassword" autocomplete="new-password" required minlength="8" maxlength="72" pattern="(?=.*[A-Za-z])(?=.*[0-9]).{8,72}"></div>

        <% if (companyInvite) { %>
          <div class="field"><label>Business document type</label><select name="documentType" required><option value="business_license">Business license</option><option value="company_registration">Company registration</option><option value="tax_certificate">Tax certificate</option></select></div>
          <div class="field"><label>Business document reference</label><input name="documentReference" value="<%= value('documentReference') %>" required></div>
          <div class="field full"><label>Secure document URL</label><input name="documentUrl" value="<%= value('documentUrl') %>" placeholder="Secure Cloudinary or object-storage URL"></div>
          <div class="field"><label>Payout method</label><select name="payoutMethod" required><option value="Mobile Money">Mobile Money</option><option value="Bank Transfer">Bank transfer</option></select></div>
          <div class="field"><label>Payout provider / bank</label><input name="payoutProvider" value="<%= value('payoutProvider') %>" required></div>
          <div class="field"><label>Account name</label><input name="accountName" value="<%= value('accountName', invitation.companyName || invitation.fullName) %>" required></div>
          <div class="field"><label>Payout account number</label><input name="accountNumber" value="<%= value('accountNumber') %>" required></div>
          <div class="field"><label>Support phone</label><input name="supportPhone" value="<%= value('supportPhone', invitation.phone || '') %>" required></div>
          <div class="field"><label>Support email</label><input type="email" name="supportEmail" value="<%= value('supportEmail', invitation.email || '') %>" required></div>
        <% } %>

        <% if (driverInvite) { %>
          <input type="hidden" name="documentType" value="driver_license">
          <div class="field"><label>Driver licence number</label><input name="documentReference" value="<%= value('documentReference', invitation.licenseNumber || '') %>" required></div>
          <div class="field"><label>Licence class</label><input name="licenseClass" value="<%= value('licenseClass', invitation.licenseClass || '') %>" required></div>
          <div class="field"><label>National ID / passport reference</label><input name="identityReference" value="<%= value('identityReference') %>" required></div>
          <div class="field"><label>Assigned service</label><input value="<%= invitation.scheduleId ? `Schedule ${invitation.scheduleId}` : invitation.vehicleId ? `Vehicle ${invitation.vehicleId}` : 'Assignment after approval' %>" readonly></div>
          <div class="field full"><label>Secure licence document URL</label><input name="documentUrl" value="<%= value('documentUrl') %>" placeholder="Secure Cloudinary or object-storage URL"></div>
        <% } %>

        <% if (promoterInvite) { %>
          <div class="field"><label>Identity document type</label><select name="documentType" required><option value="national_id">National ID</option><option value="passport">Passport</option></select></div>
          <div class="field"><label>Identity document reference</label><input name="documentReference" value="<%= value('documentReference') %>" required></div>
          <div class="field"><label>Payout method</label><select name="payoutMethod" required><option value="Mobile Money">Mobile Money</option><option value="Bank Transfer">Bank transfer</option></select></div>
          <div class="field"><label>Payout provider</label><input name="payoutProvider" value="<%= value('payoutProvider') %>" required></div>
          <div class="field full"><label>Payout account</label><input name="payoutAccount" value="<%= value('payoutAccount', invitation.phone || '') %>" required></div>
          <label class="check field full"><input type="checkbox" name="trainingAcknowledged" required <%= value('trainingAcknowledged') ? 'checked' : '' %>> I completed the anti-fraud, attribution, offline-sales, and payout rules acknowledgement.</label>
        <% } %>

        <% if (adminInvite) { %>
          <div class="field"><label>Identity document type</label><select name="documentType" required><option value="national_id">National ID</option><option value="passport">Passport</option></select></div>
          <div class="field"><label>Identity document reference</label><input name="documentReference" value="<%= value('documentReference') %>" required></div>
        <% } %>

        <% if (staffInvite) { %>
          <div class="field"><label>National ID / staff reference (optional)</label><input name="documentReference" value="<%= value('documentReference') %>"></div>
          <input type="hidden" name="documentType" value="national_id">
          <div class="field"><label>Access scope</label><input value="<%= invitation.roleTitle || 'Scoped staff member' %>" readonly></div>
        <% } %>

        <div class="field full"><label>Agreement/profile notes</label><textarea name="agreementSummary" placeholder="Confirm terms or add relevant onboarding notes"><%= value('agreementSummary', invitation.termsSummary || '') %></textarea></div>
        <label class="check field full"><input type="checkbox" name="agreementAccepted" required <%= value('agreementAccepted') ? 'checked' : '' %>> I accept the assigned role, privacy, security, and service rules and understand that operational permissions are enforced by the backend.</label>
        <div class="field full actions"><button class="submit" type="submit">Accept invitation and continue</button></div>
      </div>
    </form>
    <form method="post" action="/invite/<%= inviteToken %>/reject" style="margin-top:12px">
      <input type="hidden" name="_csrf" value="<%= csrfToken || '' %>">
      <input type="hidden" name="reason" value="Invitee declined invitation">
      <button class="danger" type="submit">Reject this invitation</button>
    </form>
  </main>
</body>
</html>
