<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/png" href="/images/favicon-48.png" />
  <title><%= seo.title %></title>
  <meta name="csrf-token" content="<%= csrfToken || '' %>" />
  <link rel="stylesheet" href="/css/base.css" />
  <link rel="stylesheet" href="/css/components.css" />
  <script src="/js/csrf.js" defer></script>
  <style>
    body{min-height:100vh;display:grid;place-items:center;background:#070a12;color:#f4f7ff;font-family:Inter,system-ui,Arial,sans-serif;padding:24px}.invite-card{width:min(720px,94vw);border:1px solid rgba(255,255,255,.14);border-radius:26px;background:rgba(255,255,255,.07);box-shadow:0 26px 80px rgba(0,0,0,.35);padding:28px}.badge{display:inline-flex;gap:8px;align-items:center;border-radius:999px;border:1px solid rgba(255,255,255,.14);padding:8px 12px;color:#b8c4dd}.grid{display:grid;grid-template-columns:1fr 1fr;gap:14px}.field{display:grid;gap:7px}.field.full{grid-column:1/-1}label{font-size:13px;color:#b8c4dd}input,select,textarea{width:100%;border:1px solid rgba(255,255,255,.14);background:rgba(255,255,255,.08);color:#fff;border-radius:16px;padding:13px}textarea{min-height:92px}.check{display:flex;align-items:flex-start;gap:10px;color:#dbe6ff}.check input{width:auto;margin-top:4px}.actions{display:flex;gap:12px;flex-wrap:wrap}.submit{border:0;border-radius:999px;padding:14px 18px;background:#4f8cff;color:#fff;font-weight:800}.danger{border:1px solid rgba(255,255,255,.16);border-radius:999px;padding:14px 18px;background:rgba(255,255,255,.06);color:#ffb5b5;font-weight:800}.muted{color:#b8c4dd}.summary{display:grid;gap:6px;margin:16px 0;padding:14px;border:1px solid rgba(255,255,255,.12);border-radius:18px;background:rgba(255,255,255,.045)}@media(max-width:720px){.grid{grid-template-columns:1fr}}
  </style>
</head>
<body>
  <main class="invite-card">
    <span class="badge">Classic Trip secure invitation</span>
    <h1>Accept your <%= invitation.type.replace(/_/g, ' ') %> invitation</h1>
    <p class="muted">Create your account from this Super Admin controlled invitation. Your account remains pending until verification is complete.</p>
    <div class="summary">
      <strong><%= invitation.fullName %></strong>
      <span class="muted"><%= invitation.email %> <% if (invitation.companyName) { %> · <%= invitation.companyName %><% } %></span>
      <span class="muted">Role: <%= invitation.roleTitle || invitation.role %> · Expires: <%= new Date(invitation.expiresAt).toLocaleString('en-GB') %></span>
      <% if (invitation.termsSummary) { %><span class="muted">Terms: <%= invitation.termsSummary %></span><% } %>
    </div>
    <form method="post" action="/invite/<%= invitation.token %>">
      <input type="hidden" name="_csrf" value="<%= csrfToken || '' %>">
      <div class="grid">
        <div class="field"><label>Full name</label><input name="fullName" value="<%= invitation.fullName %>" required></div>
        <div class="field"><label>Phone</label><input name="phone" value="<%= invitation.phone || '' %>" required></div>
        <div class="field"><label>Password</label><input type="password" name="password" autocomplete="new-password" required minlength="6"></div>
        <div class="field"><label>Confirm password</label><input type="password" name="confirmPassword" autocomplete="new-password" required minlength="6"></div>
        <div class="field"><label>Verification document type</label><select name="documentType"><option value="business_license">Business license</option><option value="driver_license">Driver license</option><option value="national_id">National ID</option><option value="company_registration">Company registration</option><option value="tax_certificate">Tax certificate</option></select></div>
        <div class="field"><label>Document reference / number</label><input name="documentReference" placeholder="Registration, NIN, license number" required></div>
        <div class="field full"><label>Document URL or Cloudinary secure link</label><input name="documentUrl" placeholder="https://res.cloudinary.com/.../document.pdf"></div>
        <div class="field"><label>Payout provider / bank</label><input name="payoutProvider" placeholder="MTN MoMo, Airtel Money, Bank name"></div>
        <div class="field"><label>Payout account number</label><input name="accountNumber" placeholder="Account / wallet number"></div>
        <div class="field"><label>Support phone</label><input name="supportPhone" value="<%= invitation.phone || '' %>"></div>
        <div class="field"><label>Support email</label><input name="supportEmail" value="<%= invitation.email || '' %>"></div>
        <div class="field full"><label>Agreement/profile notes</label><textarea name="agreementSummary" placeholder="Confirm agreement terms or add profile notes"><%= invitation.termsSummary || '' %></textarea></div>
        <label class="check field full"><input type="checkbox" name="agreementAccepted" required> I confirm the agreement terms and understand activation requires Super Admin verification.</label>
        <label class="check field full"><input type="checkbox" name="phoneVerified"> Phone number has been verified with the invitee.</label>
        <div class="field full actions"><button class="submit" type="submit">Accept invitation and submit verification</button></div>
      </div>
    </form>
    <form method="post" action="/invite/<%= invitation.token %>/reject" style="margin-top:12px">
      <input type="hidden" name="_csrf" value="<%= csrfToken || '' %>">
      <input type="hidden" name="reason" value="Invitee declined invitation">
      <button class="danger" type="submit">Reject this invitation</button>
    </form>
  </main>
</body>
</html>
