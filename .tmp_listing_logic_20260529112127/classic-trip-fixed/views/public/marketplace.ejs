  <div class="modal" id="viewModal">
    <div class="sheet">
      <div class="sheetTop">
        <div>
          <div class="badge badgeInfo" id="modalType">Bus</div>
          <div class="sheetTitle" id="modalTitle">Listing title</div>
          <div class="sheetSub" id="modalSub">Partner • route • date</div>
        </div>
        <div class="sheetTopActions">
          <button class="iconbtn" title="Save" onclick="saveListing(current?.id)"><i class="fa-regular fa-heart"></i></button>
          <button class="iconbtn" title="Share" onclick="shareListing(current?.id)"><i class="fa-solid fa-share-nodes"></i></button>
          <button class="iconbtn" onclick="closeModal()"><i class="fa-solid fa-xmark"></i></button>
        </div>
      </div>

      <div class="sheetBody">
        <div class="visual">
          <div class="visualHero">
            <img id="modalImg" src="" alt="Selected listing">
            <div class="visualText">
              <h3 id="modalHeroTitle">View structure</h3>
              <p id="modalHeroSub">Select available seats / rooms / slots.</p>
            </div>
          </div>

          <div class="selector">
            <div class="selectorTop">
              <div>
                <b id="layoutTitle">Choose your seat</b>
                <div class="muted" style="font-size:13px;font-weight:800" id="layoutHint">Click available seats to select. Taken seats cannot be selected.</div>
              </div>
              <div class="legend">
                <span class="leg"><i class="dot free"></i> Available</span>
                <span class="leg"><i class="dot selected"></i> Selected</span>
                <span class="leg"><i class="dot hold"></i> Held</span>
                <span class="leg"><i class="dot taken"></i> Taken</span>
              </div>
            </div>
            <div class="layoutBox" id="layoutBox"></div>
          </div>
        </div>

        <div class="sidePanel">
          <div class="summaryCard">
            <h3>Booking summary</h3>
            <div class="timer" id="timerBox"><span><i class="fa-regular fa-clock"></i> Hold expires in</span><b id="timer">10:00</b></div>
            <div class="kv" style="margin-top:10px">
              <div><span>Selected</span><b id="selectedOut">None</b></div>
              <div><span>Base price</span><b id="baseOut">UGX 0</b></div>
              <div><span>Service fee</span><b id="feeOut">UGX 0</b></div>
              <div><span>Total</span><b id="totalOut">UGX 0</b></div>
            </div>
          </div>

          <div class="summaryCard">
            <h3>Addons</h3>
            <div class="addons" id="addons"></div>
          </div>

          <div style="display:flex;gap:10px;flex-wrap:wrap;justify-content:flex-end">
            <button class="btn btnGhost" onclick="resetSelection()"><i class="fa-solid fa-rotate-left"></i> Reset</button>
            <button class="btn btnBlue" onclick="holdSelection()"><i class="fa-solid fa-clock"></i> Hold 10 mins</button>
            <button class="btn btnPrimary" onclick="goPaymentPage()"><i class="fa-solid fa-lock"></i> Proceed payment</button>
          </div>
        </div>
      </div>

      <div class="checkoutStep" id="checkoutStep">
        <div class="summaryCard">
          <h3>User information</h3>
          <div class="checkoutNotice">This page appears after Proceed payment. It keeps the selected seat/room/slot and collects customer information separately from the show page.</div>
          <div class="bookingForm" style="margin-top:10px">
            <input id="nameInput" placeholder="Full name">
            <input id="phoneInput" placeholder="Phone number">
            <input class="full" id="emailInput" placeholder="Email address">
            <select id="idInput"><option value="">ID type</option><option>National ID</option><option>Passport</option><option>Student ID</option></select>
            <input id="docInput" placeholder="ID / passport number">
            <textarea class="full" id="noteInput" placeholder="Special request, pickup point, hotel note, baggage note..."></textarea>
          </div>
        </div>

        <div class="summaryCard">
          <h3>Payment</h3>
          <div class="kv">
            <div><span>Listing</span><b id="checkoutListing">-</b></div>
            <div><span>Selected</span><b id="checkoutSelected">-</b></div>
            <div><span>Total to pay</span><b id="checkoutTotal">UGX 0</b></div>
          </div>
          <div class="payMethods">
            <label class="payMethod"><input type="radio" name="payMethod" value="Mobile Money" checked> Mobile Money</label>
            <label class="payMethod"><input type="radio" name="payMethod" value="Card"> Card</label>
            <label class="payMethod"><input type="radio" name="payMethod" value="Wallet"> Wallet</label>
            <label class="payMethod"><input type="radio" name="payMethod" value="Pay at office"> Pay at office</label>
          </div>
          <div class="bookingForm" style="margin-top:10px">
            <input id="paymentRefInput" class="full" placeholder="Mobile money number / card reference / wallet ID">
          </div>
          <div style="display:flex;gap:10px;flex-wrap:wrap;justify-content:flex-end;margin-top:12px">
            <button class="btn btnGhost" onclick="backToSelection()"><i class="fa-solid fa-arrow-left"></i> Back</button>
            <button class="btn btnPrimary" onclick="confirmBooking()"><i class="fa-solid fa-lock"></i> Pay & confirm</button>
          </div>
        </div>
      </div>
    </div>
  </div>



