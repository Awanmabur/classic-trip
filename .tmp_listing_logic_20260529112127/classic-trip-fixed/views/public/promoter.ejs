            </div>
          </div>
        </section>

        <section class="section" id="campaigns">
          <div class="card">
            <div class="cardHead">
              <div class="cardTitle"><h3>Campaigns</h3><p>Group referral links by platform, audience, season, or route.</p></div>
              <button class="btn btnBlue" data-modal="create" data-type="campaign"><i class="fa-solid fa-plus"></i> Create campaign</button>
            </div>
            <div class="tableWrap">
              <table>
                <thead><tr><th>Campaign</th><th>Channel</th><th>Links</th><th>Visits</th><th>Bookings</th><th>Commission</th><th>Status</th><th></th></tr></thead>
                <tbody id="campaignsTable"></tbody>
              </table>
            </div>
          </div>
        </section>

        <section class="section" id="bookings">
          <div class="card" data-tabs>
            <div class="cardHead">
              <div class="cardTitle"><h3>Referral bookings</h3><p>Bookings completed through your links.</p></div>
              <button class="btn" data-jump="share"><i class="fa-solid fa-share-nodes"></i> Share more</button>
            </div>
            <div class="tabs">
              <button class="tabBtn is-on" data-tab="all">All</button>
              <button class="tabBtn" data-tab="paid">Paid</button>
              <button class="tabBtn" data-tab="pending">Pending</button>
              <button class="tabBtn" data-tab="cancelled">Cancelled</button>
            </div>
            <div class="tabPane is-on" data-pane="all"><div class="tableWrap"><table><thead><tr><th>Booking</th><th>Listing</th><th>Customer</th><th>Ticket value</th><th>Commission</th><th>Status</th><th></th></tr></thead><tbody id="bookingsTable"></tbody></table></div></div>
            <div class="tabPane" data-pane="paid"><div class="tableWrap"><table><thead><tr><th>Booking</th><th>Listing</th><th>Customer</th><th>Ticket value</th><th>Commission</th><th>Status</th><th></th></tr></thead><tbody data-filter-table="bookings-status" data-filter="Paid"></tbody></table></div></div>
            <div class="tabPane" data-pane="pending"><div class="tableWrap"><table><thead><tr><th>Booking</th><th>Listing</th><th>Customer</th><th>Ticket value</th><th>Commission</th><th>Status</th><th></th></tr></thead><tbody data-filter-table="bookings-status" data-filter="Pending"></tbody></table></div></div>
            <div class="tabPane" data-pane="cancelled"><div class="tableWrap"><table><thead><tr><th>Booking</th><th>Listing</th><th>Customer</th><th>Ticket value</th><th>Commission</th><th>Status</th><th></th></tr></thead><tbody data-filter-table="bookings-status" data-filter="Cancelled"></tbody></table></div></div>
          </div>
        </section>

        <section class="section" id="payouts">
          <div class="card">
            <div class="cardHead">
              <div class="cardTitle"><h3>Payout history</h3><p>Successful and pending commission payout records.</p></div>
              <button class="btn" id="btnDownloadPayouts"><i class="fa-solid fa-download"></i> Download</button>
            </div>
            <div class="tableWrap">
              <table>
                <thead><tr><th>Payout</th><th>Period</th><th>Method</th><th>Amount</th><th>Reference</th><th>Status</th><th></th></tr></thead>
                <tbody id="payoutsTable"></tbody>
              </table>
            </div>
          </div>
        </section>

        <section class="section" id="fraud">
          <div class="grid2">
            <div class="card">
              <div class="cardHead">
                <div class="cardTitle"><h3>Traffic review</h3><p>Protect your account by keeping referral traffic clean and real.</p></div>
                <span class="badge ok">Low risk</span>
              </div>
              <div class="tableWrap">
                <table>
                  <thead><tr><th>Signal</th><th>Source</th><th>Value</th><th>Risk</th><th>Status</th><th></th></tr></thead>
                  <tbody id="fraudTable"></tbody>
                </table>
              </div>
            </div>
            <div class="card">
              <div class="cardHead"><div class="cardTitle"><h3>Rules</h3><p>Things that can put commission on hold.</p></div></div>
              <div class="splitGrid">
                <div class="splitItem"><div class="splitTop"><span>Fake clicks</span><span class="badge bad">Blocked</span></div></div>
                <div class="splitItem"><div class="splitTop"><span>Self-booking abuse</span><span class="badge warn">Review</span></div></div>
                <div class="splitItem"><div class="splitTop"><span>Spam sharing</span><span class="badge warn">Review</span></div></div>
                <div class="splitItem"><div class="splitTop"><span>Real customers</span><span class="badge ok">Approved</span></div></div>
                <div class="notice">In production, suspicious bookings can put commission on hold until admin review.</div>
              </div>
            </div>
          </div>
        </section>

        <section class="section" id="support">
          <div class="grid2">
            <div class="card">
              <div class="cardHead">
                <div class="cardTitle"><h3>Support</h3><p>Promoter account, commission, withdrawal, and referral issues.</p></div>
                <button class="btn btnPrimary" data-modal="create" data-type="support case"><i class="fa-solid fa-plus"></i> New case</button>
              </div>
              <div class="tableWrap">
                <table>
                  <thead><tr><th>Case</th><th>Issue</th><th>Priority</th><th>Status</th><th>Opened</th><th></th></tr></thead>
                  <tbody id="supportTable"></tbody>
                </table>
              </div>
            </div>
            <div class="card">
              <div class="cardHead"><div class="cardTitle"><h3>Contact support</h3><p>Send a message to promoter support.</p></div></div>
              <form class="formPanel" id="supportForm">
                <div class="formGrid">
                  <div class="field"><label>Issue type</label><div class="control"><i class="fa-solid fa-circle-question"></i><select><option>Commission missing</option><option>Withdrawal pending</option><option>Link not tracking</option><option>Account verification</option></select></div></div>
                  <div class="field"><label>Priority</label><div class="control"><i class="fa-solid fa-flag"></i><select><option>Normal</option><option>High</option><option>Urgent</option></select></div></div>
                  <div class="field full"><label>Message</label><div class="control"><textarea placeholder="Explain your issue..."></textarea></div></div>
                </div>
                <button class="btn btnPrimary" type="submit"><i class="fa-solid fa-paper-plane"></i> Send message</button>
              </form>
            </div>
          </div>
        </section>

        <section class="section" id="profile">
          <div class="grid2">
            <div class="card">
              <div class="cardHead"><div class="cardTitle"><h3>Profile</h3><p>Promoter identity, payout details, and verification.</p></div></div>
              <form class="formPanel" id="profileForm">
                <div class="formGrid">
                  <div class="field"><label>Promoter name</label><div class="control"><i class="fa-solid fa-user"></i><input value="Awan Promo" /></div></div>
                  <div class="field"><label>Phone</label><div class="control"><i class="fa-solid fa-phone"></i><input value="+256 700 112233" /></div></div>
                  <div class="field"><label>Email</label><div class="control"><i class="fa-solid fa-envelope"></i><input value="awanpromo@example.com" /></div></div>
                  <div class="field"><label>Default channel</label><div class="control"><i class="fa-solid fa-share-nodes"></i><select><option>WhatsApp</option><option>Facebook</option><option>TikTok</option><option>Instagram</option><option>SMS</option></select></div></div>
                  <div class="field full"><label>Bio</label><div class="control"><textarea>Travel promoter sharing the best bus, hotel, flight, tour, ferry, and car rental deals on Classic Trip.</textarea></div></div>
                </div>
                <button class="btn btnPrimary" type="submit"><i class="fa-solid fa-floppy-disk"></i> Save profile</button>
              </form>
            </div>
            <div class="card">
              <div class="cardHead"><div class="cardTitle"><h3>Verification</h3><p>Promoter account trust and payout readiness.</p></div></div>
              <div class="splitGrid">
                <div class="splitItem"><div class="splitTop"><span>Phone verified</span><span class="badge ok">Verified</span></div></div>
                <div class="splitItem"><div class="splitTop"><span>Payout account</span><span class="badge ok">Verified</span></div></div>
                <div class="splitItem"><div class="splitTop"><span>Traffic quality</span><span class="badge ok">Low risk</span></div></div>
                <div class="splitItem"><div class="splitTop"><span>Withdrawal access</span><span class="badge ok">Enabled</span></div></div>
                <button class="btn btnBlue" data-modal="edit" data-type="verification"><i class="fa-solid fa-shield-halved"></i> Update verification</button>
              </div>
            </div>
          </div>
        </section>
      </div>
    </main>
  </div>

  <div class="modal" id="crudModal">
    <div class="modalCard">
      <div class="modalHead">
        <div><h3 id="crudTitle">Create item</h3><p id="crudSub">Manage promoter data cleanly.</p></div>
        <button class="iconBtn" data-close-modal><i class="fa-solid fa-xmark"></i></button>
      </div>
      <div class="modalBody" id="crudBody"></div>
    </div>
  </div>

  <div class="modal" id="deleteModal">
    <div class="modalCard">
      <div class="modalHead">
        <div><h3>Delete record</h3><p>This demo shows the delete confirmation flow.</p></div>
        <button class="iconBtn" data-close-modal><i class="fa-solid fa-xmark"></i></button>
      </div>
      <div class="modalBody">
        <div class="deleteBox">
          <span class="badge bad"><i class="fa-solid fa-triangle-exclamation"></i> Delete action</span>
          <strong id="deleteText">Are you sure you want to delete this record?</strong>
          <p style="margin:0;color:var(--muted);font-size:12px;font-weight:800;line-height:1.55">In production, promoter actions should be logged for audit and commission tracking.</p>
          <div style="display:flex;gap:8px;flex-wrap:wrap;justify-content:flex-end">
            <button class="btn" data-close-modal>Cancel</button>
            <button class="btn btnDanger" id="confirmDelete"><i class="fa-solid fa-trash"></i> Delete</button>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="toast" id="toast"><i class="fa-solid fa-circle-check"></i><span id="toastText">Done</span></div>

  
<%- include("../partials/body-end", { bodyEndInjection }) %>
</body>
</html>
