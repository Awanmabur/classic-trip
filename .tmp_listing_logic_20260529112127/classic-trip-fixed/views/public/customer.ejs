<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Classic Trip | Customer Dashboard</title>
  <meta name="description" content="Classic Trip Customer Dashboard for bookings, saved trips, receipts, refunds, support, reviews, wallet, and profile." />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

  <style>
    :root{
      --container:min(1420px,94%);
      --sidebar:282px;
      --topbar:66px;
      --primary:#4f8cff;
      --primary2:#2f6bff;
      --accent:#ffb703;
      --hot:#ff5a1f;
      --ok:#22c55e;
      --warn:#f59e0b;
      --bad:#ef4444;
      --shadow:0 22px 70px rgba(0,0,0,.24);
      --shadow2:0 12px 38px rgba(0,0,0,.18);
    }

    html[data-theme="dark"]{
      --bg0:#03050b;
      --bg1:#060914;
      --cardA:rgba(255,255,255,.068);
      --cardB:rgba(255,255,255,.034);
      --soft:rgba(255,255,255,.048);
      --line:rgba(255,255,255,.105);
      --line2:rgba(255,255,255,.065);
      --text:#f7f9ff;
      --muted:rgba(247,249,255,.64);
      --muted2:rgba(247,249,255,.42);
      --input:rgba(255,255,255,.055);
      --table:rgba(255,255,255,.035);
      --panel:rgba(7,10,20,.94);
      --active:rgba(255,183,3,.26);
      --activeLine:rgba(255,183,3,.46);
      --selectBg:#0d1222;
    }

    html[data-theme="light"]{
      --bg0:#eef3ff;
      --bg1:#e9eef8;
      --cardA:rgba(255,255,255,.94);
      --cardB:rgba(255,255,255,.78);
      --soft:rgba(15,23,42,.045);
      --line:rgba(15,23,42,.105);
      --line2:rgba(15,23,42,.065);
      --text:#0f172a;
      --muted:rgba(15,23,42,.62);
      --muted2:rgba(15,23,42,.43);
      --input:rgba(15,23,42,.045);
      --table:rgba(15,23,42,.03);
      --panel:rgba(255,255,255,.96);
      --active:rgba(255,183,3,.28);
      --activeLine:rgba(255,183,3,.50);
      --selectBg:#ffffff;
      --shadow:0 22px 70px rgba(15,23,42,.11);
      --shadow2:0 12px 38px rgba(15,23,42,.08);
    }

    *{box-sizing:border-box}
    html{scroll-behavior:auto}
    body{
      margin:0;
      min-height:100vh;
      font-family:Inter,system-ui,-apple-system,Segoe UI,Roboto,Arial,sans-serif;
      color:var(--text);
      background:
        radial-gradient(650px 390px at 8% -12%, rgba(79,140,255,.055), transparent 68%),
        radial-gradient(560px 340px at 94% -10%, rgba(255,183,3,.03), transparent 70%),
        linear-gradient(180deg,var(--bg0),var(--bg1));
      overflow-x:hidden;
    }

    a{color:inherit;text-decoration:none}
    button,input,select,textarea{font:inherit}
    button{cursor:pointer}
    :focus,:focus-visible{outline:none!important;box-shadow:none!important}

    ::-webkit-scrollbar{width:10px;height:10px}
    ::-webkit-scrollbar-track{background:rgba(255,255,255,.035);border-radius:20px}
    ::-webkit-scrollbar-thumb{background:rgba(255,255,255,.14);border-radius:20px;border:2px solid transparent;background-clip:content-box}

    .app{
      width:var(--container);
      margin:0 auto;
      display:grid;
      grid-template-columns:var(--sidebar) minmax(0,1fr);
      gap:16px;
      padding:14px 0 24px;
    }

    .sideBackdrop{display:none}

    .sidebar{
      position:sticky;
      top:14px;
      height:calc(100vh - 28px);
      border:1px solid var(--line);
      background:linear-gradient(180deg,var(--cardA),var(--cardB));
      border-radius:30px;
      box-shadow:var(--shadow2);
      backdrop-filter:blur(16px);
      -webkit-backdrop-filter:blur(16px);
      overflow:hidden;
      display:flex;
      flex-direction:column;
      z-index:80;
    }

    .sideTop{
      padding:14px;
      border-bottom:1px solid var(--line);
      display:flex;
      align-items:center;
      gap:10px;
    }

    .mark{
      width:42px;
      height:42px;
      border-radius:16px;
      display:grid;
      place-items:center;
      color:#081026;
      background:linear-gradient(135deg,rgba(79,140,255,.96),rgba(255,183,3,.96));
      font-weight:1000;
      flex:0 0 auto;
      box-shadow:0 12px 28px rgba(79,140,255,.14);
    }

    .brandText{min-width:0}
    .brandText strong{
      display:block;
      font-size:14px;
      letter-spacing:-.2px;
      white-space:nowrap;
      overflow:hidden;
      text-overflow:ellipsis;
    }

    .brandText span{
      display:block;
      margin-top:2px;
      font-size:11px;
      color:var(--muted);
      font-weight:850;
      white-space:nowrap;
      overflow:hidden;
      text-overflow:ellipsis;
    }

    .sideSearch{padding:12px 14px 8px}

    .searchBox,.control{
      border:1px solid var(--line);
      background:var(--input);
      border-radius:22px;
      display:flex;
      align-items:center;
      gap:10px;
      padding:10px 13px;
      min-width:0;
    }

    .searchBox input,.control input,.control select,.control textarea{
      width:100%;
      border:0;
      background:transparent;
      color:var(--text);
      min-width:0;
      font-weight:850;
      font-size:12px;
    }

    select option{background:var(--selectBg);color:var(--text)}
    .searchBox input::placeholder,.control input::placeholder,.control textarea::placeholder{color:var(--muted2)}

    .sideNav{
      padding:9px;
      display:grid;
      gap:10px;
      overflow:auto;
      flex:1;
      align-content:start;
    }

    .navBtn{
      width:100%;
      min-width:0;
      border:1px solid transparent;
      background:transparent;
      color:var(--muted);
      border-radius:18px;
      padding:11px 12px;
      display:flex;
      align-items:center;
      gap:10px;
      font-size:12.2px;
      font-weight:900;
      text-align:left;
      white-space:nowrap;
      overflow:hidden;
      transition:.16s ease;
    }

    .navBtn span{
      min-width:0;
      overflow:hidden;
      text-overflow:ellipsis;
      white-space:nowrap;
      display:block;
    }

    .navBtn i{
      width:20px;
      height:20px;
      display:grid;
      place-items:center;
      font-size:13px;
      color:var(--muted);
      flex:0 0 auto;
    }

    .navBtn:hover{
      background:rgba(79,140,255,.13);
      border-color:rgba(79,140,255,.32);
      color:var(--text);
      border-radius:28px;
      padding-top:15px;
      padding-bottom:15px;
      transform:translateY(-1px);
    }

    .navBtn.is-active{
      background:var(--active);
      border-color:var(--activeLine);
      color:var(--accent);
      border-radius:28px;
      padding-top:15px;
      padding-bottom:15px;
      box-shadow:0 12px 28px rgba(255,183,3,.13);
    }

    .navBtn.is-active i{color:var(--accent)}

    .sideFoot{
      border-top:1px solid var(--line);
      padding:12px;
      display:grid;
      gap:10px;
    }

    .miniProfile{
      display:flex;
      align-items:center;
      gap:9px;
      padding:9px;
      border-radius:22px;
      background:var(--soft);
      border:1px solid var(--line2);
    }

    .avatar{
      width:36px;
      height:36px;
      border-radius:14px;
      background:linear-gradient(135deg,rgba(79,140,255,.92),rgba(255,90,31,.82));
      display:grid;
      place-items:center;
      color:#fff;
      font-weight:1000;
      flex:0 0 auto;
      font-size:12px;
    }

    .profileMeta strong{display:block;font-size:12px}
    .profileMeta span{display:block;color:var(--muted);font-size:10px;font-weight:850;margin-top:2px}

    .main{
      min-width:0;
      display:flex;
      flex-direction:column;
      gap:10px;
    }

    .topbar{
      position:sticky;
      top:14px;
      z-index:50;
      min-height:var(--topbar);
      max-height:var(--topbar);
      border:1px solid var(--line);
      border-radius:28px;
      background:linear-gradient(180deg,var(--cardA),var(--cardB));
      backdrop-filter:blur(18px);
      -webkit-backdrop-filter:blur(18px);
      box-shadow:var(--shadow2);
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:10px;
      padding:10px 12px;
      overflow:hidden;
    }

    .topLeft{
      min-width:0;
      display:flex;
      align-items:center;
      gap:10px;
    }

    .menuBtn{display:none!important}

    .pageTitle{min-width:0}
    .pageTitle h1{
      margin:0;
      font-size:18px;
      line-height:1.1;
      letter-spacing:-.35px;
      white-space:nowrap;
      overflow:hidden;
      text-overflow:ellipsis;
    }

    .pageTitle p{
      margin:4px 0 0;
      color:var(--muted);
      font-size:11.5px;
      font-weight:800;
      white-space:nowrap;
      overflow:hidden;
      text-overflow:ellipsis;
      max-width:660px;
    }

    .topActions{
      display:flex;
      align-items:center;
      gap:7px;
      flex-wrap:nowrap;
      justify-content:flex-end;
      min-width:max-content;
    }

    .btn,.iconBtn,.chip,.tabBtn{
      border:1px solid var(--line);
      background:var(--soft);
      color:var(--text);
      border-radius:999px;
      height:39px;
      padding:0 13px;
      display:inline-flex;
      align-items:center;
      justify-content:center;
      gap:8px;
      font-weight:950;
      font-size:12px;
      white-space:nowrap;
      transition:.15s ease;
    }

    .btn:hover,.iconBtn:hover,.chip:hover,.tabBtn:hover{
      transform:translateY(-1px);
      border-color:rgba(79,140,255,.26);
      background:rgba(79,140,255,.08);
    }

    .iconBtn{
      width:39px;
      padding:0;
      flex:0 0 auto;
    }

    .btnPrimary{
      border-color:transparent;
      color:#071226;
      background:linear-gradient(135deg,var(--accent),var(--hot));
      box-shadow:0 14px 34px rgba(255,90,31,.12);
    }

    .btnBlue{
      border-color:transparent;
      background:linear-gradient(135deg,rgba(79,140,255,.94),rgba(47,107,255,.94));
      color:#eef5ff;
      box-shadow:0 14px 34px rgba(79,140,255,.12);
    }

    .btnDanger{
      background:rgba(239,68,68,.12);
      color:#ff8b8b;
      border-color:rgba(239,68,68,.22);
    }

    .badge{
      display:inline-flex;
      align-items:center;
      gap:7px;
      border-radius:999px;
      border:1px solid var(--line);
      background:var(--soft);
      padding:6px 9px;
      font-size:11px;
      font-weight:950;
      color:var(--muted);
      white-space:nowrap;
    }

    .badge.ok{background:rgba(34,197,94,.105);border-color:rgba(34,197,94,.22);color:#42d77a}
    .badge.warn{background:rgba(255,183,3,.105);border-color:rgba(255,183,3,.24);color:#ffc847}
    .badge.bad{background:rgba(239,68,68,.105);border-color:rgba(239,68,68,.22);color:#ff8b8b}
    .badge.info{background:rgba(79,140,255,.115);border-color:rgba(79,140,255,.22);color:#7fb0ff}

    .content{
      display:flex;
      flex-direction:column;
      gap:14px;
      scroll-margin-top:84px;
    }

    .section{
      display:none;
      animation:fadeIn .20s ease both;
      scroll-margin-top:84px;
    }
    .section.is-open{display:block}

    @keyframes fadeIn{
      from{opacity:0;transform:translateY(6px)}
      to{opacity:1;transform:translateY(0)}
    }

    .hero,.card{
      border:1px solid var(--line);
      border-radius:30px;
      background:linear-gradient(180deg,var(--cardA),var(--cardB));
      box-shadow:var(--shadow2);
      overflow:hidden;
    }

    .hero{padding:16px}

    .heroGrid{
      display:grid;
      grid-template-columns:minmax(0,1.1fr) 360px;
      gap:14px;
      align-items:stretch;
    }

    .welcome{
      min-height:190px;
      border-radius:25px;
      padding:18px;
      border:1px solid var(--line2);
      background:rgba(255,255,255,.026);
      display:flex;
      flex-direction:column;
      justify-content:space-between;
      gap:20px;
    }

    .welcome h2{
      margin:12px 0 0;
      font-size:27px;
      line-height:1.06;
      letter-spacing:-.8px;
      max-width:720px;
    }

    .welcome p{
      margin:8px 0 0;
      color:var(--muted);
      font-size:13px;
      font-weight:800;
      max-width:780px;
      line-height:1.55;
    }

    .heroActions{display:flex;gap:9px;flex-wrap:wrap}

    .livePanel{
      border-radius:25px;
      padding:16px;
      border:1px solid var(--line2);
      background:rgba(255,255,255,.026);
      display:grid;
      gap:12px;
    }

    .liveHeader{
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:10px;
    }

    .liveHeader strong{font-size:14px}
    .pulse{
      width:9px;height:9px;border-radius:50%;
      background:var(--ok);
      box-shadow:0 0 0 8px rgba(34,197,94,.12);
    }

    .liveList{display:grid;gap:10px}
    .liveItem{
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:10px;
      padding:10px;
      border-radius:18px;
      background:var(--soft);
      border:1px solid var(--line2);
    }
    .liveItem span:first-child{font-size:12px;color:var(--muted);font-weight:850}
    .liveItem strong{font-size:13px}

    .statsGrid{
      display:grid;
      grid-template-columns:repeat(4,minmax(0,1fr));
      gap:12px;
      margin-top:14px;
    }

    .statCard{
      border:1px solid var(--line);
      border-radius:24px;
      background:linear-gradient(180deg,var(--cardA),var(--cardB));
      box-shadow:var(--shadow2);
      padding:14px;
      min-width:0;
      overflow:hidden;
    }

    .statTop{
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:8px;
    }

    .statIcon{
      width:38px;height:38px;border-radius:15px;
      display:grid;place-items:center;
      background:rgba(79,140,255,.115);
      color:#7fb0ff;
      border:1px solid rgba(79,140,255,.20);
      flex:0 0 auto;
    }

    .trend{
      display:inline-flex;align-items:center;gap:5px;
      font-size:11px;font-weight:950;
      color:#42d77a;
      padding:5px 8px;border-radius:999px;
      background:rgba(34,197,94,.10);
      border:1px solid rgba(34,197,94,.18);
    }

    .statNumber{
      font-size:22px;
      font-weight:1000;
      letter-spacing:-.7px;
      margin-top:12px;
    }

    .statLabel{
      margin-top:3px;
      color:var(--muted);
      font-size:12px;
      font-weight:850;
    }

    .grid2{display:grid;grid-template-columns:1.15fr .85fr;gap:14px}
    .grid3{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:14px}
    .grid4{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:12px}

    .cardPad{padding:16px}
    .cardHead{
      display:flex;
      align-items:flex-start;
      justify-content:space-between;
      gap:12px;
      padding:16px 16px 0;
      flex-wrap:wrap;
    }

    .cardTitle h3{
      margin:0;
      font-size:16px;
      letter-spacing:-.25px;
    }
    .cardTitle p{
      margin:5px 0 0;
      color:var(--muted);
      font-size:12px;
      font-weight:800;
      line-height:1.45;
    }

    .tabs{
      display:flex;
      gap:7px;
      flex-wrap:wrap;
      padding:12px 16px 0;
    }

    .tabBtn,.chip{
      height:33px;
      padding:0 11px;
      color:var(--muted);
      font-size:11.5px;
    }

    .tabBtn.is-on,.chip.is-on{
      background:var(--active);
      border-color:var(--activeLine);
      color:var(--accent);
    }

    .tabPane{display:none}
    .tabPane.is-on{display:block}

    .tableWrap{overflow:auto;padding:12px 16px 16px}

    table{
      width:100%;
      border-collapse:separate;
      border-spacing:0 8px;
      min-width:760px;
    }

    th{
      text-align:left;
      color:var(--muted);
      font-size:10px;
      text-transform:uppercase;
      letter-spacing:.08em;
      padding:0 10px;
      white-space:nowrap;
    }

    td{
      background:var(--table);
      border-top:1px solid var(--line2);
      border-bottom:1px solid var(--line2);
      padding:10px;
      font-size:12px;
      font-weight:800;
      vertical-align:middle;
      white-space:nowrap;
    }

    td:first-child{border-left:1px solid var(--line2);border-radius:16px 0 0 16px}
    td:last-child{border-right:1px solid var(--line2);border-radius:0 16px 16px 0}

    .nameCell{display:flex;align-items:center;gap:10px}

    .miniLogo{
      width:34px;height:34px;border-radius:13px;
      display:grid;place-items:center;
      background:rgba(79,140,255,.115);
      color:#7fb0ff;
      border:1px solid rgba(79,140,255,.20);
      flex:0 0 auto;
      font-weight:1000;
    }

    .nameCell strong{display:block;font-size:12px}
    .nameCell span{display:block;color:var(--muted);font-size:11px;margin-top:2px}

    .rowActions{display:flex;gap:6px;justify-content:flex-end}

    .tinyBtn{
      width:33px;height:33px;border-radius:999px;
      display:grid;place-items:center;
      border:1px solid var(--line);
      background:var(--soft);
      color:var(--text);
      transition:.15s ease;
      font-size:12px;
    }
    .tinyBtn:hover{transform:translateY(-1px);background:rgba(79,140,255,.08);border-color:rgba(79,140,255,.25)}
    .tinyBtn.danger{color:#ff8b8b;background:rgba(239,68,68,.10);border-color:rgba(239,68,68,.20)}

    .quickGrid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:10px}

    .quickCard{
      border:1px solid var(--line2);
      background:var(--soft);
      border-radius:22px;
      padding:13px;
      display:grid;
      gap:9px;
      min-height:112px;
      transition:.15s ease;
      color:var(--text);
      text-align:left;
    }

    .quickCard:hover{transform:translateY(-2px);border-color:rgba(79,140,255,.23);background:rgba(79,140,255,.07)}

    .quickIcon{
      width:36px;height:36px;border-radius:14px;
      display:grid;place-items:center;
      background:rgba(255,183,3,.12);
      color:var(--accent);
      border:1px solid rgba(255,183,3,.20);
    }

    .quickCard strong{font-size:13px}
    .quickCard span{font-size:11px;color:var(--muted);font-weight:800;line-height:1.45}

    .splitGrid{display:grid;gap:10px;padding:16px}

    .splitItem{
      display:grid;
      gap:8px;
      padding:12px;
      border:1px solid var(--line2);
      border-radius:20px;
      background:var(--soft);
    }

    .splitTop{
      display:flex;align-items:center;justify-content:space-between;gap:10px;
      font-size:12px;font-weight:900;
    }

    .progress{
      height:9px;
      border-radius:999px;
      background:rgba(255,255,255,.07);
      overflow:hidden;
      border:1px solid var(--line2);
    }

    html[data-theme="light"] .progress{background:rgba(15,23,42,.06)}
    .progress i{
      display:block;height:100%;border-radius:999px;
      background:linear-gradient(90deg,var(--primary),var(--accent));
    }

    .formPanel{padding:16px;display:grid;gap:12px}
    .formGrid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:10px}
    .field label{display:block;color:var(--muted);font-size:11px;font-weight:950;margin:0 0 6px}
    .control{min-height:45px;border-radius:22px;padding:10px 13px}
    .control textarea{resize:vertical;min-height:92px;padding:4px 0}
    .full{grid-column:1/-1}

    .notice{
      padding:13px;
      border-radius:22px;
      border:1px solid rgba(255,183,3,.22);
      background:rgba(255,183,3,.10);
      color:var(--text);
      font-size:12px;
      font-weight:850;
      line-height:1.55;
    }

    .ticketCard{
      border:1px solid var(--line2);
      background:var(--soft);
      border-radius:24px;
      padding:14px;
      display:grid;
      gap:12px;
    }

    .ticketCode{
      border:1px dashed rgba(255,183,3,.34);
      background:rgba(255,183,3,.08);
      border-radius:20px;
      padding:14px;
      display:flex;
      justify-content:space-between;
      gap:12px;
      align-items:center;
    }

    .qr{
      width:72px;height:72px;border-radius:16px;
      display:grid;place-items:center;
      background:
        linear-gradient(90deg,rgba(255,255,255,.7) 2px,transparent 2px) 0 0/12px 12px,
        linear-gradient(rgba(255,255,255,.7) 2px,transparent 2px) 0 0/12px 12px,
        rgba(255,255,255,.13);
      border:1px solid var(--line2);
      color:var(--text);
      font-weight:1000;
      flex:0 0 auto;
    }

    .reportGrid{
      display:grid;
      grid-template-columns:repeat(3,minmax(0,1fr));
      gap:14px;
      padding:16px;
    }

    .reportCard{
      padding:16px;
      border-radius:24px;
      border:1px solid var(--line2);
      background:var(--soft);
      display:grid;
      gap:12px;
    }

    .reportCard h4{margin:0;font-size:15px}
    .reportCard p{margin:0;color:var(--muted);font-size:12px;font-weight:800;line-height:1.55}

    .modal{
      display:none;
      position:fixed;
      inset:0;
      z-index:160;
      background:rgba(0,0,0,.62);
      padding:18px;
      place-items:center;
    }

    .modal.is-open{display:grid}

    .modalCard{
      width:min(860px,96vw);
      max-height:92vh;
      overflow:auto;
      border:1px solid var(--line);
      border-radius:30px;
      background:linear-gradient(180deg,var(--panel),rgba(9,13,26,.96));
      box-shadow:var(--shadow);
      backdrop-filter:blur(18px);
      -webkit-backdrop-filter:blur(18px);
    }

    html[data-theme="light"] .modalCard{
      background:linear-gradient(180deg,rgba(255,255,255,.96),rgba(255,255,255,.90));
    }

    .modalHead{
      padding:16px;
      border-bottom:1px solid var(--line);
      display:flex;
      align-items:flex-start;
      justify-content:space-between;
      gap:12px;
    }

    .modalHead h3{margin:0;font-size:18px}
    .modalHead p{margin:5px 0 0;color:var(--muted);font-size:12px;font-weight:800}
    .modalBody{padding:16px}

    .deleteBox{
      display:grid;
      gap:12px;
      padding:16px;
      border-radius:24px;
      background:rgba(239,68,68,.10);
      border:1px solid rgba(239,68,68,.22);
    }

    .toast{
      position:fixed;
      right:18px;
      bottom:18px;
      z-index:200;
      display:none;
      border:1px solid var(--line);
      border-radius:22px;
      background:linear-gradient(180deg,var(--cardA),var(--cardB));
      box-shadow:var(--shadow);
      padding:12px 14px;
      font-weight:900;
      font-size:13px;
      backdrop-filter:blur(16px);
    }

    .toast.show{display:flex;gap:10px;align-items:center;animation:toastIn .2s ease both}
    @keyframes toastIn{from{opacity:0;transform:translateY(12px)}to{opacity:1;transform:translateY(0)}}

    @media (max-width:1180px){
      :root{--sidebar:252px}
      .heroGrid{grid-template-columns:1fr}
      .statsGrid,.grid4{grid-template-columns:repeat(2,minmax(0,1fr))}
      .grid2{grid-template-columns:1fr}
      .grid3,.reportGrid{grid-template-columns:1fr}
      .pageTitle p{max-width:420px}
    }

    @media (max-width:760px){
      .app{
        width:min(100% - 22px,760px);
        grid-template-columns:1fr;
        padding:10px 0 20px;
      }

      .sideBackdrop{
        display:none;
        position:fixed;
        inset:0;
        background:rgba(0,0,0,.58);
        z-index:74;
      }

      body.menu-open .sideBackdrop{display:block}

      .sidebar{
        display:flex;
        position:fixed;
        left:50%;
        top:78px;
        transform:translateX(-50%) translateY(10px);
        width:min(420px,calc(100vw - 22px));
        height:min(76vh,680px);
        border-radius:30px;
        opacity:0;
        pointer-events:none;
        transition:.18s ease;
      }

      body.menu-open .sidebar{
        opacity:1;
        pointer-events:auto;
        transform:translateX(-50%) translateY(0);
      }

      .menuBtn{display:grid!important}
      .topbar{
        top:10px;
        border-radius:26px;
        min-height:62px;
        max-height:62px;
      }
      .pageTitle h1{font-size:16px}
      .pageTitle p{display:none}
      .topActions .hideMobile{display:none}
      .welcome h2{font-size:23px}
      .statsGrid{grid-template-columns:repeat(2,minmax(0,1fr))}
      .quickGrid{grid-template-columns:1fr 1fr}
      .formGrid{grid-template-columns:1fr}
      table{min-width:680px}
    }

    @media (max-width:560px){
      .app{width:min(100% - 18px,440px);padding-top:10px}
      .topbar{border-radius:24px;padding:9px}
      .pageTitle h1{font-size:15px}
      .iconBtn{width:39px;height:39px}
      .btn{height:39px;padding:0 12px}
      .topActions #btnNew span,.topActions #btnExport span{display:none}
      .hero{padding:12px;border-radius:25px}
      .welcome{padding:14px;min-height:auto;border-radius:22px}
      .welcome h2{font-size:21px}
      .welcome p{font-size:12px}
      .statsGrid{grid-template-columns:1fr 1fr;gap:9px}
      .statCard{padding:12px;border-radius:21px}
      .statNumber{font-size:20px}
      .statLabel{font-size:11px}
      .card{border-radius:24px}
      .cardHead{padding:14px 14px 0}
      .tableWrap{padding:10px 12px 14px}
      .quickGrid{grid-template-columns:1fr}
      .modal{padding:10px}
      .modalCard{border-radius:25px}
      .toast{right:10px;left:10px;bottom:10px}
    }
  </style>
<%- include("../partials/head-injection", { headInjection }) %>
</head>

<body>
  <div class="sideBackdrop" id="sideBackdrop"></div>

  <div class="app" id="appTop">
    <aside class="sidebar" id="sidebar" aria-label="Customer navigation">
      <div class="sideTop">
        <div class="mark">CT</div>
        <div class="brandText">
          <strong>Classic Trip</strong>
          <span>Customer Dashboard</span>
        </div>
      </div>

      <div class="sideSearch">
        <label class="searchBox">
          <i class="fa-solid fa-magnifying-glass"></i>
          <input id="sideSearch" placeholder="Search menu..." />
        </label>
      </div>

      <nav class="sideNav" id="sideNav">
        <button class="navBtn is-active" data-page="overview"><i class="fa-solid fa-chart-line"></i><span>Overview</span></button>
        <button class="navBtn" data-page="bookings"><i class="fa-solid fa-ticket"></i><span>My Bookings</span></button>
        <button class="navBtn" data-page="ticket"><i class="fa-solid fa-qrcode"></i><span>Current Ticket</span></button>
        <button class="navBtn" data-page="saved"><i class="fa-solid fa-heart"></i><span>Saved Trips</span></button>
        <button class="navBtn" data-page="receipts"><i class="fa-solid fa-receipt"></i><span>Receipts</span></button>
        <button class="navBtn" data-page="refunds"><i class="fa-solid fa-rotate-left"></i><span>Refunds</span></button>
        <button class="navBtn" data-page="support"><i class="fa-solid fa-headset"></i><span>Support</span></button>
        <button class="navBtn" data-page="reviews"><i class="fa-solid fa-star"></i><span>Reviews</span></button>
        <button class="navBtn" data-page="wallet"><i class="fa-solid fa-wallet"></i><span>Wallet</span></button>
        <button class="navBtn" data-page="notifications"><i class="fa-solid fa-bell"></i><span>Notifications</span></button>
        <button class="navBtn" data-page="profile"><i class="fa-solid fa-user-gear"></i><span>Profile</span></button>
        <button class="navBtn" data-page="security"><i class="fa-solid fa-shield-halved"></i><span>Security</span></button>
      </nav>

      <div class="sideFoot">
        <div class="miniProfile">
          <div class="avatar">AK</div>
          <div class="profileMeta">
            <strong>Amina K.</strong>
            <span>Traveler • Kampala</span>
          </div>
        </div>
      </div>
    </aside>

    <main class="main">
      <header class="topbar">
        <div class="topLeft">
          <button class="iconBtn menuBtn" id="openMenu" aria-label="Open menu"><i class="fa-solid fa-bars"></i></button>
          <div class="pageTitle">
            <h1 id="pageHeading">Customer Dashboard</h1>
            <p id="pageSub">Manage bookings, tickets, saved trips, receipts, refunds, support, reviews, wallet, and profile.</p>
          </div>
        </div>

        <div class="topActions">
          <button class="iconBtn" id="btnTheme" title="Toggle theme" aria-label="Toggle theme"><i class="fa-solid fa-moon" id="themeIcon"></i></button>
          <button class="btn hideMobile" id="btnExport"><i class="fa-solid fa-download"></i><span>Export</span></button>
          <button class="btn btnBlue" id="btnNew"><i class="fa-solid fa-plus"></i><span>Book Trip</span></button>
          <button class="btn btnPrimary hideMobile"><i class="fa-solid fa-user-check"></i> Verified</button>
        </div>
      </header>

      <div class="content" id="contentTop">
        <section class="section is-open" id="overview">
          <div class="hero">
            <div class="heroGrid">
              <div class="welcome">
                <div>
                  <span class="badge ok"><i class="fa-solid fa-circle-check"></i> Account active</span>
                  <h2>Welcome Amina. Your next trip is ready for check-in.</h2>
                  <p>View your upcoming tickets, download receipts, request refunds, save trips, contact support, review companies, and manage your travel profile from one clean dashboard.</p>
                </div>
                <div class="heroActions">
                  <button class="btn btnPrimary" data-jump="ticket"><i class="fa-solid fa-qrcode"></i> View ticket</button>
                  <button class="btn" data-jump="bookings"><i class="fa-solid fa-ticket"></i> My bookings</button>
                  <button class="btn" data-jump="support"><i class="fa-solid fa-headset"></i> Get help</button>
                </div>
              </div>

              <div class="livePanel">
                <div class="liveHeader">
                  <strong>Next trip</strong>
                  <span class="badge ok"><span class="pulse"></span> Confirmed</span>
                </div>
                <div class="liveList">
                  <div class="liveItem"><span>Route</span><strong>Kampala ⇄ Nairobi</strong></div>
                  <div class="liveItem"><span>Departure</span><strong>Today 08:00</strong></div>
                  <div class="liveItem"><span>Seat</span><strong>A12</strong></div>
                  <div class="liveItem"><span>Booking</span><strong>#CT-10501</strong></div>
                </div>
              </div>
            </div>

            <div class="statsGrid">
              <article class="statCard">
                <div class="statTop"><div class="statIcon"><i class="fa-solid fa-ticket"></i></div><span class="trend"><i class="fa-solid fa-arrow-trend-up"></i> 18</span></div>
                <div class="statNumber">18</div>
                <div class="statLabel">Total bookings</div>
              </article>
              <article class="statCard">
                <div class="statTop"><div class="statIcon"><i class="fa-solid fa-heart"></i></div><span class="trend">12</span></div>
                <div class="statNumber">12</div>
                <div class="statLabel">Saved trips</div>
              </article>
              <article class="statCard">
                <div class="statTop"><div class="statIcon"><i class="fa-solid fa-wallet"></i></div><span class="trend">UGX</span></div>
                <div class="statNumber">UGX 54K</div>
                <div class="statLabel">Wallet balance</div>
              </article>
              <article class="statCard">
                <div class="statTop"><div class="statIcon"><i class="fa-solid fa-star"></i></div><span class="trend">4.8</span></div>
                <div class="statNumber">4</div>
                <div class="statLabel">Reviews submitted</div>
              </article>
            </div>
          </div>

          <div class="grid2">
            <div class="card">
              <div class="cardHead">
                <div class="cardTitle"><h3>Recent bookings</h3><p>Your latest ticket and reservation history.</p></div>
                <button class="btn" data-jump="bookings"><i class="fa-regular fa-eye"></i> View all</button>
              </div>
              <div class="tableWrap">
                <table>
                  <thead><tr><th>Booking</th><th>Service</th><th>Company</th><th>Date</th><th>Status</th><th>Total</th><th></th></tr></thead>
                  <tbody id="recentBookings"></tbody>
                </table>
              </div>
            </div>

            <div class="card">
              <div class="cardHead">
                <div class="cardTitle"><h3>Quick actions</h3><p>Fast customer actions.</p></div>
              </div>
              <div class="cardPad">
                <div class="quickGrid">
                  <button class="quickCard" data-modal="create" data-type="new trip booking"><div class="quickIcon"><i class="fa-solid fa-magnifying-glass"></i></div><strong>Book a trip</strong><span>Search bus, hotel, flight, train, tour, ferry, or car rental.</span></button>
                  <button class="quickCard" data-jump="ticket"><div class="quickIcon"><i class="fa-solid fa-qrcode"></i></div><strong>Open ticket</strong><span>Show QR code, seat, passenger details, and receipt.</span></button>
                  <button class="quickCard" data-modal="create" data-type="refund request"><div class="quickIcon"><i class="fa-solid fa-rotate-left"></i></div><strong>Request refund</strong><span>Submit refund or cancellation request.</span></button>
                  <button class="quickCard" data-modal="create" data-type="support case"><div class="quickIcon"><i class="fa-solid fa-headset"></i></div><strong>Contact support</strong><span>Get help with payment, ticket, booking, or refund.</span></button>
                </div>
              </div>
            </div>
          </div>
        </section>

        <section class="section" id="bookings">
          <div class="card" data-tabs>
            <div class="cardHead">
              <div class="cardTitle"><h3>My bookings</h3><p>All your upcoming, completed, cancelled, and refund bookings.</p></div>
              <button class="btn btnBlue" data-modal="create" data-type="trip booking"><i class="fa-solid fa-plus"></i> Book new trip</button>
            </div>
            <div class="tabs">
              <button class="tabBtn is-on" data-tab="all">All</button>
              <button class="tabBtn" data-tab="upcoming">Upcoming</button>
              <button class="tabBtn" data-tab="completed">Completed</button>
              <button class="tabBtn" data-tab="hold">On hold</button>
              <button class="tabBtn" data-tab="cancelled">Cancelled</button>
              <button class="tabBtn" data-tab="refund">Refund</button>
            </div>
            <div class="tabPane is-on" data-pane="all"><div class="tableWrap"><table><thead><tr><th>Booking</th><th>Service</th><th>Company</th><th>Date</th><th>Passenger</th><th>Status</th><th>Total</th><th></th></tr></thead><tbody id="bookingsTable"></tbody></table></div></div>
            <div class="tabPane" data-pane="upcoming"><div class="tableWrap"><table><thead><tr><th>Booking</th><th>Service</th><th>Company</th><th>Date</th><th>Passenger</th><th>Status</th><th>Total</th><th></th></tr></thead><tbody data-filter-table="bookings-status" data-filter="Upcoming"></tbody></table></div></div>
            <div class="tabPane" data-pane="completed"><div class="tableWrap"><table><thead><tr><th>Booking</th><th>Service</th><th>Company</th><th>Date</th><th>Passenger</th><th>Status</th><th>Total</th><th></th></tr></thead><tbody data-filter-table="bookings-status" data-filter="Completed"></tbody></table></div></div>
            <div class="tabPane" data-pane="hold"><div class="tableWrap"><table><thead><tr><th>Booking</th><th>Service</th><th>Company</th><th>Date</th><th>Passenger</th><th>Status</th><th>Total</th><th></th></tr></thead><tbody data-filter-table="bookings-status" data-filter="Hold"></tbody></table></div></div>
            <div class="tabPane" data-pane="cancelled"><div class="tableWrap"><table><thead><tr><th>Booking</th><th>Service</th><th>Company</th><th>Date</th><th>Passenger</th><th>Status</th><th>Total</th><th></th></tr></thead><tbody data-filter-table="bookings-status" data-filter="Cancelled"></tbody></table></div></div>
            <div class="tabPane" data-pane="refund"><div class="tableWrap"><table><thead><tr><th>Booking</th><th>Service</th><th>Company</th><th>Date</th><th>Passenger</th><th>Status</th><th>Total</th><th></th></tr></thead><tbody data-filter-table="bookings-status" data-filter="Refund"></tbody></table></div></div>
          </div>
        </section>

        <section class="section" id="ticket">
          <div class="grid2">
            <div class="card">
              <div class="cardHead">
                <div class="cardTitle"><h3>Current ticket</h3><p>Show this ticket when checking in or boarding.</p></div>
                <button class="btn btnPrimary" id="btnPrintTicket"><i class="fa-solid fa-print"></i> Print</button>
              </div>
              <div class="cardPad">
                <div class="ticketCard">
                  <div class="ticketCode">
                    <div>
                      <span class="badge ok">Confirmed</span>
                      <h3 style="margin:10px 0 4px;font-size:20px">Kampala ⇄ Nairobi Executive</h3>
                      <p style="margin:0;color:var(--muted);font-size:12px;font-weight:800">Classic Express • Today 08:00 • Seat A12</p>
                    </div>
                    <div class="qr">QR</div>
                  </div>
                  <div class="grid3">
                    <div class="splitItem"><div class="splitTop"><span>Booking</span><strong>#CT-10501</strong></div></div>
                    <div class="splitItem"><div class="splitTop"><span>Passenger</span><strong>Amina K.</strong></div></div>
                    <div class="splitItem"><div class="splitTop"><span>Paid</span><strong>UGX 85,000</strong></div></div>
                  </div>
                  <div class="notice">Arrive at the departure point at least 30 minutes before departure. Keep your ID and booking QR ready.</div>
                </div>
              </div>
            </div>

            <div class="card">
              <div class="cardHead"><div class="cardTitle"><h3>Trip progress</h3><p>Useful information before your trip.</p></div></div>
              <div class="splitGrid">
                <div class="splitItem"><div class="splitTop"><span>Payment status</span><span class="badge ok">Paid</span></div></div>
                <div class="splitItem"><div class="splitTop"><span>Check-in status</span><span class="badge warn">Not checked</span></div></div>
                <div class="splitItem"><div class="splitTop"><span>Departure gate</span><strong>Kampala Bus Park • Gate 3</strong></div></div>
                <div class="splitItem"><div class="splitTop"><span>Support contact</span><strong>+256 700 000 000</strong></div></div>
              </div>
            </div>
          </div>
        </section>

        <section class="section" id="saved">
          <div class="card">
            <div class="cardHead">
              <div class="cardTitle"><h3>Saved trips</h3><p>Trips, hotels, routes, tours, and rentals you saved for later.</p></div>
              <button class="btn btnBlue" data-modal="create" data-type="saved trip"><i class="fa-solid fa-plus"></i> Add saved trip</button>
            </div>
            <div class="tableWrap">
              <table>
                <thead><tr><th>Saved item</th><th>Type</th><th>Company</th><th>Location / route</th><th>Price from</th><th>Status</th><th></th></tr></thead>
                <tbody id="savedTable"></tbody>
              </table>
            </div>
          </div>
        </section>

        <section class="section" id="receipts">
          <div class="card" data-tabs>
            <div class="cardHead">
              <div class="cardTitle"><h3>Receipts</h3><p>Download payment receipts and invoices for your bookings.</p></div>
              <button class="btn btnBlue" id="btnDownloadAll"><i class="fa-solid fa-download"></i> Download all</button>
            </div>
            <div class="tabs">
              <button class="tabBtn is-on" data-tab="all">All</button>
              <button class="tabBtn" data-tab="paid">Paid</button>
              <button class="tabBtn" data-tab="refund">Refunded</button>
              <button class="tabBtn" data-tab="pending">Pending</button>
            </div>
            <div class="tabPane is-on" data-pane="all"><div class="tableWrap"><table><thead><tr><th>Receipt</th><th>Booking</th><th>Method</th><th>Date</th><th>Amount</th><th>Status</th><th></th></tr></thead><tbody id="receiptsTable"></tbody></table></div></div>
            <div class="tabPane" data-pane="paid"><div class="tableWrap"><table><thead><tr><th>Receipt</th><th>Booking</th><th>Method</th><th>Date</th><th>Amount</th><th>Status</th><th></th></tr></thead><tbody data-filter-table="receipts-status" data-filter="Paid"></tbody></table></div></div>
            <div class="tabPane" data-pane="refund"><div class="tableWrap"><table><thead><tr><th>Receipt</th><th>Booking</th><th>Method</th><th>Date</th><th>Amount</th><th>Status</th><th></th></tr></thead><tbody data-filter-table="receipts-status" data-filter="Refunded"></tbody></table></div></div>
            <div class="tabPane" data-pane="pending"><div class="tableWrap"><table><thead><tr><th>Receipt</th><th>Booking</th><th>Method</th><th>Date</th><th>Amount</th><th>Status</th><th></th></tr></thead><tbody data-filter-table="receipts-status" data-filter="Pending"></tbody></table></div></div>
          </div>
        </section>

        <section class="section" id="refunds">
          <div class="grid2">
            <div class="card">
              <div class="cardHead">
                <div class="cardTitle"><h3>Refunds</h3><p>Track refund and cancellation requests.</p></div>
                <button class="btn btnBlue" data-modal="create" data-type="refund request"><i class="fa-solid fa-rotate-left"></i> Request refund</button>
              </div>
              <div class="tableWrap">
                <table>
                  <thead><tr><th>Refund</th><th>Booking</th><th>Reason</th><th>Amount</th><th>Status</th><th>Updated</th><th></th></tr></thead>
                  <tbody id="refundsTable"></tbody>
                </table>
              </div>
            </div>
            <div class="card">
              <div class="cardHead"><div class="cardTitle"><h3>Refund policy</h3><p>Simple policy summary shown to customers.</p></div></div>
              <div class="splitGrid">
                <div class="splitItem"><div class="splitTop"><span>Before departure</span><strong>Partial refund</strong></div></div>
                <div class="splitItem"><div class="splitTop"><span>After departure</span><span class="badge bad">Not eligible</span></div></div>
                <div class="splitItem"><div class="splitTop"><span>Company cancellation</span><span class="badge ok">Eligible</span></div></div>
                <div class="notice">Final refund rules should depend on company policy, service type, time before departure/check-in, and payment provider status.</div>
              </div>
            </div>
          </div>
        </section>

        <section class="section" id="support">
          <div class="grid2">
            <div class="card">
              <div class="cardHead">
                <div class="cardTitle"><h3>Support</h3><p>Track your support conversations and disputes.</p></div>
                <button class="btn btnPrimary" data-modal="create" data-type="support case"><i class="fa-solid fa-plus"></i> New case</button>
              </div>
              <div class="tableWrap">
                <table>
                  <thead><tr><th>Case</th><th>Booking</th><th>Issue</th><th>Priority</th><th>Status</th><th>Opened</th><th></th></tr></thead>
                  <tbody id="supportTable"></tbody>
                </table>
              </div>
            </div>
            <div class="card">
              <div class="cardHead"><div class="cardTitle"><h3>Contact support</h3><p>Send a message to Classic Trip support.</p></div></div>
              <form class="formPanel" id="supportForm">
                <div class="formGrid">
                  <div class="field"><label>Booking</label><div class="control"><i class="fa-solid fa-ticket"></i><select><option>#CT-10501</option><option>#CT-10497</option><option>#CT-10489</option></select></div></div>
                  <div class="field"><label>Issue type</label><div class="control"><i class="fa-solid fa-circle-question"></i><select><option>Ticket not received</option><option>Refund request</option><option>Wrong passenger details</option><option>Payment problem</option></select></div></div>
                  <div class="field full"><label>Message</label><div class="control"><textarea placeholder="Explain your issue..."></textarea></div></div>
                </div>
                <button class="btn btnPrimary" type="submit"><i class="fa-solid fa-paper-plane"></i> Send message</button>
              </form>
            </div>
          </div>
        </section>

        <section class="section" id="reviews">
          <div class="card" data-tabs>
            <div class="cardHead">
              <div class="cardTitle"><h3>Reviews</h3><p>Review companies after your trip and see previous ratings.</p></div>
              <button class="btn btnBlue" data-modal="create" data-type="review"><i class="fa-solid fa-star"></i> Write review</button>
            </div>
            <div class="tabs">
              <button class="tabBtn is-on" data-tab="all">All</button>
              <button class="tabBtn" data-tab="pending">Pending review</button>
              <button class="tabBtn" data-tab="submitted">Submitted</button>
            </div>
            <div class="tabPane is-on" data-pane="all"><div class="tableWrap"><table><thead><tr><th>Booking</th><th>Service</th><th>Company</th><th>Rating</th><th>Review</th><th>Status</th><th></th></tr></thead><tbody id="reviewsTable"></tbody></table></div></div>
            <div class="tabPane" data-pane="pending"><div class="tableWrap"><table><thead><tr><th>Booking</th><th>Service</th><th>Company</th><th>Rating</th><th>Review</th><th>Status</th><th></th></tr></thead><tbody data-filter-table="reviews-status" data-filter="Pending"></tbody></table></div></div>
            <div class="tabPane" data-pane="submitted"><div class="tableWrap"><table><thead><tr><th>Booking</th><th>Service</th><th>Company</th><th>Rating</th><th>Review</th><th>Status</th><th></th></tr></thead><tbody data-filter-table="reviews-status" data-filter="Submitted"></tbody></table></div></div>
          </div>
        </section>

        <section class="section" id="wallet">
          <div class="grid2">
            <div class="card">
              <div class="cardHead">
                <div class="cardTitle"><h3>Wallet</h3><p>Wallet balance, refunds, credits, and promo rewards.</p></div>
                <button class="btn btnBlue" data-modal="create" data-type="wallet top-up"><i class="fa-solid fa-plus"></i> Top up</button>
              </div>
              <div class="statsGrid" style="padding:16px;margin-top:0">
                <article class="statCard"><div class="statTop"><div class="statIcon"><i class="fa-solid fa-wallet"></i></div><span class="trend">UGX</span></div><div class="statNumber">UGX 54K</div><div class="statLabel">Available balance</div></article>
                <article class="statCard"><div class="statTop"><div class="statIcon"><i class="fa-solid fa-rotate-left"></i></div><span class="trend">2</span></div><div class="statNumber">UGX 45K</div><div class="statLabel">Refund credits</div></article>
              </div>
              <div class="tableWrap">
                <table>
                  <thead><tr><th>Transaction</th><th>Type</th><th>Method</th><th>Date</th><th>Amount</th><th>Status</th><th></th></tr></thead>
                  <tbody id="walletTable"></tbody>
                </table>
              </div>
            </div>
            <div class="card">
              <div class="cardHead"><div class="cardTitle"><h3>Referral invite</h3><p>Optional: customer can become promoter and earn from shared links.</p></div></div>
              <div class="splitGrid">
                <div class="splitItem"><div class="splitTop"><span>Promoter account</span><span class="badge info">Not enabled</span></div></div>
                <div class="splitItem"><div class="splitTop"><span>Potential commission</span><strong>3%</strong></div></div>
                <div class="notice">Customers can be invited to open promoter accounts, then they share listing links and earn commission when friends book.</div>
                <button class="btn btnPrimary" data-modal="create" data-type="promoter account"><i class="fa-solid fa-bullhorn"></i> Become promoter</button>
              </div>
            </div>
          </div>
        </section>

        <section class="section" id="notifications">
          <div class="card">
            <div class="cardHead">
              <div class="cardTitle"><h3>Notifications</h3><p>Booking updates, payment alerts, trip changes, refunds, and support messages.</p></div>
              <button class="btn" id="btnMarkRead"><i class="fa-solid fa-check-double"></i> Mark all read</button>
            </div>
            <div class="tableWrap">
              <table>
                <thead><tr><th>Notification</th><th>Type</th><th>Message</th><th>Date</th><th>Status</th><th></th></tr></thead>
                <tbody id="notificationsTable"></tbody>
              </table>
            </div>
          </div>
        </section>

        <section class="section" id="profile">
          <div class="grid2">
            <div class="card">
              <div class="cardHead"><div class="cardTitle"><h3>Profile</h3><p>Manage passenger details used for bookings.</p></div></div>
              <form class="formPanel" id="profileForm">
                <div class="formGrid">
                  <div class="field"><label>Full name</label><div class="control"><i class="fa-solid fa-user"></i><input value="Amina K." /></div></div>
                  <div class="field"><label>Phone</label><div class="control"><i class="fa-solid fa-phone"></i><input value="+256 700 112233" /></div></div>
                  <div class="field"><label>Email</label><div class="control"><i class="fa-solid fa-envelope"></i><input value="amina@example.com" /></div></div>
                  <div class="field"><label>City</label><div class="control"><i class="fa-solid fa-location-dot"></i><input value="Kampala" /></div></div>
                  <div class="field full"><label>Saved passenger details</label><div class="control"><textarea>Amina K. • Adult passenger • Passport/ID ending 2091</textarea></div></div>
                </div>
                <button class="btn btnPrimary" type="submit"><i class="fa-solid fa-floppy-disk"></i> Save profile</button>
              </form>
            </div>
            <div class="card">
              <div class="cardHead"><div class="cardTitle"><h3>Travel preferences</h3><p>Default preferences when booking.</p></div></div>
              <div class="splitGrid">
                <div class="splitItem"><div class="splitTop"><span>Preferred seat</span><strong>Window</strong></div></div>
                <div class="splitItem"><div class="splitTop"><span>Default currency</span><strong>UGX</strong></div></div>
                <div class="splitItem"><div class="splitTop"><span>Notifications</span><span class="badge ok">Enabled</span></div></div>
                <div class="splitItem"><div class="splitTop"><span>Receipt email</span><span class="badge ok">Enabled</span></div></div>
              </div>
            </div>
          </div>
        </section>

        <section class="section" id="security">
          <div class="grid2">
            <div class="card">
              <div class="cardHead"><div class="cardTitle"><h3>Security</h3><p>Protect your account and booking history.</p></div></div>
              <div class="splitGrid">
                <div class="splitItem"><div class="splitTop"><span>Phone verified</span><span class="badge ok">Verified</span></div></div>
                <div class="splitItem"><div class="splitTop"><span>Email verified</span><span class="badge ok">Verified</span></div></div>
                <div class="splitItem"><div class="splitTop"><span>Two-factor login</span><span class="badge warn">Recommended</span></div></div>
                <div class="splitItem"><div class="splitTop"><span>Last login</span><strong>Today • Kampala</strong></div></div>
                <button class="btn btnBlue" data-modal="edit" data-type="security settings"><i class="fa-solid fa-shield-halved"></i> Update security</button>
              </div>
            </div>
            <div class="card">
              <div class="cardHead"><div class="cardTitle"><h3>Login activity</h3><p>Recent devices and locations.</p></div></div>
              <div class="tableWrap">
                <table>
                  <thead><tr><th>Device</th><th>Location</th><th>Date</th><th>Status</th><th></th></tr></thead>
                  <tbody id="securityTable"></tbody>
                </table>
              </div>
            </div>
          </div>
        </section>
      </div>
    </main>
  </div>

  <div class="modal" id="crudModal">
    <div class="modalCard">
      <div class="modalHead">
        <div><h3 id="crudTitle">Create item</h3><p id="crudSub">Manage customer data cleanly.</p></div>
        <button class="iconBtn" data-close-modal><i class="fa-solid fa-xmark"></i></button>
      </div>
      <div class="modalBody" id="crudBody"></div>
    </div>
  </div>

  <div class="modal" id="deleteModal">
    <div class="modalCard">
      <div class="modalHead">
        <div><h3>Delete record</h3><p>This demo shows the delete confirmation flow.</p></div>
        <button class="iconBtn" data-close-modal><i class="fa-solid fa-xmark"></i></button>
      </div>
      <div class="modalBody">
        <div class="deleteBox">
          <span class="badge bad"><i class="fa-solid fa-triangle-exclamation"></i> Delete action</span>
          <strong id="deleteText">Are you sure you want to delete this record?</strong>
          <p style="margin:0;color:var(--muted);font-size:12px;font-weight:800;line-height:1.55">In the real system, deleting customer data should follow privacy and audit rules.</p>
          <div style="display:flex;gap:8px;flex-wrap:wrap;justify-content:flex-end">
            <button class="btn" data-close-modal>Cancel</button>
            <button class="btn btnDanger" id="confirmDelete"><i class="fa-solid fa-trash"></i> Delete</button>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="toast" id="toast"><i class="fa-solid fa-circle-check"></i><span id="toastText">Done</span></div>

  
<%- include("../partials/body-end", { bodyEndInjection }) %>
</body>
</html>
