      <section class="section" id="kyc"><div class="card"><div class="cardHead"><div class="cardTitle"><h3>KYC / Verification</h3><p>Review partner company documents, payout accounts, employee IDs, and compliance flags.</p></div><button class="btn btnPrimary" data-modal="create" data-type="verification task"><i class="fa-solid fa-id-card-clip"></i> New review</button></div><div class="innerTabs" data-tab-group="kyc-tabs"><button type="button" class="tabBtn is-on" data-tab-target="kyc-pending"><i class="fa-regular fa-hourglass-half"></i> Pending</button><button type="button" class="tabBtn" data-tab-target="kyc-approved"><i class="fa-solid fa-circle-check"></i> Approved</button><button type="button" class="tabBtn" data-tab-target="kyc-rejected"><i class="fa-solid fa-circle-xmark"></i> Rejected</button><button type="button" class="tabBtn" data-tab-target="kyc-bank"><i class="fa-solid fa-building-columns"></i> Bank mismatch</button><button type="button" class="tabBtn" data-tab-target="kyc-expired"><i class="fa-solid fa-file-circle-exclamation"></i> Expired docs</button></div><div class="tabPane is-open" id="kyc-pending"><div class="tableWrap"><table><thead><tr><th>Company</th><th>Document</th><th>Country</th><th>Payout account</th><th>Risk</th><th>Status</th><th></th></tr></thead><tbody id="kycTable"></tbody></table></div></div><div class="tabPane" id="kyc-approved"><div class="tableWrap"><table><thead><tr><th>Company</th><th>Document</th><th>Country</th><th>Payout account</th><th>Risk</th><th>Status</th><th></th></tr></thead><tbody id="kycApprovedTable"></tbody></table></div></div><div class="tabPane" id="kyc-rejected"><div class="tableWrap"><table><thead><tr><th>Company</th><th>Document</th><th>Country</th><th>Payout account</th><th>Risk</th><th>Status</th><th></th></tr></thead><tbody id="kycRejectedTable"></tbody></table></div></div><div class="tabPane" id="kyc-bank"><div class="tableWrap"><table><thead><tr><th>Company</th><th>Document</th><th>Country</th><th>Payout account</th><th>Risk</th><th>Status</th><th></th></tr></thead><tbody id="kycBankTable"></tbody></table></div></div><div class="tabPane" id="kyc-expired"><div class="tableWrap"><table><thead><tr><th>Company</th><th>Document</th><th>Country</th><th>Payout account</th><th>Risk</th><th>Status</th><th></th></tr></thead><tbody id="kycExpiredTable"></tbody></table></div></div></div></section>

      <section class="section" id="refunds"><div class="grid2"><div class="card"><div class="cardHead"><div class="cardTitle"><h3>Refunds & cancellations</h3><p>Approve customer refunds, cancellation fees, failed ticket reversals, and partner chargebacks.</p></div><button class="btn btnPrimary" data-modal="create" data-type="refund"><i class="fa-solid fa-rotate-left"></i> Create refund</button></div><div class="tableWrap"><table><thead><tr><th>Refund</th><th>Booking</th><th>Customer</th><th>Reason</th><th>Amount</th><th>Status</th><th></th></tr></thead><tbody id="refundsTable"></tbody></table></div></div><div class="card"><div class="cardHead"><div class="cardTitle"><h3>Refund policy health</h3><p>Keep refunds controlled but fast for customers.</p></div></div><div class="splitGrid"><div class="splitItem"><div class="splitTop"><span>Auto refundable</span><strong>64%</strong></div><div class="progress"><i style="width:64%"></i></div></div><div class="splitItem"><div class="splitTop"><span>Partner approval needed</span><strong>28%</strong></div><div class="progress"><i style="width:28%"></i></div></div><div class="splitItem"><div class="splitTop"><span>Fraud / duplicate review</span><strong>8%</strong></div><div class="progress"><i style="width:8%"></i></div></div></div></div></div></section>

      <section class="section" id="notifications"><div class="card"><div class="cardHead"><div class="cardTitle"><h3>Notifications</h3><p>Manage email, SMS, WhatsApp, push, booking receipts, payout alerts, and partner notices.</p></div><button class="btn btnBlue" data-modal="create" data-type="notification"><i class="fa-solid fa-paper-plane"></i> Send notification</button></div><div class="innerTabs" data-tab-group="notify-tabs"><button type="button" class="tabBtn is-on" data-tab-target="notify-campaigns"><i class="fa-solid fa-bullhorn"></i> Campaigns</button><button type="button" class="tabBtn" data-tab-target="notify-templates"><i class="fa-solid fa-envelope-open-text"></i> Templates</button></div><div class="tabPane is-open" id="notify-campaigns"><div class="tableWrap"><table><thead><tr><th>Message</th><th>Channel</th><th>Audience</th><th>Sent</th><th>Delivery</th><th>Status</th><th></th></tr></thead><tbody id="notificationsTable"></tbody></table></div></div><div class="tabPane" id="notify-templates"><div class="reportGrid"><article class="reportCard"><span class="badge ok">Active</span><h4>Booking receipt</h4><p>Email/SMS template after successful payment.</p><button class="btn" data-modal="edit" data-type="template" data-label="Booking receipt">Edit</button></article><article class="reportCard"><span class="badge ok">Active</span><h4>Payout approved</h4><p>Notice to partners and promoters when funds are released.</p><button class="btn" data-modal="edit" data-type="template" data-label="Payout approved">Edit</button></article><article class="reportCard"><span class="badge warn">Review</span><h4>Refund update</h4><p>Customer message for refund progress and cancellation rules.</p><button class="btn" data-modal="edit" data-type="template" data-label="Refund update">Edit</button></article></div></div></div></section>

      <section class="section" id="system"><div class="grid2"><div class="card"><div class="cardHead"><div class="cardTitle"><h3>System health</h3><p>Monitor API, database, payment gateway, ticket delivery, queues, and background jobs.</p></div><span class="badge ok"><i class="fa-solid fa-circle-check"></i> Healthy</span></div><div class="metricList"><div class="metricRow"><div><strong>Booking API</strong><span>Average response 118ms</span></div><b class="badge ok">Online</b></div><div class="metricRow"><div><strong>Payment webhook</strong><span>Last event 2 minutes ago</span></div><b class="badge ok">Online</b></div><div class="metricRow"><div><strong>Ticket delivery queue</strong><span>7 jobs waiting</span></div><b class="badge warn">Busy</b></div><div class="metricRow"><div><strong>Database replicas</strong><span>All replicas synchronized</span></div><b class="badge ok">Online</b></div></div></div><div class="card"><div class="cardHead"><div class="cardTitle"><h3>Operational checklist</h3><p>Daily super admin checks.</p></div></div><div class="splitGrid"><div class="splitItem"><div class="splitTop"><span>Failed payments reviewed</span><span class="badge warn">4 left</span></div></div><div class="splitItem"><div class="splitTop"><span>Pending payouts checked</span><span class="badge ok">Done</span></div></div><div class="splitItem"><div class="splitTop"><span>New partners verified</span><span class="badge warn">18 left</span></div></div><div class="splitItem"><div class="splitTop"><span>Critical support tickets</span><span class="badge bad">11 open</span></div></div></div></div></div></section>

      <section class="section" id="settings"><div class="grid2"><div class="card"><div class="cardHead"><div class="cardTitle"><h3>Platform settings</h3><p>Global marketplace configuration.</p></div></div><form class="formPanel" id="settingsForm"><div class="formGrid"><div class="field"><label>Platform fee</label><div class="control"><i class="fa-solid fa-percent"></i><input value="7%" /></div></div><div class="field"><label>Promoter commission</label><div class="control"><i class="fa-solid fa-percent"></i><input value="3%" /></div></div><div class="field"><label>Hold timer</label><div class="control"><i class="fa-regular fa-clock"></i><input value="10 minutes" /></div></div><div class="field"><label>Default currency</label><div class="control"><i class="fa-solid fa-coins"></i><select><option>UGX</option><option>KES</option><option>RWF</option><option>TZS</option><option>USD</option></select></div></div><div class="field full"><label>Support message</label><div class="control"><textarea>Classic Trip support is available for tickets, payments, refunds, partner onboarding, and promoter payouts.</textarea></div></div></div><button class="btn btnPrimary" type="submit"><i class="fa-solid fa-floppy-disk"></i> Save settings</button></form></div><div class="card"><div class="cardHead"><div class="cardTitle"><h3>Security controls</h3><p>Admin and platform protection settings.</p></div></div><div class="splitGrid"><div class="splitItem"><div class="splitTop"><span>Admin 2FA</span><span class="badge ok">Enabled</span></div></div><div class="splitItem"><div class="splitTop"><span>Partner KYC required</span><span class="badge ok">Enabled</span></div></div><div class="splitItem"><div class="splitTop"><span>Suspicious payout hold</span><span class="badge warn">Manual review</span></div></div><div class="splitItem"><div class="splitTop"><span>Audit log</span><span class="badge info">Active</span></div></div></div></div></div></section>
    </main>
  </div>

  <div class="modal" id="crudModal">
    <div class="modalCard">
      <div class="modalHead">
        <div><h3 id="crudTitle">Create item</h3><p id="crudSub">Manage platform data cleanly.</p></div>
        <button class="iconBtn" data-close-modal><i class="fa-solid fa-xmark"></i></button>
      </div>
      <div class="modalBody" id="crudBody"></div>
    </div>
  </div>

  <div class="modal" id="deleteModal">
    <div class="modalCard">
      <div class="modalHead">
        <div><h3>Delete record</h3><p>This demo shows the delete confirmation flow.</p></div>
        <button class="iconBtn" data-close-modal><i class="fa-solid fa-xmark"></i></button>
      </div>
      <div class="modalBody">
        <div class="deleteBox">
          <span class="badge bad"><i class="fa-solid fa-triangle-exclamation"></i> Delete action</span>
          <strong id="deleteText">Are you sure you want to delete this record?</strong>
          <p style="margin:0;color:var(--muted);font-size:12px;font-weight:800;line-height:1.55">In the real system, this should either soft-delete the record or require admin confirmation with audit logs.</p>
          <div style="display:flex;gap:8px;flex-wrap:wrap;justify-content:flex-end">
            <button class="btn" data-close-modal>Cancel</button>
            <button class="btn btnDanger" id="confirmDelete"><i class="fa-solid fa-trash"></i> Delete</button>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="toast" id="toast"><i class="fa-solid fa-circle-check"></i><span id="toastText">Done</span></div>

  
<%- include("../partials/body-end", { bodyEndInjection }) %>
</body>
</html>