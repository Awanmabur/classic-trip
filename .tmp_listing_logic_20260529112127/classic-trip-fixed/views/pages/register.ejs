<!doctype html>
<html lang="en">
<head>
  <title>Register - <%= APP_NAME %></title>
  <%- include("../partials/head") %>
</head>
<body data-page="register">
  <%- include("../partials/nav") %>

  <section class="section">
    <div class="container narrow">
      <h1>Create account</h1>
      <p class="lead">Choose the role you need now. Super admin access stays internal, while employee accounts link to an existing company admin.</p>

      <div class="card authCard">
        <form id="registerForm" class="form">
          <label>Name</label>
          <input name="name" placeholder="Your name" required />

          <label>Email</label>
          <input name="email" type="email" placeholder="you@example.com" required />

          <label>Phone</label>
          <input name="phone" placeholder="+256..." />

          <label>Password</label>
          <input name="password" type="password" placeholder="Strong password" required />

          <label>Role</label>
          <select name="role" id="registerRole">
            <option value="customer">Customer</option>
            <option value="promoter">Promoter</option>
            <option value="company_admin">Company Admin</option>
            <option value="company_employee">Company Employee</option>
          </select>

          <div id="companyEmailWrap" hidden>
            <label>Company Admin Email</label>
            <input name="companyEmail" id="companyEmail" type="email" placeholder="company-admin@example.com" disabled />
            <div class="muted">Use the email of the company admin you belong to.</div>
          </div>

          <button class="btn btn--primary btn--block" type="submit">Create account</button>
          <div class="muted" id="registerMsg"></div>
        </form>
      </div>
    </div>
  </section>

  <%- include("../partials/footer") %>
</body>
</html>
