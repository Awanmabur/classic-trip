{
  "name": "classic-trip-platform",
  "version": "1.0.0",
  "description": "Production multi-tenant bus and hotel marketplace with MongoDB-backed operations.",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "seed": "node src/seeds/seedSuperAdmin.js",
    "seed:superadmin": "node src/seeds/seedSuperAdmin.js",
    "check": "node scripts/check-syntax.js && node scripts/check-ejs.js",
    "check:runtime": "node scripts/check-runtime-modules.js",
    "check:production": "node scripts/check-production-architecture.js",
    "check:bus": "node scripts/check-production-bus-workflow.js",
    "check:bus-forms": "node scripts/check-bus-form-contracts.js",
    "check:smart-bus-forms": "node scripts/check-smart-bus-forms.js",
    "check:architecture-security": "node scripts/architecture-security-check.js",
    "check:routes": "node scripts/route-security-audit.js",
    "check:csrf": "node scripts/check-multipart-csrf.js && node scripts/check-browser-csrf.js",
    "check:entity-relations": "node scripts/entity-relationship-ui-audit.js",
    "check:dashboards": "node scripts/validate-dashboard-scope.js && node scripts/dashboard-route-smoke-static.js",
    "test": "jest --runInBand tests/unit",
    "verify": "npm run check && npm run check:runtime && npm run check:production && npm run check:bus && npm run check:bus-forms && npm run check:smart-bus-forms && npm run check:smart-publish && npm run check:driver-assignment && npm run check:driver-ui && npm run check:driver-materialization && npm run check:staff-driver && npm run check:partner-ownership && npm run check:architecture-security && npm run check:routes && npm run check:csrf && npm run check:entity-relations && npm run check:partner-registration && npm run check:commission-only && npm run check:dashboard-repository && npm run check:dashboards && npm run check:addons-return-seats && npm run check:stop-pricing-ui && npm run check:end-to-end-final && npm run check:bus-hotel-final && npm run check:bus-hotel-conclusion && npm run check:hotel-operations-final && npm run check:ui-final && npm run check:final-regression && npm test",
    "launch:check": "node scripts/launch-check.js --production",
    "seo:submit-indexnow": "node scripts/submit-indexnow.js",
    "check:dashboard-repository": "node scripts/check-dashboard-repository-readiness.js",
    "check:partner-registration": "node scripts/check-partner-registration-and-user-identity.js",
    "check:staff-driver": "node scripts/check-staff-driver-workflow.js",
    "check:smart-publish": "node scripts/check-smart-listing-publish.js",
    "check:driver-assignment": "node scripts/check-driver-any-status-assignment.js",
    "check:driver-ui": "node scripts/check-driver-selector-and-ui-accessibility.js",
    "check:driver-materialization": "node scripts/check-driver-request-materialization.js",
    "check:partner-ownership": "node scripts/check-final-partner-ownership.js",
    "check:final-regression": "node scripts/check-final-regression-repair.js",
    "check:addons-return-seats": "node scripts/check-addons-return-seat-layout.js",
    "check:stop-pricing-ui": "node scripts/check-final-stop-pricing-ui.js",
    "check:end-to-end-final": "node scripts/check-final-end-to-end-bus-hotel.js",
    "check:bus-hotel-final": "node scripts/check-final-bus-hotel-architecture.js",
    "migrate:hotel-domain:dry": "node scripts/migrate-normalized-hotel-domain.js",
    "migrate:hotel-domain": "node scripts/migrate-normalized-hotel-domain.js --apply",
    "check:bus-hotel-conclusion": "node scripts/check-final-bus-hotel-conclusion.js",
    "check:hotel-operations-final": "node scripts/check-final-hotel-operations.js",
    "check:commission-only": "node scripts/check-partner-commission-only.js",
    "migrate:commission-only:dry": "node scripts/migrate-partner-commission-only.js",
    "migrate:commission-only": "node scripts/migrate-partner-commission-only.js --apply",
    "check:ui-final": "node scripts/check-final-ui-consistency.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.5.1",
    "compression": "^1.8.1",
    "connect-mongo": "^5.1.0",
    "cookie-parser": "^1.4.7",
    "dotenv": "^16.4.7",
    "ejs": "^3.1.10",
    "express": "^4.21.2",
    "express-rate-limit": "^7.4.1",
    "express-session": "^1.18.1",
    "express-validator": "^7.2.1",
    "helmet": "^8.0.0",
    "mongoose": "^8.9.5",
    "multer": "^2.0.2",
    "node-cron": "^4.6.0",
    "nodemailer": "^9.0.3",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "pdfkit": "^0.15.1",
    "qrcode": "^1.5.4",
    "slugify": "^1.6.6",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.1.9",
    "supertest": "^7.0.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
